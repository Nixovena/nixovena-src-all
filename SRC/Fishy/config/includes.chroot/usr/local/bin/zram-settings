#!/bin/bash
################################
# Fishy-Linux ZRAM Manager
################################

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

GRUB_DROPIN="/etc/default/grub.d/fishy-zram.cfg"

print_header() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ███████╗██████╗  █████╗ ███╗   ███╗"
    echo "  ╚══███╔╝██╔══██╗██╔══██╗████╗ ████║"
    echo "    ███╔╝ ██████╔╝███████║██╔████╔██║"
    echo "   ███╔╝  ██╔══██╗██╔══██║██║╚██╔╝██║"
    echo "  ███████╗██║  ██║██║  ██║██║ ╚═╝ ██║"
    echo "  ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═╝     ╚═╝"
    echo -e "${NC}"
    echo -e "${YELLOW}${BOLD}         ZRAM Manager — Fishy-Linux${NC}"
    echo -e "  ${CYAN}──────────────────────────────────────${NC}"
    echo ""
}

press_enter() {
    echo ""
    read -p "  Press Enter to continue..."
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "  ${RED}✗ This operation requires root privileges.${NC}"
        echo -e "  ${YELLOW}Run the command with 'sudo'.${NC}"
        press_enter
        return 1
    fi
    return 0
}

detect_backend() {
    if [[ -f /usr/lib/systemd/zram-generator.conf ]] || \
       [[ -f /etc/systemd/zram-generator.conf ]]; then
        echo "zram-generator"
    elif systemctl list-unit-files 2>/dev/null | grep -qE "^zramswap\.service" || \
         [[ -f /etc/default/zramswap ]]; then
        echo "zramswap"
    else
        echo "none"
    fi
}

_grub_disable_zswap() {
    mkdir -p /etc/default/grub.d/

    if [[ ! -f "$GRUB_DROPIN" ]]; then
        cat > "$GRUB_DROPIN" <<EOF
# Fishy-Linux — Auto-generated by ZRAM Manager
# zswap disabled because ZRAM is active.
# Prevents double compression (zswap + zRAM = wasted CPU).
GRUB_CMDLINE_LINUX_DEFAULT="\$GRUB_CMDLINE_LINUX_DEFAULT zswap.enabled=0"
EOF
        echo -e "  ${GREEN}✓ zswap.enabled=0 added to GRUB.${NC}"
        echo -e "  ${CYAN}  File: $GRUB_DROPIN${NC}"

        if command -v update-grub &>/dev/null; then
            update-grub 2>/dev/null && \
            echo -e "  ${GREEN}✓ GRUB updated.${NC}" || \
            echo -e "  ${YELLOW}⚠ update-grub failed, run manually.${NC}"
        elif command -v grub-mkconfig &>/dev/null; then
            grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null && \
            echo -e "  ${GREEN}✓ GRUB updated.${NC}" || \
            echo -e "  ${YELLOW}⚠ grub-mkconfig failed, run manually.${NC}"
        fi
    else
        echo -e "  ${CYAN}  zswap.enabled=0 already in GRUB, skipping.${NC}"
    fi
}

_grub_enable_zswap() {
    if [[ -f "$GRUB_DROPIN" ]]; then
        rm -f "$GRUB_DROPIN"
        echo -e "  ${GREEN}✓ zswap.enabled=0 removed from GRUB.${NC}"

        if command -v update-grub &>/dev/null; then
            update-grub 2>/dev/null && \
            echo -e "  ${GREEN}✓ GRUB updated.${NC}" || \
            echo -e "  ${YELLOW}⚠ update-grub failed, run manually.${NC}"
        elif command -v grub-mkconfig &>/dev/null; then
            grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null && \
            echo -e "  ${GREEN}✓ GRUB updated.${NC}" || \
            echo -e "  ${YELLOW}⚠ grub-mkconfig failed, run manually.${NC}"
        fi
    else
        echo -e "  ${YELLOW}⚠ No GRUB drop-in found, nothing to remove.${NC}"
    fi
}

install_zram() {
    print_header
    echo -e "  ${YELLOW}${BOLD}[1] ZRAM Installation${NC}"
    echo -e "  ${CYAN}──────────────────────────────────────${NC}"
    echo ""

    require_root || return

    BACKEND=$(detect_backend)
    if [[ "$BACKEND" != "none" ]]; then
        echo -e "  ${GREEN}✓ ZRAM is already installed (backend: $BACKEND)${NC}"
        press_enter; return
    fi

    echo -e "  ${YELLOW}► Installing ZRAM tools...${NC}"
    echo ""

    apt-get update -qq 2>/dev/null

    if apt-get install -y zram-tools 2>/dev/null; then
        echo -e "  ${GREEN}✓ zram-tools installed.${NC}"
        _configure_zramswap
    elif apt-get install -y systemd-zram-generator 2>/dev/null; then
        echo -e "  ${GREEN}✓ systemd-zram-generator installed.${NC}"
        _configure_zram_generator
    else
        echo -e "  ${RED}✗ Installation failed. Packages 'zram-tools' or 'systemd-zram-generator' not found.${NC}"
    fi

    press_enter
}

_configure_zram_generator() {
    RAM_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    RAM_GB=$(awk -v kb="$RAM_KB" 'BEGIN {printf "%.1f", kb / 1048576}')

    cat > /etc/systemd/zram-generator.conf <<EOF
[zram0]
zram-size = ram / 2
compression-algorithm = lz4
swap-priority = 100
fs-type = swap
EOF

    echo ""
    echo -e "  ${CYAN}  Configuration:${NC}"
    echo -e "     RAM Size     : ${RAM_GB}GB"
    echo -e "     ZRAM Size    : $(awk -v gb="$RAM_GB" 'BEGIN {printf "%.1f", gb / 2}')GB (RAM/2)"
    echo -e "     Algorithm    : lz4  ${YELLOW}(fastest for old CPUs)${NC}"
    echo -e "     Priority     : 100  ${YELLOW}(used before disk swap)${NC}"
}

_configure_zramswap() {
    cat > /etc/default/zramswap <<EOF
ALGO=lz4
PERCENT=50
PRIORITY=100
EOF
    echo -e "  ${CYAN}  /etc/default/zramswap configured (lz4, 50% RAM)${NC}"
}

enable_zram() {
    print_header
    echo -e "  ${YELLOW}${BOLD}[2] Enable ZRAM${NC}"
    echo -e "  ${CYAN}──────────────────────────────────────${NC}"
    echo ""

    require_root || return

    BACKEND=$(detect_backend)

    case "$BACKEND" in
        zram-generator)
            systemctl daemon-reload
            systemctl start systemd-zram-setup@zram0.service 2>/dev/null || \
            udevadm trigger --subsystem-match=block 2>/dev/null
            echo -e "  ${GREEN}✓ ZRAM enabled (zram-generator).${NC}"
            ;;
        zramswap)
            systemctl enable zramswap
            systemctl start zramswap
            echo -e "  ${GREEN}✓ ZRAM enabled (zramswap).${NC}"
            ;;
        none)
            echo -e "  ${RED}✗ ZRAM is not installed. Install it first (Option 1).${NC}"
            press_enter; return
            ;;
    esac

    echo ""
    echo -e "  ${YELLOW}► Disabling zswap in GRUB (prevents double compression)...${NC}"
    _grub_disable_zswap

    echo ""
    echo -e "  ${YELLOW}  ⚠ Reboot required for GRUB changes to take effect.${NC}"

    press_enter
}

_manual_enable() {
    RAM_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    ZRAM_BYTES=$((RAM_KB * 512))

    modprobe zram || { echo -e "  ${RED}✗ Failed to load zram module.${NC}"; return 1; }
    echo lz4 > /sys/block/zram0/comp_algorithm 2>/dev/null
    echo "$ZRAM_BYTES" > /sys/block/zram0/disksize || \
        { echo -e "  ${RED}✗ Failed to set zram size.${NC}"; return 1; }
    mkswap /dev/zram0
    swapon -p 100 /dev/zram0
    echo -e "  ${GREEN}✓ ZRAM enabled manually.${NC}"
    echo -e "  ${YELLOW}  Note: This is temporary, will reset on reboot.${NC}"
}

disable_zram() {
    print_header
    echo -e "  ${YELLOW}${BOLD}[3] Disable ZRAM${NC}"
    echo -e "  ${CYAN}──────────────────────────────────────${NC}"
    echo ""

    require_root || return

    BACKEND=$(detect_backend)

    case "$BACKEND" in
        zram-generator)
            systemctl stop systemd-zram-setup@zram0.service 2>/dev/null
            swapoff /dev/zram0 2>/dev/null
            echo -e "  ${GREEN}✓ ZRAM stopped.${NC}"
            echo -e "  ${YELLOW}  Note: Delete /etc/systemd/zram-generator.conf to remove permanently.${NC}"
            ;;
        zramswap)
            systemctl stop zramswap
            systemctl disable zramswap
            echo -e "  ${GREEN}✓ ZRAM stopped and disabled.${NC}"
            ;;
        none)
            if swapon --show | grep -q zram; then
                swapoff /dev/zram0 2>/dev/null && \
                echo -e "  ${GREEN}✓ ZRAM swap disabled.${NC}" || \
                echo -e "  ${RED}✗ Failed to disable ZRAM.${NC}"
            else
                echo -e "  ${YELLOW}⚠ No active ZRAM found.${NC}"
            fi
            ;;
    esac

    echo ""
    echo -e "  ${YELLOW}► Restoring zswap in GRUB...${NC}"
    _grub_enable_zswap

    echo ""
    echo -e "  ${YELLOW}  ⚠ Reboot required for GRUB changes to take effect.${NC}"

    press_enter
}

show_status() {
    print_header
    echo -e "  ${YELLOW}${BOLD}[4] ZRAM Status${NC}"
    echo -e "  ${CYAN}──────────────────────────────────────${NC}"
    echo ""

    BACKEND=$(detect_backend)
    echo -e "  ${BOLD}Backend      :${NC} $BACKEND"

    if [[ -f "$GRUB_DROPIN" ]]; then
        echo -e "  ${BOLD}zswap (GRUB) :${NC} ${GREEN}disabled ✓${NC}"
    else
        echo -e "  ${BOLD}zswap (GRUB) :${NC} ${YELLOW}enabled (enable ZRAM to fix)${NC}"
    fi

    echo ""

    if swapon --show | grep -q zram; then
        echo -e "  ${BOLD}Status       :${NC} ${GREEN}${BOLD}ACTIVE ✓${NC}"
        echo ""

        if command -v zramctl &>/dev/null; then
            echo -e "  ${CYAN}── zramctl ──────────────────────────${NC}"
            zramctl --output NAME,DISKSIZE,DATA,COMPR,ALGORITHM,STREAMS 2>/dev/null | \
            while read line; do echo "  $line"; done
        fi

        echo ""
        echo -e "  ${CYAN}── Swap Information ─────────────────${NC}"
        swapon --show | while read line; do echo "  $line"; done

        echo ""
        echo -e "  ${CYAN}── Memory Summary ───────────────────${NC}"
        RAM_TOTAL=$(grep MemTotal /proc/meminfo | awk '{print $2}')
        RAM_FREE=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
        RAM_USED=$((RAM_TOTAL - RAM_FREE))
        SWAP_TOTAL=$(grep SwapTotal /proc/meminfo | awk '{print $2}')
        SWAP_FREE=$(grep SwapFree /proc/meminfo | awk '{print $2}')
        SWAP_USED=$((SWAP_TOTAL - SWAP_FREE))

        printf "  %-14s %8s MB\n" "RAM Total:"    "$((RAM_TOTAL / 1024))"
        printf "  %-14s %8s MB\n" "RAM Usage:"    "$((RAM_USED / 1024))"
        printf "  %-14s %8s MB\n" "RAM Free:"     "$((RAM_FREE / 1024))"
        echo ""
        printf "  %-14s %8s MB\n" "ZRAM Total:"   "$((SWAP_TOTAL / 1024))"
        printf "  %-14s %8s MB\n" "ZRAM Usage:"   "$((SWAP_USED / 1024))"

        if [[ -f /sys/block/zram0/orig_data_size ]] && \
           [[ -f /sys/block/zram0/compr_data_size ]]; then
            ORIG=$(cat /sys/block/zram0/orig_data_size 2>/dev/null)
            COMPR=$(cat /sys/block/zram0/compr_data_size 2>/dev/null)
            if [[ "$COMPR" -gt 0 && "$ORIG" -gt 0 ]]; then
                RATIO=$(awk -v orig="$ORIG" -v compr="$COMPR" 'BEGIN {printf "%.1f", orig / compr}')
                echo ""
                echo -e "  ${BOLD}Compression Ratio: ${GREEN}${RATIO}:1${NC}"
            fi
        fi
    else
        echo -e "  ${BOLD}Status       :${NC} ${RED}${BOLD}DISABLED ✗${NC}"
        echo ""
        echo -e "  ${YELLOW}  ZRAM is not active. Use Option 2 to enable.${NC}"
    fi

    press_enter
}

show_about() {
    print_header
    echo -e "  ${YELLOW}${BOLD}[5] About ZRAM${NC}"
    echo -e "  ${CYAN}──────────────────────────────────────${NC}"
    echo ""
    echo -e "  ZRAM creates a compressed virtual block device in RAM"
    echo -e "  and uses it as swap space."
    echo ""
    echo -e "  ${CYAN}${BOLD}  Why ZRAM?${NC}"
    echo ""
    echo -e "  ${GREEN}  ✓${NC} ${BOLD}10-20x faster${NC} than disk swap"
    echo -e "  ${GREEN}  ✓${NC} Extends HDD lifespan (no write cycles)"
    echo -e "  ${GREEN}  ✓${NC} Highly effective on systems with 2-8 GB RAM"
    echo -e "  ${GREEN}  ✓${NC} Reduces freezing/stuttering on old hardware"
    echo ""
    echo -e "  ${CYAN}${BOLD}  Algorithm Comparison (For old hardware):${NC}"
    echo ""
    printf "  ${BOLD}  %-12s %-10s %-10s %-20s${NC}\n" "Algorithm" "Speed" "Compression" "Recommendation"
    echo -e "  ${CYAN}  ─────────────────────────────────────────────────────${NC}"
    printf "  ${GREEN}  %-12s %-10s %-10s %-20s${NC}\n" "lz4"      "★★★★★" "★★★☆☆" "Old CPU ← Recommended"
    printf "  ${YELLOW}  %-12s %-10s %-10s %-20s${NC}\n" "zstd"    "★★★☆☆" "★★★★★" "Modern CPU"
    printf "  ${YELLOW}  %-12s %-10s %-10s %-20s${NC}\n" "lzo"     "★★★★☆" "★★☆☆☆" "Medium"
    printf "  ${YELLOW}  %-12s %-10s %-10s %-20s${NC}\n" "deflate" "★★☆☆☆" "★★★★☆" "Not Recommended"
    echo ""
    echo -e "  ${CYAN}${BOLD}  Typical results:${NC}"
    echo ""
    echo -e "     RAM usage 70%+      → ZRAM kicks in"
    echo -e "     Compression ratio   → between 2:1 to 3:1"
    echo -e "     Latency             → negligible compared to disk swap"
    echo ""
    echo -e "  ${CYAN}${BOLD}  About zswap auto-disable:${NC}"
    echo ""
    echo -e "     When ZRAM is enabled, this tool automatically adds"
    echo -e "     ${BOLD}zswap.enabled=0${NC} to GRUB to prevent double compression."
    echo -e "     File: ${CYAN}$GRUB_DROPIN${NC}"
    echo ""

    press_enter
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        clear
        echo -e "${RED}${BOLD}"
        echo "  ✗ Permission Denied"
        echo -e "${NC}"
        echo -e "  This tool requires ${BOLD}sudo${NC} privileges to run."
        echo ""
        echo -e "  ${YELLOW}Usage: sudo $0${NC}"
        echo ""
        exit 1
    fi
}

main_menu() {
    while true; do
        print_header

        if swapon --show | grep -q zram; then
            echo -e "  Status: ${GREEN}${BOLD}● ACTIVE${NC}"
        else
            echo -e "  Status: ${RED}${BOLD}○ DISABLED${NC}"
        fi

        echo ""
        echo -e "  ${BOLD}  1.${NC} Install ZRAM"
        echo -e "  ${BOLD}  2.${NC} Enable ZRAM"
        echo -e "  ${BOLD}  3.${NC} Disable ZRAM"
        echo -e "  ${BOLD}  4.${NC} Status & Statistics"
        echo -e "  ${BOLD}  5.${NC} About ZRAM"
        echo -e "  ${BOLD}  0.${NC} Exit"
        echo ""
        echo -e "  ${CYAN}──────────────────────────────────────${NC}"
        read -p "  Option: " choice

        case $choice in
            1) install_zram ;;
            2) enable_zram ;;
            3) disable_zram ;;
            4) show_status ;;
            5) show_about ;;
            0) clear; exit 0 ;;
            *) echo -e "\n  ${RED}Invalid option!${NC}"; sleep 1 ;;
        esac
    done
}

check_root
main_menu