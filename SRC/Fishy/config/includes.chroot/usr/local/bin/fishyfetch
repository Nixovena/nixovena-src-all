#!/bin/bash

# Fishy Fetch - System Information Tool
# A lightweight neofetch-style tool for Fishy Linux.

# Colors
C1=$(printf '\033[0;31m') # Red
C2=$(printf '\033[1;31m') # Bright Red
WHITE=$(printf '\033[1;37m')
GRAY=$(printf '\033[0;90m')
NC=$(printf '\033[0m')

# System Data
USER_HOST="${USER}@$(hostname)"
# Get distro name, version and code name from os-release
if [ -f /etc/os-release ]; then
    . /etc/os-release
    DISTRO=$PRETTY_NAME
    OS_VERSION=$VERSION_ID
    OS_CODENAME=$VERSION_CODENAME
fi

# Fallback mechanisms
[ -z "$DISTRO" ] && DISTRO=$(lsb_release -ds 2>/dev/null || echo "Almighty Linux")
[ -z "$OS_VERSION" ] && OS_VERSION=$(lsb_release -rs 2>/dev/null || echo "Unknown")
[ -z "$OS_CODENAME" ] && OS_CODENAME=$(lsb_release -cs 2>/dev/null || echo "Unknown")
UPTIME=$(uptime -p | sed 's/up //')
KERNEL=$(uname -r)
SHELL_NAME=$(basename "$SHELL")
# Detect DE dynamically
DE_NAME=$(echo "$XDG_CURRENT_DESKTOP" | cut -d ':' -f 2)
[ -z "$DE_NAME" ] && DE_NAME="$XDG_CURRENT_DESKTOP"
SESSION_TYPE=$(echo "$XDG_SESSION_TYPE" | sed 's/.*/\L&/; s/^./\U&/')
DE="${DE_NAME:-GNOME} (${SESSION_TYPE:-Wayland})"

PACKAGES=$(dpkg -l | wc -l)
MEM_USED=$(free -m | awk '/Mem:/ { print $3 }')
MEM_TOTAL=$(free -m | awk '/Mem:/ { print $2 }')
CPU=$(grep "model name" /proc/cpuinfo | head -1 | cut -d ":" -f 2 | xargs)
GPU=$(lspci | grep -i 'vga\|display' | cut -d ":" -f 3 | xargs | sed 's/\[.*\]//g' | cut -c 1-40)
DISK=$(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}')
RES=$(xdpyinfo | grep dimensions | awk '{print $2}' 2>/dev/null || echo "Wayland Display")

# ASCII Art & Info Table
echo -e "
${C2}       ___  _            ${C2}${USER_HOST}${NC}
${C2}    ___)  \\\\ )\\\\           ${GRAY}-----------------------${NC}
${C2}  __)    _/   \\\\          ${C2}OS: ${WHITE}${DISTRO}${NC}
${C2} _)    _/    _/''--._    ${C2}Version: ${WHITE}${OS_VERSION} (${OS_CODENAME})${NC}
${C2}/__   \\\\___.-'   {>(O /   ${C2}Kernel: ${WHITE}$KERNEL${NC}
${C2} )__     ;-...;__;-''    ${C2}Uptime: ${WHITE}$UPTIME${NC}
${C2}   )__     /)   /|))     ${C2}Packages: ${WHITE}$PACKAGES (dpkg)${NC}
${C2}     )_   / \\\\/\\\\/ )//     ${C2}Shell: ${WHITE}$SHELL_NAME${NC}
${C2}       )_/               ${C2}Resolution: ${WHITE}$RES${NC}
${C2}                         ${C2}DE: ${WHITE}$DE${NC}
${C2}                         ${C2}CPU: ${WHITE}$CPU${NC}
${C2}                         ${C2}GPU: ${WHITE}$GPU${NC}
${C2}                         ${C2}Memory: ${WHITE}${MEM_USED}MiB / ${MEM_TOTAL}MiB${NC}
${C2}                         ${C2}Disk: ${WHITE}$DISK${NC}
"