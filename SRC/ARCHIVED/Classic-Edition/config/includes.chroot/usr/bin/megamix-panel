def run_cmd(cmd, shell=False, capture=False):
    if capture:
        return subprocess.run(cmd, shell=shell, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
    return subprocess.run(cmd, shell=shell)

def press_enter():
    console.print(f"\n[dim]{_t('press_enter')}[/dim]")
    input()
    show_menu()

def is_live_mode():
    try:
        with open("/proc/mounts", "r") as f:
            return "overlay" in f.read()
    except:
        return False

# ==============================================================================
# ACTIONS
# ==============================================================================

def system_update():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_update')}[/bold yellow]"))
    os.environ["DEBIAN_FRONTEND"] = "noninteractive"
    
    console.print("[bold cyan][1/4][/bold cyan] Updating package lists...")
    run_cmd(["sudo", "apt-get", "update"])
    
    console.print("[bold cyan][2/4][/bold cyan] Upgrading packages...")
    run_cmd(["sudo", "apt-get", "upgrade", "-y"])
    run_cmd(["sudo", "apt-get", "full-upgrade", "-y"])
    
    console.print("[bold cyan][3/4][/bold cyan] Removing unnecessary packages...")
    run_cmd(["sudo", "apt-get", "autoremove", "--purge", "-y"])
    run_cmd(["sudo", "apt-get", "clean"])
    
    console.print("[bold cyan][4/4][/bold cyan] Checking for Flatpak...")
    if shutil.which("flatpak"):
        console.print("Updating Flatpak applications...")
        run_cmd(["flatpak", "update", "-y"])
        run_cmd(["flatpak", "uninstall", "--unused", "-y"])
    else:
        console.print("Flatpak not installed, skipping.")
        
    console.print(f"[bold green]✓ {_t('success')}[/bold green]")
    press_enter()

def install_nvidia():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_nvidia')}[/bold yellow]"))
    if is_live_mode():
        console.print(f"[bold red]✗ {_t('live_mode_error')}[/bold red]")
        press_enter()
        return
        
    console.print("Scanning for NVIDIA GPU...")
    res = run_cmd("lspci | grep -i nvidia", shell=True)
    if res.returncode != 0:
        console.print("[bold red]✗ No NVIDIA GPU detected on this system.[/bold red]")
        if not Confirm.ask(_t("are_you_sure")):
            console.print(_t("cancelled"))
            press_enter()
            return
    else:
        console.print("[bold green]✓ NVIDIA GPU found.[/bold green]")
        
    console.print("Installing NVIDIA drivers...")
    run_cmd(["sudo", "apt-get", "update"])
    kernel = run_cmd(["uname", "-r"], capture=True).stdout.strip()
    run_cmd(["sudo", "apt-get", "install", "-y", "nvidia-driver", "nvidia-smi", f"linux-headers-{kernel}"])
    
    console.print(f"[bold green]✓ Installation complete! Please reboot your system.[/bold green]")
    press_enter()

def sys_info():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_sysinfo')}[/bold yellow]"))
    
    # OS
    os_name = "Unknown"
    if os.path.exists("/etc/os-release"):
        with open("/etc/os-release", "r") as f:
            for line in f:
                if line.startswith("PRETTY_NAME="):
                    os_name = line.split("=")[1].strip().strip('"')
                    break
    
    # Kernel
    kernel = run_cmd(["uname", "-r"], capture=True).stdout.strip()
    
    # Uptime
    uptime = "Unknown"
    if os.path.exists("/proc/uptime"):
        with open("/proc/uptime", "r") as f:
            up_s = float(f.read().split()[0])
            hours, rem = divmod(up_s, 3600)
            mins, secs = divmod(rem, 60)
            uptime = f"{int(hours)}h {int(mins)}m {int(secs)}s"
            
    # CPU
    cpu_name = "Unknown"
    if os.path.exists("/proc/cpuinfo"):
        with open("/proc/cpuinfo", "r") as f:
            for line in f:
                if line.startswith("model name"):
                    cpu_name = line.split(":")[1].strip()
                    break
                    
    # RAM
    ram_total = "Unknown"
    ram_free = "Unknown"
    if os.path.exists("/proc/meminfo"):
        with open("/proc/meminfo", "r") as f:
            meminfo = f.read()
        for line in meminfo.splitlines():
            if line.startswith("MemTotal:"):
                ram_total = f"{int(line.split()[1]) // 1024} MB"
            elif line.startswith("MemAvailable:"):
                ram_free = f"{int(line.split()[1]) // 1024} MB"
                
    # Disk
    disk = "Unknown"
    try:
        st = os.statvfs("/")
        total = (st.f_blocks * st.f_frsize) / (1024**3)
        free = (st.f_bavail * st.f_frsize) / (1024**3)
        used = total - free
        disk = f"{used:.1f} GB / {total:.1f} GB"
    except:
        pass
    
    table = Table(show_header=False, box=None)
    table.add_row("[bold cyan]OS[/bold cyan]", os_name)
    table.add_row("[bold cyan]Kernel[/bold cyan]", kernel)
    table.add_row("[bold cyan]Uptime[/bold cyan]", uptime)
    table.add_row("[bold cyan]CPU[/bold cyan]", cpu_name)
    table.add_row("[bold cyan]RAM (Available/Total)[/bold cyan]", f"{ram_free} / {ram_total}")
    table.add_row("[bold cyan]Disk (Root)[/bold cyan]", disk)
    
    console.print(Panel(table, border_style="green"))
    press_enter()

def view_logs():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_logs')}[/bold yellow]"))
    table = Table(show_header=False, box=None)
    table.add_row("1", "System Logs (journalctl)")
    table.add_row("2", "Kernel Logs (dmesg)")
    table.add_row("3", "Xorg / Wayland Logs")
    table.add_row("0", "Back")
    console.print(table)
    
    choice = Prompt.ask("Selection")
    if choice == "1":
        run_cmd("sudo journalctl -xe | less", shell=True)
    elif choice == "2":
        run_cmd("sudo dmesg -H | less", shell=True)
    elif choice == "3":
        if os.environ.get("XDG_SESSION_TYPE") == "wayland":
            run_cmd("sudo journalctl -b 0 _COMM=kwin_wayland | less", shell=True)
        else:
            if os.path.exists("/var/log/Xorg.0.log"):
                run_cmd("less /var/log/Xorg.0.log", shell=True)
            else:
                console.print("[bold red]Xorg log not found.[/bold red]")
    elif choice == "0":
        show_menu()
        return
    else:
        console.print(f"[bold red]{_t('invalid_option')}[/bold red]")
    press_enter()

def manage_services():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_services')}[/bold yellow]"))
    srv = Prompt.ask("Service name (e.g. ssh, bluetooth)")
    if not srv:
        press_enter()
        return
    action = Prompt.ask("Action", choices=["start", "stop", "restart", "status", "enable", "disable"])
    run_cmd(["sudo", "systemctl", action, srv])
    if action != "status":
        console.print(f"[bold green]✓ systemctl {action} {srv}[/bold green]")
    press_enter()

def list_packages():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_packages')}[/bold yellow]"))
    run_cmd("dpkg-query -W -f='${binary:Package}\t${Version}\t${Status}\n' | column -t | less", shell=True)
    press_enter()

