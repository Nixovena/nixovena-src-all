def manage_users():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_users')}[/bold yellow]"))
    table = Table(show_header=False, box=None)
    table.add_row("1", "Add new user")
    table.add_row("2", "Change user password")
    table.add_row("3", "Delete user")
    table.add_row("4", "List users")
    table.add_row("0", "Back")
    console.print(table)
    
    choice = Prompt.ask("Select option")
    if choice == "1":
        uname = Prompt.ask("New username")
        if uname: run_cmd(["sudo", "adduser", uname])
    elif choice == "2":
        uname = Prompt.ask("Username")
        if uname: run_cmd(["sudo", "passwd", uname])
    elif choice == "3":
        uname = Prompt.ask("Username to delete")
        if uname and Confirm.ask(f"Delete user '{uname}'?"):
            run_cmd(["sudo", "deluser", uname])
            console.print("[bold green]✓ User deleted.[/bold green]")
    elif choice == "4":
        run_cmd("awk -F: '$3 >= 1000 && $3 < 65534 {print $1}' /etc/passwd", shell=True)
    elif choice == "0":
        show_menu()
        return
    press_enter()

def disk_info():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_disk')}[/bold yellow]"))
    table = Table(show_header=False, box=None)
    table.add_row("1", "Block Devices (lsblk)")
    table.add_row("2", "Disk Space Usage (df -h)")
    table.add_row("3", "Disk I/O Stats (iostat)")
    table.add_row("0", "Back")
    console.print(table)
    
    choice = Prompt.ask("Select option")
    if choice == "1":
        run_cmd(["lsblk", "-o", "NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT"])
    elif choice == "2":
        run_cmd(["df", "-h", "--exclude-type=tmpfs", "--exclude-type=devtmpfs"])
    elif choice == "3":
        if shutil.which("iostat"):
            run_cmd(["iostat", "-xh", "1", "3"])
        else:
            console.print("[bold yellow]iostat not found. Install with: sudo apt install sysstat[/bold yellow]")
    elif choice == "0":
        show_menu()
        return
    press_enter()

def clean_temp():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_clean')}[/bold yellow]"))
    console.print("This will clear: user cache, thumbnails, apt cache, old journals, trash.")
    if Confirm.ask(_t("are_you_sure")):
        console.print("[cyan]Clearing thumbnail cache...[/cyan]")
        os.system("rm -rf ~/.cache/thumbnails/* 2>/dev/null")
        
        console.print("[cyan]Emptying trash...[/cyan]")
        os.system("rm -rf ~/.local/share/Trash/files/* ~/.local/share/Trash/info/* 2>/dev/null")
        
        console.print("[cyan]Cleaning APT cache...[/cyan]")
        run_cmd(["sudo", "apt-get", "clean"])
        
        console.print("[cyan]Vacuuming journal logs (keeping last 3 days)...[/cyan]")
        run_cmd(["sudo", "journalctl", "--vacuum-time=3d"])
        
        console.print(f"[bold green]✓ {_t('success')}[/bold green]")
    else:
        console.print(_t("cancelled"))
    press_enter()

def change_dns():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_dns')}[/bold yellow]"))
    console.print("Current DNS servers:")
    os.system("grep '^nameserver' /etc/resolv.conf 2>/dev/null || echo '  (none found)'")
    console.print("\nCommon DNS servers:\n  1.1.1.1      - Cloudflare\n  8.8.8.8      - Google\n  9.9.9.9      - Quad9\n  208.67.222.222 - OpenDNS\n")
    
    new_dns = Prompt.ask("Enter new DNS IP (leave empty to cancel)")
    if new_dns:
        nm_conf_dir = "/etc/NetworkManager/conf.d"
        run_cmd(["sudo", "mkdir", "-p", nm_conf_dir])
        os.system(f"echo -e '[main]\\ndns=none' | sudo tee {nm_conf_dir}/90-dns-none.conf > /dev/null")
        run_cmd(["sudo", "systemctl", "restart", "NetworkManager"])
        
        run_cmd(["sudo", "chattr", "-i", "/etc/resolv.conf"])
        os.system(f"echo 'nameserver {new_dns}' | sudo tee /etc/resolv.conf > /dev/null")
        run_cmd(["sudo", "chattr", "+i", "/etc/resolv.conf"])
        console.print(f"[bold green]✓ DNS set to {new_dns} (NetworkManager patched to not override it).[/bold green]")
    press_enter()

def change_hostname():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_hostname')}[/bold yellow]"))
    current = run_cmd(["hostname"], capture=True).stdout.strip()
    console.print(f"Current hostname: [cyan]{current}[/cyan]\n")
    
    new_host = Prompt.ask("Enter new hostname (leave empty to cancel)")
    if new_host:
        run_cmd(["sudo", "hostnamectl", "set-hostname", new_host])
        run_cmd(["sudo", "sed", "-i", f"s/\\b{current}\\b/{new_host}/g", "/etc/hosts"])
        console.print(f"[bold green]✓ Hostname changed to '{new_host}'. Re-login to see the effect in prompt.[/bold green]")
    press_enter()

def zram_manager():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_zram')}[/bold yellow]"))
    table = Table(show_header=False, box=None)
    table.add_row("1", "Install ZRAM tools")
    table.add_row("2", "Enable ZRAM")
    table.add_row("3", "Disable ZRAM")
    table.add_row("4", "Status")
    table.add_row("5", "About ZRAM")
    table.add_row("0", "Back")
    console.print(table)
    
    choice = Prompt.ask("Select option")
    if choice == "1":
        run_cmd(["sudo", "apt-get", "update"])
        run_cmd(["sudo", "apt-get", "install", "-y", "zram-tools"])
        console.print("[bold green]✓ ZRAM tools installed.[/bold green]")
    elif choice == "2":
        run_cmd(["sudo", "systemctl", "enable", "zramswap"])
        run_cmd(["sudo", "systemctl", "start", "zramswap"])
        console.print("[bold green]✓ ZRAM enabled.[/bold green]")
    elif choice == "3":
        run_cmd(["sudo", "systemctl", "stop", "zramswap"])
        run_cmd(["sudo", "systemctl", "disable", "zramswap"])
        console.print("[bold green]✓ ZRAM disabled.[/bold green]")
    elif choice == "4":
        if run_cmd(["systemctl", "is-active", "--quiet", "zramswap"]).returncode == 0:
            console.print("Status: [bold green]ACTIVE[/bold green]")
            os.system("zramctl 2>/dev/null || swapon --show")
        else:
            console.print("Status: [bold red]INACTIVE[/bold red]")
    elif choice == "5":
        console.print("\nZRAM creates a compressed block device in RAM used as swap space.\n\nBenefits:\n  • Much faster than disk swap\n  • Reduces SSD write cycles\n  • Effective on systems with 2-8 GB RAM\n\nTypical compression ratio: 2:1 to 3:1 (LZ4 algorithm)")
    elif choice == "0":
        show_menu()
        return
    press_enter()

def deb_installer():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_deb')}[/bold yellow]"))
    table = Table(show_header=False, box=None)
    table.add_row("1", "Install .deb from local path")
    table.add_row("2", "Install .deb from URL")
    table.add_row("3", "Recently installed packages")
    table.add_row("0", "Back")
    console.print(table)
    
    choice = Prompt.ask("Select option")
    if choice == "1":
        path = Prompt.ask("Path to .deb file").replace("~", os.environ.get("HOME", "~"))
        if not os.path.isfile(path):
            console.print(f"[bold red]✗ File not found: {path}[/bold red]")
        else:
            console.print(f"Installing {path}...")
            run_cmd(["sudo", "dpkg", "-i", path])
            run_cmd(["sudo", "apt-get", "install", "-f", "-y"])
            console.print("[bold green]✓ Installation complete.[/bold green]")
    elif choice == "2":
        url = Prompt.ask("URL of .deb file")
        if url:
            tmp = "/tmp/megamix_install.deb"
            console.print("Downloading...")
            if run_cmd(["wget", "-q", "--show-progress", "-O", tmp, url]).returncode == 0:
                console.print("Installing...")
                run_cmd(["sudo", "dpkg", "-i", tmp])
                run_cmd(["sudo", "apt-get", "install", "-f", "-y"])
                os.remove(tmp)
                console.print("[bold green]✓ Installation complete.[/bold green]")
            else:
                console.print("[bold red]✗ Download failed.[/bold red]")
                if os.path.exists(tmp): os.remove(tmp)
    elif choice == "3":
        console.print("\n[cyan]Recently installed packages:[/cyan]")
        os.system("grep ' install ' /var/log/dpkg.log 2>/dev/null | tail -30 || echo 'Log not available.'")
    elif choice == "0":
        show_menu()
        return
    press_enter()

def apt_installer():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_apt')}[/bold yellow]"))
    pkg = Prompt.ask("Package name to install (leave empty to cancel)")
    if pkg:
        console.print(f"Searching for '{pkg}'...")
        if run_cmd(["apt-cache", "show", pkg], capture=True).returncode == 0:
            run_cmd(["sudo", "apt-get", "update"])
            run_cmd(["sudo", "apt-get", "install", "-y", pkg])
            console.print(f"[bold green]✓ '{pkg}' installed successfully.[/bold green]")
        else:
            console.print(f"[bold red]✗ Package '{pkg}' not found.[/bold red]\nTry: apt-cache search <keyword>")
    press_enter()

def flatpak_installer():
    console.clear()
    console.print(Panel(f"[bold yellow]{_t('menu_flatpak')}[/bold yellow]"))
    if not shutil.which("flatpak"):
        console.print("[bold red]✗ Flatpak is not installed.[/bold red]")
        if Confirm.ask("Install Flatpak now?"):
            run_cmd(["sudo", "apt-get", "install", "-y", "flatpak"])
            run_cmd(["flatpak", "remote-add", "--if-not-exists", "flathub", "https://dl.flathub.org/repo/flathub.flatpakrepo"])
            console.print("[bold green]✓ Flatpak installed. Please reboot before installing apps.[/bold green]")
        press_enter()
        return
        
    table = Table(show_header=False, box=None)
    table.add_row("1", "Install app by ID")
    table.add_row("2", "Search for an app")
    table.add_row("3", "List installed Flatpak apps")
    table.add_row("4", "Remove a Flatpak app")
    table.add_row("0", "Back")
    console.print(table)
    
    choice = Prompt.ask("Select option")
    if choice == "1":
        appid = Prompt.ask("Flatpak app ID (e.g. com.spotify.Client)")
        if appid:
            run_cmd(["flatpak", "install", "-y", "flathub", appid])
            console.print("[bold green]✓ Done.[/bold green]")
    elif choice == "2":
        term = Prompt.ask("Search term")
        if term: run_cmd(["flatpak", "search", term])
    elif choice == "3":
        run_cmd(["flatpak", "list", "--app", "--columns=name,application,version"])
    elif choice == "4":
        appid = Prompt.ask("App ID to remove")
        if appid:
            run_cmd(["flatpak", "uninstall", appid, "-y"])
            console.print("[bold green]✓ Removed.[/bold green]")
    elif choice == "0":
        show_menu()
        return
    press_enter()

