CURRENT_LANG = "en"

def _t(key):
    return TRANSLATIONS.get(CURRENT_LANG, TRANSLATIONS["en"]).get(key, TRANSLATIONS["en"].get(key, key))

ASCII_ART = """[bold cyan]

