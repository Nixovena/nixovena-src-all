def show_menu():
    console.clear()
    console.print(ASCII_ART)
    
    table = Table(title=_t("title"), title_style="bold yellow", show_header=False, box=None, padding=(0, 2))
    table.add_column("Key", style="bold cyan")
    table.add_column("Action", style="white")
    
    table.add_row(" 1.", _t("menu_update"))
    table.add_row(" 2.", _t("menu_nvidia"))
    table.add_row(" 3.", _t("menu_sysinfo"))
    table.add_row(" 4.", _t("menu_logs"))
    table.add_row(" 5.", _t("menu_services"))
    table.add_row(" 6.", _t("menu_packages"))
    table.add_row(" 7.", _t("menu_network"))
    table.add_row(" 8.", _t("menu_users"))
    table.add_row(" 9.", _t("menu_disk"))
    table.add_row("10.", _t("menu_clean"))
    table.add_row("11.", _t("menu_dns"))
    table.add_row("12.", _t("menu_hostname"))
    table.add_row("13.", _t("menu_zram"))
    table.add_row("14.", _t("menu_deb"))
    table.add_row("15.", _t("menu_apt"))
    table.add_row("16.", _t("menu_flatpak"))
    table.add_row("17.", _t("menu_settings"))
    table.add_row(" 0.", f"[bold red]{_t('menu_exit')}[/bold red]")
    
    console.print(Panel(table, border_style="blue"))
    
    choice = Prompt.ask(f"[bold cyan]{_t('select_option')}[/bold cyan]")
    
    actions = {
        "1": system_update,
        "2": install_nvidia,
        "3": sys_info,
        "4": view_logs,
        "5": manage_services,
        "6": list_packages,
        "7": manage_network,
        "8": manage_users,
        "9": disk_info,
        "10": clean_temp,
        "11": change_dns,
        "12": change_hostname,
        "13": zram_manager,
        "14": deb_installer,
        "15": apt_installer,
        "16": flatpak_installer,
        "17": change_language_setting
    }
    
    if choice == "0":
        console.print(f"[bold green]{_t('goodbye')}[/bold green]")
        sys.exit(0)
    elif choice in actions:
        actions[choice]()
    else:
        console.print(f"[bold red]{_t('invalid_option')}[/bold red]")
        import time
        time.sleep(1)
        show_menu()

LANG_FILE = "/etc/megamix/language"

def save_language(lang):
    run_cmd(["sudo", "mkdir", "-p", "/etc/megamix"])
    os.system(f"echo '{lang}' | sudo tee {LANG_FILE} > /dev/null")

def load_language():
    global CURRENT_LANG
    try:
        if os.path.exists(LANG_FILE):
            with open(LANG_FILE, "r") as f:
                CURRENT_LANG = f.read().strip()
                return True
    except:
        pass
    return False

def select_language(force=False):
    global CURRENT_LANG
    if not force and load_language():
        return
        
    console.clear()
    console.print(ASCII_ART)
    
    console.print("[bold yellow]Select Language / Dil Seçin / Choisissez la langue:[/bold yellow]\n")
    langs = list(TRANSLATIONS.keys())
    
    table = Table(show_header=False, box=None)
    for i in range(0, len(langs), 4):
        row = []
        for j in range(4):
            if i+j < len(langs):
                row.append(f"{i+j+1}. {langs[i+j]}")
            else:
                row.append("")
        table.add_row(*row)
    console.print(table)
    
    choice = Prompt.ask("\nLanguage", default="1")
    try:
        idx = int(choice) - 1
        if 0 <= idx < len(langs):
            CURRENT_LANG = langs[idx]
            save_language(CURRENT_LANG)
    except ValueError:
        pass

def change_language_setting():
    select_language(force=True)
    show_menu()

if __name__ == "__main__":
    try:
        select_language()
        show_menu()
    except KeyboardInterrupt:
        console.print(f"\n[bold green]{_t('goodbye')}[/bold green]")
        sys.exit(0)