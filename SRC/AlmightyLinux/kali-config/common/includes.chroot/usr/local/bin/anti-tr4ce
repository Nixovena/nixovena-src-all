#!/bin/bash
# ==============================
# anti-tr4ce - Trace & Log Cleaner
# Author: Nixovena Labs
# ==============================

# Colors for output
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
NC='\033[0m'

# Banner
banner() {
    clear
    echo -e "${YELLOW}============================================${NC}"
    echo -e "${GREEN}     anti-tr4ce - System Trace Cleaner${NC}"
    echo -e "${YELLOW}============================================${NC}"
    echo ""
}

# Check if running as root
check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}[!] Please run as root.${NC}"
        exit 1
    fi
}

# Display menu
show_menu() {
    banner
    echo -e "${CYAN}Select cleaning options:${NC}"
    echo "1) Quick Clean (Shell history, temp files, DNS cache)"
    echo "2) Standard Clean (Quick + user cache, trash, recent files)"
    echo "3) Deep Clean (Standard + system logs, journalctl, swap memory)"
    echo "4) Extreme Clean (All traces + mail/printers + scattered files + all users)"
    echo "5) Custom Clean (Select specific items)"
    echo "6) Exit"
    echo ""
}

# Custom clean submenu
custom_clean_menu() {
    banner
    echo -e "${CYAN}Custom Clean Options:${NC}"
    echo " 1) Clear shell histories for current user"
    echo " 2) Clean /tmp and /var/tmp directories securely"
    echo " 3) Clean user cache and thumbnails"
    echo " 4) Clean systemd journal logs securely"
    echo " 5) Shred package manager logs (apt/dpkg)"
    echo " 6) Shred core system security/auth logs"
    echo " 7) Clean user trash and recently used lists"
    echo " 8) Clean browser session/cache/cookie data"
    echo " 9) Clear swap memory and drop pagecache"
    echo "10) Remove scattered temp/core/thumbnail files dynamically"
    echo "11) Clean bash/zsh history in ALL user home directories"
    echo "12) Flush DNS resolver caches"
    echo "13) Clean mail spools and CUPS printer jobs"
    echo "14) Back to main menu"
    echo ""
}

# Function to confirm action
confirm_action() {
    echo -e "${YELLOW}[?] Are you sure you want to proceed? (y/N): ${NC}"
    read -r response
    case "$response" in
        [yY][eE][sS]|[yY]) 
            return 0
            ;;
        *)
            echo -e "${RED}[!] Operation cancelled.${NC}"
            return 1
            ;;
    esac
}

# 1. Clear and shred shell histories
clean_shell_histories() {
    echo -e "${GREEN}[*] Clearing shell histories for current user...${NC}"
    history -c 2>/dev/null || true
    history -w 2>/dev/null || true
    for hist in ~/.bash_history ~/.zsh_history ~/.lesshst ~/.mysql_history ~/.sqlite_history ~/.python_history ~/.node_repl_history ~/.psql_history ~/.php_history; do
        if [ -f "$hist" ]; then
            shred -u -z -n 3 "$hist" 2>/dev/null || rm -f "$hist"
            echo -e "${GREEN}[+] Shredded $hist${NC}"
        fi
    done
}

# 2. Clean /tmp and /var/tmp
clean_temp_dirs() {
    echo -e "${GREEN}[*] Securely cleaning /tmp and /var/tmp...${NC}"
    find /tmp -type f -exec shred -u -z -n 3 {} \; 2>/dev/null
    find /var/tmp -type f -exec shred -u -z -n 3 {} \; 2>/dev/null
    rm -rf /tmp/* /tmp/.* 2>/dev/null
    rm -rf /var/tmp/* /var/tmp/.* 2>/dev/null
    echo -e "${GREEN}[+] Cleaned temporary directories${NC}"
}

# 3. Clean user cache
clean_user_cache() {
    echo -e "${GREEN}[*] Cleaning user cache...${NC}"
    rm -rf ~/.cache/* 2>/dev/null
    rm -rf ~/.thumbnails/* 2>/dev/null
    rm -rf ~/.local/share/icons/* 2>/dev/null
    
    # Firefox cache
    if [ -d ~/.mozilla/firefox/ ]; then
        find ~/.mozilla/firefox/ -name "cache2" -type d -exec sh -c 'rm -rf "$1"/*' sh {} \; 2>/dev/null
        echo -e "${GREEN}[+] Cleaned Firefox cache${NC}"
    fi
    # Chromium-based cache
    for browser_dir in ~/.config/chromium ~/.config/google-chrome ~/.config/brave-browser ~/.config/opera; do
        if [ -d "$browser_dir" ]; then
            find "$browser_dir" -name "Cache" -type d -exec sh -c 'rm -rf "$1"/*' sh {} \; 2>/dev/null
            echo -e "${GREEN}[+] Cleaned cache in $browser_dir${NC}"
        fi
    done
}

# 4. Clean systemd journal logs securely
clean_journal_logs() {
    echo -e "${GREEN}[*] Cleaning journal logs...${NC}"
    journalctl --rotate >/dev/null 2>&1
    journalctl --vacuum-time=1s >/dev/null 2>&1
    journalctl --vacuum-size=1M >/dev/null 2>&1
    if [ -d /var/log/journal/ ]; then
        find /var/log/journal/ -type f -exec shred -u -z -n 3 {} \; 2>/dev/null -o -exec rm -f {} \; 2>/dev/null
        echo -e "${GREEN}[+] Wiped journal files${NC}"
    fi
}

# 5. Shred and wipe apt/dpkg logs
clean_package_logs() {
    echo -e "${GREEN}[*] Shredding package logs...${NC}"
    find /var/log/apt /var/log -maxdepth 1 -type f \( -name "dpkg.log*" -o -name "aptitude*" \) 2>/dev/null | while read f; do
        if [ -f "$f" ]; then
            shred -u -z -n 3 "$f" 2>/dev/null || rm -f "$f"
            echo -e "${GREEN}[+] Shredded package log: $f${NC}"
        fi
    done
}

# 6. Shred and wipe system logs
clean_system_logs() {
    echo -e "${GREEN}[*] Shredding core system logs...${NC}"
    find /var/log -type f \( -name "syslog*" -o -name "auth.log*" -o -name "kern.log*" -o -name "messages*" -o -name "faillog*" -o -name "wtmp*" -o -name "btmp*" -o -name "daemon.log*" -o -name "user.log*" -o -name "dmesg*" -o -name "lastlog" \) 2>/dev/null | while read f; do
        shred -u -z -n 3 "$f" 2>/dev/null || rm -f "$f"
        echo -e "${GREEN}[+] Shredded system log: $f${NC}"
    done
    touch /var/log/wtmp /var/log/lastlog /var/log/btmp
    chmod 664 /var/log/wtmp /var/log/lastlog
    chmod 660 /var/log/btmp
}

# 7. Clean user trash and recent files
clean_user_trash() {
    echo -e "${GREEN}[*] Cleaning user trash and desktop traces...${NC}"
    rm -rf ~/.local/share/Trash/* 2>/dev/null
    echo -e "${GREEN}[+] Cleaned user trash${NC}"
    if [ -f ~/.local/share/recently-used.xbel ]; then
        shred -u -z -n 3 ~/.local/share/recently-used.xbel 2>/dev/null
        touch ~/.local/share/recently-used.xbel
        echo -e "${GREEN}[+] Cleaned recently-used files list${NC}"
    fi
}

# 8. Clean browser session data
clean_browser_sessions() {
    echo -e "${GREEN}[*] Cleaning browser session and cookie files...${NC}"
    # Firefox
    if [ -d ~/.mozilla/firefox/ ]; then
        find ~/.mozilla/firefox/ -name "sessionstore-backups" -type d -exec sh -c 'rm -rf "$1"/*' sh {} \; 2>/dev/null
        find ~/.mozilla/firefox/ -type f \( -name "recovery.jsonlz4" -o -name "cookies.sqlite" -o -name "places.sqlite" -o -name "formhistory.sqlite" \) -exec shred -u -z -n 3 {} \; 2>/dev/null
        echo -e "${GREEN}[+] Cleaned Firefox session & history data${NC}"
    fi
    
    # Chromium-based
    for browser_dir in ~/.config/chromium ~/.config/google-chrome ~/.config/brave-browser ~/.config/opera; do
        if [ -d "$browser_dir" ]; then
            find "$browser_dir" -name "Session Storage" -type d -exec sh -c 'rm -rf "$1"/*' sh {} \; 2>/dev/null
            find "$browser_dir" -type f \( -name "History" -o -name "Cookies" -o -name "Login Data" -o -name "Web Data" \) -exec shred -u -z -n 3 {} \; 2>/dev/null
            echo -e "${GREEN}[+] Cleaned $browser_dir session & history data${NC}"
        fi
    done
}

# 9. Clean swap memory and drop pagecache
clean_swap_memory() {
    echo -e "${GREEN}[*] Clearing swap memory and RAM caches...${NC}"
    sync; echo 3 > /proc/sys/vm/drop_caches
    echo -e "${GREEN}[+] Dropped kernel page cache, dentries, and inodes${NC}"
    if swapon --show | grep -q "^/"; then
        swapoff -a && swapon -a
        echo -e "${GREEN}[+] Swap memory reinitialized and cleared${NC}"
    else
        echo -e "${GREEN}[+] No active swap found.${NC}"
    fi
}

# 10. Remove temporary files, core dumps, thumbnails dynamically
clean_temp_files() {
    echo -e "${GREEN}[*] Dynamically searching and destroying temp/core/thumbnail files...${NC}"
    find / -type f \( -name '*.swp' -o -name '*.swo' -o -name 'core' -o -name '*.crdownload' -o -name 'thumbnail*' -o -name '*~' -o -name '*.bak' \) 2>/dev/null | while read f; do
        if [ -n "$f" ] && [ -f "$f" ]; then
            shred -u -z -n 3 "$f" 2>/dev/null || rm -f "$f"
        fi
    done
    echo -e "${GREEN}[+] Removed scattered temporary and core dump files globally${NC}"
}

# 11. Clean bash history in all user home directories
clean_all_user_histories() {
    echo -e "${GREEN}[*] Locating and destroying shell histories for ALL users...${NC}"
    for dir in /home/* /root; do
        if [ -d "$dir" ]; then
            for hist in .bash_history .zsh_history .lesshst .mysql_history .sqlite_history .python_history .node_repl_history .psql_history .php_history; do
                if [ -f "$dir/$hist" ]; then
                    shred -u -z -n 3 "$dir/$hist" 2>/dev/null || rm -f "$dir/$hist"
                    echo -e "${GREEN}[+] Shredded $dir/$hist${NC}"
                fi
            done
        fi
    done
}

# 12. Flush DNS caches
clean_dns_cache() {
    echo -e "${GREEN}[*] Flushing DNS resolver caches...${NC}"
    if command -v resolvectl &> /dev/null; then
        resolvectl flush-caches
        echo -e "${GREEN}[+] Flushed systemd-resolved DNS cache${NC}"
    elif command -v systemd-resolve &> /dev/null; then
        systemd-resolve --flush-caches
        echo -e "${GREEN}[+] Flushed systemd-resolve DNS cache${NC}"
    fi
    if command -v nscd &> /dev/null && systemctl is-active --quiet nscd; then
        service nscd restart
        echo -e "${GREEN}[+] Restarted nscd to flush DNS cache${NC}"
    fi
    if command -v dnsmasq &> /dev/null && systemctl is-active --quiet dnsmasq; then
        service dnsmasq restart
        echo -e "${GREEN}[+] Restarted dnsmasq to flush DNS cache${NC}"
    fi
}

# 13. Clean mail spools and CUPS printer jobs
clean_mail_printers() {
    echo -e "${GREEN}[*] Cleaning mail spools and CUPS printer jobs...${NC}"
    if [ -d /var/mail/ ]; then
        find /var/mail/ -type f -exec shred -u -z -n 3 {} \; 2>/dev/null
        echo -e "${GREEN}[+] Shredded /var/mail logs${NC}"
    fi
    if [ -d /var/spool/mail/ ]; then
        find /var/spool/mail/ -type f -exec shred -u -z -n 3 {} \; 2>/dev/null
        echo -e "${GREEN}[+] Shredded /var/spool/mail logs${NC}"
    fi
    if [ -d /var/spool/cups/ ]; then
        rm -rf /var/spool/cups/* 2>/dev/null
        echo -e "${GREEN}[+] Cleaned CUPS printer jobs${NC}"
    fi
}

# Quick clean option
quick_clean() {
    echo -e "${YELLOW}[!] Performing Quick Clean${NC}"
    if confirm_action; then
        clean_shell_histories
        clean_temp_dirs
        clean_dns_cache
        echo -e "${GREEN}[✓] Quick clean completed!${NC}"
    fi
}

# Standard clean option
standard_clean() {
    echo -e "${YELLOW}[!] Performing Standard Clean${NC}"
    if confirm_action; then
        clean_shell_histories
        clean_temp_dirs
        clean_dns_cache
        clean_user_cache
        clean_user_trash
        echo -e "${GREEN}[✓] Standard clean completed!${NC}"
    fi
}

# Deep clean option
deep_clean() {
    echo -e "${YELLOW}[!] Performing Deep Clean${NC}"
    if confirm_action; then
        clean_shell_histories
        clean_temp_dirs
        clean_dns_cache
        clean_user_cache
        clean_user_trash
        clean_browser_sessions
        clean_journal_logs
        clean_package_logs
        clean_system_logs
        clean_swap_memory
        echo -e "${GREEN}[✓] Deep clean completed!${NC}"
    fi
}

# Extreme clean option
extreme_clean() {
    echo -e "${RED}[!] WARNING: Performing Extreme Clean${NC}"
    echo -e "${RED}[!] This will comprehensively destroy logs and traces system-wide.${NC}"
    if confirm_action; then
        clean_shell_histories
        clean_temp_dirs
        clean_dns_cache
        clean_user_cache
        clean_user_trash
        clean_browser_sessions
        clean_journal_logs
        clean_package_logs
        clean_system_logs
        clean_mail_printers
        clean_swap_memory
        clean_temp_files
        clean_all_user_histories
        echo -e "${GREEN}[✓] Extreme clean completed!${NC}"
    fi
}

# Custom clean option
custom_clean() {
    while true; do
        custom_clean_menu
        echo -e "${CYAN}Enter your choice [1-14]:${NC}"
        read -r custom_choice
        
        case $custom_choice in
            1) clean_shell_histories ;;
            2) clean_temp_dirs ;;
            3) clean_user_cache ;;
            4) clean_journal_logs ;;
            5) clean_package_logs ;;
            6) clean_system_logs ;;
            7) clean_user_trash ;;
            8) clean_browser_sessions ;;
            9) clean_swap_memory ;;
            10) clean_temp_files ;;
            11) clean_all_user_histories ;;
            12) clean_dns_cache ;;
            13) clean_mail_printers ;;
            14) return ;;
            *) echo -e "${RED}[!] Invalid option. Please select 1-14.${NC}" ;;
        esac
        
        echo ""
        echo -e "${YELLOW}Press Enter to continue...${NC}"
        read -r
    done
}

# Main function
main() {
    check_root
    
    while true; do
        show_menu
        echo -e "${CYAN}Enter your choice [1-6]:${NC}"
        read -r choice
        
        case $choice in
            1) quick_clean ;;
            2) standard_clean ;;
            3) deep_clean ;;
            4) extreme_clean ;;
            5) custom_clean ;;
            6) 
                echo -e "${GREEN}Goodbye!${NC}"
                exit 0
                ;;
            *) 
                echo -e "${RED}[!] Invalid option. Please select 1-6.${NC}"
                ;;
        esac
        
        echo ""
        echo -e "${YELLOW}Press Enter to continue...${NC}"
        read -r
    done
}

# Run main function
main