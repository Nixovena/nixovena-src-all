#!/bin/bash

# DNS Changer for Linux
# Changes DNS settings in /etc/resolv.conf

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Popular DNS options
declare -A DNS_OPTIONS=(
    [1]="Google DNS|8.8.8.8|8.8.4.4"
    [2]="Cloudflare DNS|1.1.1.1|1.0.0.1"
    [3]="OpenDNS|208.67.222.222|208.67.220.220"
    [4]="Quad9 DNS|9.9.9.9|149.112.112.112"
    [5]="Level 3 DNS|4.2.2.1|4.2.2.2"
    [6]="Comodo Secure DNS|8.26.56.26|8.20.247.20"
    [7]="CleanBrowsing Family Filter|185.228.168.168|185.228.169.168"
    [8]="AdGuard DNS|94.140.14.14|94.140.15.15"
)

# Function to display menu
show_menu() {
    clear
    echo "=================================="
    echo "        DNS Changer Script"
    echo "=================================="
    echo "Select a DNS option:"
    echo ""
    
    for i in {1..8}; do
        IFS='|' read -r name dns1 dns2 <<< "${DNS_OPTIONS[$i]}"
        echo "$i) $name ($dns1, $dns2)"
    done
    
    echo ""
    echo "9) Custom DNS"
    echo "10) Unlock & Reset DNS (Allow NetworkManager)"
    echo "0) Exit"
    echo ""
}

# Function to validate IP address
validate_ip() {
    local ip=$1
    if [[ $ip =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        IFS='.' read -ra ADDR <<< "$ip"
        for i in "${ADDR[@]}"; do
            if [[ $i -gt 255 ]]; then
                return 1
            fi
        done
        return 0
    else
        return 1
    fi
}

# Function to change DNS
change_dns() {
    local dns1=$1
    local dns2=$2
    local provider=$3
    
    # Check if script is run as root
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}This script must be run as root${NC}" 
        exit 1
    fi
    
    # Remove immutable flag temporarily if it exists
    chattr -i /etc/resolv.conf 2>/dev/null
    
    # Backup current resolv.conf
    cp -L /etc/resolv.conf /etc/resolv.conf.backup 2>/dev/null
    
    # Remove to break any symlinks (like systemd-resolved)
    rm -f /etc/resolv.conf
    
    # Write new DNS settings
    echo "# Generated by DNS Changer Script" > /etc/resolv.conf
    echo "# Note: Immutable flag is set to prevent NetworkManager overrides" >> /etc/resolv.conf
    echo "nameserver $dns1" >> /etc/resolv.conf
    echo "nameserver $dns2" >> /etc/resolv.conf
    
    # Lock the file unconditionally
    chattr +i /etc/resolv.conf
    
    echo -e "${GREEN}DNS changed successfully to $provider${NC}"
    echo "Primary DNS: $dns1"
    echo "Secondary DNS: $dns2"
    echo ""
    echo "Backup of original DNS settings saved to /etc/resolv.conf.backup"
    echo -e "${YELLOW}[!] /etc/resolv.conf is now locked (immutable) to prevent NetworkManager overrides.${NC}"
}

# Function to set custom DNS
set_custom_dns() {
    echo "Enter custom DNS servers:"
    read -p "Primary DNS: " custom_dns1
    read -p "Secondary DNS: " custom_dns2
    
    # Validate IPs
    if ! validate_ip "$custom_dns1"; then
        echo -e "${RED}Invalid primary DNS address${NC}"
        return
    fi
    
    if ! validate_ip "$custom_dns2"; then
        echo -e "${RED}Invalid secondary DNS address${NC}"
        return
    fi
    
    change_dns "$custom_dns1" "$custom_dns2" "Custom DNS"
}

# Function to reset and unlock DNS
reset_dns() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}This script must be run as root${NC}" 
        exit 1
    fi

    echo "Unlocking /etc/resolv.conf..."
    chattr -i /etc/resolv.conf 2>/dev/null

    if [[ -f /etc/resolv.conf.backup ]]; then
        cp -af /etc/resolv.conf.backup /etc/resolv.conf 2>/dev/null
        echo -e "${GREEN}Restored backup successfully.${NC}"
    else
        rm -f /etc/resolv.conf
        echo -e "${GREEN}Removed static file. Restarting NetworkManager...${NC}"
        systemctl restart NetworkManager 2>/dev/null
    fi
    echo -e "${GREEN}NetworkManager can now manage DNS again.${NC}"
}

# Main script
main() {
    while true; do
        show_menu
        read -p "Enter your choice [0-10]: " choice
        
        case $choice in
            1|2|3|4|5|6|7|8)
                IFS='|' read -r name dns1 dns2 <<< "${DNS_OPTIONS[$choice]}"
                change_dns "$dns1" "$dns2" "$name"
                ;;
            9)
                set_custom_dns
                ;;
            10)
                reset_dns
                ;;
            0)
                echo "Exiting..."
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid option! Please select 0-10.${NC}"
                sleep 2
                continue
                ;;
        esac
        
        echo ""
        read -p "Press Enter to continue..."
    done
}

# Run the script
main