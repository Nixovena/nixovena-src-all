#!/bin/bash

# ================================================
#       Almighty Flatpak Setup
# ================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}================================================${NC}"
echo -e "${YELLOW}       Almighty Flatpak Setup${NC}"
echo -e "${CYAN}================================================${NC}"
echo ""

if [ "$(id -u)" -ne 0 ]; then
    echo -e "${RED}This script must be run as root.${NC}"
    echo "Usage: sudo flatpak-setup"
    exit 1
fi

export DEBIAN_FRONTEND=noninteractive

# Check if flatpak is already installed
if command -v flatpak &>/dev/null; then
    echo -e "${GREEN}Flatpak is already installed.${NC}"
    flatpak --version
    echo ""
else
    echo -e "${CYAN}[1/2] Installing Flatpak...${NC}"
    apt-get update
    apt-get install -y flatpak
    if [ $? -ne 0 ]; then
        echo -e "${RED}Failed to install Flatpak.${NC}"
        exit 1
    fi
    echo -e "${GREEN}Flatpak installed successfully.${NC}"
    echo ""
fi

# Add Flathub repository
echo -e "${CYAN}[2/2] Adding Flathub repository...${NC}"
flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo

if [ $? -eq 0 ]; then
    echo -e "${GREEN}Flathub repository added successfully.${NC}"
else
    echo -e "${YELLOW}Flathub repository may already exist or there was an error.${NC}"
fi

echo ""
echo -e "${CYAN}================================================${NC}"
echo -e "${GREEN}Setup complete.${NC}"
echo -e "${YELLOW}A system reboot is required for Flatpak to work properly.${NC}"
echo -e "${CYAN}================================================${NC}"
echo ""
read -p "Reboot now? (y/N): " _reboot
if [[ "$_reboot" =~ ^[yY]$ ]]; then
    echo -e "${CYAN}Rebooting...${NC}"
    reboot
else
    echo -e "${GREEN}Please reboot manually when ready.${NC}"
fi
