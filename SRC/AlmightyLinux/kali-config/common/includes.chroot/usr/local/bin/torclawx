#!/usr/bin/env python3

import os
import sys
import time
import signal
try:
    import requests
except ImportError:
    import sys; sys.exit("[!] Missing: requests")
import hashlib
try:
    from bs4 import BeautifulSoup
except ImportError:
    import sys; sys.exit("[!] Missing: bs4")
from urllib.parse import urljoin, urlparse
from urllib.robotparser import RobotFileParser
from datetime import datetime
import json
import mimetypes
import pickle
import sqlite3
import re
import csv
from concurrent.futures import ThreadPoolExecutor, as_completed
from threading import Lock
import socket
import random

BANNER = r"""
═══════════════════════════════════════
   _____           ____ _                      
 |_   _|__  _ __ / ___| | __ ___      ____  __
   | |/ _ \| '__| |   | |/ _` \ \ /\ / /\ \/ /
   | | (_) | |  | |___| | (_| |\ V  V /  >  < 
   |_|\___/|_|   \____|_|\__,_| \_/\_/  /_/\_\

═══════════════════════════════════════
Onion Crawler & Archive Tool                                             
═══════════════════════════════════════
"""

LEGAL_WARNING = """
⚠ LEGAL WARNING ⚠
This tool is for EDUCATIONAL purposes only.
