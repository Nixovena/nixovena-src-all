        "carrier_lookup": f"https://www.carrierlookup.com/results.php?phone={clean}",
        "freecarrierlookup": f"https://freecarrierlookup.com/?phone={clean}",
        "phoneinfoga": f"https://demo.phoneinfoga.crvx.fr/#/scan/{clean}",
        "opencnam": f"https://api.opencnam.com/v3/phone/{clean}",
        "twilio_lookup": f"https://www.twilio.com/console/phone-numbers/lookup/{clean}",
        "numverify_web": f"https://numverify.com/?number={clean}",
        "google_search": f"https://www.google.com/search?q=\"{clean}\"",
        "bing_search": f"https://www.bing.com/search?q=\"{clean}\"",
        "yandex_search": f"https://yandex.com/search/?text=\"{clean}\"",
        "ahmia_darkweb": f"https://ahmia.fi/search/?q={clean}",
        "torch_darkweb": f"http://xmh57jrknzkhv6y3ls3ubitzfqnkrwxhopf5aygthi7d6rplyvk3noyd.onion/cgi-bin/omega/omega?P={clean}",
        "cybergordon": f"https://cybergordon.com/search/{clean}",
    }


def _number_age_estimation(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    region = phonenumbers.region_code_for_number(parsed)
    nsn = phonenumbers.national_significant_number(parsed)
    ntype = phonenumbers.number_type(parsed)
    result = {
        "estimated_allocation_era": "unknown",
        "confidence": "low",
        "analysis": [],
    }
    if region == "US" and nsn and len(nsn) >= 3:
        area_code = nsn[:3]
        original_1947 = ["201", "202", "203", "205", "206", "207", "208", "209", "210",
                         "212", "213", "214", "215", "216", "217", "218", "219",
                         "301", "302", "303", "304", "305", "307", "308", "309",
                         "312", "313", "314", "315", "316", "317", "318", "319",
                         "401", "402", "404", "405", "406", "407", "408", "409",
                         "412", "413", "414", "415", "416", "417", "418", "419",
                         "501", "502", "503", "504", "505", "506", "507", "508", "509",
                         "512", "513", "514", "515", "516", "517", "518", "519",
                         "601", "602", "603", "604", "605", "606", "607", "608", "609",
                         "612", "613", "614", "615", "616", "617", "618", "619",
                         "701", "702", "703", "704", "706", "707", "708", "709",
                         "712", "713", "714", "715", "716", "717", "718", "719",
                         "801", "802", "803", "804", "805", "806", "808", "809",
                         "812", "813", "814", "815", "816", "817", "818", "819",
                         "901", "902", "903", "904", "906", "907", "912", "913", "914", "915", "916", "918", "919"]
        mid_codes = ["917", "347", "646", "929", "469", "832", "678", "786", "857", "484",
                     "267", "443", "571", "770", "972", "281", "925", "949", "310", "323"]
        new_codes = ["332", "680", "838", "564", "943", "726", "640", "548", "223", "463",
                     "472", "534", "557", "574", "624", "659", "689", "737"]
        if area_code in original_1947:
            result["estimated_allocation_era"] = "pre-1990s (original area code from 1947)"
            result["confidence"] = "medium"
            result["analysis"].append(f"Area code {area_code} is one of the original NANP codes assigned in 1947")
        elif area_code in mid_codes:
            result["estimated_allocation_era"] = "1990s-2010s (overlay/split code)"
            result["confidence"] = "medium"
            result["analysis"].append(f"Area code {area_code} was introduced as an overlay or split during expansion")
        elif area_code in new_codes:
            result["estimated_allocation_era"] = "2010s-present (recent allocation)"
            result["confidence"] = "medium"
            result["analysis"].append(f"Area code {area_code} is a recently allocated code")
    elif region == "TR" and nsn and len(nsn) >= 3:
        prefix = nsn[:3]
        old_prefixes = ["532", "533", "534", "535", "536", "537", "538", "505", "506", "507"]
        new_prefixes = ["551", "552", "553", "554", "559", "540", "539", "501"]
        if prefix in old_prefixes:
            result["estimated_allocation_era"] = "2000s-2010s (early mobile era)"
            result["confidence"] = "medium"
            result["analysis"].append(f"Prefix {prefix} is from the early Turkish mobile allocation")
        elif prefix in new_prefixes:
            result["estimated_allocation_era"] = "2015-present (newer allocation)"
            result["confidence"] = "medium"
            result["analysis"].append(f"Prefix {prefix} is a more recently allocated Turkish mobile prefix")
    elif region == "GB" and nsn:
        if nsn.startswith("20"):
            result["analysis"].append("London (020) numbers - established geographic range")
        elif nsn.startswith("7"):
            result["analysis"].append("UK mobile (07xxx) - range allocated progressively since 1990s")
    if ntype == PhoneNumberType.MOBILE:
        result["analysis"].append("Mobile numbers are frequently recycled by carriers (typical cycle: 90-180 days)")
        result["analysis"].append("Number portability makes age estimation less reliable for mobile")
    elif ntype == PhoneNumberType.VOIP:
        result["analysis"].append("VoIP numbers are typically recently allocated (post-2000)")
        result["estimated_allocation_era"] = "2000s-present (VoIP era)"
        result["confidence"] = "medium"
    elif ntype == PhoneNumberType.TOLL_FREE:
        result["analysis"].append("Toll-free numbers can be very old or recently allocated")
    return result


def _risk_assessment(parsed, carrier_name, voip_result, disposable_result, reputation_result):
    risk = {
        "overall_risk": "low",
        "risk_score": 0,
        "risk_factors": [],
        "trust_indicators": [],
        "recommendations": [],
    }
    ntype = phonenumbers.number_type(parsed) if HAS_PHONENUMBERS else None
    region = phonenumbers.region_code_for_number(parsed) if HAS_PHONENUMBERS else None
    if ntype == PhoneNumberType.VOIP:
        risk["risk_score"] += 15
        risk["risk_factors"].append("VoIP number - can be created anonymously without identity verification")
        risk["recommendations"].append("Request alternative contact method for verification")
    elif ntype == PhoneNumberType.TOLL_FREE:
        risk["risk_score"] += 10
        risk["risk_factors"].append("Toll-free number - commonly used by businesses but also by scammers")
    elif ntype == PhoneNumberType.PREMIUM_RATE:
        risk["risk_score"] += 30
        risk["risk_factors"].append("Premium rate number - calling this number will incur charges")
        risk["recommendations"].append("CAUTION: Do not call back - premium rate charges apply")
    elif ntype == PhoneNumberType.MOBILE:
        risk["trust_indicators"].append("Mobile number - likely registered with carrier identity verification")
        if region and region in COUNTRY_DIAL_INFO:
            if COUNTRY_DIAL_INFO[region].get("sim_registration"):
                risk["trust_indicators"].append(f"SIM registration required in {region} - identity linked to number")
                risk["risk_score"] -= 5
    elif ntype == PhoneNumberType.FIXED_LINE:
        risk["trust_indicators"].append("Fixed line number - associated with physical location")
        risk["risk_score"] -= 10
    if voip_result and voip_result.get("likely_voip"):
        risk["risk_score"] += 10
        risk["risk_factors"].append(f"VoIP detection confidence: {voip_result.get('voip_confidence', 0)}%")
    if disposable_result and disposable_result.get("likely_disposable"):
        risk["risk_score"] += 30
        risk["risk_factors"].append("Potentially disposable/temporary number")
        risk["recommendations"].append("This number may be temporary and could become inactive soon")
    if reputation_result:
        rep_score = reputation_result.get("reputation_score")
        if rep_score is not None:
            if rep_score <= 20:
                risk["risk_score"] += 40
                risk["risk_factors"].append(f"Very poor reputation score: {rep_score}/100")
                risk["recommendations"].append("Number reported as dangerous by multiple sources - exercise extreme caution")
            elif rep_score <= 40:
                risk["risk_score"] += 30
                risk["risk_factors"].append(f"Poor reputation score: {rep_score}/100")
                risk["recommendations"].append("Number has significant spam/scam reports")
            elif rep_score <= 60:
                risk["risk_score"] += 15
                risk["risk_factors"].append(f"Suspicious reputation score: {rep_score}/100")
            elif rep_score >= 80:
                risk["trust_indicators"].append(f"Good reputation score: {rep_score}/100")
                risk["risk_score"] -= 5
    if carrier_name:
        risk["trust_indicators"].append(f"Carrier identified: {carrier_name}")
    else:
        risk["risk_score"] += 5
        risk["risk_factors"].append("Carrier could not be identified - potentially anonymized")
    nsn = phonenumbers.national_significant_number(parsed) if HAS_PHONENUMBERS else ""
    entropy = _shannon_entropy(nsn)
    if entropy < 1.5 and len(nsn) >= 7:
        risk["risk_score"] += 10
        risk["risk_factors"].append(f"Low digit entropy ({entropy}) - unusual/synthetic pattern")
    elif entropy > 3.2 and len(nsn) >= 7:
        risk["trust_indicators"].append(f"Normal digit entropy ({entropy}) - natural number pattern")
    risk["risk_score"] = max(0, min(100, risk["risk_score"]))
    if risk["risk_score"] >= 70:
        risk["overall_risk"] = "critical"
    elif risk["risk_score"] >= 50:
        risk["overall_risk"] = "high"
    elif risk["risk_score"] >= 35:
        risk["overall_risk"] = "medium"
    elif risk["risk_score"] >= 15:
        risk["overall_risk"] = "low-medium"
    else:
        risk["overall_risk"] = "low"
    return risk


def _generate_report_hash(phone_number):
    timestamp = datetime.now(timezone.utc).isoformat()
    data = f"{phone_number}:{timestamp}:{os.getpid()}"
    return _sha256(data)[:16]


def _print_section(title, width=72):
    print(f"\n{'─' * width}")
    print(f"  {title}")
    print(f"{'─' * width}")


def _print_kv(key, value, indent=4):
    prefix = " " * indent
    if value is None or value == "" or value == "Unknown":
        print(f"{prefix}{key}: N/A")
    elif isinstance(value, bool):
        print(f"{prefix}{key}: {'Yes' if value else 'No'}")
    elif isinstance(value, dict):
        print(f"{prefix}{key}:")
        for k, v in value.items():
            _print_kv(k, v, indent + 4)
    elif isinstance(value, list):
        if not value:
            print(f"{prefix}{key}: (empty)")
        elif len(value) == 1:
            if isinstance(value[0], dict):
                print(f"{prefix}{key}:")
                print(f"{prefix}    [1]")
                for k, v in value[0].items():
                    _print_kv(k, v, indent + 8)
            else:
                print(f"{prefix}{key}: {value[0]}")
        else:
            print(f"{prefix}{key}:")
            for i, item in enumerate(value, 1):
                if isinstance(item, dict):
                    print(f"{prefix}    [{i}]")
                    for k, v in item.items():
                        _print_kv(k, v, indent + 8)
                else:
                    print(f"{prefix}    [{i}] {item}")
    else:
        print(f"{prefix}{key}: {value}")


def _print_results(phone_number, results, output_format="text"):
    if output_format == "json":
        print(json.dumps(results, indent=2, default=str, ensure_ascii=False))
        return
    w = 72
    print(f"\n{'═' * w}")
    print(f"  ph000enix v{results.get('tool_version', '4.x')} - Phone Number Intelligence Report")
    print(f"{'═' * w}")
    print(f"    Target: {phone_number}")
    print(f"    Report ID: {results.get('report_id', 'N/A')}")
    print(f"    Generated: {results.get('timestamp', 'N/A')}")
    scan_count = sum(1 for k, v in results.items() if k not in ("target", "report_id", "timestamp", "tool_version") and v)
    print(f"    Modules Executed: {scan_count}")
    print(f"{'═' * w}")
    if "validation" in results and results["validation"]:
        _print_section("VALIDATION & NUMBER PROPERTIES")
        v = results["validation"]
        _print_kv("Valid Number", v.get("is_valid"))
        _print_kv("Possible Number", v.get("is_possible"))
        _print_kv("Valid for Region", v.get("is_valid_for_region"))
        _print_kv("Validation Reason", v.get("validation_reason"))
        _print_kv("Number Type", v.get("number_type"))
        _print_kv("NSN Length", v.get("nsn_length"))
        _print_kv("Expected NSN Length", v.get("expected_nsn_length"))
        _print_kv("Has Leading Zero", v.get("has_leading_zero"))
        _print_kv("Can Be Internationally Dialed", v.get("can_be_internationally_dialed"))
        _print_kv("Example for Type", v.get("example_for_type"))
    if "formats" in results and results["formats"]:
        _print_section("NUMBER FORMATS")
        f = results["formats"]
        for fmt_name, fmt_val in f.items():
            _print_kv(fmt_name.upper(), fmt_val)
    if "international_dialing" in results and results["international_dialing"]:
        _print_section("INTERNATIONAL DIALING FORMATS")
        for name, dial_str in list(results["international_dialing"].items())[:15]:
            _print_kv(name.replace("dial_from_", "From "), dial_str)
    if "country_info" in results and results["country_info"]:
        _print_section("COUNTRY & REGION INTELLIGENCE")
        c = results["country_info"]
        _print_kv("Country Code", c.get("country_code"))
        _print_kv("Region Code", c.get("region_code"))
        _print_kv("Country Name", c.get("country_name"))
        _print_kv("All Regions for Code", c.get("all_regions_for_code"))
        if "dial_info" in c:
            di = c["dial_info"]
            _print_kv("Emergency Number", di.get("emergency"))
            _print_kv("Exit Code", di.get("exit_code"))
            _print_kv("Trunk Prefix", di.get("trunk"))
            _print_kv("Regulatory Authority", di.get("reg_authority"))
            _print_kv("Numbering Plan", di.get("numbering_plan"))
            _print_kv("SIM Registration Required", di.get("sim_registration"))
            _print_kv("Number Portability", di.get("number_portability"))
        if "carrier_landscape" in c:
            _print_kv("Major Carriers", c["carrier_landscape"].get("major_carriers"))
            _print_kv("MVNO Carriers", c["carrier_landscape"].get("mvno_carriers"))
    if "geo" in results and results["geo"]:
        _print_section("GEOLOCATION (Multi-Language)")
        for lang, desc in results["geo"].items():
            _print_kv(f"Location [{lang}]", desc)
    if "carrier" in results and results["carrier"]:
        _print_section("CARRIER INFORMATION")
        for lang, c_name in results["carrier"].items():
            _print_kv(f"Carrier [{lang}]", c_name)
    if "carrier_prefix" in results and results["carrier_prefix"]:
        cp = results["carrier_prefix"]
        if cp.get("carrier_from_prefix"):
            _print_kv("Prefix-Based Carrier", f"{cp['carrier_from_prefix']} (prefix: {cp.get('prefix_match', '?')})")
    if "timezone" in results and results["timezone"]:
        _print_section("TIMEZONE & LOCAL TIME")
        tz = results["timezone"]
        _print_kv("Timezones", tz.get("timezones"))
        _print_kv("UTC Offsets", tz.get("utc_offsets"))
        if tz.get("current_times"):
            for ct in tz["current_times"]:
                _print_kv(f"Local Time ({ct['timezone']})", f"{ct['time']} {ct.get('day_of_week', '')} (DST: {ct['dst_active']})")
        if tz.get("business_hours"):
            for bh in tz["business_hours"]:
                _print_kv(f"Availability ({bh['timezone']})", f"{bh['status'].upper()} (hour: {bh['local_hour']})")
    if "pattern_analysis" in results and results["pattern_analysis"]:
        _print_section("NUMBER PATTERN ANALYSIS")
        p = results["pattern_analysis"]
        _print_kv("National Number", p.get("national_number"))
        _print_kv("Digit Count", p.get("digit_count"))
        _print_kv("Entropy", p.get("entropy"))
        _print_kv("Unique Digits", p.get("unique_digits"))
        _print_kv("Complexity Score", p.get("complexity_score"))
        _print_kv("Digit Sum", p.get("digit_sum"))
        _print_kv("Sequential", p.get("is_sequential"))
        _print_kv("Repeating", p.get("is_repeating"))
        _print_kv("Palindrome", p.get("is_palindrome"))
        _print_kv("Vanity Potential", p.get("vanity_potential"))
        _print_kv("Max Consecutive Repeat", p.get("max_consecutive_repeat"))
        _print_kv("Digit Frequency", p.get("digit_frequency"))
    if "voip_detection" in results and results["voip_detection"]:
        _print_section("VoIP DETECTION")
        vd = results["voip_detection"]
        _print_kv("Likely VoIP", vd.get("likely_voip"))
        _print_kv("VoIP Confidence", f"{vd.get('voip_confidence', 0)}%")
        if vd.get("indicators"):
            _print_kv("Indicators", vd["indicators"])
    if "disposable_check" in results and results["disposable_check"]:
        _print_section("DISPOSABLE NUMBER CHECK")
        dc = results["disposable_check"]
        _print_kv("Likely Disposable", dc.get("likely_disposable"))
        _print_kv("Confidence", f"{dc.get('confidence', 0)}%")
        if dc.get("indicators"):
            _print_kv("Indicators", dc["indicators"])
    if "hlr_simulation" in results and results["hlr_simulation"]:
        _print_section("HLR / NETWORK SIMULATION")
        h = results["hlr_simulation"]
        _print_kv("MCC", h.get("mcc"))
        _print_kv("MNC", h.get("mnc"))
        _print_kv("Network Name", h.get("network_name"))
        _print_kv("Number Portability", h.get("number_portability"))
        _print_kv("Roaming Status", h.get("roaming_status"))
        _print_kv("Network Generation", h.get("network_generation"))
    if "number_age" in results and results["number_age"]:
        _print_section("NUMBER AGE ESTIMATION")
        na = results["number_age"]
        _print_kv("Estimated Era", na.get("estimated_allocation_era"))
        _print_kv("Confidence", na.get("confidence"))
        if na.get("analysis"):
            _print_kv("Analysis", na["analysis"])
    if "messaging_platforms" in results and results["messaging_platforms"]:
        _print_section("MESSAGING PLATFORM COMPATIBILITY")
        mp = results["messaging_platforms"]
        for platform, info in mp.items():
            if isinstance(info, dict):
                status = "Possible" if info.get("possible") else "Unlikely"
                check_url = info.get("check_url", "")
                if check_url:
                    _print_kv(platform.upper(), f"{status} | {check_url}")
                else:
                    _print_kv(platform.upper(), status)
    if "whatsapp_check" in results and results["whatsapp_check"]:
        _print_section("WHATSAPP LINK CHECK")
        wa = results["whatsapp_check"]
        _print_kv("WA.me Reachable", wa.get("wa_me_reachable"))
        _print_kv("Likely Registered", wa.get("likely_registered"))
        _print_kv("Direct Link", wa.get("direct_link"))
        _print_kv("API Link", wa.get("api_link"))
    if "reputation" in results and results["reputation"]:
        _print_section("REPUTATION & SPAM ANALYSIS")
        rep = results["reputation"]
        _print_kv("Reputation Score", f"{rep.get('reputation_score', 'N/A')}/100")
        _print_kv("Overall Sentiment", rep.get("overall_sentiment", "").upper())
        if rep.get("sources_checked"):
            for src in rep["sources_checked"]:
                print(f"\n    --- {src.get('source', 'Unknown')} ---")
                _print_kv("Status", src.get("status"), 6)
                for key in ["rating", "scam_detection", "number_type", "solution", "score", "rating_text", "caller_type", "numeric_score"]:
                    if src.get(key):
                        _print_kv(key.replace("_", " ").title(), src[key], 6)
                if src.get("comments"):
                    for ci, comment in enumerate(src["comments"][:5], 1):
                        _print_kv(f"Comment {ci}", comment[:200], 6)
    if "risk_assessment" in results and results["risk_assessment"]:
        _print_section("RISK ASSESSMENT")
        ra = results["risk_assessment"]
        _print_kv("Overall Risk", ra.get("overall_risk", "unknown").upper())
        _print_kv("Risk Score", f"{ra.get('risk_score', 0)}/100")
        if ra.get("risk_factors"):
            _print_kv("Risk Factors", ra["risk_factors"])
        if ra.get("trust_indicators"):
            _print_kv("Trust Indicators", ra["trust_indicators"])
        if ra.get("recommendations"):
            _print_kv("Recommendations", ra["recommendations"])
    if "web_links" in results and results["web_links"]:
        _print_section("WEB PRESENCE (DuckDuckGo)")
        for i, link in enumerate(results["web_links"][:20], 1):
            title = link.get("title", "")
            url = link.get("url", "")
            domain = link.get("domain", "")
            print(f"    [{i:02d}] {title}")
            print(f"         {url}")
            if domain:
                print(f"         [{domain}]")
    if "search_dorks" in results and results["search_dorks"]:
        _print_section("SEARCH ENGINE DORK URLS")
        sd = results["search_dorks"]
        for engine in ["google", "duckduckgo", "bing", "yandex", "brave", "startpage"]:
            if sd.get(engine):
                _print_kv(engine.title(), sd[engine])
        if sd.get("number_variants"):
            _print_kv("Search Variants", sd["number_variants"])
        if sd.get("advanced_dorks"):
            print(f"\n    --- Advanced Dorks ---")
            for name, url in sd["advanced_dorks"].items():
                _print_kv(name.replace("_", " ").title(), url, 6)
    if "reverse_lookup" in results and results["reverse_lookup"]:
        _print_section("REVERSE LOOKUP URLS")
        for name, url in results["reverse_lookup"].items():
            _print_kv(name, url)
    if "social_media_urls" in results and results["social_media_urls"]:
        _print_section("SOCIAL MEDIA PROFILE URLS")
        for name, url in results["social_media_urls"].items():
            _print_kv(name, url)
    if "breach_search_urls" in results and results["breach_search_urls"]:
        _print_section("DATA BREACH SEARCH URLS")
        for name, url in results["breach_search_urls"].items():
            _print_kv(name, url)
    if "osint_framework" in results and results["osint_framework"]:
        _print_section("OSINT FRAMEWORK URLS")
        for name, url in results["osint_framework"].items():
            _print_kv(name, url)
    if "dorking_targets" in results and results["dorking_targets"]:
        _print_section("ADVANCED DORKING TARGETS")
        for dt in results["dorking_targets"][:15]:
            _print_kv(f"[{dt.get('category')}] {dt.get('site')}", dt.get("search_url"))
    if "api_results" in results and results["api_results"]:
        _print_section("EXTERNAL API RESULTS")
        for api_name, api_data in results["api_results"].items():
            print(f"\n    --- {api_name} ---")
            if isinstance(api_data, dict):
                for k, v in api_data.items():
                    _print_kv(k, v, 6)
            else:
                _print_kv("Result", api_data, 6)
    print(f"\n{'═' * w}")
    print(f"  ph000enix - Investigation Complete")
    print(f"{'═' * w}\n")


async def main():
    if not HAS_PHONENUMBERS:
        print("[FATAL] phonenumbers library is required. Install: pip install phonenumbers")
        sys.exit(1)

    parser = argparse.ArgumentParser(
        description="ph000enix - Phone Number Intelligence Tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Example: ph000enix -n +14155552671 --full-scan\n"
               "         ph000enix -n +905551234567 --no-web --json\n"
               "         ph000enix -n +442071234567 --no-reputation --delay 1.5\n"
               "         ph000enix -n +14155552671 --save report.json"
    )
    parser.add_argument("-n", "--number", required=True, help="Phone number with country code (e.g. +14155552671)")
    parser.add_argument("--json", action="store_true", help="Output results in JSON format")
    parser.add_argument("--full-scan", action="store_true", help="Enable all scan modules including web lookups")
    parser.add_argument("--no-web", action="store_true", help="Skip web-based lookups (DuckDuckGo, reputation)")
    parser.add_argument("--no-reputation", action="store_true", help="Skip reputation/spam database checks")
    parser.add_argument("--no-links", action="store_true", help="Skip web link discovery")
    parser.add_argument("--no-dorks", action="store_true", help="Skip search engine dork generation")
    parser.add_argument("--no-social", action="store_true", help="Skip social media URL generation")
    parser.add_argument("--no-breach", action="store_true", help="Skip breach search URL generation")
    parser.add_argument("--no-reverse", action="store_true", help="Skip reverse lookup URL generation")
    parser.add_argument("--no-messaging", action="store_true", help="Skip messaging platform analysis")
    parser.add_argument("--no-hlr", action="store_true", help="Skip HLR simulation")
    parser.add_argument("--no-risk", action="store_true", help="Skip risk assessment")
    parser.add_argument("--no-osint", action="store_true", help="Skip OSINT framework URL generation")
    parser.add_argument("--no-whatsapp", action="store_true", help="Skip WhatsApp link check")
    parser.add_argument("--no-dialing", action="store_true", help="Skip international dialing format generation")
    parser.add_argument("--numverify-key", default=None, help="API key for numverify.com lookup")
    parser.add_argument("--abstractapi-key", default=None, help="API key for abstractapi.com phone validation")
    parser.add_argument("--veriphone-key", default=None, help="API key for veriphone.io lookup")
    parser.add_argument("--delay", type=float, default=1.0, help="Delay between web requests in seconds (default: 1.0)")
    parser.add_argument("--timeout", type=int, default=12, help="HTTP request timeout in seconds (default: 12)")
    parser.add_argument("--save", default=None, help="Save JSON results to specified file path")

    args = parser.parse_args()
    phone_number = args.number.strip()

    if not phone_number.startswith("+"):
        print("[ERROR] Phone number must start with + and include country code (e.g. +14155552671)")
        sys.exit(1)

    parsed = _parse_number(phone_number)
    if not parsed:
        print(f"[ERROR] Cannot parse phone number: {phone_number}")
        sys.exit(1)

    if not phonenumbers.is_possible_number(parsed):
        print(f"[WARNING] Number may not be valid: {phone_number}")

    if not args.json:
        print(f"\n[*] ph000enix v4.1.0 - Starting intelligence gathering for {phone_number}")
        print(f"[*] Timestamp: {datetime.now(timezone.utc).isoformat()}")

    results = {
        "target": phone_number,
        "report_id": _generate_report_hash(phone_number),
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "tool_version": "4.1.0",
    }

    if not args.json:
        print("[*] Running deep validation...")
    results["validation"] = _deep_validation(parsed)

    if not args.json:
        print("[*] Generating number formats...")
    results["formats"] = _get_all_formats(parsed)

    if not args.no_dialing:
        if not args.json:
            print("[*] Generating international dialing formats...")
        results["international_dialing"] = _get_international_dialing_formats(parsed)

    if not args.json:
        print("[*] Gathering country intelligence...")
    results["country_info"] = _get_country_code_info(parsed)

    if not args.json:
        print("[*] Resolving geolocation data...")
    results["geo"] = _get_geo_info(parsed)

    if not args.json:
        print("[*] Identifying carrier information...")
    results["carrier"] = _get_carrier_info(parsed)
    carrier_en = results["carrier"].get("en", "")

    if not args.json:
        print("[*] Matching carrier prefix database...")
    results["carrier_prefix"] = _get_carrier_prefix_info(parsed)

    if not args.json:
        print("[*] Resolving timezone data...")
    results["timezone"] = _get_timezone_info(parsed)

    if not args.json:
        print("[*] Analyzing number patterns...")
    results["pattern_analysis"] = _number_pattern_analysis(parsed)

    if not args.json:
        print("[*] Running VoIP detection...")
    results["voip_detection"] = _voip_detection(parsed, carrier_en)

    if not args.json:
        print("[*] Checking disposable number indicators...")
    results["disposable_check"] = _disposable_number_check(parsed, carrier_en)

    if not args.no_hlr:
        if not args.json:
            print("[*] Running HLR simulation...")
        results["hlr_simulation"] = _hlr_simulation(parsed)

    if not args.json:
        print("[*] Estimating number age...")
    results["number_age"] = _number_age_estimation(parsed)

    region = phonenumbers.region_code_for_number(parsed)

    if not args.no_messaging:
        if not args.json:
            print("[*] Analyzing messaging platform compatibility...")
        results["messaging_platforms"] = _messaging_platform_analysis(parsed, region)

    if not args.no_whatsapp and not args.no_web:
        if not args.json:
            print("[*] Checking WhatsApp link availability...")
        results["whatsapp_check"] = _whatsapp_link_check(parsed)
        await asyncio.sleep(args.delay * 0.5)

    if not args.no_web and not args.no_reputation:
        if not args.json:
            print("[*] Checking reputation databases (concurrent)...")
        results["reputation"] = _web_reputation_check(phone_number, parsed, timeout=args.timeout)
        await asyncio.sleep(args.delay)

    if not args.no_risk:
        if not args.json:
            print("[*] Performing risk assessment...")
        results["risk_assessment"] = _risk_assessment(
            parsed, carrier_en,
            results.get("voip_detection", {}),
            results.get("disposable_check", {}),
            results.get("reputation", {})
        )

    if not args.no_web and not args.no_links:
        if not args.json:
            print("[*] Discovering web presence...")
        results["web_links"] = _duckduckgo_links(phone_number, parsed)
        await asyncio.sleep(args.delay)

    if not args.no_dorks:
        if not args.json:
            print("[*] Generating search engine dorks...")
        results["search_dorks"] = _search_engine_dork(phone_number, parsed)

    if not args.no_reverse:
        if not args.json:
            print("[*] Generating reverse lookup URLs...")
        results["reverse_lookup"] = _reverse_lookup_urls(parsed)

    if not args.no_social:
        if not args.json:
            print("[*] Generating social media profile URLs...")
        results["social_media_urls"] = _social_media_profile_urls(parsed)

    if not args.no_breach:
        if not args.json:
            print("[*] Generating breach search URLs...")
        results["breach_search_urls"] = _data_breach_search_urls(parsed)

    if not args.no_osint:
        if not args.json:
            print("[*] Generating OSINT framework URLs...")
        results["osint_framework"] = _osint_framework_urls(parsed)

    if args.full_scan or args.numverify_key or args.abstractapi_key or args.veriphone_key:
        if not args.json:
            print("[*] Generating advanced dorking targets...")
        results["dorking_targets"] = _google_dorking_results(phone_number, parsed)

    results["api_results"] = {}

    if args.numverify_key:
        if not args.json:
            print("[*] Querying numverify API...")
        nv = _numverify_check(phone_number, args.numverify_key)
        if nv:
            results["api_results"]["numverify"] = nv

    if args.abstractapi_key:
        if not args.json:
            print("[*] Querying AbstractAPI...")
        aa = _abstractapi_check(phone_number, args.abstractapi_key)
        if aa:
            results["api_results"]["abstractapi"] = aa

    if args.veriphone_key:
        if not args.json:
            print("[*] Querying Veriphone API...")
        vp = _veriphone_check(phone_number, args.veriphone_key)
        if vp:
            results["api_results"]["veriphone"] = vp

    if not results["api_results"]:
        del results["api_results"]

    _print_results(phone_number, results, "json" if args.json else "text")

    if args.save:
        try:
            save_dir = os.path.dirname(args.save)
            if save_dir and not os.path.exists(save_dir):
                os.makedirs(save_dir, exist_ok=True)
            with open(args.save, "w", encoding="utf-8") as f:
                json.dump(results, f, indent=2, default=str, ensure_ascii=False)
            if not args.json:
                print(f"[*] Results saved to: {args.save}")
        except Exception as e:
            print(f"[ERROR] Failed to save results: {e}")


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\n[!] Investigation interrupted by user.")
        sys.exit(0)
    except Exception as e:
        print(f"\n[ERROR] Unexpected error: {e}")
        sys.exit(1)