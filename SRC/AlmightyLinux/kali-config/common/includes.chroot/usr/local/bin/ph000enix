INTERNATIONAL_DIALING_PREFIXES = {
    "from_US": "011", "from_CA": "011", "from_GB": "00", "from_DE": "00",
    "from_FR": "00", "from_TR": "00", "from_RU": "810", "from_CN": "00",
    "from_JP": "010", "from_IN": "00", "from_BR": "00", "from_AU": "0011",
    "from_KR": "001", "from_MX": "00", "from_SG": "001", "from_HK": "001",
    "from_TW": "002", "from_TH": "001", "from_MY": "00", "from_ID": "001",
    "from_PH": "00", "from_VN": "00", "from_NZ": "00", "from_ZA": "00",
    "from_AE": "00", "from_SA": "00", "from_IL": "00",
}


def _get_ua():
    return USER_AGENTS[int(time.time()) % len(USER_AGENTS)]


def _md5(data):
    return hashlib.md5(data.encode("utf-8")).hexdigest()


def _sha256(data):
    return hashlib.sha256(data.encode("utf-8")).hexdigest()


def _sha1(data):
    return hashlib.sha1(data.encode("utf-8")).hexdigest()


def _shannon_entropy(text):
    if not text:
        return 0.0
    freq = {}
    for c in text:
        freq[c] = freq.get(c, 0) + 1
    length = len(text)
    ent = 0.0
    for count in freq.values():
        p = count / length
        ent -= p * math.log2(p)
    return round(ent, 4)


def _create_session(timeout=12):
    if not HAS_REQUESTS:
        return None
    session = requests.Session()
    if HAS_RETRY:
        retry_strategy = Retry(
            total=3,
            backoff_factor=0.5,
            status_forcelist=[429, 500, 502, 503, 504],
            allowed_methods=["GET", "POST", "HEAD"],
        )
        adapter = HTTPAdapter(max_retries=retry_strategy, pool_connections=10, pool_maxsize=10)
    else:
        adapter = HTTPAdapter(max_retries=2, pool_connections=10, pool_maxsize=10)
    session.mount("http://", adapter)
    session.mount("https://", adapter)
    return session


_global_session = None
_session_lock = threading.Lock()


def _get_session():
    global _global_session
    if _global_session is None:
        with _session_lock:
            if _global_session is None:
                _global_session = _create_session()
    return _global_session


def _safe_request(url, method="GET", timeout=12, headers=None, params=None, allow_redirects=True, data=None):
    if not HAS_REQUESTS:
        return None
    default_headers = {
        "User-Agent": _get_ua(),
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language": "en-US,en;q=0.9",
        "Accept-Encoding": "gzip, deflate",
        "DNT": "1",
        "Connection": "keep-alive",
        "Sec-Fetch-Dest": "document",
        "Sec-Fetch-Mode": "navigate",
        "Sec-Fetch-Site": "none",
    }
    if headers:
        default_headers.update(headers)
    try:
        session = _get_session()
        if session is None:
            return None
        resp = session.request(
            method, url, timeout=timeout, headers=default_headers,
            params=params, allow_redirects=allow_redirects, verify=True,
            data=data
        )
        return resp
    except requests.exceptions.Timeout:
        return None
    except requests.exceptions.ConnectionError:
        return None
    except requests.exceptions.TooManyRedirects:
        return None
    except Exception:
        return None


def _concurrent_requests(url_tasks, max_workers=5, timeout=12):
    results = {}
    if not HAS_REQUESTS:
        return results

    def _fetch(name, url, extra_headers=None):
        resp = _safe_request(url, timeout=timeout, headers=extra_headers)
        return name, resp

    with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = {}
        for task in url_tasks:
            name = task["name"]
            url = task["url"]
            extra_headers = task.get("headers")
            future = executor.submit(_fetch, name, url, extra_headers)
            futures[future] = name
        for future in concurrent.futures.as_completed(futures, timeout=timeout + 5):
            try:
                name, resp = future.result(timeout=timeout)
                results[name] = resp
            except Exception:
                results[futures[future]] = None
    return results


def _parse_number(raw_number):
    if not HAS_PHONENUMBERS:
        return None
    try:
        parsed = phonenumbers.parse(raw_number, None)
        if not phonenumbers.is_possible_number(parsed):
            for region in ["US", "GB", "DE", "TR", "FR"]:
                try:
                    alt = phonenumbers.parse(raw_number, region)
                    if phonenumbers.is_possible_number(alt):
                        return alt
                except Exception:
                    continue
            return parsed
        return parsed
    except NumberParseException:
        return None


def _get_number_type_str(parsed):
    if not HAS_PHONENUMBERS:
        return "Unknown"
    ntype = phonenumbers.number_type(parsed)
    return PHONE_TYPE_MAP.get(ntype, "Unknown")


def _get_all_formats(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    formats = {}
    try:
        formats["e164"] = phonenumbers.format_number(parsed, PhoneNumberFormat.E164)
    except Exception:
        formats["e164"] = None
    try:
        formats["international"] = phonenumbers.format_number(parsed, PhoneNumberFormat.INTERNATIONAL)
    except Exception:
        formats["international"] = None
    try:
        formats["national"] = phonenumbers.format_number(parsed, PhoneNumberFormat.NATIONAL)
    except Exception:
        formats["national"] = None
    try:
        formats["rfc3966"] = phonenumbers.format_number(parsed, PhoneNumberFormat.RFC3966)
    except Exception:
        formats["rfc3966"] = None
    try:
        formats["e164_cc"] = f"+{parsed.country_code}"
    except Exception:
        formats["e164_cc"] = None
    try:
        national_significant = phonenumbers.national_significant_number(parsed)
        formats["national_significant"] = national_significant
    except Exception:
        formats["national_significant"] = None
    return formats


def _get_international_dialing_formats(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    e164 = phonenumbers.format_number(parsed, PhoneNumberFormat.E164)
    cc = str(parsed.country_code)
    nsn = phonenumbers.national_significant_number(parsed)
    result = {}
    for key, prefix in INTERNATIONAL_DIALING_PREFIXES.items():
        country = key.replace("from_", "")
        result[f"dial_from_{country}"] = f"{prefix}{cc}{nsn}"
    return result


def _get_timezone_info(parsed):
    if not HAS_PHONENUMBERS or not HAS_PYTZ:
        return {}
    try:
        tz_list = pn_timezone.time_zones_for_number(parsed)
        if not tz_list:
            return {"timezones": [], "current_times": []}
        result = {"timezones": [], "current_times": [], "utc_offsets": [], "business_hours": []}
        for tz_name in tz_list:
            tz_str = str(tz_name)
            result["timezones"].append(tz_str)
            if tz_str != "Etc/Unknown":
                try:
                    tz_obj = pytz.timezone(tz_str)
                    now = datetime.now(tz_obj)
                    result["current_times"].append({
                        "timezone": tz_str,
                        "time": now.strftime("%Y-%m-%d %H:%M:%S"),
                        "utc_offset": now.strftime("%z"),
                        "dst_active": bool(now.dst()),
                        "day_of_week": now.strftime("%A"),
                    })
                    utc_offset = now.utcoffset()
                    if utc_offset:
                        hours = utc_offset.total_seconds() / 3600
                        result["utc_offsets"].append(f"UTC{'+' if hours >= 0 else ''}{hours:.1f}")
                    hour = now.hour
                    if 9 <= hour <= 17:
                        result["business_hours"].append({"timezone": tz_str, "status": "business_hours", "local_hour": hour})
                    elif 7 <= hour <= 22:
                        result["business_hours"].append({"timezone": tz_str, "status": "awake_hours", "local_hour": hour})
                    else:
                        result["business_hours"].append({"timezone": tz_str, "status": "sleeping_hours", "local_hour": hour})
                except Exception:
                    pass
        return result
    except Exception:
        return {}


def _get_geo_info(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    result = {}
    for lang in ["en", "de", "fr", "es", "tr", "ru", "zh", "ja", "ar", "pt", "ko", "it", "nl", "pl", "sv"]:
        try:
            desc = pn_geocoder.description_for_number(parsed, lang)
            if desc:
                result[lang] = desc
        except Exception:
            pass
    return result


def _get_carrier_info(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    result = {}
    for lang in ["en", "de", "fr", "es", "tr", "ru", "zh", "ja"]:
        try:
            c = pn_carrier.name_for_number(parsed, lang)
            if c:
                result[lang] = c
        except Exception:
            pass
    return result


def _get_carrier_prefix_info(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    region = phonenumbers.region_code_for_number(parsed)
    nsn = phonenumbers.national_significant_number(parsed)
    if not nsn or not region:
        return {}
    result = {"region": region, "prefix_match": None, "carrier_from_prefix": None}
    if region in CARRIER_PREFIX_MAP:
        prefix_map = CARRIER_PREFIX_MAP[region]
        for prefix_len in [4, 3, 2, 1]:
            if len(nsn) >= prefix_len:
                prefix = nsn[:prefix_len]
                if prefix in prefix_map:
                    result["prefix_match"] = prefix
                    result["carrier_from_prefix"] = prefix_map[prefix]
                    break
    return result


def _get_country_code_info(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    try:
        cc = parsed.country_code
        region = phonenumbers.region_code_for_number(parsed)
        regions = phonenumbers.region_codes_for_country_code(cc)
        country_name = pn_geocoder.country_name_for_number(parsed, "en") if hasattr(pn_geocoder, "country_name_for_number") else None
        result = {
            "country_code": cc,
            "region_code": region,
            "all_regions_for_code": list(regions) if regions else [],
            "country_name": country_name,
        }
        if region and region in COUNTRY_DIAL_INFO:
            result["dial_info"] = COUNTRY_DIAL_INFO[region]
        if region and region in KNOWN_CARRIER_RANGES:
            result["carrier_landscape"] = KNOWN_CARRIER_RANGES[region]
        return result
    except Exception:
        return {}


def _deep_validation(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    result = {}
    try:
        result["is_valid"] = phonenumbers.is_valid_number(parsed)
    except Exception:
        result["is_valid"] = None
    try:
        result["is_possible"] = phonenumbers.is_possible_number(parsed)
    except Exception:
        result["is_possible"] = None
    try:
        reason = phonenumbers.is_possible_number_with_reason(parsed)
        reason_map = {
            phonenumberutil.ValidationResult.IS_POSSIBLE: "IS_POSSIBLE",
            phonenumberutil.ValidationResult.IS_POSSIBLE_LOCAL_ONLY: "IS_POSSIBLE_LOCAL_ONLY",
            phonenumberutil.ValidationResult.INVALID_COUNTRY_CODE: "INVALID_COUNTRY_CODE",
            phonenumberutil.ValidationResult.TOO_SHORT: "TOO_SHORT",
            phonenumberutil.ValidationResult.TOO_LONG: "TOO_LONG",
            phonenumberutil.ValidationResult.INVALID_LENGTH: "INVALID_LENGTH",
        }
        result["validation_reason"] = reason_map.get(reason, str(reason))
    except Exception:
        result["validation_reason"] = None
    try:
        result["number_type"] = _get_number_type_str(parsed)
    except Exception:
        result["number_type"] = None
    nsn = phonenumbers.national_significant_number(parsed)
    result["nsn_length"] = len(nsn) if nsn else 0
    result["has_leading_zero"] = parsed.italian_leading_zero if hasattr(parsed, "italian_leading_zero") else False
    result["raw_input"] = parsed.raw_input if hasattr(parsed, "raw_input") and parsed.raw_input else None
    result["preferred_domestic_prefix"] = parsed.preferred_domestic_carrier_code if hasattr(parsed, "preferred_domestic_carrier_code") else None
    result["country_code_source"] = str(parsed.country_code_source) if hasattr(parsed, "country_code_source") else None
    try:
        region = phonenumbers.region_code_for_number(parsed)
        ntype = phonenumbers.number_type(parsed)
        example = phonenumbers.example_number_for_type(region, ntype)
        if example:
            result["example_for_type"] = phonenumbers.format_number(example, PhoneNumberFormat.INTERNATIONAL)
            example_nsn = phonenumbers.national_significant_number(example)
            result["expected_nsn_length"] = len(example_nsn) if example_nsn else None
    except Exception:
        pass
    try:
        result["is_valid_for_region"] = phonenumbers.is_valid_number_for_region(
            parsed, phonenumbers.region_code_for_number(parsed)
        ) if phonenumbers.region_code_for_number(parsed) else None
    except Exception:
        result["is_valid_for_region"] = None
    try:
        result["can_be_internationally_dialed"] = phonenumberutil.can_be_internationally_dialled(parsed) if hasattr(phonenumberutil, "can_be_internationally_dialled") else None
    except Exception:
        result["can_be_internationally_dialed"] = None
    return result


def _number_pattern_analysis(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    nsn = phonenumbers.national_significant_number(parsed)
    if not nsn:
        return {}
    result = {
        "national_number": nsn,
        "digit_count": len(nsn),
        "digit_frequency": {},
        "entropy": _shannon_entropy(nsn),
        "is_sequential": False,
        "is_repeating": False,
        "is_palindrome": nsn == nsn[::-1],
        "has_pattern": False,
        "vanity_potential": False,
        "digit_sum": sum(int(d) for d in nsn if d.isdigit()),
        "starts_with": nsn[:3] if len(nsn) >= 3 else nsn,
        "ends_with": nsn[-3:] if len(nsn) >= 3 else nsn,
    }
    for d in nsn:
        result["digit_frequency"][d] = result["digit_frequency"].get(d, 0) + 1
    most_common = max(result["digit_frequency"].values())
    if most_common >= len(nsn) * 0.6:
        result["is_repeating"] = True
        result["has_pattern"] = True
    if len(nsn) >= 3:
        pairs = [(int(nsn[i+1]) - int(nsn[i])) for i in range(len(nsn)-1) if nsn[i].isdigit() and nsn[i+1].isdigit()]
        if pairs:
            if all(d == 1 for d in pairs):
                result["is_sequential"] = True
                result["has_pattern"] = True
            elif all(d == -1 for d in pairs):
                result["is_sequential"] = True
                result["has_pattern"] = True
            elif all(d == 0 for d in pairs):
                result["is_repeating"] = True
                result["has_pattern"] = True
    if len(nsn) >= 7:
        vanity_map = {"2": "ABC", "3": "DEF", "4": "GHI", "5": "JKL", "6": "MNO", "7": "PQRS", "8": "TUV", "9": "WXYZ"}
        has_vanity_digits = sum(1 for d in nsn if d in vanity_map)
        if has_vanity_digits >= 4:
            result["vanity_potential"] = True
    unique_digits = len(set(nsn))
    result["unique_digits"] = unique_digits
    result["complexity_score"] = round(result["entropy"] * unique_digits / max(len(nsn), 1), 4)
    if len(nsn) >= 6:
        half = len(nsn) // 2
        first_half = nsn[:half]
        second_half = nsn[half:half+len(first_half)]
        if first_half == second_half:
            result["has_pattern"] = True
            result["pattern_type"] = "repeating_halves"
    runs = []
    current_run = 1
    for i in range(1, len(nsn)):
        if nsn[i] == nsn[i-1]:
            current_run += 1
        else:
            runs.append(current_run)
            current_run = 1
    runs.append(current_run)
    result["max_consecutive_repeat"] = max(runs) if runs else 0
    result["run_count"] = len(runs)
    return result


def _voip_detection(parsed, carrier_name):
    if not HAS_PHONENUMBERS:
        return {}
    result = {
        "likely_voip": False,
        "voip_confidence": 0,
        "indicators": [],
    }
    ntype = phonenumbers.number_type(parsed)
    if ntype == PhoneNumberType.VOIP:
        result["likely_voip"] = True
        result["voip_confidence"] = 95
        result["indicators"].append("Number type classified as VoIP by phonenumbers library")
        return result
    if carrier_name:
        carrier_lower = carrier_name.lower()
        for voip_name in VOIP_INDICATORS:
            if voip_name in carrier_lower:
                result["likely_voip"] = True
                result["voip_confidence"] = max(result["voip_confidence"], 80)
                result["indicators"].append(f"Carrier matches known VoIP provider: {voip_name}")
    region = phonenumbers.region_code_for_number(parsed)
    nsn = phonenumbers.national_significant_number(parsed)
    if region == "US" and nsn:
        voip_area_codes = ["456", "500", "521", "522", "523", "524", "525", "526", "527", "528", "529", "533", "544", "566", "577", "588"]
        if nsn[:3] in voip_area_codes:
            result["likely_voip"] = True
            result["voip_confidence"] = max(result["voip_confidence"], 70)
            result["indicators"].append(f"Area code {nsn[:3]} is commonly associated with VoIP/personal services")
    if region == "GB" and nsn and nsn.startswith("56"):
        result["likely_voip"] = True
        result["voip_confidence"] = max(result["voip_confidence"], 85)
        result["indicators"].append("UK 056x range is allocated for VoIP services")
    if region == "GB" and nsn and nsn.startswith("70"):
        result["voip_confidence"] = max(result["voip_confidence"], 60)
        result["indicators"].append("UK 070 range is personal numbering (often VoIP)")
    if region == "DE" and nsn and nsn.startswith("32"):
        result["likely_voip"] = True
        result["voip_confidence"] = max(result["voip_confidence"], 80)
        result["indicators"].append("German 032x range is allocated for VoIP")
    if region == "FR" and nsn and nsn.startswith("9"):
        result["voip_confidence"] = max(result["voip_confidence"], 50)
        result["indicators"].append("French 09 range includes VoIP services")
    if region == "NL" and nsn and nsn.startswith("85"):
        result["voip_confidence"] = max(result["voip_confidence"], 60)
        result["indicators"].append("Dutch 085 range is commonly used by VoIP")
    if ntype == PhoneNumberType.PERSONAL_NUMBER:
        result["voip_confidence"] = max(result["voip_confidence"], 40)
        result["indicators"].append("Personal number type may indicate VoIP or virtual number")
    if result["voip_confidence"] >= 60 and not result["likely_voip"]:
        result["likely_voip"] = True
    return result


def _disposable_number_check(parsed, carrier_name):
    result = {
        "likely_disposable": False,
        "confidence": 0,
        "indicators": [],
    }
    if carrier_name:
        carrier_lower = carrier_name.lower()
        for svc in DISPOSABLE_NUMBER_SERVICES:
            if svc in carrier_lower:
                result["likely_disposable"] = True
                result["confidence"] = 90
                result["indicators"].append(f"Carrier matches known disposable number service: {svc}")
                return result
    ntype = phonenumbers.number_type(parsed) if HAS_PHONENUMBERS else None
    if ntype == PhoneNumberType.VOIP:
        result["confidence"] = max(result["confidence"], 30)
        result["indicators"].append("VoIP numbers have higher disposable probability")
    if ntype == PhoneNumberType.PERSONAL_NUMBER:
        result["confidence"] = max(result["confidence"], 20)
        result["indicators"].append("Personal numbers can be virtual/disposable")
    return result


def _messaging_platform_analysis(parsed, region):
    if not HAS_PHONENUMBERS:
        return {}
    ntype = phonenumbers.number_type(parsed)
    result = {
        "whatsapp": {"possible": False, "check_url": None},
        "telegram": {"possible": False, "check_url": None},
        "signal": {"possible": False},
        "viber": {"possible": False, "check_url": None},
        "imessage": {"possible": False},
        "line": {"possible": False},
        "kakao": {"possible": False},
        "wechat": {"possible": False},
        "zalo": {"possible": False},
        "imo": {"possible": False},
    }
    e164 = phonenumbers.format_number(parsed, PhoneNumberFormat.E164)
    clean = e164.replace("+", "")
    if ntype in (PhoneNumberType.MOBILE, PhoneNumberType.FIXED_LINE_OR_MOBILE):
        result["whatsapp"]["possible"] = True
        result["whatsapp"]["check_url"] = f"https://wa.me/{clean}"
        result["telegram"]["possible"] = True
        result["telegram"]["check_url"] = f"https://t.me/+{clean}"
        result["signal"]["possible"] = True
        result["viber"]["possible"] = True
        result["viber"]["check_url"] = f"viber://chat?number={e164}"
        result["imo"]["possible"] = True
    if region in ("US", "CA", "GB", "AU", "NZ", "IE"):
        result["imessage"]["possible"] = True
    if region in ("JP", "TH", "TW", "ID", "MY"):
        result["line"]["possible"] = True
    if region == "KR":
        result["kakao"]["possible"] = True
    if region in ("CN", "HK", "MO", "TW"):
        result["wechat"]["possible"] = True
    if region == "VN":
        result["zalo"]["possible"] = True
    if ntype == PhoneNumberType.VOIP:
        result["whatsapp"]["possible"] = False
        result["whatsapp"]["check_url"] = None
        result["signal"]["possible"] = False
        result["viber"]["possible"] = False
        result["viber"]["check_url"] = None
        result["imessage"]["possible"] = False
    return result


def _whatsapp_link_check(parsed):
    if not HAS_PHONENUMBERS or not HAS_REQUESTS:
        return {}
    e164 = phonenumbers.format_number(parsed, PhoneNumberFormat.E164)
    clean = e164.replace("+", "")
    result = {
        "api_link": f"https://api.whatsapp.com/send?phone={clean}",
        "direct_link": f"https://wa.me/{clean}",
        "qr_link": f"https://wa.me/qr/{clean}",
        "business_check_url": f"https://wa.me/{clean}?text=",
    }
    try:
        resp = _safe_request(
            f"https://wa.me/{clean}",
            timeout=8,
            allow_redirects=False,
            headers={"User-Agent": "Mozilla/5.0 (Linux; Android 13) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Mobile Safari/537.36"}
        )
        if resp:
            if resp.status_code in (200, 302):
                result["wa_me_reachable"] = True
                if resp.status_code == 302:
                    location = resp.headers.get("Location", "")
                    if "send" in location or "api" in location:
                        result["likely_registered"] = True
                    else:
                        result["likely_registered"] = False
            elif resp.status_code == 404:
                result["wa_me_reachable"] = True
                result["likely_registered"] = False
            else:
                result["wa_me_reachable"] = False
        else:
            result["wa_me_reachable"] = False
    except Exception:
        result["wa_me_reachable"] = False
    return result


def _search_engine_dork(phone_number, parsed):
    if not HAS_PHONENUMBERS:
        return {}
    e164 = phonenumbers.format_number(parsed, PhoneNumberFormat.E164)
    national = phonenumbers.format_number(parsed, PhoneNumberFormat.NATIONAL)
    international = phonenumbers.format_number(parsed, PhoneNumberFormat.INTERNATIONAL)
    nsn = phonenumbers.national_significant_number(parsed)
    clean = e164.replace("+", "")
    variants = list(set(filter(None, [
        e164, national, international, clean, nsn,
        national.replace(" ", ""), national.replace(" ", "-"),
        international.replace(" ", ""), clean[:3] + "-" + clean[3:6] + "-" + clean[6:] if len(clean) >= 10 else None,
        f"({national[:3]})" + national[3:] if len(national) >= 7 else None,
        national.replace(" ", "."),
        clean[:3] + "." + clean[3:6] + "." + clean[6:] if len(clean) >= 10 else None,
    ])))
    search_urls = {}
    or_query = "+OR+".join([f'"{v}"' for v in variants[:6]])
    search_urls["google"] = f"https://www.google.com/search?q={or_query}"
    search_urls["duckduckgo"] = f"https://duckduckgo.com/?q={or_query}"
    search_urls["bing"] = f"https://www.bing.com/search?q={or_query}"
    search_urls["yandex"] = f"https://yandex.com/search/?text={or_query}"
    search_urls["brave"] = f"https://search.brave.com/search?q={or_query}"
    search_urls["startpage"] = f"https://www.startpage.com/do/dsearch?query={or_query}"
    site_dorks = {
        "facebook": f"site:facebook.com \"{clean}\"",
        "linkedin": f"site:linkedin.com \"{clean}\"",
        "twitter": f"site:twitter.com OR site:x.com \"{clean}\"",
        "instagram": f"site:instagram.com \"{clean}\"",
        "vk": f"site:vk.com \"{clean}\"",
        "tiktok": f"site:tiktok.com \"{clean}\"",
        "youtube": f"site:youtube.com \"{clean}\"",
        "reddit": f"site:reddit.com \"{clean}\"",
        "quora": f"site:quora.com \"{clean}\"",
        "whocallsme": f"site:whocallsme.com \"{clean}\"",
        "800notes": f"site:800notes.com \"{clean}\"",
        "callercomplaints": f"site:callercomplaints.com \"{clean}\"",
        "shouldianswer": f"site:shouldianswer.com \"{clean}\"",
        "tellows": f"site:tellows.com \"{clean}\"",
        "whitepages": f"site:whitepages.com \"{clean}\"",
        "truecaller_web": f"site:truecaller.com \"{clean}\"",
        "pipl": f"site:pipl.com \"{clean}\"",
        "spokeo": f"site:spokeo.com \"{clean}\"",
        "zabasearch": f"site:zabasearch.com \"{clean}\"",
        "pastebin": f"site:pastebin.com \"{clean}\"",
        "github": f"site:github.com \"{clean}\"",
        "gitlab": f"site:gitlab.com \"{clean}\"",
        "medium": f"site:medium.com \"{clean}\"",
        "pinterest": f"site:pinterest.com \"{clean}\"",
        "telegram_web": f"site:t.me \"{clean}\"",
    }
    search_urls["site_dorks"] = {}
    for name, dork in site_dorks.items():
        search_urls["site_dorks"][name] = f"https://www.google.com/search?q={quote(dork)}"
    search_urls["number_variants"] = variants
    search_urls["advanced_dorks"] = {
        "inurl_search": f"https://www.google.com/search?q=inurl:{clean}",
        "intext_search": f"https://www.google.com/search?q=intext:\"{clean}\"",
        "filetype_pdf": f"https://www.google.com/search?q=\"{clean}\"+filetype:pdf",
        "filetype_doc": f"https://www.google.com/search?q=\"{clean}\"+filetype:doc+OR+filetype:docx",
        "filetype_xls": f"https://www.google.com/search?q=\"{clean}\"+filetype:xls+OR+filetype:xlsx",
        "filetype_csv": f"https://www.google.com/search?q=\"{clean}\"+filetype:csv",
        "cache_search": f"https://www.google.com/search?q=cache:\"{clean}\"",
        "contact_page": f"https://www.google.com/search?q=\"{clean}\"+intitle:\"contact\"+OR+intitle:\"about\"",
        "directory_listing": f"https://www.google.com/search?q=\"{clean}\"+intitle:\"index+of\"",
    }
    return search_urls


def _web_reputation_check(phone_number, parsed, timeout=12):
    if not HAS_REQUESTS or not HAS_BS4:
        return {}
    clean = phone_number.replace("+", "").replace(" ", "").replace("-", "")
    result = {
        "sources_checked": [],
        "reputation_score": None,
        "overall_sentiment": "neutral",
    }
    spam_score = 0
    total_sources = 0

    url_tasks = [
        {"name": "spamcalls", "url": f"https://spamcalls.net/en/number/{clean}"},
        {"name": "unknownphone", "url": f"https://www.unknownphone.com/phone/{clean}"},
        {"name": "shouldianswer", "url": f"https://www.shouldianswer.com/phone-number/{clean}"},
        {"name": "tellows", "url": f"https://www.tellows.com/num/{clean}"},
        {"name": "whocalld", "url": f"https://whocalld.com/+{clean}"},
    ]
    responses = _concurrent_requests(url_tasks, max_workers=5, timeout=timeout)

    resp = responses.get("spamcalls")
    source_result = {"source": "spamcalls.net", "status": "error"}
    try:
        if resp and resp.status_code == 200:
            soup = BeautifulSoup(resp.content, "html.parser")
            rating_elements = soup.select('a[href="#ratings"]')
            type_elements = soup.select('a[href="#estimates"]')
            solution_elements = soup.select('a[href="#solution"]')
            source_result["status"] = "ok"
            source_result["rating"] = rating_elements[0].text.strip() if rating_elements else None
            source_result["number_type"] = type_elements[0].text.strip() if type_elements else None
            source_result["solution"] = solution_elements[0].text.strip() if solution_elements else None
            comments = []
            comment_elements = soup.select('p[lang="en"]')
            for el in comment_elements[:10]:
                txt = el.text.strip()
                if txt:
                    comments.append(txt)
            source_result["comments"] = comments
            if source_result["rating"] and any(w in source_result["rating"].lower() for w in ["spam", "scam", "fraud", "dangerous", "harass", "telemarket"]):
                spam_score += 30
            total_sources += 1
    except Exception:
        pass
    result["sources_checked"].append(source_result)

    resp = responses.get("unknownphone")
    source_result = {"source": "unknownphone.com", "status": "error"}
    try:
        if resp and resp.status_code == 200:
            soup = BeautifulSoup(resp.content, "html.parser")
            source_result["status"] = "ok"
            scam_el = soup.select('#content > div > main > section.user-scam-detected > div > p > mark > strong:nth-child(2)')
            source_result["scam_detection"] = scam_el[0].text.strip() if scam_el else None
            comments = []
            for i in range(1, 15):
                try:
                    comment_el = soup.select(f'#content > div > main > section.comments > ul > li:nth-child({i}) > article > div')
                    if comment_el:
                        txt = comment_el[0].text.strip()
                        if txt:
                            comments.append(txt)
                except Exception:
                    continue
            source_result["comments"] = comments
            if source_result["scam_detection"] and any(w in source_result["scam_detection"].lower() for w in ["spam", "scam", "fraud", "unsafe"]):
                spam_score += 30
            total_sources += 1
    except Exception:
        pass
    result["sources_checked"].append(source_result)

    resp = responses.get("shouldianswer")
    source_result = {"source": "shouldianswer.com", "status": "error"}
    try:
        if resp and resp.status_code == 200:
            soup = BeautifulSoup(resp.content, "html.parser")
            source_result["status"] = "ok"
            rating_el = soup.select(".review_rating, .rating, .score, .negative, .positive")
            if rating_el:
                source_result["rating_text"] = rating_el[0].text.strip()
                if any(w in source_result["rating_text"].lower() for w in ["negative", "spam", "scam", "dangerous"]):
                    spam_score += 20
            total_sources += 1
    except Exception:
        pass
    result["sources_checked"].append(source_result)

    resp = responses.get("tellows")
    source_result = {"source": "tellows.com", "status": "error"}
    try:
        if resp and resp.status_code == 200:
            soup = BeautifulSoup(resp.content, "html.parser")
            source_result["status"] = "ok"
            score_el = soup.select(".score, .tellows-score, .scoreValue")
            if score_el:
                source_result["score"] = score_el[0].text.strip()
                try:
                    s = int(re.search(r'\d+', source_result["score"]).group())
                    source_result["numeric_score"] = s
                    if s >= 7:
                        spam_score += 25
                    elif s >= 5:
                        spam_score += 10
                except Exception:
                    pass
            call_type_el = soup.select(".calltype, .callertype")
            if call_type_el:
                source_result["caller_type"] = call_type_el[0].text.strip()
            total_sources += 1
    except Exception:
        pass
    result["sources_checked"].append(source_result)

    resp = responses.get("whocalld")
    source_result = {"source": "whocalld.com", "status": "error"}
    try:
        if resp and resp.status_code == 200:
            source_result["status"] = "ok"
            total_sources += 1
    except Exception:
        pass
    result["sources_checked"].append(source_result)

    if total_sources > 0:
        result["reputation_score"] = max(0, 100 - spam_score)
        if result["reputation_score"] <= 20:
            result["overall_sentiment"] = "dangerous"
        elif result["reputation_score"] <= 40:
            result["overall_sentiment"] = "highly_suspicious"
        elif result["reputation_score"] <= 60:
            result["overall_sentiment"] = "suspicious"
        elif result["reputation_score"] <= 75:
            result["overall_sentiment"] = "mixed"
        else:
            result["overall_sentiment"] = "clean"
    return result


def _duckduckgo_links(phone_number, parsed):
    if not HAS_REQUESTS or not HAS_BS4:
        return []
    clean = phone_number.replace("+", "").replace(" ", "")
    e164 = phonenumbers.format_number(parsed, PhoneNumberFormat.E164) if HAS_PHONENUMBERS else phone_number
    national = phonenumbers.format_number(parsed, PhoneNumberFormat.NATIONAL) if HAS_PHONENUMBERS else phone_number
    queries = [f'"{clean}"', f'"{e164}"', clean]
    if national != clean:
        queries.append(f'"{national}"')
    all_links = []
    seen = set()
    for q in queries[:3]:
        try:
            url = f"https://duckduckgo.com/html/?q={quote(q)}"
            resp = _safe_request(url, timeout=12, headers={"User-Agent": _get_ua()})
            if resp and resp.status_code == 200:
                soup = BeautifulSoup(resp.content, "html.parser")
                for a_tag in soup.find_all("a", class_="result__url", href=True):
                    href = a_tag["href"].strip()
                    if href and href not in seen:
                        seen.add(href)
                        title_el = a_tag.find_parent("div")
                        title = ""
                        snippet = ""
                        if title_el:
                            title_link = title_el.find("a", class_="result__a")
                            if title_link:
                                title = title_link.text.strip()
                            snippet_el = title_el.find("a", class_="result__snippet")
                            if snippet_el:
                                snippet = snippet_el.text.strip()[:200]
                        try:
                            domain = urlparse(href).netloc
                        except Exception:
                            domain = ""
                        all_links.append({
                            "url": href,
                            "title": title,
                            "snippet": snippet,
                            "domain": domain,
                            "source_query": q,
                        })
                    if len(all_links) >= 30:
                        break
        except Exception:
            continue
        if len(all_links) >= 30:
            break
        time.sleep(0.5)
    return all_links


def _google_dorking_results(phone_number, parsed):
    if not HAS_PHONENUMBERS:
        return []
    clean = phone_number.replace("+", "").replace(" ", "")
    results = []
    paste_sites = ["pastebin.com", "ghostbin.com", "dpaste.org", "hastebin.com", "paste.ee", "justpaste.it"]
    social_sites = ["facebook.com", "linkedin.com", "twitter.com", "x.com", "instagram.com", "vk.com", "tiktok.com", "pinterest.com"]
    directory_sites = ["whitepages.com", "truecaller.com", "pipl.com", "spokeo.com", "intelius.com", "zabasearch.com",
                       "beenverified.com", "peekyou.com", "thatsthem.com", "fastpeoplesearch.com"]
    forum_sites = ["reddit.com", "quora.com", "stackoverflow.com", "hackernews.com", "medium.com"]
    categories = {
        "paste_sites": paste_sites,
        "social_media": social_sites,
        "directories": directory_sites,
        "forums": forum_sites,
    }
    for category, sites in categories.items():
        for site in sites:
            results.append({
                "category": category,
                "site": site,
                "dork": f'site:{site} "{clean}"',
                "search_url": f"https://duckduckgo.com/html/?q={quote(f'site:{site} \"{clean}\"')}",
            })
    return results


def _numverify_check(phone_number, api_key=None):
    if not HAS_REQUESTS or not api_key:
        return None
    clean = phone_number.replace("+", "").replace(" ", "").replace("-", "")
    url = f"http://apilayer.net/api/validate?access_key={api_key}&number={clean}&format=1"
    resp = _safe_request(url, timeout=10)
    if resp and resp.status_code == 200:
        try:
            return resp.json()
        except Exception:
            return None
    return None


