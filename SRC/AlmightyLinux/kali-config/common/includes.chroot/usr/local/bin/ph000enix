def _hlr_simulation(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    region = phonenumbers.region_code_for_number(parsed)
    ntype = phonenumbers.number_type(parsed)
    carrier_en = pn_carrier.name_for_number(parsed, "en")
    result = {
        "mcc": None,
        "mnc": None,
        "network_name": carrier_en if carrier_en else None,
        "number_portability": "unknown",
        "roaming_status": "unknown",
        "imsi_estimation": None,
        "network_generation": None,
    }
    mcc_map = {
        "US": "310-316", "GB": "234-235", "DE": "262", "FR": "208", "TR": "286",
        "RU": "250", "CN": "460-461", "JP": "440-441", "IN": "404-405", "BR": "724",
        "AU": "505", "CA": "302", "IT": "222", "ES": "214", "MX": "334",
        "KR": "450", "NL": "204", "SE": "240", "CH": "228", "PL": "260",
        "AT": "232", "BE": "206", "NO": "242", "DK": "238", "FI": "244",
        "PT": "268", "IE": "272", "GR": "202", "CZ": "230", "RO": "226",
        "HU": "216", "ZA": "655", "EG": "602", "NG": "621", "KE": "639",
        "SA": "420", "AE": "424-431", "IL": "425", "TH": "520", "SG": "525",
        "MY": "502", "PH": "515", "ID": "510", "VN": "452", "PK": "410",
        "BD": "470", "AR": "722", "CL": "730", "CO": "732", "PE": "716",
        "UA": "255", "NZ": "530", "TW": "466", "HK": "454",
    }
    result["mcc"] = mcc_map.get(region, "Unknown")
    if ntype == PhoneNumberType.MOBILE:
        result["number_portability"] = "possible"
        result["network_generation"] = "4G/5G (likely)"
    elif ntype == PhoneNumberType.FIXED_LINE:
        result["number_portability"] = "unlikely"
        result["network_generation"] = "PSTN/VoLTE"
    elif ntype == PhoneNumberType.VOIP:
        result["number_portability"] = "not_applicable"
        result["network_generation"] = "VoIP/IP"
    elif ntype == PhoneNumberType.FIXED_LINE_OR_MOBILE:
        result["number_portability"] = "possible"
        result["network_generation"] = "mixed"
    return result


def _reverse_lookup_urls(parsed):
    if not HAS_PHONENUMBERS:
        return {}
    e164 = phonenumbers.format_number(parsed, PhoneNumberFormat.E164)
    clean = e164.replace("+", "")
    region = phonenumbers.region_code_for_number(parsed)
    urls = {
        "truecaller": f"https://www.truecaller.com/search/{region.lower() if region else 'us'}/{clean}",
        "sync_me": f"https://sync.me/search/?number=%2B{clean}",
        "whocalld": f"https://whocalld.com/%2B{clean}",
        "emobiletracker": f"https://www.emobiletracker.com/index.php?phone={clean}",
        "whitepages": f"https://www.whitepages.com/phone/{clean}",
        "spokeo": f"https://www.spokeo.com/phone-lookup/{clean}",
        "thatsthem": f"https://thatsthem.com/phone/{clean}",
        "fastpeoplesearch": f"https://www.fastpeoplesearch.com/{clean}",
        "nuwber": f"https://nuwber.com/phone/{clean}",
        "intelius": f"https://www.intelius.com/phone-lookup/{clean}",
        "zlookup": f"https://www.zlookup.com/phone-lookup/{clean}",
        "phonevalidator": f"https://www.phonevalidator.com/index.aspx?phone={clean}",
        "calleridtest": f"https://calleridtest.com/look-up/{clean}",
        "spydialer": f"https://spydialer.com/results.aspx?type=phone&q={clean}",
        "national_registry": f"https://www.donotcall.gov/search/{clean}" if region == "US" else None,
        "callername": f"https://callername.com/{clean}",
        "phoneowner": f"https://phoneowner.com/phone/{clean}",
        "searchbug": f"https://www.searchbug.com/peoplefinder/results.aspx?pid=rp&typ=pid&ph={clean}",
    }
    if region == "US":
        urls["usphonebook"] = f"https://www.usphonebook.com/{clean}"
        urls["anywho"] = f"https://www.anywho.com/phone/{clean}"
        urls["yellowpages"] = f"https://www.yellowpages.com/phone?phone_search_terms={clean}"
        urls["beenverified"] = f"https://www.beenverified.com/phone/{clean}/"
        urls["peekyou"] = f"https://www.peekyou.com/phone/{clean}"
    elif region == "GB":
        urls["thephonebook"] = f"https://www.thephonebook.bt.com/result?dn={clean}"
        urls["192com"] = f"https://www.192.com/reverse-phone/{clean}/"
    elif region == "TR":
        urls["rehber"] = f"https://www.rehber.net/sorgula/{clean}"
        urls["numbering_btk"] = f"https://www.btk.gov.tr/numaralandirilmis-hizmetler"
    elif region == "DE":
        urls["dasoertliche"] = f"https://www.dasoertliche.de/Rueckwaertssuche/{clean}"
        urls["dastelefonbuch"] = f"https://www.dastelefonbuch.de/Rueckwaertssuche/{clean}"
        urls["klicktel"] = f"https://www.klicktel.de/rueckwaertssuche/{clean}"
    elif region == "FR":
        urls["pagesjaunes"] = f"https://www.pagesjaunes.fr/annuaireinverse/recherche?quoiqui={clean}"
        urls["118712"] = f"https://www.118712.fr/recherche?q={clean}"
    elif region == "IN":
        urls["indiamart"] = f"https://dir.indiamart.com/search.mp?ss={clean}"
        urls["justdial"] = f"https://www.justdial.com/search/{clean}"
        urls["findandtrace"] = f"https://www.findandtrace.com/trace-mobile-number-location/{clean}"
    elif region == "AU":
        urls["whitepages_au"] = f"https://www.whitepages.com.au/phone/{clean}"
        urls["reverseaustralia"] = f"https://www.reverseaustralia.com/lookup/{clean}/"
    elif region == "RU":
        urls["nomer_org"] = f"https://www.nomer.org/{clean}"
    elif region == "BR":
        urls["consultanumero"] = f"https://consultanumero.abrtelecom.com.br/{clean}"
    elif region == "KR":
        urls["114_search"] = f"https://www.114.co.kr/search?query={clean}"
    return {k: v for k, v in urls.items() if v is not None}


