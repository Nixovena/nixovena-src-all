class C:
    RST = "\033[0m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    RED = "\033[38;2;255;85;85m"
    GREEN = "\033[38;2;80;250;123m"
    YELLOW = "\033[38;2;241;250;140m"
    BLUE = "\033[38;2;139;233;253m"
    PURPLE = "\033[38;2;189;147;249m"
    PINK = "\033[38;2;255;121;198m"
    ORANGE = "\033[38;2;255;183;77m"
    CYAN = "\033[38;2;0;255;255m"
    WHITE = "\033[38;2;248;248;242m"
    GRAY = "\033[38;2;108;108;108m"
    DARK = "\033[38;2;68;68;68m"


def _c(color, text):
    return f"{color}{text}{C.RST}"


BANNER = f"""
   {C.GRAY}v{VERSION} imagexhunt - Image Forensics & Visual Intelligence{C.RST}
   {C.GRAY}Developed by emka'thas{C.RST}
   {C.DARK}-----------------------------------------------------{C.RST}
"""

MAGIC_SIGNATURES = {
    b'\xff\xd8\xff':         ("JPEG", False),
    b'\x89PNG\r\n\x1a\n':   ("PNG", False),
    b'GIF87a':               ("GIF87a", False),
    b'GIF89a':               ("GIF89a", False),
    b'BM':                   ("BMP", False),
    b'II*\x00':              ("TIFF (little-endian)", False),
    b'MM\x00*':              ("TIFF (big-endian)", False),
    b'RIFF':                 ("RIFF (WebP/AVI)", False),
    b'\x00\x00\x01\x00':    ("ICO", False),
    b'\x00\x00\x02\x00':    ("CUR", False),
    b'%PDF':                 ("PDF - Polyglot suspected!", True),
    b'PK\x03\x04':          ("ZIP - Polyglot suspected!", True),
    b'\x7fELF':              ("ELF Binary - Polyglot suspected!", True),
    b'MZ':                   ("PE/EXE - Polyglot suspected!", True),
    b'\x1f\x8b':             ("GZIP - Polyglot suspected!", True),
    b'\xca\xfe\xba\xbe':    ("Java Class - Polyglot suspected!", True),
    b'Rar!\x1a\x07':        ("RAR - Polyglot suspected!", True),
}

