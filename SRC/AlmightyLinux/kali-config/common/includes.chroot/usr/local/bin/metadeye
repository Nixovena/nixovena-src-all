#!/usr/bin/env python3
"""
Metadata Extractor & EXIF Analyzer for Linux
Extract and analyze file metadata for forensic purposes on Linux systems
"""

import os
import json
import argparse
from datetime import datetime
import hashlib
import struct
import zipfile
import xml.etree.ElementTree as ET
try:
    from PIL import Image
    from PIL.ExifTags import TAGS, GPSTAGS
except ImportError:
    import sys; sys.exit("[!] Missing: Pillow. Install: pip install Pillow")
import math
import subprocess
import re
from collections import defaultdict

class MetadataExtractor:
    def __init__(self, target_path):
        self.target_path = target_path
        self.results = {
            'target_path': target_path,
            'timestamp': datetime.now().isoformat(),
            'files_analyzed': [],
            'metadata_summary': {}
        }
        
        self.supported_extensions = {
            'images': ['.jpg', '.jpeg', '.png', '.tiff', '.tif', '.bmp', '.gif', '.webp'],
            'documents': ['.pdf', '.doc', '.docx', '.xls', '.xlsx', '.ppt', '.pptx'],
            'archives': ['.zip', '.rar', '.7z', '.tar', '.gz'],
            'executables': ['.exe', '.dll', '.elf', '.bin'],
            'videos': ['.mp4', '.avi', '.mov', '.mkv', '.wmv', '.flv'],
            'audio': ['.mp3', '.wav', '.flac', '.aac', '.ogg'],
            'text': ['.txt', '.log', '.csv', '.xml', '.json']
        }
    
    def extract_file_metadata(self, file_path):
        try:
            stat_info = os.stat(file_path)
            
            # Basic file information
            metadata = {
                'file_path': file_path,
                'file_name': os.path.basename(file_path),
                'file_size': stat_info.st_size,
                'created_time': datetime.fromtimestamp(stat_info.st_ctime).isoformat(),
                'modified_time': datetime.fromtimestamp(stat_info.st_mtime).isoformat(),
                'accessed_time': datetime.fromtimestamp(stat_info.st_atime).isoformat(),
                'file_hash': self.calculate_file_hash(file_path),
                'file_extension': os.path.splitext(file_path)[1].lower(),
                'permissions': oct(stat_info.st_mode)[-3:],
                'owner_id': stat_info.st_uid,
                'group_id': stat_info.st_gid
            }
            
            # Try to get extended attributes on Linux
            try:
                import xattr
                extended_attrs = {}
                try:
                    attrs = xattr.listxattr(file_path)
                    for attr in attrs:
                        extended_attrs[attr] = xattr.getxattr(file_path, attr).decode('utf-8', errors='ignore')
                    if extended_attrs:
                        metadata['extended_attributes'] = extended_attrs
                except Exception:
                    pass  # Extended attributes not available or accessible
            except ImportError:
                pass  # xattr module not installed
            
            # Try to get SELinux context
            try:
                result = subprocess.run(['getfattr', '--name=security.selinux', file_path], 
                                      capture_output=True, text=True, timeout=5)
                if result.returncode == 0 and 'security.selinux' in result.stdout:
                    # Extract SELinux context from output
                    match = re.search(r'security.selinux="([^"]+)"', result.stdout)
                    if match:
                        metadata['selinux_context'] = match.group(1)
            except (subprocess.TimeoutExpired, FileNotFoundError):
                pass  # getfattr not available or timed out
            
            return metadata
        
        except Exception as e:
            return {'error': str(e), 'file_path': file_path}
    

    
    def extract_exif_metadata(self, image_path):
        try:
            with Image.open(image_path) as image:
                exif_data = image._getexif()
                
                if not exif_data:
                    return {}
                
                exif_metadata = {}
                
                # Camera and device information
                camera_info = {}
                
                for tag_id, value in exif_data.items():
                    tag = TAGS.get(tag_id, tag_id)
                    
                    # Handle GPS data specially
                    if tag == 'GPSInfo':
                        gps_data = {}
                        for gps_tag_id, gps_value in value.items():
                            gps_tag = GPSTAGS.get(gps_tag_id, gps_tag_id)
                            gps_data[gps_tag] = gps_value
                        exif_metadata['GPSInfo'] = gps_data
                        
                        # Extract coordinates if available
                        coordinates = self.extract_gps_coordinates(gps_data)
                        if coordinates:
                            exif_metadata['GPS_Coordinates'] = coordinates
                    else:
                        # Convert bytes to string if needed
                        if isinstance(value, bytes):
                            try:
                                value = value.decode('utf-8')
                            except Exception:
                                value = str(value)
                        
                        exif_metadata[tag] = value
                        
                        # Collect camera-specific information
                        if tag in ['Make', 'Model', 'Software', 'DateTime', 'DateTimeOriginal', 'DateTimeDigitized']:
                            camera_info[tag] = value
                        elif tag == 'ExifImageWidth':
                            camera_info['ImageWidth'] = value
                        elif tag == 'ExifImageHeight':
                            camera_info['ImageHeight'] = value
                        elif tag == 'FNumber':
                            camera_info['Aperture'] = value
                        elif tag == 'ExposureTime':
                            camera_info['ExposureTime'] = value
                        elif tag == 'ISOSpeedRatings':
                            camera_info['ISO'] = value
                        elif tag == 'FocalLength':
                            camera_info['FocalLength'] = value
                        elif tag == 'Flash':
                            camera_info['Flash'] = 'Fired' if value else 'Not fired'
                
                # Add camera info if we found any
                if camera_info:
                    exif_metadata['CameraInfo'] = camera_info
                
                return exif_metadata
        
        except Exception as e:
            return {'error': f'EXIF extraction failed: {e}'}
    
    def extract_gps_coordinates(self, gps_data):
        try:
            lat = gps_data.get('GPSLatitude')
            lat_ref = gps_data.get('GPSLatitudeRef')
            lon = gps_data.get('GPSLongitude')
            lon_ref = gps_data.get('GPSLongitudeRef')
            
            if lat and lon and lat_ref and lon_ref:
                # Convert DMS to decimal degrees
                def dms_to_decimal(dms, ref):
                    degrees = float(dms[0])
                    minutes = float(dms[1])
                    seconds = float(dms[2])
                    decimal = degrees + (minutes / 60.0) + (seconds / 3600.0)
                    if ref in ['S', 'W']:
                        decimal = -decimal
                    return decimal
                
                lat_decimal = dms_to_decimal(lat, lat_ref)
                lon_decimal = dms_to_decimal(lon, lon_ref)
                
                return {
                    'latitude': lat_decimal,
                    'longitude': lon_decimal,
                    'lat_ref': lat_ref,
                    'lon_ref': lon_ref
                }
        
        except Exception as e:
            return None
    
    def extract_office_metadata(self, file_path):
        try:
            metadata = {}
            
            if file_path.endswith(('.docx', '.xlsx', '.pptx')):
                # Modern Office formats (ZIP-based)
                with zipfile.ZipFile(file_path, 'r') as zip_file:
                    # Core properties
                    try:
                        core_props = zip_file.read('docProps/core.xml')
                        metadata.update(self.parse_office_core_properties(core_props))
                    except Exception:
                        pass
                    
                    # App properties
                    try:
                        app_props = zip_file.read('docProps/app.xml')
                        metadata.update(self.parse_office_app_properties(app_props))
                    except Exception:
                        pass
            
            return metadata
        
        except Exception as e:
            return {'error': f'Office metadata extraction failed: {e}'}
    
    def parse_office_core_properties(self, xml_data):
        try:
            root = ET.fromstring(xml_data)
            properties = {}
            
            # Define namespace
            ns = {'cp': 'http://schemas.openxmlformats.org/package/2006/metadata/core-properties',
                  'dc': 'http://purl.org/dc/elements/1.1/',
                  'dcterms': 'http://purl.org/dc/terms/'}
            
            # Extract common properties
            mappings = {
                'dc:title': 'title',
                'dc:creator': 'creator',
                'dc:subject': 'subject',
                'dc:description': 'description',
                'cp:lastModifiedBy': 'last_modified_by',
                'dcterms:created': 'created',
                'dcterms:modified': 'modified'
            }
            
            for xml_path, prop_name in mappings.items():
                element = root.find(xml_path, ns)
                if element is not None and element.text:
                    properties[prop_name] = element.text
            
            return properties
        
        except Exception as e:
            return {}
    
    def parse_office_app_properties(self, xml_data):
        try:
            root = ET.fromstring(xml_data)
            properties = {}
            
            # Extract application info
            app_mappings = {
                'Application': 'application',
                'DocSecurity': 'doc_security',
                'Company': 'company',
                'Manager': 'manager',
                'TotalTime': 'total_edit_time'
            }
            
            for xml_tag, prop_name in app_mappings.items():
                element = root.find(xml_tag)
                if element is not None and element.text:
                    properties[prop_name] = element.text
            
            return properties
        
        except Exception as e:
            return {}
    
    def extract_pe_metadata(self, exe_path):
        try:
            metadata = {}
            
            with open(exe_path, 'rb') as f:
                # Check PE signature
                f.seek(60)  # Offset to PE header location
                pe_offset = struct.unpack('<I', f.read(4))[0]
                
                f.seek(pe_offset)
                pe_signature = f.read(4)
                
                if pe_signature != b'PE\x00\x00':
                    return {'error': 'Not a valid PE file'}
                
                # Read COFF header
                f.seek(pe_offset + 4)
                machine = struct.unpack('<H', f.read(2))[0]
                num_sections = struct.unpack('<H', f.read(2))[0]
                timestamp = struct.unpack('<I', f.read(4))[0]
                
                metadata['machine_type'] = machine
                metadata['num_sections'] = num_sections
                metadata['compile_time'] = datetime.fromtimestamp(timestamp).isoformat()
                
                # Try to extract version info (simplified)
                metadata['file_type'] = 'PE Executable'
                
                # Try to extract additional PE info
                try:
                    # Import pefile if available for more detailed analysis
                    import pefile
                    pe = pefile.PE(exe_path)
                    
                    # Extract more detailed info
                    if hasattr(pe, 'FileInfo') and pe.FileInfo:
                        metadata['file_version'] = getattr(pe.FileInfo[0].StringTable[0], 'file_version', 'N/A')
                        metadata['product_name'] = getattr(pe.FileInfo[0].StringTable[0], 'product_name', 'N/A')
                        metadata['company_name'] = getattr(pe.FileInfo[0].StringTable[0], 'company_name', 'N/A')
                        metadata['copyright'] = getattr(pe.FileInfo[0].StringTable[0], 'copyright', 'N/A')
                except ImportError:
                    pass  # pefile not available
                except Exception:
                    pass  # Error in pefile processing
            
            return metadata
        
        except Exception as e:
            return {'error': f'PE metadata extraction failed: {e}'}
    
    def extract_media_metadata(self, media_path):
        """Extract metadata from video/audio files using FFmpeg"""
        try:
            metadata = {}
            
            # Try to use ffprobe (part of FFmpeg) to extract metadata
            try:
                cmd = [
                    'ffprobe',
                    '-v', 'quiet',
                    '-print_format', 'json',
                    '-show_format',
                    '-show_streams',
                    media_path
                ]
                
                result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
                
                if result.returncode == 0 and result.stdout:
                    probe_data = json.loads(result.stdout)
                    metadata['media_info'] = probe_data
                    
                    # Extract key information
                    format_info = probe_data.get('format', {})
                    streams = probe_data.get('streams', [])
                    
                    # Basic format info
                    if format_info:
                        metadata['duration'] = format_info.get('duration')
                        metadata['bit_rate'] = format_info.get('bit_rate')
                        metadata['format_name'] = format_info.get('format_name')
                        
                        # Tags
                        tags = format_info.get('tags', {})
                        if tags:
                            metadata['media_tags'] = tags
                    
                    # Stream info
                    if streams:
                        metadata['stream_count'] = len(streams)
                        # Get primary stream info
                        for i, stream in enumerate(streams):
                            stream_type = stream.get('codec_type', 'unknown')
                            if stream_type == 'video':
                                metadata['video_codec'] = stream.get('codec_name')
                                metadata['width'] = stream.get('width')
                                metadata['height'] = stream.get('height')
                                metadata['avg_frame_rate'] = stream.get('avg_frame_rate')
                                break
                            elif stream_type == 'audio' and 'audio_codec' not in metadata:
                                metadata['audio_codec'] = stream.get('codec_name')
                                metadata['sample_rate'] = stream.get('sample_rate')
                                metadata['channels'] = stream.get('channels')
                else:
                    metadata['media_error'] = 'FFprobe failed to extract metadata'
            
            except FileNotFoundError:
                metadata['media_note'] = 'Install FFmpeg for detailed media metadata'
            except subprocess.TimeoutExpired:
                metadata['media_error'] = 'FFprobe timed out'
            except Exception as e:
                metadata['media_error'] = str(e)
            
            return metadata
        
        except Exception as e:
            return {'error': f'Media metadata extraction failed: {e}'}
    
    def extract_archive_metadata(self, archive_path):
        try:
            metadata = {}
            
            if archive_path.endswith('.zip'):
                with zipfile.ZipFile(archive_path, 'r') as zip_file:
                    file_list = zip_file.filelist
                    
                    metadata['archive_type'] = 'ZIP'
                    metadata['file_count'] = len(file_list)
                    metadata['compressed_size'] = sum(f.compress_size for f in file_list)
                    metadata['uncompressed_size'] = sum(f.file_size for f in file_list)
                    
                    # Get file list with dates
                    files_info = []
                    for file_info in file_list[:10]:  # Limit to first 10 files
                        files_info.append({
                            'filename': file_info.filename,
                            'file_size': file_info.file_size,
                            'compressed_size': file_info.compress_size,
                            'date_time': datetime(*file_info.date_time).isoformat() if file_info.date_time else None
                        })
                    
                    metadata['files'] = files_info
            
            return metadata
        
        except Exception as e:
            return {'error': f'Archive metadata extraction failed: {e}'}
    
    def extract_pdf_metadata(self, pdf_path):
        try:
            metadata = {}
            
            # Try to extract PDF metadata using PyPDF2 if available
            try:
                import PyPDF2
                with open(pdf_path, 'rb') as f:
                    pdf_reader = PyPDF2.PdfReader(f)
                    if pdf_reader.metadata:
                        # Convert PDF metadata to regular dict
                        pdf_metadata = {}
                        for key, value in pdf_reader.metadata.items():
                            # Clean up the key name
                            clean_key = key.replace('/', '') if key.startswith('/') else key
                            pdf_metadata[clean_key] = str(value)
                        metadata['pdf_info'] = pdf_metadata
                    
                    # Get number of pages
                    metadata['page_count'] = len(pdf_reader.pages)
                    
                    # Try to get producer, creator, etc.
                    if hasattr(pdf_reader, 'xmp_metadata') and pdf_reader.xmp_metadata:
                        xmp = pdf_reader.xmp_metadata
                        xmp_data = {}
                        if xmp:
                            # Basic XMP metadata extraction
                            xmp_data['xmp_metadata_present'] = True
                        metadata['xmp_info'] = xmp_data
            except ImportError:
                # PyPDF2 not available, use basic approach
                metadata['pdf_info'] = {'note': 'Install PyPDF2 for detailed PDF metadata'}
            except Exception as e:
                metadata['pdf_error'] = str(e)
            
            return metadata
        
        except Exception as e:
            return {'error': f'PDF metadata extraction failed: {e}'}
    
    def calculate_file_hash(self, file_path):
        try:
            md5_hash = hashlib.md5()
            sha1_hash = hashlib.sha1()
            sha256_hash = hashlib.sha256()
            
            with open(file_path, 'rb') as f:
                for chunk in iter(lambda: f.read(4096), b""):
                    md5_hash.update(chunk)
                    sha1_hash.update(chunk)
                    sha256_hash.update(chunk)
            
            return {
                'md5': md5_hash.hexdigest(),
                'sha1': sha1_hash.hexdigest(),
                'sha256': sha256_hash.hexdigest()
            }
        
        except Exception as e:
            return {'error': str(e)}
    
    def calculate_file_entropy(self, file_path):
        try:
            # Read file in chunks to handle large files
            chunk_size = 4096
            byte_counts = [0] * 256
            total_bytes = 0
            
            with open(file_path, 'rb') as f:
                while True:
                    chunk = f.read(chunk_size)
                    if not chunk:
                        break
                    
                    # Count bytes in chunk
                    for byte in chunk:
                        if isinstance(byte, str):  # Python 2 compatibility
                            byte_counts[ord(byte)] += 1
                        else:  # Python 3
                            byte_counts[byte] += 1
                        total_bytes += 1
            
            # Calculate entropy
            entropy = 0.0
            for count in byte_counts:
                if count == 0:
                    continue
                probability = float(count) / total_bytes
                entropy -= probability * math.log2(probability)
            
            # Normalize entropy (0-1 range)
            normalized_entropy = entropy / 8.0  # Max entropy for 8-bit bytes
            
            return {
                'entropy': entropy,
                'normalized_entropy': normalized_entropy,
                'suspicious': normalized_entropy > 0.95  # Threshold for high entropy
            }
        
        except Exception as e:
            return {'error': str(e)}
    
    def analyze_file_type(self, file_path, metadata):
        extension = metadata.get('file_extension', '').lower()
        
        # Determine file category
        file_category = 'unknown'
        for category, extensions in self.supported_extensions.items():
            if extension in extensions:
                file_category = category
                break
        
        metadata['file_category'] = file_category
        
        # Calculate file entropy for all files
        entropy_data = self.calculate_file_entropy(file_path)
        if entropy_data and 'error' not in entropy_data:
            metadata['entropy_analysis'] = entropy_data
        
        # Extract category-specific metadata
        if file_category == 'images':
            exif_data = self.extract_exif_metadata(file_path)
            if exif_data:
                metadata['exif_metadata'] = exif_data
        
        elif file_category == 'documents':
            if extension == '.pdf':
                pdf_data = self.extract_pdf_metadata(file_path)
                if pdf_data:
                    metadata['pdf_metadata'] = pdf_data
            elif extension in ['.docx', '.xlsx', '.pptx']:
                office_data = self.extract_office_metadata(file_path)
                if office_data:
                    metadata['office_metadata'] = office_data
        
        elif file_category == 'executables':
            pe_data = self.extract_pe_metadata(file_path)
            if pe_data:
                metadata['pe_metadata'] = pe_data
        
        elif file_category == 'archives':
            archive_data = self.extract_archive_metadata(file_path)
            if archive_data:
                metadata['archive_metadata'] = archive_data
        
        elif file_category in ['videos', 'audio']:
            media_data = self.extract_media_metadata(file_path)
            if media_data:
                metadata['media_metadata'] = media_data
        
        return metadata
    
    def analyze_single_file(self, file_path):
        print(f"[*] Analyzing: {file_path}")
        
        # Extract basic metadata
        metadata = self.extract_file_metadata(file_path)
        
        if 'error' not in metadata:
            # Extract file-type specific metadata
            metadata = self.analyze_file_type(file_path, metadata)
        
        self.results['files_analyzed'].append(metadata)
        return metadata
    
    def analyze_directory(self, directory_path):
        print(f"[*] Analyzing directory: {directory_path}")
        
        file_count = 0
        for root, dirs, files in os.walk(directory_path):
            for file in files:
                file_path = os.path.join(root, file)
                
                try:
                    self.analyze_single_file(file_path)
                    file_count += 1
                    
                    if file_count % 100 == 0:
                        print(f"[*] Processed {file_count} files...")
                
                except Exception as e:
                    print(f"[-] Error analyzing {file_path}: {e}")
    
    def generate_metadata_summary(self):
        print("[*] Generating metadata summary...")
        
        summary = {
            'total_files_analyzed': len(self.results['files_analyzed']),
            'file_categories': {},
            'files_with_gps': [],
            'files_with_metadata': 0,
            'suspicious_files': [],
            'hash_duplicates': {},
            'high_entropy_files': [],
            'timeline_analysis': {},
            'metadata_types': defaultdict(int)
        }
        
        # Timeline analysis data
        creation_times = []
        modification_times = []
        
        # Categorize files
        hash_groups = {}
        
        for file_data in self.results['files_analyzed']:
            if 'error' in file_data:
                continue
            
            category = file_data.get('file_category', 'unknown')
            summary['file_categories'][category] = summary['file_categories'].get(category, 0) + 1
            
            # Check for GPS coordinates
            exif_data = file_data.get('exif_metadata', {})
            if 'GPS_Coordinates' in exif_data:
                summary['files_with_gps'].append({
                    'file_path': file_data['file_path'],
                    'coordinates': exif_data['GPS_Coordinates']
                })
            
            # Count files with metadata
            metadata_found = False
            for metadata_key in ['exif_metadata', 'office_metadata', 'pe_metadata', 'pdf_metadata', 'archive_metadata', 'media_metadata']:
                if metadata_key in file_data:
                    summary['files_with_metadata'] += 1
                    summary['metadata_types'][metadata_key] += 1
                    metadata_found = True
                    break
            
            # Check for high entropy files (potential steganography)
            entropy_data = file_data.get('entropy_analysis', {})
            if entropy_data.get('suspicious', False):
                summary['high_entropy_files'].append({
                    'file_path': file_data['file_path'],
                    'entropy': entropy_data.get('normalized_entropy', 0)
                })
            
            # Collect timeline data
            try:
                created_time = datetime.fromisoformat(file_data.get('created_time', '').replace('Z', '+00:00'))
                modified_time = datetime.fromisoformat(file_data.get('modified_time', '').replace('Z', '+00:00'))
                creation_times.append((created_time, file_data['file_path']))
                modification_times.append((modified_time, file_data['file_path']))
            except Exception:
                pass  # Skip if date parsing fails
            
            # Group by hash for duplicate detection
            file_hash = file_data.get('file_hash', {})
            if isinstance(file_hash, dict) and 'md5' in file_hash:
                md5 = file_hash['md5']
                if md5 not in hash_groups:
                    hash_groups[md5] = []
                hash_groups[md5].append(file_data['file_path'])
        
        # Find duplicates
        for md5, file_paths in hash_groups.items():
            if len(file_paths) > 1:
                summary['hash_duplicates'][md5] = file_paths
        
        # Timeline analysis
        if creation_times:
            creation_times.sort()
            summary['timeline_analysis']['earliest_created'] = {
                'timestamp': creation_times[0][0].isoformat(),
                'file_path': creation_times[0][1]
            }
            summary['timeline_analysis']['latest_created'] = {
                'timestamp': creation_times[-1][0].isoformat(),
                'file_path': creation_times[-1][1]
            }
        
        if modification_times:
            modification_times.sort()
            summary['timeline_analysis']['earliest_modified'] = {
                'timestamp': modification_times[0][0].isoformat(),
                'file_path': modification_times[0][1]
            }
            summary['timeline_analysis']['latest_modified'] = {
                'timestamp': modification_times[-1][0].isoformat(),
                'file_path': modification_times[-1][1]
            }
        
        self.results['metadata_summary'] = summary
        
        print(f"[*] Metadata Summary:")
        print(f"  Total files analyzed: {summary['total_files_analyzed']}")
        print(f"  Files with metadata: {summary['files_with_metadata']}")
        print(f"  Files with GPS data: {len(summary['files_with_gps'])}")
        print(f"  Duplicate files found: {len(summary['hash_duplicates'])}")
        print(f"  High entropy files (potential steganography): {len(summary['high_entropy_files'])}")
        if summary['timeline_analysis']:
            print(f"  Timeline analysis completed")
    
    def analyze(self):
        print(f"[*] Starting metadata extraction: {self.target_path}")
        print("=" * 60)
        
        if os.path.isfile(self.target_path):
            self.analyze_single_file(self.target_path)
        elif os.path.isdir(self.target_path):
            self.analyze_directory(self.target_path)
        else:
            print(f"[-] Invalid path: {self.target_path}")
            return None
        
        self.generate_metadata_summary()
        
        # Save results
        output_file = f"metadata_analysis_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        with open(output_file, 'w', encoding='utf-8') as f:
            json.dump(self.results, f, indent=2, ensure_ascii=False, default=str)
        
        print(f"\n[*] Analysis completed. Results saved to: {output_file}")
        return self.results

def main():
    parser = argparse.ArgumentParser(description="Metadata Extractor & EXIF Analyzer for Linux")
    parser.add_argument('target', help='Target file or directory path')
    parser.add_argument('-o', '--output', help='Output file name')
    parser.add_argument('-v', '--verbose', action='store_true', help='Verbose output')
    
    args = parser.parse_args()
    
    extractor = MetadataExtractor(args.target)
    results = extractor.analyze()
    
    if args.output and results:
        with open(args.output, 'w', encoding='utf-8') as f:
            json.dump(results, f, indent=2, ensure_ascii=False, default=str)

if __name__ == "__main__":
    main()
