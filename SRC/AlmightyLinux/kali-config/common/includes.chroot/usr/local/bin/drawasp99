def search_google(query, num_results):
    encoded_query = urllib.parse.quote(query)
    url = f"https://www.google.com/search?q={encoded_query}&num={num_results}&hl=en"
    headers = {"User-Agent": random.choice(USER_AGENTS)}
    req = urllib.request.Request(url, headers=headers)
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    try:
        with urllib.request.urlopen(req, context=ctx, timeout=20) as resp:
            return resp.read().decode('utf-8', errors='ignore')
    except Exception:
        return None


def search_bing(query, num_results):
    encoded_query = urllib.parse.quote(query)
    url = f"https://www.bing.com/search?q={encoded_query}&count={num_results}"
    headers = {"User-Agent": random.choice(USER_AGENTS)}
    req = urllib.request.Request(url, headers=headers)
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    try:
        with urllib.request.urlopen(req, context=ctx, timeout=20) as resp:
            return resp.read().decode('utf-8', errors='ignore')
    except Exception:
        return None


def search_duckduckgo(query, num_results):
    encoded_query = urllib.parse.quote(query)
    url = f"https://html.duckduckgo.com/html/?q={encoded_query}"
    headers = {"User-Agent": random.choice(USER_AGENTS)}
    req = urllib.request.Request(url, headers=headers)
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    try:
        with urllib.request.urlopen(req, context=ctx, timeout=20) as resp:
            return resp.read().decode('utf-8', errors='ignore')
    except Exception:
        return None


SEARCH_ENGINES = {
    "google": search_google,
    "bing": search_bing,
    "duckduckgo": search_duckduckgo,
}

BLOCKED_DOMAINS = {
    "google.com", "google.co", "googleapis.com", "gstatic.com",
    "bing.com", "microsoft.com", "msn.com",
    "duckduckgo.com", "duck.com",
    "yahoo.com", "yimg.com",
    "accounts.google.com", "support.google.com",
    "maps.google.com", "translate.google.com",
}


def extract_urls(html_content, engine="google"):
    if not html_content:
        return []
    results = []

    if engine == "google":
        patterns = [
            re.findall(r'href=["\']\/url\?q=([^"\'&]+)', html_content),
            re.findall(r'<a href="(https?://[^"]+)"', html_content),
        ]
    elif engine == "bing":
        patterns = [
            re.findall(r'<a[^>]+href="(https?://[^"]+)"', html_content),
        ]
    elif engine == "duckduckgo":
        patterns = [
            re.findall(r'href="(https?://[^"]+)"', html_content),
            re.findall(r'<a[^>]+rel="nofollow"[^>]+href="(https?://[^"]+)"', html_content),
        ]
    else:
        patterns = [re.findall(r'href="(https?://[^"]+)"', html_content)]

    for url_list in patterns:
        for url in url_list:
            url = urllib.parse.unquote(url)
            parsed = urllib.parse.urlparse(url)
            domain = parsed.netloc.lower().lstrip("www.")
            if not url.startswith("http"):
                continue
            if any(blocked in domain for blocked in BLOCKED_DOMAINS):
                continue
            if "/search?" in url or "/url?" in url:
                continue
            results.append(url)

    return list(dict.fromkeys(results))


def setup_proxy(proxy_host, proxy_port):
    try:
        import socks
        import socket
        socks.set_default_proxy(socks.SOCKS5, proxy_host, proxy_port)
        socket.socket = socks.socksocket
        print(f"{GREEN}[+] SOCKS5 proxy -> {proxy_host}:{proxy_port}{RESET}")
        return True
    except ImportError:
        print(f"{YELLOW}[!] PySocks not installed, proxy not available{RESET}")
        return False
    except Exception as e:
        print(f"{RED}[!] Proxy error: {e}{RESET}")
        return False


def main():
    parser = argparse.ArgumentParser(
        prog="drawasp99",
        description=f"drawasp99 v{VERSION} - Google Dorking & Recon Tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  drawasp99 -t example.com
  drawasp99 -t example.com -c sql
  drawasp99 -t example.com -c all -n 20
  drawasp99 -q "inurl:admin login" -n 15
  drawasp99 -t example.com --engine bing
  drawasp99 -t example.com -o results.json --json
  drawasp99 -t example.com --proxy-host 127.0.0.1 --proxy-port 9050

Categories:
  """ + ", ".join(sorted(DORKS.keys()))
    )
    parser.add_argument("-t", "--target", help="Target domain")
    parser.add_argument("-c", "--category", choices=list(DORKS.keys()) + ["all"], help="Dork category")
    parser.add_argument("-q", "--query", help="Custom search query")
    parser.add_argument("-n", "--num", type=int, default=10, help="Results per query (default: 10)")
    parser.add_argument("-o", "--output", help="Output file")
    parser.add_argument("-s", "--silent", action="store_true", help="Silent mode (URLs only)")
    parser.add_argument("--json", action="store_true", dest="json_output", help="JSON output format")
    parser.add_argument("--engine", choices=["google", "bing", "duckduckgo", "all"], default="google", help="Search engine (default: google)")
    parser.add_argument("--delay-min", type=float, default=2.0, help="Min delay between requests (default: 2.0)")
    parser.add_argument("--delay-max", type=float, default=6.0, help="Max delay between requests (default: 6.0)")
    parser.add_argument("--proxy-host", help="SOCKS5 proxy host")
    parser.add_argument("--proxy-port", type=int, help="SOCKS5 proxy port")
    parser.add_argument("--version", action="version", version=f"drawasp99 v{VERSION}")

    args = parser.parse_args()

    if not args.target and not args.query and not args.category:
        parser.print_help()
        sys.exit(1)

    if args.proxy_host and args.proxy_port:
        setup_proxy(args.proxy_host, args.proxy_port)

    if not args.silent:
        print(f"{CYAN}{BOLD}drawasp99 v{VERSION} - Google Dorking & Recon{RESET}")
        print(f"{DIM}{'=' * 50}{RESET}")
        if args.target:
            print(f"{CYAN}[*] Target: {args.target}{RESET}")
        print(f"{CYAN}[*] Engine: {args.engine}{RESET}")
        print(f"{CYAN}[*] Results per query: {args.num}{RESET}")
        print()

    queries = []
    query_metadata = []

    if args.query:
        dork_query = args.query
        if args.target:
            dork_query = f"site:{args.target} {dork_query}"
        queries.append(dork_query)
        query_metadata.append({"query": dork_query, "category": "custom"})
    elif args.category:
        categories = list(DORKS.keys()) if args.category == "all" else [args.category]
        for cat in categories:
            for dork in DORKS[cat]:
                dork_query = dork
                if args.target:
                    if "{target}" in dork_query:
                        dork_query = dork_query.replace("{target}", args.target)
                    else:
                        dork_query = f"site:{args.target} {dork_query}"
                elif "{target}" in dork_query:
                    continue
                queries.append(dork_query)
                query_metadata.append({"query": dork_query, "category": cat})
    elif args.target:
        for cat, dork_list in DORKS.items():
            for dork in dork_list:
                dork_query = dork
                if "{target}" in dork_query:
                    dork_query = dork_query.replace("{target}", args.target)
                else:
                    dork_query = f"site:{args.target} {dork_query}"
                queries.append(dork_query)
                query_metadata.append({"query": dork_query, "category": cat})

    all_results = set()
    json_results = []
    engines_to_use = list(SEARCH_ENGINES.keys()) if args.engine == "all" else [args.engine]
    total_queries = len(queries) * len(engines_to_use)
    current = 0

    for idx, dork_query in enumerate(queries):
        meta = query_metadata[idx] if idx < len(query_metadata) else {}

        for engine_name in engines_to_use:
            current += 1
            search_func = SEARCH_ENGINES[engine_name]

            if not args.silent:
                progress = f"[{current}/{total_queries}]"
                print(f"{YELLOW}{progress} [{engine_name}] {dork_query}{RESET}")

            delay = random.uniform(args.delay_min, args.delay_max)
            time.sleep(delay)

            raw_html = search_func(dork_query, args.num)
            found_urls = extract_urls(raw_html, engine_name)

            if found_urls:
                for result_url in found_urls:
                    if result_url not in all_results:
                        all_results.add(result_url)
                        if args.silent:
                            print(result_url)
                        else:
                            print(f"  {GREEN}[+] {result_url}{RESET}")
                        if args.json_output:
                            json_results.append({
                                "url": result_url,
                                "query": dork_query,
                                "category": meta.get("category", "custom"),
                                "engine": engine_name,
                                "timestamp": datetime.now().isoformat(),
                            })
            else:
                if not args.silent:
                    print(f"  {DIM}[-] No results{RESET}")

    if not args.silent:
        print(f"\n{CYAN}{'=' * 50}{RESET}")
        print(f"{GREEN}[+] Total unique URLs found: {len(all_results)}{RESET}")
        print(f"{CYAN}[*] Queries executed: {total_queries}{RESET}")

    if args.output and all_results:
        if args.json_output:
            output_data = {
                "tool": f"drawasp99 v{VERSION}",
                "target": args.target,
                "timestamp": datetime.now().isoformat(),
                "total_results": len(all_results),
                "queries_executed": total_queries,
                "engine": args.engine,
                "results": json_results,
            }
            with open(args.output, "w", encoding="utf-8") as out_file:
                json.dump(output_data, out_file, indent=2, ensure_ascii=False)
        else:
            with open(args.output, "w", encoding="utf-8") as out_file:
                for result_url in sorted(all_results):
                    out_file.write(f"{result_url}\n")
        if not args.silent:
            print(f"{GREEN}[+] Results saved to: {args.output}{RESET}")


if __name__ == "__main__":
    main()
