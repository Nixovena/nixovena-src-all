LANG_PATTERNS = {
    "en": re.compile(r'\b(the|is|are|was|were|have|has|had|will|would|could|should|can|this|that|with|from|for|not|but|and|its|you|your)\b', re.I),
    "ru": re.compile(r'[а-яёА-ЯЁ]{3,}'),
    "ar": re.compile(r'[\u0600-\u06FF]{3,}'),
    "zh": re.compile(r'[\u4e00-\u9fff]{2,}'),
    "ja": re.compile(r'[\u3040-\u309f\u30a0-\u30ff]{2,}'),
    "ko": re.compile(r'[\uac00-\ud7af]{2,}'),
    "tr": re.compile(r'\b(bir|ve|bu|ile|için|olan|gibi|daha|çok|var|yok|ama|hem|ise|olarak|kadar)\b', re.I),
    "de": re.compile(r'\b(der|die|das|und|ist|von|mit|auf|für|nicht|ein|eine|sich|auch|werden)\b', re.I),
    "fr": re.compile(r'\b(les|des|une|est|que|dans|pour|pas|qui|sur|avec|sont|cette|mais|tout)\b', re.I),
    "es": re.compile(r'\b(los|las|del|una|que|por|con|para|está|son|como|más|pero|sus|este)\b', re.I),
    "pt": re.compile(r'\b(que|uma|dos|das|para|com|por|são|está|mais|tem|seu|sua|como|mas)\b', re.I),
    "fa": re.compile(r'[\u0600-\u06FF]{3,}'),
    "hi": re.compile(r'[\u0900-\u097F]{3,}'),
    "uk": re.compile(r'[а-яіїєґА-ЯІЇЄҐ]{3,}'),
}

