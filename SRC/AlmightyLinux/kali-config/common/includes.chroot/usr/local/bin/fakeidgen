    def generate_first_name(self, gender: str = None, country: str = "US") -> str:
        """Generate a random first name based on gender and country"""
        if gender is None:
            gender = random.choice(["male", "female"])
            
        # Select name lists based on country
        country = country.upper()
        if country == "UK":
            male_names = self.uk_male_first_names
            female_names = self.uk_female_first_names
        elif country == "DE":
            male_names = self.de_male_first_names
            female_names = self.de_female_first_names
        elif country == "FR":
            male_names = self.fr_male_first_names
            female_names = self.fr_female_first_names
        elif country == "TR":
            male_names = self.tr_male_first_names
            female_names = self.tr_female_first_names
        elif country == "IT":
            male_names = self.it_male_first_names
            female_names = self.it_female_first_names
        elif country == "ES":
            male_names = self.es_male_first_names
            female_names = self.es_female_first_names
        elif country == "CA":
            male_names = self.ca_male_first_names
            female_names = self.ca_female_first_names
        elif country == "AU":
            male_names = self.au_male_first_names
            female_names = self.au_female_first_names
        elif country == "JP":
            male_names = self.jp_male_first_names
            female_names = self.jp_female_first_names
        elif country == "BR":
            male_names = self.br_male_first_names
            female_names = self.br_female_first_names
        elif country == "RU":
            male_names = self.ru_male_first_names
            female_names = self.ru_female_first_names
        elif country == "CN":
            male_names = self.cn_male_first_names
            female_names = self.cn_female_first_names
        elif country == "IN":
            male_names = self.in_male_first_names
            female_names = self.in_female_first_names
        else:  # Default to US
            male_names = self.us_male_first_names
            female_names = self.us_female_first_names
            
        if gender.lower() == "male":
            return random.choice(male_names)
        else:
            return random.choice(female_names)
    
    def generate_last_name(self, country: str = "US") -> str:
        """Generate a random last name based on country"""
        country = country.upper()
        if country == "UK":
            return random.choice(self.uk_last_names)
        elif country == "DE":
            return random.choice(self.de_last_names)
        elif country == "FR":
            return random.choice(self.fr_last_names)
        elif country == "TR":
            return random.choice(self.tr_last_names)
        elif country == "IT":
            return random.choice(self.it_last_names)
        elif country == "ES":
            return random.choice(self.es_last_names)
        elif country == "CA":
            return random.choice(self.ca_last_names)
        elif country == "AU":
            return random.choice(self.au_last_names)
        elif country == "JP":
            return random.choice(self.jp_last_names)
        elif country == "BR":
            return random.choice(self.br_last_names)
        elif country == "RU":
            return random.choice(self.ru_last_names)
        elif country == "CN":
            return random.choice(self.cn_last_names)
        elif country == "IN":
            return random.choice(self.in_last_names)
        else:  # Default to US
            return random.choice(self.us_last_names)
    
    def generate_full_name(self, gender: str = None, country: str = "US") -> str:
        """Generate a full name based on gender and country"""
        first_name = self.generate_first_name(gender, country)
        last_name = self.generate_last_name(country)
        return f"{first_name} {last_name}"
    
    def generate_country(self) -> str:
        """Generate a random country"""
        return random.choice(self.countries)
    
    def generate_occupation(self) -> str:
        """Generate a random occupation"""
        return random.choice(self.occupations)
    
    def generate_fake_profile(self, gender: str = None, country: str = None) -> Dict[str, str]:
        """Generate a fake profile with name, country, and occupation"""
        # If no country specified, randomly select one
        if country is None:
            country_codes = ["US", "UK", "DE", "FR", "TR", "IT", "ES", "CA", "AU", "JP", "BR", "RU", "CN", "IN"]
            country_code = random.choice(country_codes)
        else:
            country_code = country
        
        full_name = self.generate_full_name(gender, country_code)
        name_parts = full_name.split()
        first_name = name_parts[0]
        last_name = name_parts[1]
        
        # Map country codes to full names
        country_map = {
            "US": "United States", "UK": "United Kingdom", "DE": "Germany", "FR": "France", 
            "TR": "Turkey", "IT": "Italy", "ES": "Spain", "CA": "Canada", "AU": "Australia", 
            "JP": "Japan", "BR": "Brazil", "RU": "Russia", "CN": "China", "IN": "India"
        }
        
        return {
            "Full Name": full_name,
            "First Name": first_name,
            "Last Name": last_name,
            "Gender": gender.title() if gender else random.choice(["Male", "Female"]),
            "Country": country_map.get(country_code, self.generate_country()),
            "Occupation": self.generate_occupation()
        }
    
    def generate_multiple_profiles(self, count: int = 5, gender: str = None, country: str = None) -> List[Dict[str, str]]:
        """Generate multiple fake profiles"""
        return [self.generate_fake_profile(gender, country) for _ in range(count)]

def main():
    generator = FakeNameGenerator()
    
    print("=== Fake Name Generator ===")
    print("1. Generate single profile")
    print("2. Generate multiple profiles")
    print("3. Generate male profile")
    print("4. Generate female profile")
    print("5. Generate profile by country")
    print("6. Generate multiple profiles by country")
    
    choice = input("Select an option (1-6): ").strip()
    
    if choice == "1":
        profile = generator.generate_fake_profile()
        print("\nGenerated Profile:")
        print("-" * 30)
        for key, value in profile.items():
            print(f"{key:<15}: {value}")
            
    elif choice == "2":
        try:
            count = int(input("How many profiles to generate? (1-20): "))
            count = max(1, min(count, 20))  # Limit between 1 and 20
        except ValueError:
            count = 5
            
        profiles = generator.generate_multiple_profiles(count)
        print(f"\nGenerated {count} Profiles:")
        print("=" * 50)
        for i, profile in enumerate(profiles, 1):
            print(f"\nProfile #{i}")
            print("-" * 20)
            for key, value in profile.items():
                print(f"{key:<15}: {value}")
                
    elif choice == "3":
        profile = generator.generate_fake_profile("male")
        print("\nGenerated Male Profile:")
        print("-" * 30)
        for key, value in profile.items():
            print(f"{key:<15}: {value}")
            
    elif choice == "4":
        profile = generator.generate_fake_profile("female")
        print("\nGenerated Female Profile:")
        print("-" * 30)
        for key, value in profile.items():
            print(f"{key:<15}: {value}")
            
    elif choice == "5":
        print("\nAvailable countries:")
        print("1. US (United States)")
        print("2. UK (United Kingdom)")
        print("3. DE (Germany)")
        print("4. FR (France)")
        print("5. TR (Turkey)")
        print("6. IT (Italy)")
        print("7. ES (Spain)")
        print("8. CA (Canada)")
        print("9. AU (Australia)")
        print("10. JP (Japan)")
        print("11. BR (Brazil)")
        print("12. RU (Russia)")
        print("13. CN (China)")
        print("14. IN (India)")
        
        country_choice = input("Select a country (1-14): ").strip()
        country_map = {
            "1": "US", "2": "UK", "3": "DE", "4": "FR", "5": "TR",
            "6": "IT", "7": "ES", "8": "CA", "9": "AU", "10": "JP",
            "11": "BR", "12": "RU", "13": "CN", "14": "IN"
        }
        country = country_map.get(country_choice, "US")
        
        gender_choice = input("Select gender (1. Male, 2. Female, 3. Random): ").strip()
        gender_map = {"1": "male", "2": "female"}
        gender = gender_map.get(gender_choice, None)
        
        profile = generator.generate_fake_profile(gender, country)
        print(f"\nGenerated {country} Profile:")
        print("-" * 40)
        for key, value in profile.items():
            print(f"{key:<15}: {value}")
            
    elif choice == "6":
        print("\nAvailable countries:")
        print("1. US (United States)")
        print("2. UK (United Kingdom)")
        print("3. DE (Germany)")
        print("4. FR (France)")
        print("5. TR (Turkey)")
        print("6. IT (Italy)")
        print("7. ES (Spain)")
        print("8. CA (Canada)")
        print("9. AU (Australia)")
        print("10. JP (Japan)")
        print("11. BR (Brazil)")
        print("12. RU (Russia)")
        print("13. CN (China)")
        print("14. IN (India)")
        
        country_choice = input("Select a country (1-14): ").strip()
        country_map = {
            "1": "US", "2": "UK", "3": "DE", "4": "FR", "5": "TR",
            "6": "IT", "7": "ES", "8": "CA", "9": "AU", "10": "JP",
            "11": "BR", "12": "RU", "13": "CN", "14": "IN"
        }
        country = country_map.get(country_choice, "US")
        
        gender_choice = input("Select gender (1. Male, 2. Female, 3. Random): ").strip()
        gender_map = {"1": "male", "2": "female"}
        gender = gender_map.get(gender_choice, None)
        
        try:
            count = int(input("How many profiles to generate? (1-20): "))
            count = max(1, min(count, 20))  # Limit between 1 and 20
        except ValueError:
            count = 5
            
        profiles = generator.generate_multiple_profiles(count, gender, country)
        print(f"\nGenerated {count} {country} Profiles:")
        print("=" * 50)
        for i, profile in enumerate(profiles, 1):
            print(f"\nProfile #{i}")
            print("-" * 25)
            for key, value in profile.items():
                print(f"{key:<15}: {value}")
    else:
        print("Invalid option. Generating default profile:")
        profile = generator.generate_fake_profile()
        print("\nGenerated Profile:")
        print("-" * 30)
        for key, value in profile.items():
            print(f"{key:<15}: {value}")

if __name__ == "__main__":
    main()