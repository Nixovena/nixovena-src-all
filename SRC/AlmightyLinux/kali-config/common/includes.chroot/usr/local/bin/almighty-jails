#!/bin/bash

#########################################################
#                                                       #
#              Almighty Jails Manager                   #
#         Interactive Firejail Sandbox Tool             #
#                                                       #
#########################################################

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m' 

# Check if running as root
if [[ $EUID -eq 0 ]]; then
    echo -e "${RED}[!] This tool should not be run as root for security reasons.${NC}"
    echo -e "${YELLOW}[i] Please run as a regular user.${NC}"
    exit 1
fi

# Check if firejail is installed
if ! command -v firejail &> /dev/null; then
    echo -e "${RED}[!] Firejail is not installed. Please install it first:${NC}"
    echo -e "${CYAN}    sudo apt install firejail${NC}"
    exit 1
fi

# ASCII Banner
show_banner() {
    clear
    echo -e "${CYAN}"
    cat << "EOF"

 █████╗ ██╗     ███╗   ███╗██╗ ██████╗ ██╗  ██╗████████╗██╗   ██╗
██╔══██╗██║     ████╗ ████║██║██╔════╝ ██║  ██║╚══██╔══╝╚██╗ ██╔╝
███████║██║     ██╔████╔██║██║██║  ███╗███████║   ██║    ╚████╔╝ 
██╔══██║██║     ██║╚██╔╝██║██║██║   ██║██╔══██║   ██║     ╚██╔╝  
██║  ██║███████╗██║ ╚═╝ ██║██║╚██████╔╝██║  ██║   ██║      ██║   
╚═╝  ╚═╝╚══════╝╚═╝     ╚═╝╚═╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝      ╚═╝   
EOF
    echo -e "${NC}"
    echo -e "${PURPLE}═══════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${WHITE}                    Interactive Firejail Sandbox Manager${NC}"
    echo -e "${WHITE}                         Secure Application Isolation${NC}"
    echo -e "${PURPLE}═══════════════════════════════════════════════════════════════════════════${NC}"
    echo
}

# Show main menu
show_menu() {
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                        MAIN MENU                                │${NC}"
    echo -e "${CYAN}├─────────────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}1.${NC} ${WHITE}Launch Application in Sandbox${NC}                                ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}2.${NC} ${WHITE}Quick Launch with Presets${NC}                                    ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}3.${NC} ${WHITE}List Active Sandboxes${NC}                                        ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}4.${NC} ${WHITE}Kill Sandbox Process${NC}                                         ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}5.${NC} ${WHITE}Show Firejail Profiles${NC}                                       ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}6.${NC} ${WHITE}System Information${NC}                                           ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}0.${NC} ${RED}Exit${NC}                                                         ${CYAN}│${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
}

# Get yes/no input
get_yes_no() {
    local prompt="$1"
    local response
    while true; do
        echo -ne "${YELLOW}$prompt (Y/N): ${NC}"
        read -r response
        case $response in
            [Yy]* ) return 0;;
            [Nn]* ) return 1;;
            * ) echo -e "${RED}Please answer Y or N.${NC}";;
        esac
    done
}

# Build firejail command based on user choices
build_firejail_command() {
    local app_path="$1"
    local firejail_cmd="firejail"
    
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                    SANDBOX CONFIGURATION                       │${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
    
    # Network access
    if get_yes_no "Allow network access?"; then
        echo -e "${GREEN}[+] Network access: ENABLED${NC}"
    else
        firejail_cmd+=" --net=none"
        echo -e "${RED}[-] Network access: DISABLED${NC}"
    fi
    
    # Home directory isolation
    if get_yes_no "Isolate from home directory?"; then
        firejail_cmd+=" --private"
        echo -e "${RED}[-] Home directory: ISOLATED${NC}"
    else
        echo -e "${GREEN}[+] Home directory: ACCESSIBLE${NC}"
    fi
    
    # Temporary filesystem
    if get_yes_no "Use temporary filesystem for /tmp?"; then
        firejail_cmd+=" --private-tmp"
        echo -e "${YELLOW}[~] Temporary filesystem: ENABLED${NC}"
    fi
    
    # Disable sound
    if get_yes_no "Disable sound access?"; then
        firejail_cmd+=" --nosound"
        echo -e "${RED}[-] Sound access: DISABLED${NC}"
    fi
    
    # Disable 3D acceleration
    if get_yes_no "Disable 3D acceleration?"; then
        firejail_cmd+=" --no3d"
        echo -e "${RED}[-] 3D acceleration: DISABLED${NC}"
    fi
    
    # Disable webcam
    if get_yes_no "Disable webcam access?"; then
        firejail_cmd+=" --novideo"
        echo -e "${RED}[-] Webcam access: DISABLED${NC}"
    fi
    
    # Read-only filesystem
    if get_yes_no "Make filesystem read-only?"; then
        firejail_cmd+=" --read-only=~"
        echo -e "${YELLOW}[~] Filesystem: READ-ONLY${NC}"
    fi
    
    # Seccomp filter
    if get_yes_no "Enable seccomp syscall filtering?"; then
        firejail_cmd+=" --seccomp"
        echo -e "${GREEN}[+] Seccomp filtering: ENABLED${NC}"
    fi
    
    # AppArmor
    if get_yes_no "Enable AppArmor confinement?"; then
        firejail_cmd+=" --apparmor"
        echo -e "${GREEN}[+] AppArmor: ENABLED${NC}"
    fi
    
    # Custom profile
    echo -ne "${YELLOW}Enter custom Firejail profile (or press Enter to skip): ${NC}"
    read -r custom_profile
    if [[ -n "$custom_profile" ]]; then
        if [[ -f "/etc/firejail/$custom_profile.profile" ]]; then
            firejail_cmd+=" --profile=$custom_profile"
            echo -e "${GREEN}[+] Custom profile: $custom_profile${NC}"
        else
            echo -e "${RED}[!] Profile not found: $custom_profile${NC}"
        fi
    fi
    
    echo
    echo -e "${PURPLE}═══════════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${WHITE}Final command: ${CYAN}$firejail_cmd $app_path${NC}"
    echo -e "${PURPLE}═══════════════════════════════════════════════════════════════════════════${NC}"
    echo
    
    if get_yes_no "Execute this command?"; then
        echo -e "${GREEN}[+] Launching application in sandbox...${NC}"
        echo -e "${YELLOW}[i] Press Ctrl+C to return to menu${NC}"
        echo
        $firejail_cmd "$app_path"
    else
        echo -e "${YELLOW}[i] Command cancelled.${NC}"
    fi
}

# Launch application in sandbox
launch_application() {
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                    APPLICATION LAUNCHER                        │${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
    
    echo -ne "${YELLOW}Enter the full path to application/script: ${NC}"
    read -r app_path
    
    if [[ -z "$app_path" ]]; then
        echo -e "${RED}[!] No application path provided.${NC}"
        return
    fi
    
    if [[ ! -f "$app_path" ]] && ! command -v "$app_path" &> /dev/null; then
        echo -e "${RED}[!] Application not found: $app_path${NC}"
        return
    fi
    
    build_firejail_command "$app_path"
}

# Quick launch with presets
quick_launch() {
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                      QUICK PRESETS                             │${NC}"
    echo -e "${CYAN}├─────────────────────────────────────────────────────────────────┤${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}1.${NC} ${WHITE}Maximum Security (No network, isolated, read-only)${NC}      ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}2.${NC} ${WHITE}Internet Browser (Network enabled, private home)${NC}        ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}3.${NC} ${WHITE}Office Application (No network, home access)${NC}           ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}4.${NC} ${WHITE}Media Player (No network, limited access)${NC}              ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}5.${NC} ${WHITE}Development Tool (Network, home, full access)${NC}          ${CYAN}│${NC}"
    echo -e "${CYAN}│${NC} ${GREEN}0.${NC} ${RED}Back to Main Menu${NC}                                     ${CYAN}│${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
    
    echo -ne "${YELLOW}Select preset: ${NC}"
    read -r preset_choice
    
    echo -ne "${YELLOW}Enter application path: ${NC}"
    read -r app_path
    
    if [[ -z "$app_path" ]]; then
        echo -e "${RED}[!] No application path provided.${NC}"
        return
    fi
    
    case $preset_choice in
        1)
            echo -e "${RED}[MAXIMUM SECURITY] Launching with strictest settings...${NC}"
            firejail --net=none --private --private-tmp --nosound --no3d --novideo --read-only=~ --seccomp --apparmor "$app_path"
            ;;
        2)
            echo -e "${BLUE}[BROWSER MODE] Launching with internet access...${NC}"
            firejail --private --private-tmp --nosound --seccomp --apparmor "$app_path"
            ;;
        3)
            echo -e "${GREEN}[OFFICE MODE] Launching for document editing...${NC}"
            firejail --net=none --private-tmp --nosound --no3d --novideo --seccomp "$app_path"
            ;;
        4)
            echo -e "${PURPLE}[MEDIA MODE] Launching media player...${NC}"
            firejail --net=none --private --private-tmp --no3d --seccomp "$app_path"
            ;;
        5)
            echo -e "${CYAN}[DEVELOPMENT MODE] Launching with development access...${NC}"
            firejail --private-tmp --seccomp "$app_path"
            ;;
        0)
            return
            ;;
        *)
            echo -e "${RED}[!] Invalid choice.${NC}"
            ;;
    esac
}

# List active sandboxes
list_sandboxes() {
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                    ACTIVE SANDBOXES                            │${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
    
    if command -v firejail &> /dev/null; then
        firejail --list
    else
        echo -e "${RED}[!] Firejail not found.${NC}"
    fi
    
    echo
    echo -e "${YELLOW}Press Enter to continue...${NC}"
    read -r
}

# Kill sandbox process
kill_sandbox() {
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                    KILL SANDBOX                                │${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
    
    echo -e "${YELLOW}Active sandboxes:${NC}"
    firejail --list
    echo
    
    echo -ne "${YELLOW}Enter PID to kill (or 'all' to kill all): ${NC}"
    read -r pid_input
    
    if [[ "$pid_input" == "all" ]]; then
        if get_yes_no "Kill ALL sandbox processes?"; then
            firejail --shutdown
            echo -e "${GREEN}[+] All sandboxes terminated.${NC}"
        fi
    elif [[ "$pid_input" =~ ^[0-9]+$ ]]; then
        if get_yes_no "Kill sandbox with PID $pid_input?"; then
            firejail --shutdown="$pid_input"
            echo -e "${GREEN}[+] Sandbox $pid_input terminated.${NC}"
        fi
    else
        echo -e "${RED}[!] Invalid PID.${NC}"
    fi
    
    echo
    echo -e "${YELLOW}Press Enter to continue...${NC}"
    read -r
}

# Show available profiles
show_profiles() {
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                   FIREJAIL PROFILES                            │${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
    
    if [[ -d "/etc/firejail" ]]; then
        echo -e "${GREEN}Available profiles in /etc/firejail:${NC}"
        ls -1 /etc/firejail/*.profile 2>/dev/null | sed 's|/etc/firejail/||g' | sed 's|\.profile||g' | head -20
        echo
        echo -e "${YELLOW}[i] Use profile name (without .profile extension) in custom configuration${NC}"
    else
        echo -e "${RED}[!] Firejail profiles directory not found.${NC}"
    fi
    
    echo
    echo -e "${YELLOW}Press Enter to continue...${NC}"
    read -r
}

# Show system information
show_system_info() {
    echo -e "${CYAN}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│                   SYSTEM INFORMATION                           │${NC}"
    echo -e "${CYAN}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo
    
    echo -e "${GREEN}Firejail Version:${NC}"
    firejail --version 2>/dev/null || echo "Not available"
    echo
    
    echo -e "${GREEN}Kernel Version:${NC}"
    uname -r
    echo
    
    echo -e "${GREEN}Available Namespaces:${NC}"
    if [[ -f "/proc/self/ns/pid" ]]; then
        echo -e "${GREEN}✓${NC} PID namespace"
    fi
    if [[ -f "/proc/self/ns/net" ]]; then
        echo -e "${GREEN}✓${NC} Network namespace"
    fi
    if [[ -f "/proc/self/ns/mnt" ]]; then
        echo -e "${GREEN}✓${NC} Mount namespace"
    fi
    if [[ -f "/proc/self/ns/user" ]]; then
        echo -e "${GREEN}✓${NC} User namespace"
    fi
    echo
    
    echo -e "${GREEN}Security Features:${NC}"
    if [[ -f "/sys/kernel/security/apparmor/profiles" ]]; then
        echo -e "${GREEN}✓${NC} AppArmor enabled"
    else
        echo -e "${RED}✗${NC} AppArmor not available"
    fi
    
    if grep -q seccomp /proc/self/status 2>/dev/null; then
        echo -e "${GREEN}✓${NC} Seccomp available"
    else
        echo -e "${RED}✗${NC} Seccomp not available"
    fi
    
    echo
    echo -e "${YELLOW}Press Enter to continue...${NC}"
    read -r
}

# Main program loop
main() {
    while true; do
        show_banner
        show_menu
        
        echo -ne "${YELLOW}Select an option: ${NC}"
        read -r choice
        
        case $choice in
            1)
                launch_application
                ;;
            2)
                quick_launch
                ;;
            3)
                list_sandboxes
                ;;
            4)
                kill_sandbox
                ;;
            5)
                show_profiles
                ;;
            6)
                show_system_info
                ;;
            0)
                echo -e "${GREEN}[+] Thank you for using Almighty Jails Manager!${NC}"
                echo -e "${CYAN}[i] Stay secure!${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}[!] Invalid option. Please try again.${NC}"
                sleep 2
                ;;
        esac
        
        echo
        echo -e "${YELLOW}Press Enter to continue...${NC}"
        read -r
    done
}

# Run main function
main "$@"