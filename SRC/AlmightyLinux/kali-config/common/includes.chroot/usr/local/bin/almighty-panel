# ------------------------------------------------
# HELPERS
# ------------------------------------------------

def run_cmd(cmd, capture=False, shell=True):
    try:
        if capture:
            result = subprocess.run(cmd, shell=shell, capture_output=True, text=True, timeout=60)
            return result.stdout.strip()
        else:
            subprocess.run(cmd, shell=shell, timeout=300)
    except subprocess.TimeoutExpired:
        console.print("[red]Command timed out.[/red]")
    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")
    return ""

def run_cmd_live(cmd):
    try:
        subprocess.run(cmd, shell=True, timeout=600)
    except subprocess.TimeoutExpired:
        console.print("[red]Command timed out.[/red]")
    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")

def press_enter():
    console.print()
    Prompt.ask("[dim]Press Enter to return to menu[/dim]", default="")

def is_root():
    return os.geteuid() == 0

def require_root():
    if not is_root():
        console.print("[red]This operation requires root privileges.[/red]")
        console.print("[yellow]Run with: sudo almighty-panel[/yellow]")
        return False
    return True

def is_live_mode():
    try:
        with open("/proc/mounts", "r") as f:
            return "overlay" in f.read()
    except Exception:
        return False

# ------------------------------------------------
# HEADER
# ------------------------------------------------

def show_header():
    os.system("clear")
    banner_text = Text(ASCII_BANNER, style="bold red")
    console.print(Align.center(banner_text))
    subtitle = Text("System Management Panel", style="bold white")
    console.print(Align.center(subtitle))
    console.print()

# ------------------------------------------------
# MAIN MENU
# ------------------------------------------------

def show_menu():
    show_header()

    menu_table = Table(
        show_header=False,
        box=box.ROUNDED,
        border_style="red",
        padding=(0, 2),
        expand=False,
    )
    menu_table.add_column("No", style="bold red", width=4)
    menu_table.add_column("Option", style="white", width=38)

    menu_items = [
        ("1", "System Update & Cleanup"),
        ("2", "System Information"),
        ("3", "View System Logs"),
        ("4", "Systemd Service Management"),
        ("5", "List Installed Packages"),
        ("6", "Network Management"),
        ("7", "User Management"),
        ("8", "Disk Information"),
        ("9", "Clean System Caches & Trash"),
        ("10", "Change DNS Settings"),
        ("11", "Change Hostname"),
        ("12", "ZRAM Manager"),
        ("13", "Kernel Parameters"),
        ("14", "Firewall Manager"),
        ("15", "Swap Manager"),
        ("16", "Hardware Diagnostics"),
        ("17", "Update Python Libraries"),
        ("0", "Exit"),
    ]

    for num, label in menu_items:
        style = "bold red" if num == "0" else "white"
        menu_table.add_row(num, Text(label, style=style))

    console.print(Align.center(menu_table))
    console.print()
    choice = Prompt.ask("[bold red]Select an option[/bold red]", default="0")
    return choice

# ------------------------------------------------
# 1. SYSTEM UPDATE & CLEANUP
# ------------------------------------------------

def system_update():
    show_header()
    console.print(Panel("[bold]System Update & Cleanup[/bold]", border_style="red"))

    if not require_root():
        press_enter()
        return

    os.environ["DEBIAN_FRONTEND"] = "noninteractive"

    steps = [
        ("Updating package lists...", "apt-get update"),
        ("Upgrading packages...", "apt-get upgrade -y"),
        ("Full upgrade...", "apt-get full-upgrade -y"),
        ("Removing unnecessary packages...", "apt-get autoremove --purge -y"),
        ("Cleaning APT cache...", "apt-get clean"),
    ]

    for i, (msg, cmd) in enumerate(steps, 1):
        console.print(f"[cyan][{i}/{len(steps)}] {msg}[/cyan]")
        run_cmd_live(cmd)

    if shutil.which("flatpak"):
        console.print("[cyan]Updating Flatpak applications...[/cyan]")
        run_cmd_live("flatpak update -y")
        run_cmd_live("flatpak uninstall --unused -y")
    else:
        console.print("[dim]Flatpak not installed, skipping.[/dim]")

    console.print("[green]System update completed successfully.[/green]")
    press_enter()

# ------------------------------------------------
# 3. SYSTEM INFORMATION
# ------------------------------------------------

def sys_info():
    show_header()
    console.print(Panel("[bold]System Information[/bold]", border_style="red"))

    if shutil.which("almighty-fetch"):
        os.system("almighty-fetch")
    elif shutil.which("fastfetch"):
        os.system("fastfetch")
    elif shutil.which("neofetch"):
        os.system("neofetch")
    else:
        info_table = Table(show_header=False, box=box.SIMPLE, border_style="red")
        info_table.add_column("Key", style="bold cyan", width=12)
        info_table.add_column("Value", style="white")

        distro = run_cmd("grep '^PRETTY_NAME=' /etc/os-release | cut -d'\"' -f2", capture=True) or "Unknown"
        kernel = run_cmd("uname -r", capture=True)
        cpu = run_cmd("lscpu | awk -F: '/^Model name/{gsub(/^[ \\t]+/, \"\", $2); print $2}'", capture=True)
        ram = run_cmd("free -h | awk '/^Mem:/{print $3 \"/\" $2}'", capture=True)
        disk = run_cmd("df -h / | awk 'NR==2{print $3 \"/\" $2 \" (\" $5 \" used)\"}'", capture=True)
        uptime = run_cmd("uptime -p", capture=True)

        info_table.add_row("OS", distro)
        info_table.add_row("Kernel", kernel)
        info_table.add_row("CPU", cpu)
        info_table.add_row("RAM", ram)
        info_table.add_row("Disk", disk)
        info_table.add_row("Uptime", uptime)
        console.print(info_table)

    press_enter()

# ------------------------------------------------
# 4. VIEW SYSTEM LOGS
# ------------------------------------------------

def view_logs():
    show_header()
    console.print(Panel("[bold]Log Viewer[/bold]", border_style="red"))

    log_table = Table(show_header=False, box=box.SIMPLE)
    log_table.add_column("No", style="bold red", width=4)
    log_table.add_column("Option", style="white")
    log_table.add_row("1", "System Logs (journalctl)")
    log_table.add_row("2", "Kernel Logs (dmesg)")
    log_table.add_row("3", "Xorg / Wayland Logs")
    log_table.add_row("4", "Auth Logs")
    log_table.add_row("5", "Boot Messages")
    log_table.add_row("0", "Back")
    console.print(log_table)

    choice = Prompt.ask("[bold red]Selection[/bold red]", default="0")
    if choice == "1":
        os.system("sudo journalctl -xe | less")
    elif choice == "2":
        os.system("sudo dmesg -H | less")
    elif choice == "3":
        session = os.environ.get("XDG_SESSION_TYPE", "")
        if session == "wayland":
            os.system("sudo journalctl -b 0 _COMM=kwin_wayland | less")
        elif os.path.isfile("/var/log/Xorg.0.log"):
            os.system("less /var/log/Xorg.0.log")
        else:
            console.print("[red]Display log not found.[/red]")
    elif choice == "4":
        os.system("sudo journalctl _COMM=sshd + _COMM=sudo + _COMM=login | less")
    elif choice == "5":
        os.system("sudo journalctl -b 0 --no-pager | less")
    elif choice == "0":
        return
    press_enter()

# ------------------------------------------------
# 5. SERVICE MANAGEMENT
# ------------------------------------------------

def manage_services():
    show_header()
    console.print(Panel("[bold]Systemd Service Management[/bold]", border_style="red"))

    srv = Prompt.ask("[cyan]Service name (e.g. ssh, bluetooth)[/cyan]", default="")
    if not srv:
        console.print("[red]Service name cannot be empty.[/red]")
        press_enter()
        return

    status = run_cmd(f"systemctl is-active {srv} 2>/dev/null", capture=True)
    enabled = run_cmd(f"systemctl is-enabled {srv} 2>/dev/null", capture=True)
    console.print(f"[cyan]Status:[/cyan] {status}  [cyan]Enabled:[/cyan] {enabled}")
    console.print()

    actions = "start | stop | restart | status | enable | disable"
    console.print(f"[dim]Actions: {actions}[/dim]")
    action = Prompt.ask("[cyan]Action[/cyan]", default="status")

    if action in ("start", "stop", "restart", "status", "enable", "disable"):
        run_cmd_live(f"sudo systemctl {action} {srv}")
        if action != "status":
            console.print(f"[green]systemctl {action} {srv} executed.[/green]")
    else:
        console.print(f"[red]Invalid action: {action}[/red]")
    press_enter()

# ------------------------------------------------
# 6. LIST INSTALLED PACKAGES
# ------------------------------------------------

def list_packages():
    show_header()
    console.print(Panel("[bold]Installed Packages[/bold]", border_style="red"))

    total = run_cmd("dpkg -l | grep '^ii' | wc -l", capture=True)
    console.print(f"[cyan]Total installed packages:[/cyan] {total}")
    console.print("[dim]Press q to quit the pager.[/dim]")
    time.sleep(1)
    os.system("dpkg-query -W -f='${binary:Package}\t${Version}\t${Status}\n' | column -t | less")
    press_enter()

# ------------------------------------------------
# 7. NETWORK MANAGEMENT
# ------------------------------------------------

def manage_network():
    show_header()
    console.print(Panel("[bold]Network Management[/bold]", border_style="red"))

    net_table = Table(show_header=False, box=box.SIMPLE)
    net_table.add_column("No", style="bold red", width=4)
    net_table.add_column("Option", style="white")
    net_table.add_row("1", "Show IP Addresses")
    net_table.add_row("2", "Show Routing Table")
    net_table.add_row("3", "Ping Test (google.com)")
    net_table.add_row("4", "Restart NetworkManager")
    net_table.add_row("5", "Show Active Connections")
    net_table.add_row("6", "Show Listening Ports")
    net_table.add_row("0", "Back")
    console.print(net_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")
    if choice == "1":
        os.system("ip -br a")
    elif choice == "2":
        os.system("ip route")
    elif choice == "3":
        os.system("ping -c 4 google.com")
    elif choice == "4":
        run_cmd_live("sudo systemctl restart NetworkManager")
        console.print("[green]NetworkManager restarted.[/green]")
    elif choice == "5":
        os.system("ss -tunap 2>/dev/null | head -30")
    elif choice == "6":
        os.system("ss -tlnp 2>/dev/null")
    elif choice == "0":
        return
    press_enter()

# ------------------------------------------------
# 8. USER MANAGEMENT
# ------------------------------------------------

def manage_users():
    show_header()
    console.print(Panel("[bold]User Management[/bold]", border_style="red"))

    user_table = Table(show_header=False, box=box.SIMPLE)
    user_table.add_column("No", style="bold red", width=4)
    user_table.add_column("Option", style="white")
    user_table.add_row("1", "Add new user")
    user_table.add_row("2", "Change user password")
    user_table.add_row("3", "Delete user")
    user_table.add_row("4", "List users")
    user_table.add_row("5", "Show user groups")
    user_table.add_row("0", "Back")
    console.print(user_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")
    if choice == "1":
        u_name = Prompt.ask("[cyan]New username[/cyan]", default="")
        if u_name:
            os.system(f"sudo adduser {u_name}")
    elif choice == "2":
        u_name = Prompt.ask("[cyan]Username[/cyan]", default="")
        if u_name:
            os.system(f"sudo passwd {u_name}")
    elif choice == "3":
        u_name = Prompt.ask("[cyan]Username to delete[/cyan]", default="")
        if u_name and Confirm.ask(f"Delete user '{u_name}'?", default=False):
            run_cmd_live(f"sudo deluser {u_name}")
            console.print("[green]User deleted.[/green]")
    elif choice == "4":
        os.system("awk -F: '$3 >= 1000 && $3 < 65534 {print $1}' /etc/passwd")
    elif choice == "5":
        u_name = Prompt.ask("[cyan]Username[/cyan]", default="")
        if u_name:
            os.system(f"groups {u_name}")
    elif choice == "0":
        return
    press_enter()

# ------------------------------------------------
# 9. DISK INFORMATION
# ------------------------------------------------

def disk_info():
    show_header()
    console.print(Panel("[bold]Disk Information[/bold]", border_style="red"))

    disk_table = Table(show_header=False, box=box.SIMPLE)
    disk_table.add_column("No", style="bold red", width=4)
    disk_table.add_column("Option", style="white")
    disk_table.add_row("1", "Block Devices (lsblk)")
    disk_table.add_row("2", "Disk Space Usage (df -h)")
    disk_table.add_row("3", "Disk I/O Stats (iostat)")
    disk_table.add_row("4", "SMART Health Status")
    disk_table.add_row("0", "Back")
    console.print(disk_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")
    if choice == "1":
        os.system("lsblk -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT")
    elif choice == "2":
        os.system("df -h --exclude-type=tmpfs --exclude-type=devtmpfs")
    elif choice == "3":
        if shutil.which("iostat"):
            os.system("iostat -xh 1 3")
        else:
            console.print("[yellow]iostat not found. Install with: sudo apt install sysstat[/yellow]")
    elif choice == "4":
        if shutil.which("smartctl"):
            disk_dev = Prompt.ask("[cyan]Device (e.g. /dev/sda)[/cyan]", default="/dev/sda")
            os.system(f"sudo smartctl -H {disk_dev}")
        else:
            console.print("[yellow]smartctl not found. Install with: sudo apt install smartmontools[/yellow]")
    elif choice == "0":
        return
    press_enter()

# ------------------------------------------------
# 10. CLEAN CACHES & TRASH
# ------------------------------------------------

def clean_temp():
    show_header()
    console.print(Panel("[bold]Clean System Caches & Trash[/bold]", border_style="red"))

    console.print("[dim]This will clear: user cache, thumbnails, apt cache, old journals, trash.[/dim]")
    if not Confirm.ask("Are you sure?", default=False):
        console.print("Operation cancelled.")
        press_enter()
        return

    home = os.path.expanduser("~")
    steps = [
        ("Clearing thumbnail cache...", f"rm -rf {home}/.cache/thumbnails/* 2>/dev/null"),
        ("Emptying trash...", f"rm -rf {home}/.local/share/Trash/files/* {home}/.local/share/Trash/info/* 2>/dev/null"),
        ("Cleaning APT cache...", "sudo apt-get clean"),
        ("Vacuuming journal logs (keeping last 3 days)...", "sudo journalctl --vacuum-time=3d"),
        ("Clearing font cache...", "fc-cache -f 2>/dev/null"),
    ]

    for msg, cmd in steps:
        console.print(f"[cyan]{msg}[/cyan]")
        run_cmd(cmd)

    console.print("[green]Cleanup completed.[/green]")
    press_enter()

# ------------------------------------------------
# 11. CHANGE DNS
# ------------------------------------------------

def change_dns():
    show_header()
    console.print(Panel("[bold]DNS Settings[/bold]", border_style="red"))

    console.print("[cyan]Current DNS servers:[/cyan]")
    current = run_cmd("grep '^nameserver' /etc/resolv.conf 2>/dev/null", capture=True)
    console.print(current if current else "  (none found)")
    console.print()

    dns_table = Table(show_header=True, box=box.SIMPLE, border_style="red")
    dns_table.add_column("IP", style="bold white")
    dns_table.add_column("Provider", style="cyan")
    dns_table.add_row("1.1.1.1", "Cloudflare")
    dns_table.add_row("8.8.8.8", "Google")
    dns_table.add_row("9.9.9.9", "Quad9")
    dns_table.add_row("208.67.222.222", "OpenDNS")
    console.print(dns_table)

    new_dns = Prompt.ask("[cyan]Enter new DNS IP (leave empty to cancel)[/cyan]", default="")
    if new_dns:
        import re
        if not re.match(r"^(\d{1,3}\.){3}\d{1,3}$", new_dns):
            console.print("[red]Invalid IP address format.[/red]")
            press_enter()
            return
        run_cmd("sudo chattr -i /etc/resolv.conf 2>/dev/null")
        run_cmd(f"echo 'nameserver {new_dns}' | sudo tee /etc/resolv.conf > /dev/null")
        run_cmd("sudo chattr +i /etc/resolv.conf")
        console.print(f"[green]DNS set to {new_dns} (file locked against NetworkManager overrides).[/green]")
    press_enter()

# ------------------------------------------------
# 12. CHANGE HOSTNAME
# ------------------------------------------------

def change_hostname():
    show_header()
    console.print(Panel("[bold]Hostname Settings[/bold]", border_style="red"))

    current = run_cmd("hostname", capture=True)
    console.print(f"[cyan]Current hostname:[/cyan] {current}")
    console.print()

    new_host = Prompt.ask("[cyan]Enter new hostname (leave empty to cancel)[/cyan]", default="")
    if new_host:
        import re
        if not re.match(r"^[a-zA-Z0-9]([a-zA-Z0-9\-]*[a-zA-Z0-9])?$", new_host):
            console.print("[red]Invalid hostname. Use only letters, numbers and hyphens.[/red]")
            press_enter()
            return
        run_cmd(f"sudo hostnamectl set-hostname {new_host}")
        run_cmd(f"sudo sed -i 's/\\b{current}\\b/{new_host}/g' /etc/hosts")
        console.print(f"[green]Hostname changed to '{new_host}'. Re-login to see the effect.[/green]")
    press_enter()

