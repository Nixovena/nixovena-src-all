# ------------------------------------------------

def firewall_manager():
    show_header()
    console.print(Panel("[bold]Firewall Manager[/bold]", border_style="red"))

    if not shutil.which("ufw"):
        console.print("[red]UFW is not installed. Install with: sudo apt install ufw[/red]")
        press_enter()
        return

    fw_table = Table(show_header=False, box=box.SIMPLE)
    fw_table.add_column("No", style="bold red", width=4)
    fw_table.add_column("Option", style="white")
    fw_table.add_row("1", "Show firewall status")
    fw_table.add_row("2", "Enable firewall")
    fw_table.add_row("3", "Disable firewall")
    fw_table.add_row("4", "Allow a port")
    fw_table.add_row("5", "Deny a port")
    fw_table.add_row("6", "List rules")
    fw_table.add_row("7", "Reset firewall rules")
    fw_table.add_row("0", "Back")
    console.print(fw_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")
    if choice == "1":
        os.system("sudo ufw status verbose")
    elif choice == "2":
        run_cmd_live("sudo ufw --force enable")
        console.print("[green]Firewall enabled.[/green]")
    elif choice == "3":
        run_cmd_live("sudo ufw disable")
        console.print("[green]Firewall disabled.[/green]")
    elif choice == "4":
        port = Prompt.ask("[cyan]Port to allow (e.g. 22, 80/tcp)[/cyan]", default="")
        if port:
            run_cmd_live(f"sudo ufw allow {port}")
    elif choice == "5":
        port = Prompt.ask("[cyan]Port to deny[/cyan]", default="")
        if port:
            run_cmd_live(f"sudo ufw deny {port}")
    elif choice == "6":
        os.system("sudo ufw status numbered")
    elif choice == "7":
        if Confirm.ask("Reset all firewall rules?", default=False):
            run_cmd_live("sudo ufw --force reset")
            console.print("[green]Firewall rules reset.[/green]")

    if choice != "0":
        press_enter()

# ------------------------------------------------
# 19. SWAP MANAGER
# ------------------------------------------------

def swap_manager():
    show_header()
    console.print(Panel("[bold]Swap Manager[/bold]", border_style="red"))

    console.print("[cyan]Current swap status:[/cyan]")
    os.system("swapon --show")
    console.print()

    swap_table = Table(show_header=False, box=box.SIMPLE)
    swap_table.add_column("No", style="bold red", width=4)
    swap_table.add_column("Option", style="white")
    swap_table.add_row("1", "Create swap file (2GB)")
    swap_table.add_row("2", "Create swap file (4GB)")
    swap_table.add_row("3", "Create swap file (8GB)")
    swap_table.add_row("4", "Remove swap file")
    swap_table.add_row("5", "Set swappiness value")
    swap_table.add_row("6", "Show current swappiness")
    swap_table.add_row("0", "Back")
    console.print(swap_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")

    def create_swap(size_gb):
        if not require_root():
            return
        swapfile = "/swapfile"
        if os.path.exists(swapfile):
            console.print("[yellow]Swap file already exists. Remove it first.[/yellow]")
            return
        console.print(f"[cyan]Creating {size_gb}GB swap file...[/cyan]")
        run_cmd_live(f"fallocate -l {size_gb}G {swapfile}")
        run_cmd(f"chmod 600 {swapfile}")
        run_cmd_live(f"mkswap {swapfile}")
        run_cmd_live(f"swapon {swapfile}")
        run_cmd(f"echo '{swapfile} none swap sw 0 0' | sudo tee -a /etc/fstab > /dev/null")
        console.print(f"[green]{size_gb}GB swap file created and activated.[/green]")

    if choice == "1":
        create_swap(2)
    elif choice == "2":
        create_swap(4)
    elif choice == "3":
        create_swap(8)
    elif choice == "4":
        if os.path.exists("/swapfile"):
            run_cmd_live("sudo swapoff /swapfile")
            run_cmd("sudo rm -f /swapfile")
            run_cmd("sudo sed -i '/\\/swapfile/d' /etc/fstab")
            console.print("[green]Swap file removed.[/green]")
        else:
            console.print("[yellow]No swap file found at /swapfile.[/yellow]")
    elif choice == "5":
        current = run_cmd("cat /proc/sys/vm/swappiness", capture=True)
        console.print(f"[dim]Current swappiness: {current}[/dim]")
        val = Prompt.ask("[cyan]New swappiness value (0-100)[/cyan]", default="60")
        run_cmd(f"sudo sysctl vm.swappiness={val}")
        run_cmd(f"sudo sed -i '/vm.swappiness/d' /etc/sysctl.conf")
        run_cmd(f"echo 'vm.swappiness={val}' | sudo tee -a /etc/sysctl.conf > /dev/null")
        console.print(f"[green]Swappiness set to {val}.[/green]")
    elif choice == "6":
        val = run_cmd("cat /proc/sys/vm/swappiness", capture=True)
        console.print(f"[cyan]Current swappiness:[/cyan] {val}")
    elif choice == "0":
        return
    press_enter()

# ------------------------------------------------
# 20. UPDATE PYTHON LIBRARIES
# ------------------------------------------------

def update_python_libraries():
    show_header()
    console.print(Panel("[bold]Update Python Libraries[/bold]", border_style="red"))

    if not require_root():
        press_enter()
        return

    update_dir = "/usr/share/almighty"
    update_file = os.path.join(update_dir, "updates.txt")
    
    if not os.path.exists(update_dir):
        try:
            os.makedirs(update_dir, exist_ok=True)
        except Exception as e:
            console.print(f"[red]Error creating directory {update_dir}: {e}[/red]")
            press_enter()
            return

    console.print("[cyan]Checking for outdated Python packages...[/cyan]")
    run_cmd(f"pip list --outdated | awk 'NR>2 {{print $1}}' > {update_file}")

    if not os.path.exists(update_file) or os.path.getsize(update_file) == 0:
        console.print("[green]All Python libraries are up to date.[/green]")
        if os.path.exists(update_file):
            os.remove(update_file)
        press_enter()
        return

    with open(update_file, "r") as f:
        packages = f.read().splitlines()

    console.print(f"[yellow]Found {len(packages)} outdated packages.[/yellow]")
    if Confirm.ask("Do you want to upgrade them now?", default=True):
        console.print("[cyan]Upgrading packages...[/cyan]")
        run_cmd_live(f"pip install --upgrade -r {update_file} --break-system-packages")
        console.print("[green]Upgrade completed.[/green]")
    else:
        console.print("[dim]Upgrade cancelled.[/dim]")

    if os.path.exists(update_file):
        os.remove(update_file)
        console.print("[dim]Temporary update list removed.[/dim]")
    
    press_enter()

# ------------------------------------------------
# 20. HARDWARE DIAGNOSTICS
# ------------------------------------------------

def hardware_diagnostics():
    show_header()
    console.print(Panel("[bold]Hardware Diagnostics[/bold]", border_style="red"))

    hw_table = Table(show_header=False, box=box.SIMPLE)
    hw_table.add_column("No", style="bold red", width=4)
    hw_table.add_column("Option", style="white")
    hw_table.add_row("1", "CPU Information")
    hw_table.add_row("2", "Memory Details")
    hw_table.add_row("3", "PCI Devices")
    hw_table.add_row("4", "USB Devices")
    hw_table.add_row("5", "Sensors / Temperatures")
    hw_table.add_row("6", "Battery Status")
    hw_table.add_row("7", "Full Hardware Report (lshw)")
    hw_table.add_row("0", "Back")
    console.print(hw_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")
    if choice == "1":
        os.system("lscpu")
    elif choice == "2":
        os.system("free -h")
        console.print()
        os.system("sudo dmidecode -t memory 2>/dev/null | grep -E 'Size|Type|Speed|Manufacturer' | head -20")
    elif choice == "3":
        os.system("lspci")
    elif choice == "4":
        os.system("lsusb")
    elif choice == "5":
        if shutil.which("sensors"):
            os.system("sensors")
        else:
            console.print("[yellow]lm-sensors not found. Install with: sudo apt install lm-sensors[/yellow]")
    elif choice == "6":
        if os.path.exists("/sys/class/power_supply/BAT0"):
            status = run_cmd("cat /sys/class/power_supply/BAT0/status", capture=True)
            capacity = run_cmd("cat /sys/class/power_supply/BAT0/capacity", capture=True)
            console.print(f"[cyan]Status:[/cyan] {status}")
            console.print(f"[cyan]Capacity:[/cyan] {capacity}%")
        else:
            console.print("[dim]No battery detected (desktop system).[/dim]")
    elif choice == "7":
        os.system("sudo lshw -short 2>/dev/null | less")
    elif choice == "0":
        return
    press_enter()

# ------------------------------------------------
# ENTRY POINT
# ------------------------------------------------

def main():
    signal.signal(signal.SIGINT, lambda s, f: (console.print("\n[red]Interrupted.[/red]"), sys.exit(0)))

    while True:
        choice = show_menu()
        actions = {
            "1": system_update,
            "2": sys_info,
            "3": view_logs,
            "4": manage_services,
            "5": list_packages,
            "6": manage_network,
            "7": manage_users,
            "8": disk_info,
            "9": clean_temp,
            "10": change_dns,
            "11": change_hostname,
            "12": zram_manager,
            "13": kernel_params,
            "14": firewall_manager,
            "15": swap_manager,
            "16": hardware_diagnostics,
            "17": update_python_libraries,
            "0": lambda: (console.print("[green]Goodbye![/green]"), sys.exit(0)),
        }
        action = actions.get(choice)
        if action:
            action()
        else:
            console.print("[red]Invalid option.[/red]")
            time.sleep(1)

if __name__ == "__main__":
    main()