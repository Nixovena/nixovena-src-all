def kernel_params():
    show_header()
    console.print(Panel("[bold]Kernel Parameters[/bold]", border_style="red"))

    kern_table = Table(show_header=False, box=box.SIMPLE)
    kern_table.add_column("No", style="bold red", width=4)
    kern_table.add_column("Option", style="white")
    kern_table.add_row("1", "View all sysctl parameters")
    kern_table.add_row("2", "View network parameters")
    kern_table.add_row("3", "View security parameters")
    kern_table.add_row("4", "Set a sysctl parameter")
    kern_table.add_row("5", "Reload sysctl.conf")
    kern_table.add_row("0", "Back")
    console.print(kern_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")
    if choice == "1":
        os.system("sysctl -a 2>/dev/null | less")
    elif choice == "2":
        os.system("sysctl -a 2>/dev/null | grep -E '^net\\.' | less")
    elif choice == "3":
        os.system("sysctl -a 2>/dev/null | grep -E '^kernel\\.' | less")
    elif choice == "4":
        param = Prompt.ask("[cyan]Parameter (e.g. net.ipv4.ip_forward)[/cyan]", default="")
        value = Prompt.ask("[cyan]Value[/cyan]", default="")
        if param and value:
            run_cmd_live(f"sudo sysctl -w {param}={value}")
            console.print(f"[green]Set {param} = {value}[/green]")
    elif choice == "5":
        run_cmd_live("sudo sysctl -p")
        console.print("[green]sysctl.conf reloaded.[/green]")
    elif choice == "0":
        return
    press_enter()

