def zram_manager():
    show_header()
    console.print(Panel("[bold]ZRAM Manager[/bold]", border_style="red"))

    zram_table = Table(show_header=False, box=box.SIMPLE)
    zram_table.add_column("No", style="bold red", width=4)
    zram_table.add_column("Option", style="white")
    zram_table.add_row("1", "Install ZRAM tools")
    zram_table.add_row("2", "Enable ZRAM")
    zram_table.add_row("3", "Disable ZRAM")
    zram_table.add_row("4", "Status")
    zram_table.add_row("5", "About ZRAM")
    zram_table.add_row("0", "Back")
    console.print(zram_table)

    choice = Prompt.ask("[bold red]Select option[/bold red]", default="0")
    if choice == "1":
        run_cmd_live("sudo apt-get update && sudo apt-get install -y zram-tools")
        console.print("[green]ZRAM tools installed.[/green]")
    elif choice == "2":
        run_cmd_live("sudo systemctl enable zramswap && sudo systemctl start zramswap")
        console.print("[green]ZRAM enabled.[/green]")
    elif choice == "3":
        run_cmd_live("sudo systemctl stop zramswap && sudo systemctl disable zramswap")
        console.print("[green]ZRAM disabled.[/green]")
    elif choice == "4":
        status = run_cmd("systemctl is-active zramswap 2>/dev/null", capture=True)
        if status == "active":
            console.print("[green]Status: ACTIVE[/green]")
            os.system("zramctl 2>/dev/null || swapon --show")
        else:
            console.print("[red]Status: INACTIVE[/red]")
    elif choice == "5":
        console.print(Panel(
            "[white]ZRAM creates a compressed block device in RAM used as swap space.\n\n"
            "[cyan]Benefits:[/cyan]\n"
            "  - Much faster than disk swap\n"
            "  - Reduces SSD write cycles\n"
            "  - Effective on systems with 2-8 GB RAM\n\n"
            "Typical compression ratio: 2:1 to 3:1 (LZ4 algorithm)[/white]",
            border_style="red",
            title="About ZRAM"
        ))
    elif choice == "0":
        return
    press_enter()



