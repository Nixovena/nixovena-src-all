class AddressInvestigator:

    def __init__(self, http):
        self.http = http
        self.api = BlockchainAPI(http)
        self.risk = RiskAnalyzer()
        self.profiler = WalletProfiler()
        self.price = PriceFeed(http)
        self.sanctions = SanctionsCheck(http)
        self.ens = ENSResolver(http)
        self.counterparty = CounterpartyAnalyzer()
        self.cluster = ClusterAnalyzer()
        self.timing = TimingAnalyzer()

    def _fetch_txs(self, chain, address):
        if chain == "BTC":
            return self.api.get_btc_txs(address)
        if chain == "XRP":
            return self.api.get_xrp_txs(address)
        if chain == "TRX":
            return self.api.get_trx_txs(address)
        return []

    def investigate(self, address):
        Log.header("ADDRESS INTELLIGENCE")

        chain, addr_type = ChainValidator.identify(address)
        if not chain:
            Log.error(f"Unrecognized address format: {address}")
            return None

        Log.info(f"Target : {_c(C.WHITE, address)}")
        Log.info(f"Chain  : {_c(C.CYAN, CHAIN_NAMES.get(chain, chain))}")
        Log.info(f"Type   : {_c(C.GRAY, addr_type)}")

        entity = lookup_entity(address)
        if entity:
            name, category = entity
            cat_info = ENTITY_CATEGORIES.get(category, {})
            Log.warn(f"Known entity: {_c(C.ORANGE, name)} [{cat_info.get('label', category)}]")

        ens_name = None
        if chain == "ETH":
            ens_name = self.ens.reverse(address)
            if ens_name:
                Log.found("ENS", _c(C.PURPLE, ens_name))

        sanctioned = False
        try:
            sanctioned = self.sanctions.is_sanctioned(address)
        except Exception:
            sanctioned = False
        if sanctioned:
            Log.error(_c(C.RED, "OFAC SANCTIONED ADDRESS - HANDLE WITH CARE"))

        Log.subheader("Balance & Activity")
        addr_info = self.api.get_address(chain, address)
        if not addr_info:
            Log.error("Could not retrieve address data from any API")
            return None

        unit = chain
        balance = addr_info.get("balance", 0) or 0
        total_recv = addr_info.get("total_received", 0) or 0
        total_sent = addr_info.get("total_sent", 0) or 0

        price_info = None
        try:
            price_info = self.price.get_usd(chain)
        except Exception:
            price_info = None
        usd_balance = None
        if price_info and price_info.get("usd"):
            usd_balance = balance * price_info["usd"]

        Log.detail("Balance", f"{balance:.8f} {unit}" + (f"  ({_c(C.GREEN, f'${usd_balance:,.2f}')} USD)" if usd_balance is not None else ""))
        Log.detail("Total Received", f"{total_recv:.8f} {unit}")
        Log.detail("Total Sent", f"{total_sent:.8f} {unit}")
        Log.detail("Transactions", str(addr_info.get("tx_count", 0)))
        if addr_info.get("first_seen"):
            Log.detail("First Seen", addr_info["first_seen"])
        if addr_info.get("last_seen"):
            Log.detail("Last Seen", addr_info["last_seen"])
        if price_info and price_info.get("usd"):
            change = price_info.get("change_24h") or 0
            change_str = f"{change:+.2f}%"
            color = C.GREEN if change >= 0 else C.RED
            Log.detail("Market Price", f"${price_info['usd']:,.4f}  ({_c(color, change_str)} 24h)")
        Log.detail_last("Source", addr_info.get("source", "N/A"))

        if addr_info.get("tokens"):
            Log.subheader("Token Holdings")
            for tok in addr_info["tokens"][:15]:
                if chain == "ETH":
                    decimals = tok.get("decimals", 18)
                    raw_bal = tok.get("balance", 0)
                    try:
                        bal = float(raw_bal) / (10 ** decimals)
                    except Exception:
                        bal = 0
                else:
                    bal = tok.get("balance", 0)
                Log.detail(tok.get("symbol", "???"), f"{bal:.6f} ({tok.get('name', '')})")

        txs = self._fetch_txs(chain, address)
        if txs:
            Log.subheader("Recent Transactions")
            for i, tx in enumerate(txs[:12]):
                direction = tx.get("direction", "?")
                d_color = C.GREEN if direction == "incoming" else (C.RED if direction == "outgoing" else C.GRAY)
                ts_str = tx.get("timestamp") or "unconfirmed"
                if ts_str and ts_str != "unconfirmed":
                    try:
                        ts_str = datetime.fromisoformat(str(ts_str).replace("Z", "+00:00")).strftime("%Y-%m-%d %H:%M")
                    except Exception:
                        pass
                Log.detail(
                    f"TX {i+1}",
                    f"{_c(d_color, direction):>10s}  "
                    f"{tx.get('total_output', 0):.8f} {unit}  "
                    f"fee={tx.get('fee', 0):.8f}  "
                    f"{ts_str}  "
                    f"{(tx.get('txid', '') or '')[:16]}..."
                )
            if len(txs) > 12:
                Log.info(f"... and {len(txs) - 12} more transactions")

        token_transfers = []
        if chain == "ETH":
            try:
                token_transfers = self.api.get_eth_token_transfers(address)
            except Exception:
                token_transfers = []
            if token_transfers:
                Log.subheader("Recent Token Transfers")
                for i, op in enumerate(token_transfers[:10]):
                    direction = op.get("direction", "?")
                    d_color = C.GREEN if direction == "incoming" else C.RED
                    ts_str = op.get("timestamp") or ""
                    if ts_str:
                        try:
                            ts_str = datetime.fromisoformat(str(ts_str).replace("Z", "+00:00")).strftime("%Y-%m-%d %H:%M")
                        except Exception:
                            pass
                    Log.detail(
                        f"TT {i+1}",
                        f"{_c(d_color, direction):>10s}  "
                        f"{op.get('value', 0):.6f} {op.get('symbol', '?')}  "
                        f"{ts_str}  "
                        f"{(op.get('txid', '') or '')[:16]}..."
                    )

        Log.subheader("Risk Assessment")
        risk_result = self.risk.score_address(addr_info, txs)
        if sanctioned and "OFAC sanctioned (live feed)" not in risk_result["indicators"]:
            risk_result["score"] = min(100, risk_result["score"] + 70)
            risk_result["indicators"].insert(0, "OFAC sanctioned (live feed)")
            if risk_result["score"] >= 50:
                risk_result["level"] = "CRITICAL"
        score = risk_result["score"]
        level = risk_result["level"]

        level_colors = {"CRITICAL": C.RED, "HIGH": C.ORANGE, "MEDIUM": C.YELLOW, "LOW": C.GREEN}
        Log.detail("Risk Score", f"{_c(level_colors.get(level, C.WHITE), str(score))}/100")
        Log.detail("Risk Level", _c(level_colors.get(level, C.WHITE), level))
        Log.risk_bar(score)

        if risk_result["indicators"]:
            for ind in risk_result["indicators"]:
                Log.detail("Indicator", _c(C.YELLOW, ind))
        else:
            Log.detail_last("Indicators", "No significant risk indicators detected")

        Log.subheader("Wallet Profile")
        profile_result = self.profiler.profile(addr_info, txs)
        Log.detail("Classification", _c(C.CYAN, profile_result["classification"]))
        if profile_result["behavior_tags"]:
            Log.detail("Tags", ", ".join(profile_result["behavior_tags"]))
        summary = profile_result.get("activity_summary", {})
        if summary.get("first_activity"):
            Log.detail("First Activity", summary["first_activity"])
        if summary.get("last_activity"):
            Log.detail("Last Activity", summary["last_activity"])
        if summary.get("active_days"):
            Log.detail("Active Span", f"{summary['active_days']} days")
        if summary.get("tx_per_day"):
            Log.detail("TX/Day", f"{summary['tx_per_day']:.4f}")
        if summary.get("incoming_txs") is not None:
            Log.detail("Incoming TXs", str(summary["incoming_txs"]))
            Log.detail_last("Outgoing TXs", str(summary["outgoing_txs"]))

        counterparty_result = self.counterparty.analyze(address, txs or [])
        if counterparty_result["unique_counterparties"] > 0:
            Log.subheader("Counterparties")
            Log.detail("Unique Counterparties", str(counterparty_result["unique_counterparties"]))
            if counterparty_result["top_senders"]:
                Log.info("Top Senders (by volume):")
                for cp in counterparty_result["top_senders"][:6]:
                    tag = f" [{_c(C.ORANGE, cp['entity'])}]" if cp.get("entity") else ""
                    Log.detail(cp["address"][:24] + "..." + tag, f"{cp['value']:.6f} {unit}")
            if counterparty_result["top_receivers"]:
                Log.info("Top Receivers (by volume):")
                for cp in counterparty_result["top_receivers"][:6]:
                    tag = f" [{_c(C.ORANGE, cp['entity'])}]" if cp.get("entity") else ""
                    Log.detail(cp["address"][:24] + "..." + tag, f"{cp['value']:.6f} {unit}")

        cluster_result = None
        if chain == "BTC":
            cluster_result = self.cluster.analyze(address, txs or [])
            if cluster_result["cluster_size"] > 0:
                Log.subheader("Address Cluster (Common-Input-Ownership)")
                Log.detail("Cluster Size", str(cluster_result["cluster_size"]))
                Log.detail("Evidence TXs", str(cluster_result["evidence_txs"]))
                for entry in cluster_result["sample"][:8]:
                    tag = f" [{_c(C.ORANGE, entry['entity'])}]" if entry.get("entity") else ""
                    Log.detail("Linked", entry["address"][:32] + "..." + tag)

        timing_result = self.timing.analyze(txs or [])
        if any(timing_result.get("hours", [])):
            Log.subheader("Activity Timing")
            hours = timing_result["hours"]
            mx = max(hours) or 1
            bars = "".join(
                C.GREEN + "#" + C.RST if hours[h] == mx else
                (C.YELLOW + "+" + C.RST if hours[h] > mx * 0.5 else
                 (C.GRAY + "." + C.RST if hours[h] > 0 else " "))
                for h in range(24)
            )
            Log.detail("Hours (UTC)", f"00 {bars} 23")
            if timing_result.get("peak_hour_utc") is not None:
                Log.detail("Peak Hour (UTC)", f"{timing_result['peak_hour_utc']:02d}:00")
            if timing_result.get("likely_tz_offset") is not None:
                sign = "+" if timing_result["likely_tz_offset"] >= 0 else ""
                Log.detail("Inferred TZ", f"UTC{sign}{timing_result['likely_tz_offset']}")
            Log.detail_last("Burstiness", f"{timing_result['burstiness']}")

        return {
            "target": address,
            "chain": chain,
            "ens": ens_name,
            "sanctioned": sanctioned,
            "address_info": addr_info,
            "price": price_info,
            "usd_balance": usd_balance,
            "risk": risk_result,
            "profile": profile_result,
            "transactions": txs,
            "token_transfers": token_transfers,
            "counterparties": counterparty_result,
            "cluster": cluster_result,
            "timing": timing_result,
        }


class TransactionInvestigator:

    def __init__(self, http):
        self.api = BlockchainAPI(http)

    def investigate(self, txid):
        Log.header("TRANSACTION TRACE")
        Log.info(f"TXID: {_c(C.WHITE, txid)}")

        tx = self.api.get_btc_tx(txid)
        if not tx:
            Log.error("Could not retrieve transaction data")
            return None

        status = tx.get("status", {})
        confirmed = status.get("confirmed", False)
        block_height = status.get("block_height", 0)
        block_time = status.get("block_time", 0)

        total_in = sum(v.get("prevout", {}).get("value", 0) for v in tx.get("vin", []))
        total_out = sum(v.get("value", 0) for v in tx.get("vout", []))
        fee = total_in - total_out if total_in > 0 else 0

        Log.subheader("Transaction Overview")
        Log.detail("TXID", txid)
        Log.detail("Confirmed", str(confirmed))
        if block_height:
            Log.detail("Block", str(block_height))
        if block_time:
            Log.detail("Time", datetime.fromtimestamp(block_time, tz=timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC"))
        Log.detail("Total Input", f"{total_in / SAT_PER_BTC:.8f} BTC")
        Log.detail("Total Output", f"{total_out / SAT_PER_BTC:.8f} BTC")
        Log.detail("Fee", f"{fee / SAT_PER_BTC:.8f} BTC ({fee} sat)")
        Log.detail("Input Count", str(len(tx.get("vin", []))))
        Log.detail_last("Output Count", str(len(tx.get("vout", []))))

        Log.subheader("Inputs")
        for i, vin in enumerate(tx.get("vin", [])[:15]):
            prevout = vin.get("prevout", {})
            addr = prevout.get("scriptpubkey_address", "coinbase" if vin.get("is_coinbase") else "unknown")
            val = prevout.get("value", 0) / SAT_PER_BTC
            entity = lookup_entity(addr)
            tag = f" [{entity[0]}]" if entity else ""
            Log.detail(f"IN  {i+1}", f"{addr}{_c(C.ORANGE, tag)}  {val:.8f} BTC")

        Log.subheader("Outputs")
        outputs = tx.get("vout", [])
        for i, vout in enumerate(outputs[:15]):
            addr = vout.get("scriptpubkey_address", "unknown")
            val = vout.get("value", 0) / SAT_PER_BTC
            spent = ""
            entity = lookup_entity(addr)
            tag = f" [{entity[0]}]" if entity else ""
            Log.detail(f"OUT {i+1}", f"{addr}{_c(C.ORANGE, tag)}  {val:.8f} BTC")

        Log.subheader("Flow Analysis")
        n_in = len(tx.get("vin", []))
        n_out = len(outputs)
        if n_in > 5 and n_out <= 2:
            Log.warn("Pattern: UTXO Consolidation (many inputs -> few outputs)")
        elif n_in <= 2 and n_out > 5:
            Log.warn("Pattern: Distribution/Payment (few inputs -> many outputs)")
        elif n_in >= 3 and n_out >= 3:
            output_vals = [v.get("value", 0) for v in outputs]
            unique_vals = len(set(output_vals))
            if unique_vals <= 2:
                Log.warn("Pattern: Possible CoinJoin/Mixing (equal outputs)")
            else:
                Log.info("Pattern: Standard multi-party transaction")
        else:
            Log.info("Pattern: Standard transaction")

        if n_out >= 2:
            vals = [(v.get("scriptpubkey_address", ""), v.get("value", 0)) for v in outputs]
            vals.sort(key=lambda x: x[1], reverse=True)
            if len(vals) >= 2:
                Log.detail("Likely Payment", f"{vals[-1][0]}  ({vals[-1][1] / SAT_PER_BTC:.8f} BTC)")
                Log.detail_last("Likely Change", f"{vals[0][0]}  ({vals[0][1] / SAT_PER_BTC:.8f} BTC)")

        return {
            "txid": txid,
            "confirmed": confirmed,
            "block_height": block_height,
            "timestamp": datetime.fromtimestamp(block_time, tz=timezone.utc).isoformat() if block_time else None,
            "total_input": total_in / SAT_PER_BTC,
            "total_output": total_out / SAT_PER_BTC,
            "fee": fee / SAT_PER_BTC,
            "input_count": n_in,
            "output_count": n_out,
        }


class MultiAddressAnalyzer:

    def __init__(self, http):
        self.investigator = AddressInvestigator(http)

    def analyze(self, addresses):
        Log.header("MULTI-ADDRESS ANALYSIS")
        Log.info(f"Analyzing {len(addresses)} addresses...")

        results = []
        for i, addr in enumerate(addresses):
            Log.info(f"[{i+1}/{len(addresses)}] {addr}")
            result = self.investigator.investigate(addr)
            if result:
                results.append(result)
            print()

        if len(results) < 2:
            return results

        Log.header("CROSS-ADDRESS CORRELATION")

        Log.subheader("Risk Comparison")
        for r in sorted(results, key=lambda x: x["risk"]["score"], reverse=True):
            addr = r["target"][:20] + "..."
            score = r["risk"]["score"]
            level = r["risk"]["level"]
            chain = r["chain"]
            level_colors = {"CRITICAL": C.RED, "HIGH": C.ORANGE, "MEDIUM": C.YELLOW, "LOW": C.GREEN}
            Log.detail(addr, f"{chain} | Score: {_c(level_colors.get(level, C.WHITE), str(score))} | {level}")

        Log.subheader("Common Entity Check")
        entities_found = {}
        for r in results:
            entity = lookup_entity(r["target"])
            if entity:
                entities_found[r["target"]] = entity
        if entities_found:
            for addr, (name, cat) in entities_found.items():
                Log.detail(addr[:20] + "...", f"{name} ({cat})")
        else:
            Log.info("No addresses matched known entities")

        return results

def build_parser():
    p = argparse.ArgumentParser(
        prog="deepchaintk",
        description=f"DeepChainTK v{VERSION} - Blockchain Forensics & Crypto OSINT",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
Examples:
  deepchaintk -a 1A1zP1eP5QGefi2DMPTfTL5SLmv7DivfNa   Investigate BTC address
  deepchaintk -a 0x742d35Cc6634C0532925a3b844Bc9e7595f  Investigate ETH address
  deepchaintk -t <txid>                             Trace BTC transaction
  deepchaintk -a addr1 addr2 addr3                  Multi-address analysis
  deepchaintk -a <address> --export all             Export all report formats
  deepchaintk -g <address>                          Google dork generator
  deepchaintk -v <address>                          Validate address format

Supported Chains: BTC, ETH, LTC, DOGE, DASH, XRP, TRX, BCH

Intelligence Modules:
  - Multi-API balance & tx aggregation (Blockstream / mempool.space / blockchain.info / Blockchair / Ethplorer / Tronscan / XRPScan)
  - OFAC live sanctions check + curated entity database (exchanges, mixers, ransomware, darknet, Lazarus, Tornado Cash)
  - Counterparty analysis (top senders/receivers by volume, entity tagging)
  - Common-input-ownership clustering (BTC)
  - Activity timing fingerprint (hourly heatmap + timezone inference + burstiness)
  - Risk scoring: mixing, peel-chain, round amounts, rapid movement, consolidation, dust attack, dormancy break
  - Wallet behavior profiler (HODLer / accumulator / pass-through / service / trader)
  - Live USD pricing & 24h change (CoinGecko)
  - ENS reverse resolution for ETH
  - ERC-20 token holdings + recent token transfers
  - Google dorks (Reddit, Bitcointalk, Telegram, GitHub, paste sites, breach forums, Wayback, abuse DBs)
  - JSON / TXT / HTML investigation reports

Developed by emka'thas | For legal and ethical use only.
        """,
    )
    p.add_argument("-a", "--address", nargs="+", help="Address(es) to investigate")
    p.add_argument("-t", "--transaction", type=str, help="BTC transaction hash to trace")
    p.add_argument("-g", "--dorks", type=str, help="Generate Google dorks for target")
    p.add_argument("-v", "--validate", type=str, help="Validate address format")
    p.add_argument("--export", type=str, choices=["json", "txt", "html", "all"], help="Export report format")
    p.add_argument("--version", action="version", version=f"DeepChainTK v{VERSION}")
    return p


def cli_main():
    parser = build_parser()
    args = parser.parse_args()

    if len(sys.argv) == 1:
        parser.print_help()
        return

    print(BANNER)
    http = HTTPClient()
    result = None

    if args.validate:
        chain, addr_type = ChainValidator.identify(args.validate)
        if chain:
            Log.success(f"Valid {CHAIN_NAMES.get(chain, chain)} address ({addr_type})")
            entity = lookup_entity(args.validate)
            if entity:
                Log.detail("Entity", f"{entity[0]} ({entity[1]})")
        else:
            Log.error("Unrecognized address format")
        return

    if args.dorks:
        chain, _ = ChainValidator.identify(args.dorks)
        DorkGenerator.generate(args.dorks, chain or "BTC")
        return

    if args.transaction:
        inv = TransactionInvestigator(http)
        result = inv.investigate(args.transaction)

    elif args.address:
        if len(args.address) == 1:
            inv = AddressInvestigator(http)
            result = inv.investigate(args.address[0])
        else:
            analyzer = MultiAddressAnalyzer(http)
            results = analyzer.analyze(args.address)
            result = {"multi_analysis": True, "results": results, "target": "multi"}

    else:
        parser.print_help()
        return

    if result and args.export:
        target = result.get("target", "output")
        paths = []
        if args.export in ("json", "all"):
            paths.append(ReportExporter.export_json(result, target))
        if args.export in ("txt", "all"):
            paths.append(ReportExporter.export_txt(result, target))
        if args.export in ("html", "all"):
            paths.append(ReportExporter.export_html(result, target))
        for p in paths:
            Log.success(f"Saved: {p}")


def main():
    try:
        cli_main()
    except KeyboardInterrupt:
        print(f"\n  {C.GRAY}Exiting...{C.RST}")
        sys.exit(0)


if __name__ == "__main__":
    main()