        return [{"query": q, "desc": d} for q, d in dorks] + [{"url": u, "desc": d} for u, d in direct_links]


class ReportExporter:

    @staticmethod
    def ensure_dir():
        os.makedirs(REPORT_DIR, exist_ok=True)

    @staticmethod
    def export_json(data, target):
        ReportExporter.ensure_dir()
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        safe = re.sub(r'[^\w\-.]', '_', target)[:40]
        path = os.path.join(REPORT_DIR, f"deepchain_{safe}_{ts}.json")
        with open(path, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2, ensure_ascii=False, default=str)
        return path

    @staticmethod
    def export_txt(data, target):
        ReportExporter.ensure_dir()
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        safe = re.sub(r'[^\w\-.]', '_', target)[:40]
        path = os.path.join(REPORT_DIR, f"deepchain_{safe}_{ts}.txt")
        lines = [
            "=" * 60,
            f"  DeepChainTK v{VERSION} - Investigation Report",
            "=" * 60,
            f"  Target    : {data.get('target', target)}",
            f"  Chain     : {data.get('chain', 'N/A')}",
            f"  Generated : {datetime.now().isoformat()}",
            "=" * 60, "",
        ]
        addr = data.get("address_info", {})
        if addr:
            lines.append(f"Balance       : {addr.get('balance', 0)}")
            if data.get("usd_balance") is not None:
                lines.append(f"USD Value     : ${data['usd_balance']:,.2f}")
            lines.append(f"Total Recv    : {addr.get('total_received', 0)}")
            lines.append(f"Total Sent    : {addr.get('total_sent', 0)}")
            lines.append(f"TX Count      : {addr.get('tx_count', 0)}")
            if data.get("ens"):
                lines.append(f"ENS           : {data['ens']}")
            if data.get("sanctioned"):
                lines.append("Sanctions     : *** OFAC SANCTIONED ***")
            lines.append("")
        risk = data.get("risk", {})
        if risk:
            lines.append(f"Risk Score    : {risk.get('score', 0)}/100")
            lines.append(f"Risk Level    : {risk.get('level', 'N/A')}")
            for ind in risk.get("indicators", []):
                lines.append(f"  - {ind}")
            lines.append("")
        profile_data = data.get("profile", {})
        if profile_data:
            lines.append(f"Classification: {profile_data.get('classification', 'N/A')}")
            lines.append(f"Tags          : {', '.join(profile_data.get('behavior_tags', []))}")
            lines.append("")
        cp = data.get("counterparties") or {}
        if cp.get("unique_counterparties"):
            lines.append(f"Counterparties: {cp['unique_counterparties']} unique")
            for s in (cp.get("top_senders") or [])[:5]:
                tag = f" [{s['entity']}]" if s.get("entity") else ""
                lines.append(f"  <- {s['address']}{tag}  {s['value']:.6f}")
            for r in (cp.get("top_receivers") or [])[:5]:
                tag = f" [{r['entity']}]" if r.get("entity") else ""
                lines.append(f"  -> {r['address']}{tag}  {r['value']:.6f}")
            lines.append("")
        cluster = data.get("cluster") or {}
        if cluster.get("cluster_size"):
            lines.append(f"Cluster Size  : {cluster['cluster_size']} ({cluster.get('evidence_txs', 0)} evidence txs)")
            for entry in (cluster.get("sample") or [])[:8]:
                tag = f" [{entry['entity']}]" if entry.get("entity") else ""
                lines.append(f"  ~ {entry['address']}{tag}")
            lines.append("")
        timing = data.get("timing") or {}
        if timing.get("peak_hour_utc") is not None:
            lines.append(f"Peak Hour     : {timing['peak_hour_utc']:02d}:00 UTC")
            if timing.get("likely_tz_offset") is not None:
                sign = "+" if timing["likely_tz_offset"] >= 0 else ""
                lines.append(f"Inferred TZ   : UTC{sign}{timing['likely_tz_offset']}")
            lines.append(f"Burstiness    : {timing.get('burstiness', 0)}")
            lines.append("")
        with open(path, "w", encoding="utf-8") as f:
            f.write("\n".join(lines))
        return path

    @staticmethod
    def export_html(data, target):
        ReportExporter.ensure_dir()
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        safe = re.sub(r'[^\w\-.]', '_', target)[:40]
        path = os.path.join(REPORT_DIR, f"deepchain_{safe}_{ts}.html")
        addr = data.get("address_info", {})
        risk = data.get("risk", {})
        profile_data = data.get("profile", {})
        score = risk.get("score", 0)
        level = risk.get("level", "LOW")
        level_color = {"CRITICAL": "#ff5555", "HIGH": "#ffb86c", "MEDIUM": "#f1fa8c", "LOW": "#50fa7b"}.get(level, "#50fa7b")
        indicators_html = "".join(f"<li>{i}</li>" for i in risk.get("indicators", []))
        tokens_html = ""
