class Log:

    @staticmethod
    def info(msg):
        print(f"  {C.BLUE}[*]{C.RST} {msg}")

    @staticmethod
    def success(msg):
        print(f"  {C.GREEN}[+]{C.RST} {msg}")

    @staticmethod
    def warn(msg):
        print(f"  {C.YELLOW}[!]{C.RST} {msg}")

    @staticmethod
    def error(msg):
        print(f"  {C.RED}[-]{C.RST} {msg}")

    @staticmethod
    def found(source, details=""):
        extra = f" - {details}" if details else ""
        print(f"  {C.GREEN}[+]{C.RST} {C.WHITE}{source}{C.RST}{extra}")

    @staticmethod
    def header(title):
        w = 55
        print()
        print(f"  {C.PINK}{'=' * w}{C.RST}")
        print(f"  {C.PINK}|{C.RST}  {C.BOLD}{C.WHITE}{title}{C.RST}")
        print(f"  {C.PINK}{'=' * w}{C.RST}")

    @staticmethod
    def subheader(title):
        print(f"\n  {C.PURPLE}-- {title} --{C.RST}")

    @staticmethod
    def detail(key, value, indent=2):
        pad = "  " * indent
        print(f"{pad}{C.GRAY}|-- {C.CYAN}{key}{C.RST}: {value}")

    @staticmethod
    def detail_last(key, value, indent=2):
        pad = "  " * indent
        print(f"{pad}{C.GRAY}\\-- {C.CYAN}{key}{C.RST}: {value}")

    @staticmethod
    def risk_bar(score, max_score=100):
        bar_len = 20
        filled = min(bar_len, int(bar_len * score / max_score))
        if score >= 50:
            color = C.RED
        elif score >= 25:
            color = C.YELLOW
        else:
            color = C.GREEN
        bar = f"{color}{'#' * filled}{C.DARK}{'.' * (bar_len - filled)}{C.RST}"
        print(f"    {bar} {score}/{max_score}")


