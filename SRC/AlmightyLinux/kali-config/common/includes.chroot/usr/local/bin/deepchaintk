                for h in range(24)
            )
            hours_html = f'<div style="display:flex;align-items:flex-end;height:44px">{bar_cells}</div><div style="display:flex;justify-content:space-between;color:var(--dim);font-size:.7rem">00<span>06</span><span>12</span><span>18</span>23</div>'
        ens_html = f'<tr><td>ENS</td><td><strong>{data.get("ens")}</strong></td></tr>' if data.get("ens") else ""
