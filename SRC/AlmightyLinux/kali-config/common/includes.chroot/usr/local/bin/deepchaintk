        usd_html = f'<tr><td>USD Value</td><td>${data["usd_balance"]:,.2f}</td></tr>' if data.get("usd_balance") is not None else ""
        price = data.get("price") or {}
        price_html = ""
        if price.get("usd"):
            change = price.get("change_24h") or 0
            ccolor = "#50fa7b" if change >= 0 else "#ff5555"
            price_html = f'<tr><td>Market Price</td><td>${price["usd"]:,.4f} <span style="color:{ccolor}">({change:+.2f}% 24h)</span></td></tr>'
        html = f"""<!DOCTYPE html>
