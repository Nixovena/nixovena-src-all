class ChainValidator:

    BTC_P2PKH = re.compile(r'^[1][a-km-zA-HJ-NP-Z1-9]{25,34}$')
    BTC_P2SH = re.compile(r'^[3][a-km-zA-HJ-NP-Z1-9]{25,34}$')
    BTC_BECH32 = re.compile(r'^bc1[a-z0-9]{39,59}$')
    ETH_ADDR = re.compile(r'^0x[a-fA-F0-9]{40}$')
    LTC_LEGACY = re.compile(r'^[LM][a-km-zA-HJ-NP-Z1-9]{25,34}$')
    LTC_BECH32 = re.compile(r'^ltc1[a-z0-9]{39,59}$')
    DOGE_ADDR = re.compile(r'^D[5-9A-HJ-NP-U][1-9A-HJ-NP-Za-km-z]{32}$')
    DASH_ADDR = re.compile(r'^X[1-9A-HJ-NP-Za-km-z]{33}$')
    XRP_ADDR = re.compile(r'^r[0-9a-zA-Z]{24,34}$')
    TRX_ADDR = re.compile(r'^T[a-zA-Z0-9]{33}$')
    BCH_CASH = re.compile(r'^(bitcoincash:)?[qp][a-z0-9]{41}$')

    @staticmethod
    def identify(address):
        addr = address.strip()
        if ChainValidator.BTC_P2PKH.match(addr):
            return "BTC", "P2PKH (Legacy)"
        if ChainValidator.BTC_P2SH.match(addr):
            return "BTC", "P2SH (SegWit-compatible)"
        if ChainValidator.BTC_BECH32.match(addr):
            return "BTC", "Bech32 (Native SegWit)"
        if ChainValidator.ETH_ADDR.match(addr):
            return "ETH", "Ethereum"
        if ChainValidator.LTC_LEGACY.match(addr):
            return "LTC", "Litecoin Legacy"
        if ChainValidator.LTC_BECH32.match(addr):
            return "LTC", "Litecoin Bech32"
        if ChainValidator.DOGE_ADDR.match(addr):
            return "DOGE", "Dogecoin"
        if ChainValidator.DASH_ADDR.match(addr):
            return "DASH", "Dash"
        if ChainValidator.XRP_ADDR.match(addr):
            return "XRP", "Ripple"
        if ChainValidator.TRX_ADDR.match(addr):
            return "TRX", "Tron"
        if ChainValidator.BCH_CASH.match(addr):
            return "BCH", "Bitcoin Cash"
        return None, None


class HTTPClient:

    def __init__(self, base_delay=1.5, max_delay=30, backoff=2.0):
        self._delay = base_delay
        self._base = base_delay
        self._max = max_delay
        self._backoff = backoff
        self._session = requests.Session()
        self._session.headers.update({
            "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:125.0) Gecko/20100101 Firefox/125.0",
            "Accept": "application/json",
        })

    def get(self, url, params=None, retries=2):
        for attempt in range(retries + 1):
            try:
                time.sleep(self._delay)
                resp = self._session.get(url, params=params, timeout=REQUEST_TIMEOUT)
                if resp.status_code == 200:
                    self._delay = self._base
                    return resp
                if resp.status_code == 429:
                    self._delay = min(self._delay * self._backoff, self._max)
                    if attempt < retries:
                        continue
                return resp
            except (requests.ConnectionError, requests.Timeout, requests.ReadTimeout):
                if attempt < retries:
                    self._delay = min(self._delay * self._backoff, self._max)
                    continue
            except Exception:
                return None
        return None

    def get_json(self, url, params=None):
        resp = self.get(url, params=params)
        if resp and resp.status_code == 200:
            try:
                return resp.json()
            except Exception:
                return None
        return None


class BlockchainAPI:

    def __init__(self, http):
        self.http = http

    def get_btc_address(self, address):
        data = self._blockstream_address(address)
        if data:
            return data
        data = self._mempool_address(address)
        if data:
            return data
        data = self._blockchain_info_address(address)
        if data:
            return data
        return None

    def get_btc_txs(self, address):
        txs = self._blockstream_txs(address)
        if txs is not None:
            return txs
        txs = self._mempool_txs(address)
        if txs is not None:
            return txs
        return []

    def get_btc_tx(self, txid):
        data = self.http.get_json(f"https://blockstream.info/api/tx/{txid}")
        if data:
            return data
        data = self.http.get_json(f"https://mempool.space/api/tx/{txid}")
        if data:
            return data
        return None

    def get_eth_address(self, address):
        data = self.http.get_json(
            "https://api.ethplorer.io/getAddressInfo/" + address,
            params={"apiKey": "freekey"}
        )
        if data and "error" not in data:
            return self._parse_ethplorer(data, address)

        data = self.http.get_json(
            f"https://api.blockchair.com/ethereum/dashboards/address/{address}"
        )
        if data and "data" in data:
            return self._parse_blockchair_eth(data, address)
        return None

    def get_ltc_address(self, address):
        return self._blockchair_address("litecoin", address)

    def get_doge_address(self, address):
        return self._blockchair_address("dogecoin", address)

    def get_dash_address(self, address):
        return self._blockchair_address("dash", address)

    def get_bch_address(self, address):
        return self._blockchair_address("bitcoin-cash", address)

    def get_xrp_address(self, address):
        data = self.http.get_json(f"https://api.xrpscan.com/api/v1/account/{address}")
        if data and isinstance(data, dict) and not data.get("error"):
            return {
                "address": address,
                "chain": "XRP",
                "balance": float(data.get("xrpBalance", 0) or 0),
                "total_received": 0,
                "total_sent": 0,
                "tx_count": data.get("transactionCount", 0) or 0,
                "first_seen": (data.get("inception") or "")[:10] or None,
                "parent_account": data.get("parentAccount"),
                "account_name": (data.get("accountName") or {}).get("name") if isinstance(data.get("accountName"), dict) else None,
                "source": "xrpscan",
            }
        return None

    def get_xrp_txs(self, address, limit=25):
        data = self.http.get_json(f"https://api.xrpscan.com/api/v1/account/{address}/transactions")
        if not data or not isinstance(data, dict):
            return []
        txs_raw = data.get("transactions") or []
        out = []
        for tx in txs_raw[:limit]:
            tx_obj = tx.get("tx") or tx
            ts = tx.get("date") or tx_obj.get("date")
            ttype = tx_obj.get("TransactionType", "")
            amt = tx_obj.get("Amount")
            try:
                value = float(amt) / 1_000_000 if isinstance(amt, (str, int, float)) else 0
            except Exception:
                value = 0
            src = tx_obj.get("Account", "")
            dst = tx_obj.get("Destination", "")
            direction = "incoming" if dst == address else ("outgoing" if src == address else "other")
            out.append({
                "txid": tx_obj.get("hash") or tx.get("hash", ""),
                "confirmed": True,
                "timestamp": ts,
                "type": ttype,
                "total_output": value,
                "fee": float(tx_obj.get("Fee", 0) or 0) / 1_000_000,
                "input_count": 1,
                "output_count": 1,
                "inputs": [{"address": src, "value": value}],
                "outputs": [{"address": dst, "value": value}],
                "direction": direction,
            })
        return out

    def get_trx_address(self, address):
        data = self.http.get_json(
            "https://apilist.tronscanapi.com/api/account",
            params={"address": address}
        )
        if data and isinstance(data, dict) and (data.get("address") or data.get("balance") is not None):
            balance = float(data.get("balance", 0) or 0) / 1_000_000
            tx_count = data.get("totalTransactionCount") or data.get("transactions") or 0
            tokens = []
            for tok in (data.get("trc20token_balances") or [])[:20]:
                try:
                    bal_raw = tok.get("balance") or "0"
                    dec = int(tok.get("tokenDecimal", 6))
                    bal = float(bal_raw) / (10 ** dec) if dec >= 0 else float(bal_raw)
                except Exception:
                    bal = 0
                tokens.append({
                    "symbol": tok.get("tokenAbbr", "?"),
                    "name": tok.get("tokenName", ""),
                    "balance": bal,
                    "decimals": int(tok.get("tokenDecimal", 6)),
                    "contract": tok.get("tokenId", ""),
                })
            created = data.get("date_created")
            first_seen = None
            if created:
                try:
                    first_seen = datetime.fromtimestamp(int(created) / 1000, tz=timezone.utc).strftime("%Y-%m-%d")
                except Exception:
                    first_seen = None
            return {
                "address": address,
                "chain": "TRX",
                "balance": balance,
                "total_received": float(data.get("totalReceived", 0) or 0) / 1_000_000,
                "total_sent": float(data.get("totalTransferOut", 0) or 0) / 1_000_000,
                "tx_count": tx_count,
                "first_seen": first_seen,
                "tokens": tokens,
                "source": "tronscan",
            }
        return None

    def get_trx_txs(self, address, limit=25):
        data = self.http.get_json(
            "https://apilist.tronscanapi.com/api/transaction",
            params={"address": address, "limit": limit, "sort": "-timestamp"}
        )
        if not data or not isinstance(data, dict):
            return []
        out = []
        for tx in (data.get("data") or [])[:limit]:
            ts = tx.get("timestamp")
            if ts:
                try:
                    ts_iso = datetime.fromtimestamp(int(ts) / 1000, tz=timezone.utc).isoformat()
                except Exception:
                    ts_iso = None
            else:
                ts_iso = None
            src = tx.get("ownerAddress", "")
            dst = tx.get("toAddress", "")
            amount = float(tx.get("amount", 0) or 0) / 1_000_000
            direction = "incoming" if dst == address else "outgoing"
            out.append({
                "txid": tx.get("hash", ""),
                "confirmed": tx.get("confirmed", True),
                "timestamp": ts_iso,
                "total_output": amount,
                "fee": float(tx.get("cost", {}).get("net_fee", 0) or 0) / 1_000_000 if isinstance(tx.get("cost"), dict) else 0,
                "input_count": 1,
                "output_count": 1,
                "inputs": [{"address": src, "value": amount}],
                "outputs": [{"address": dst, "value": amount}],
                "direction": direction,
            })
        return out

    def get_eth_token_transfers(self, address, limit=15):
        data = self.http.get_json(
            "https://api.ethplorer.io/getAddressHistory/" + address,
            params={"apiKey": "freekey", "limit": limit, "type": "transfer"}
        )
        if not data or "error" in data:
            return []
        out = []
        for op in (data.get("operations") or [])[:limit]:
            tinfo = op.get("tokenInfo", {}) or {}
            dec = int(tinfo.get("decimals", 18) or 18)
            try:
                value = float(op.get("value", 0)) / (10 ** dec)
            except Exception:
                value = 0
            ts = op.get("timestamp")
            ts_iso = datetime.fromtimestamp(ts, tz=timezone.utc).isoformat() if ts else None
            out.append({
                "txid": op.get("transactionHash", ""),
                "timestamp": ts_iso,
                "from": op.get("from", ""),
                "to": op.get("to", ""),
                "value": value,
                "symbol": tinfo.get("symbol", "?"),
                "name": tinfo.get("name", ""),
                "direction": "incoming" if (op.get("to", "").lower() == address.lower()) else "outgoing",
            })
        return out

    def get_address(self, chain, address):
        dispatch = {
            "BTC": self.get_btc_address,
            "ETH": self.get_eth_address,
            "LTC": self.get_ltc_address,
            "DOGE": self.get_doge_address,
            "DASH": self.get_dash_address,
            "BCH": self.get_bch_address,
            "XRP": self.get_xrp_address,
            "TRX": self.get_trx_address,
        }
        func = dispatch.get(chain)
        if func:
            return func(address)
        return None

    def _blockstream_address(self, address):
        data = self.http.get_json(f"https://blockstream.info/api/address/{address}")
        if not data:
            return None
        cs = data.get("chain_stats", {})
        ms = data.get("mempool_stats", {})
        funded = cs.get("funded_txo_sum", 0) + ms.get("funded_txo_sum", 0)
        spent = cs.get("spent_txo_sum", 0) + ms.get("spent_txo_sum", 0)
        tx_count = cs.get("tx_count", 0) + ms.get("tx_count", 0)
        return {
            "address": address,
            "chain": "BTC",
            "balance": (funded - spent) / SAT_PER_BTC,
            "total_received": funded / SAT_PER_BTC,
            "total_sent": spent / SAT_PER_BTC,
            "tx_count": tx_count,
            "source": "blockstream",
        }

    def _mempool_address(self, address):
        data = self.http.get_json(f"https://mempool.space/api/address/{address}")
        if not data:
            return None
        cs = data.get("chain_stats", {})
        ms = data.get("mempool_stats", {})
        funded = cs.get("funded_txo_sum", 0) + ms.get("funded_txo_sum", 0)
        spent = cs.get("spent_txo_sum", 0) + ms.get("spent_txo_sum", 0)
        tx_count = cs.get("tx_count", 0) + ms.get("tx_count", 0)
        return {
            "address": address,
            "chain": "BTC",
            "balance": (funded - spent) / SAT_PER_BTC,
            "total_received": funded / SAT_PER_BTC,
            "total_sent": spent / SAT_PER_BTC,
            "tx_count": tx_count,
            "source": "mempool.space",
        }

    def _blockchain_info_address(self, address):
        data = self.http.get_json(f"https://blockchain.info/rawaddr/{address}?limit=0")
        if not data or "error" in data:
            return None
        return {
            "address": address,
            "chain": "BTC",
            "balance": data.get("final_balance", 0) / SAT_PER_BTC,
            "total_received": data.get("total_received", 0) / SAT_PER_BTC,
            "total_sent": data.get("total_sent", 0) / SAT_PER_BTC,
            "tx_count": data.get("n_tx", 0),
            "source": "blockchain.info",
        }

    def _blockstream_txs(self, address):
        data = self.http.get_json(f"https://blockstream.info/api/address/{address}/txs")
        if not data or not isinstance(data, list):
            return None
        txs = []
        for tx in data[:MAX_TX_DISPLAY]:
            txs.append(self._normalize_btc_tx(tx, address))
        return txs

    def _mempool_txs(self, address):
        data = self.http.get_json(f"https://mempool.space/api/address/{address}/txs")
        if not data or not isinstance(data, list):
            return None
        txs = []
        for tx in data[:MAX_TX_DISPLAY]:
            txs.append(self._normalize_btc_tx(tx, address))
        return txs

    def _normalize_btc_tx(self, tx, target_addr):
        txid = tx.get("txid", "")
        status = tx.get("status", {})
        confirmed = status.get("confirmed", False)
        block_time = status.get("block_time", 0)
        block_height = status.get("block_height", 0)

        total_in = sum(v.get("prevout", {}).get("value", 0) for v in tx.get("vin", []))
        total_out = sum(v.get("value", 0) for v in tx.get("vout", []))
        fee = total_in - total_out if total_in > 0 else 0

        input_addrs = []
        for vin in tx.get("vin", []):
            prevout = vin.get("prevout", {})
            addr = prevout.get("scriptpubkey_address", "")
            val = prevout.get("value", 0)
            if addr:
                input_addrs.append({"address": addr, "value": val / SAT_PER_BTC})

        output_addrs = []
        for vout in tx.get("vout", []):
            addr = vout.get("scriptpubkey_address", "")
            val = vout.get("value", 0)
            if addr:
                output_addrs.append({"address": addr, "value": val / SAT_PER_BTC})

        is_incoming = not any(i["address"] == target_addr for i in input_addrs)

        return {
            "txid": txid,
            "confirmed": confirmed,
            "block_height": block_height,
            "timestamp": datetime.fromtimestamp(block_time, tz=timezone.utc).isoformat() if block_time else None,
            "total_input": total_in / SAT_PER_BTC,
            "total_output": total_out / SAT_PER_BTC,
            "fee": fee / SAT_PER_BTC,
            "input_count": len(tx.get("vin", [])),
            "output_count": len(tx.get("vout", [])),
            "inputs": input_addrs,
            "outputs": output_addrs,
            "direction": "incoming" if is_incoming else "outgoing",
        }

    def _parse_ethplorer(self, data, address):
        eth_data = data.get("ETH", {})
        balance = eth_data.get("balance", 0)
        total_in = eth_data.get("totalIn", 0)
        total_out = eth_data.get("totalOut", 0)
        tx_count = data.get("countTxs", 0)
        tokens = []
        for tok in data.get("tokens", [])[:20]:
            tinfo = tok.get("tokenInfo", {})
            tokens.append({
                "name": tinfo.get("name", "Unknown"),
                "symbol": tinfo.get("symbol", "???"),
                "balance": tok.get("balance", 0),
                "decimals": int(tinfo.get("decimals", 18)),
            })
        return {
            "address": address,
            "chain": "ETH",
            "balance": balance,
            "total_received": total_in,
            "total_sent": total_out,
            "tx_count": tx_count,
            "tokens": tokens,
            "source": "ethplorer",
        }

    def _parse_blockchair_eth(self, data, address):
        addr_key = list(data.get("data", {}).keys())
        if not addr_key:
            return None
        info = data["data"][addr_key[0]].get("address", {})
        return {
            "address": address,
            "chain": "ETH",
            "balance": info.get("balance", 0) / WEI_PER_ETH,
            "total_received": info.get("received", 0) / WEI_PER_ETH,
            "total_sent": info.get("spent", 0) / WEI_PER_ETH,
            "tx_count": info.get("transaction_count", 0),
            "tokens": [],
            "source": "blockchair",
        }

    def _blockchair_address(self, chain_name, address):
        data = self.http.get_json(
            f"https://api.blockchair.com/{chain_name}/dashboards/address/{address}"
        )
        if not data or "data" not in data:
            return None
        addr_key = list(data["data"].keys())
        if not addr_key:
            return None
        info = data["data"][addr_key[0]].get("address", {})
        chain_code = {
            "litecoin": "LTC", "dogecoin": "DOGE", "dash": "DASH",
            "bitcoin-cash": "BCH"
        }.get(chain_name, chain_name.upper())
        divisor = SAT_PER_BTC
        return {
            "address": address,
            "chain": chain_code,
            "balance": info.get("balance", 0) / divisor,
            "total_received": info.get("received", 0) / divisor,
            "total_sent": info.get("spent", 0) / divisor,
            "tx_count": info.get("transaction_count", 0),
            "first_seen": info.get("first_seen_receiving"),
            "last_seen": info.get("last_seen_spending") or info.get("last_seen_receiving"),
            "source": "blockchair",
        }


class RiskAnalyzer:

    ROUND_AMOUNTS_BTC = [0.001, 0.01, 0.1, 0.5, 1.0, 2.0, 5.0, 10.0, 50.0, 100.0, 500.0, 1000.0]

    def score_address(self, addr_info, txs=None):
        score = 0
        indicators = []
        address = addr_info.get("address", "")
        chain = addr_info.get("chain", "BTC")

        entity = lookup_entity(address)
        if entity:
            name, category = entity
            cat_info = ENTITY_CATEGORIES.get(category, {})
            score += cat_info.get("risk", 0)
            indicators.append(f"Known entity: {name} ({cat_info.get('label', category)})")

        balance = addr_info.get("balance", 0)
        total_recv = addr_info.get("total_received", 0)
        tx_count = addr_info.get("tx_count", 0)

        if chain == "BTC":
            if balance > 1000:
                score += 10
                indicators.append("Very high BTC balance (>1000)")
            elif balance > 100:
                score += 5
                indicators.append("High BTC balance (>100)")
            if total_recv > 10000:
                score += 10
                indicators.append("Very high total volume (>10000 BTC)")
            elif total_recv > 1000:
                score += 5
                indicators.append("High total volume (>1000 BTC)")
        elif chain == "ETH":
            if balance > 10000:
                score += 10
                indicators.append("Very high ETH balance (>10000)")
            elif balance > 1000:
                score += 5
                indicators.append("High ETH balance (>1000)")

        if tx_count > 10000:
            score += 10
            indicators.append("Extremely high tx count (>10000)")
        elif tx_count > 1000:
            score += 5
            indicators.append("Very high tx count (>1000)")

        if txs:
            pattern_results = self.analyze_patterns(txs)
            for p_name, p_detected, p_score, p_desc in pattern_results:
                if p_detected:
                    score += p_score
                    indicators.append(p_desc)

            dust_hit = self._detect_dust_attack(txs)
            if dust_hit:
                score += 5
                indicators.append(f"Possible dust attack pattern ({dust_hit} micro-deposits)")

            dormancy = self._detect_dormancy_break(txs)
            if dormancy:
                score += 10
                indicators.append(f"Dormancy break: {dormancy} days inactive then sudden movement")

        if score >= 50:
            level = "CRITICAL"
        elif score >= 30:
            level = "HIGH"
        elif score >= 15:
            level = "MEDIUM"
        else:
            level = "LOW"

        return {
            "score": min(score, 100),
            "level": level,
            "indicators": indicators,
        }

    def analyze_patterns(self, txs):
        results = []

        if len(txs) >= 3:
            mixing = self._detect_mixing(txs)
            results.append(("mixing", mixing, 15, "Potential mixing/tumbling pattern"))

        if len(txs) >= 5:
            peel = self._detect_peel_chain(txs)
            results.append(("peel_chain", peel, 15, "Peel chain pattern detected"))

        round_pct = self._detect_round_amounts(txs)
        if round_pct > 0.4:
            results.append(("round_amounts", True, 10, f"High ratio of round amounts ({round_pct:.0%})"))

        if len(txs) >= 3:
            rapid = self._detect_rapid_movement(txs)
            results.append(("rapid_movement", rapid, 10, "Rapid fund movement pattern"))

        consolidation_pct = sum(1 for t in txs if t.get("input_count", 0) > 5 and t.get("output_count", 0) <= 2) / max(len(txs), 1)
        if consolidation_pct > 0.3:
            results.append(("consolidation", True, 8, "Frequent UTXO consolidation"))

        return results

    def _detect_mixing(self, txs):
        for tx in txs:
            ins = tx.get("input_count", 0)
            outs = tx.get("output_count", 0)
            if ins > 10 and outs <= 3:
                return True
            if ins >= 3 and outs >= 3:
                output_vals = [o.get("value", 0) for o in tx.get("outputs", [])]
                if output_vals and len(set(round(v, 4) for v in output_vals)) <= 2:
                    return True
        return False

    def _detect_peel_chain(self, txs):
        outgoing = [t for t in txs if t.get("direction") == "outgoing"]
        if len(outgoing) < 5:
            return False
        timestamps = []
        for t in outgoing:
            ts = t.get("timestamp")
            if ts:
                try:
                    timestamps.append(datetime.fromisoformat(ts.replace("Z", "+00:00")))
                except Exception:
                    pass
        if len(timestamps) < 5:
            return False
        timestamps.sort()
        short_intervals = 0
        for i in range(1, len(timestamps)):
            diff = (timestamps[i] - timestamps[i-1]).total_seconds()
            if diff < 3600:
                short_intervals += 1
        return short_intervals >= 4

    def _detect_round_amounts(self, txs):
        if not txs:
            return 0.0
        round_count = 0
        total = 0
        for tx in txs:
            for out in tx.get("outputs", []):
                val = out.get("value", 0)
                total += 1
                if any(abs(val - ra) < 0.001 for ra in self.ROUND_AMOUNTS_BTC):
                    round_count += 1
                elif val > 0 and abs(val - round(val, 1)) < 0.001:
                    round_count += 1
        return round_count / max(total, 1)

    def _detect_dust_attack(self, txs):
        count = 0
        for tx in txs:
            if tx.get("direction") != "incoming":
                continue
            for o in tx.get("outputs", []):
                v = o.get("value", 0)
                if 0 < v <= 0.00001:
                    count += 1
        return count if count >= 3 else 0

    def _detect_dormancy_break(self, txs):
        timestamps = []
        for t in txs:
            ts = t.get("timestamp")
            if not ts:
                continue
            try:
                timestamps.append(datetime.fromisoformat(str(ts).replace("Z", "+00:00")))
            except Exception:
                continue
        if len(timestamps) < 2:
            return 0
        timestamps.sort()
        max_gap = 0
        for i in range(1, len(timestamps)):
            gap = (timestamps[i] - timestamps[i-1]).days
            if gap > max_gap:
                max_gap = gap
        last_gap = (timestamps[-1] - timestamps[-2]).days if len(timestamps) >= 2 else 0
        if max_gap >= 365 and last_gap >= 180:
            return last_gap
        return 0

    def _detect_rapid_movement(self, txs):
        incoming_ts = []
        outgoing_ts = []
        for t in txs:
            ts = t.get("timestamp")
            if not ts:
                continue
            try:
                dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
            except Exception:
                continue
            if t.get("direction") == "incoming":
                incoming_ts.append(dt)
            else:
                outgoing_ts.append(dt)
        for i_ts in incoming_ts:
            for o_ts in outgoing_ts:
                diff = abs((o_ts - i_ts).total_seconds())
                if 0 < diff < 1800:
                    return True
        return False


class WalletProfiler:

    def profile(self, addr_info, txs=None):
        profile = {
            "classification": "Unknown",
            "behavior_tags": [],
            "activity_summary": {},
        }
        balance = addr_info.get("balance", 0)
        tx_count = addr_info.get("tx_count", 0)
        total_recv = addr_info.get("total_received", 0)
        total_sent = addr_info.get("total_sent", 0)

        if tx_count == 0 and balance == 0:
            profile["classification"] = "Empty/Unused"
            return profile

        if tx_count == 0 and balance > 0:
            profile["classification"] = "Receive-only (Cold Storage?)"
            profile["behavior_tags"].append("never-spent")
            return profile

        if total_recv > 0 and total_sent == 0:
            profile["classification"] = "Accumulator"
            profile["behavior_tags"].append("never-spent")
        elif balance < total_recv * 0.01 and total_sent > 0:
            profile["classification"] = "Pass-through"
            profile["behavior_tags"].append("low-retention")
        elif tx_count > 5000:
            profile["classification"] = "High-volume (Exchange/Service)"
            profile["behavior_tags"].append("service-like")
        elif tx_count > 500:
            profile["classification"] = "Active Trader"
            profile["behavior_tags"].append("frequent-user")
        elif tx_count < 10 and balance > total_recv * 0.8:
            profile["classification"] = "Long-term Holder"
            profile["behavior_tags"].append("hodler")
        else:
            profile["classification"] = "Regular User"

        if txs:
            timestamps = []
            for t in txs:
                ts = t.get("timestamp")
                if ts:
                    try:
                        timestamps.append(datetime.fromisoformat(ts.replace("Z", "+00:00")))
                    except Exception:
                        pass
            if timestamps:
                timestamps.sort()
                first = timestamps[0]
                last = timestamps[-1]
                span = (last - first).days
                profile["activity_summary"]["first_activity"] = first.strftime("%Y-%m-%d")
                profile["activity_summary"]["last_activity"] = last.strftime("%Y-%m-%d")
                profile["activity_summary"]["active_days"] = span
                if span > 0:
                    profile["activity_summary"]["tx_per_day"] = round(len(timestamps) / span, 4)

            incoming = sum(1 for t in txs if t.get("direction") == "incoming")
            outgoing = len(txs) - incoming
            profile["activity_summary"]["incoming_txs"] = incoming
            profile["activity_summary"]["outgoing_txs"] = outgoing

        return profile


class PriceFeed:

    SYMBOL_TO_CG = {
        "BTC": "bitcoin",
        "ETH": "ethereum",
        "LTC": "litecoin",
        "DOGE": "dogecoin",
        "DASH": "dash",
        "BCH": "bitcoin-cash",
        "XRP": "ripple",
        "TRX": "tron",
    }

    def __init__(self, http):
        self.http = http
        self._cache = {}

    def get_usd(self, chain):
        cg = self.SYMBOL_TO_CG.get(chain)
        if not cg:
            return None
        if cg in self._cache:
            return self._cache[cg]
        data = self.http.get_json(
            "https://api.coingecko.com/api/v3/simple/price",
            params={"ids": cg, "vs_currencies": "usd", "include_24hr_change": "true", "include_market_cap": "true"}
        )
        if not data or cg not in data:
            return None
        info = {
            "usd": data[cg].get("usd"),
            "change_24h": data[cg].get("usd_24h_change"),
            "market_cap": data[cg].get("usd_market_cap"),
        }
        self._cache[cg] = info
        return info


class SanctionsCheck:

    OFAC_FEEDS = [
        "https://raw.githubusercontent.com/0xB10C/ofac-sanctioned-digital-currency-addresses/lists/sanctioned_addresses_BTC.txt",
        "https://raw.githubusercontent.com/0xB10C/ofac-sanctioned-digital-currency-addresses/lists/sanctioned_addresses_ETH.txt",
        "https://raw.githubusercontent.com/0xB10C/ofac-sanctioned-digital-currency-addresses/lists/sanctioned_addresses_XBT.txt",
        "https://raw.githubusercontent.com/0xB10C/ofac-sanctioned-digital-currency-addresses/lists/sanctioned_addresses_BCH.txt",
        "https://raw.githubusercontent.com/0xB10C/ofac-sanctioned-digital-currency-addresses/lists/sanctioned_addresses_LTC.txt",
        "https://raw.githubusercontent.com/0xB10C/ofac-sanctioned-digital-currency-addresses/lists/sanctioned_addresses_USDT.txt",
        "https://raw.githubusercontent.com/0xB10C/ofac-sanctioned-digital-currency-addresses/lists/sanctioned_addresses_XMR.txt",
    ]

    def __init__(self, http):
        self.http = http
        self._set = None

    def _load(self):
        if self._set is not None:
            return self._set
        merged = set()
        for url in self.OFAC_FEEDS:
            try:
                resp = self.http.get(url)
                if resp and resp.status_code == 200:
                    for line in resp.text.splitlines():
                        line = line.strip()
                        if line and not line.startswith("#"):
                            merged.add(line.lower())
            except Exception:
                continue
        self._set = merged
        return merged

    def is_sanctioned(self, address):
        if not address:
            return False
        s = self._load()
        return address.lower() in s


class ENSResolver:

    def __init__(self, http):
        self.http = http

    def reverse(self, address):
        if not address or not address.startswith("0x"):
            return None
        data = self.http.get_json(f"https://api.ensideas.com/ens/resolve/{address}")
        if data and isinstance(data, dict):
            return data.get("name") or None
        return None


class CounterpartyAnalyzer:

    def analyze(self, address, txs, max_top=8):
        if not txs:
            return {"top_senders": [], "top_receivers": [], "unique_counterparties": 0}
        senders = defaultdict(float)
        receivers = defaultdict(float)
        unique = set()
        for tx in txs:
            for vin in tx.get("inputs", []):
                a = vin.get("address", "")
                if a and a != address:
                    senders[a] += float(vin.get("value", 0) or 0)
                    unique.add(a)
            for vout in tx.get("outputs", []):
                a = vout.get("address", "")
                if a and a != address:
                    receivers[a] += float(vout.get("value", 0) or 0)
                    unique.add(a)
        top_s = sorted(senders.items(), key=lambda x: x[1], reverse=True)[:max_top]
        top_r = sorted(receivers.items(), key=lambda x: x[1], reverse=True)[:max_top]
        def _label(a, v):
            ent = lookup_entity(a)
            return {
                "address": a,
                "value": v,
                "entity": ent[0] if ent else None,
                "category": ent[1] if ent else None,
            }
        return {
            "top_senders": [_label(a, v) for a, v in top_s],
            "top_receivers": [_label(a, v) for a, v in top_r],
            "unique_counterparties": len(unique),
        }


class ClusterAnalyzer:

    def analyze(self, address, txs, limit=12):
        cluster = set()
        evidence = 0
        for tx in txs or []:
            inputs = [i.get("address", "") for i in tx.get("inputs", []) if i.get("address")]
            if address in inputs and len(inputs) > 1:
                for a in inputs:
                    if a and a != address:
                        cluster.add(a)
                evidence += 1
        sample = list(cluster)[:limit]
        labels = []
        for a in sample:
            ent = lookup_entity(a)
            labels.append({"address": a, "entity": ent[0] if ent else None})
        return {
            "cluster_size": len(cluster),
            "evidence_txs": evidence,
            "sample": labels,
        }


class TimingAnalyzer:

    def analyze(self, txs):
        if not txs:
            return {"hours": [0] * 24, "weekdays": [0] * 7, "peak_hour_utc": None, "likely_tz_offset": None, "burstiness": 0.0}
        hours = [0] * 24
        weekdays = [0] * 7
        timestamps = []
        for t in txs:
            ts = t.get("timestamp")
            if not ts:
                continue
            try:
                dt = datetime.fromisoformat(str(ts).replace("Z", "+00:00"))
            except Exception:
                continue
            timestamps.append(dt)
            hours[dt.hour] += 1
            weekdays[dt.weekday()] += 1
        peak_hour = max(range(24), key=lambda h: hours[h]) if any(hours) else None
        tz_offset = None
        if peak_hour is not None:
            tz_offset = (15 - peak_hour) % 24
            if tz_offset > 12:
                tz_offset -= 24
        burstiness = 0.0
        if len(timestamps) >= 3:
            timestamps.sort()
            diffs = [(timestamps[i] - timestamps[i-1]).total_seconds() for i in range(1, len(timestamps))]
            if diffs:
                avg = sum(diffs) / len(diffs)
                if avg > 0:
                    var = sum((d - avg) ** 2 for d in diffs) / len(diffs)
                    sd = var ** 0.5
                    burstiness = (sd - avg) / (sd + avg) if (sd + avg) > 0 else 0
        return {
            "hours": hours,
            "weekdays": weekdays,
            "peak_hour_utc": peak_hour,
            "likely_tz_offset": tz_offset,
            "burstiness": round(burstiness, 3),
        }


