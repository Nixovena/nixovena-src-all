    # Create argument parser
    parser = argparse.ArgumentParser(description="WHOSINTAPP - WhatsApp OSINT Tool")
    parser.add_argument("-n", "--number", help="Phone number to investigate (with country code)")
    parser.add_argument("-k", "--api-key", help="RapidAPI key")
    parser.add_argument("-H", "--api-host", help="RapidAPI host")
    parser.add_argument("--no-warning", action="store_true", help="Skip legal warning")
    
    args = parser.parse_args()
    
    # WHOSINTAPP Banner
    print(Fore.GREEN + """
