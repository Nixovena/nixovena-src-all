class FacebookProfiler:
    def __init__(self, http):
        self.http = http

    def investigate_username(self, username):
        Log.header("FACEBOOK PROFILE INTELLIGENCE")
        username = username.strip().strip("/")
        Log.info(f"Target: {_c(C.WHITE, username)}")

        Log.subheader("Profile URLs")
        urls = {
