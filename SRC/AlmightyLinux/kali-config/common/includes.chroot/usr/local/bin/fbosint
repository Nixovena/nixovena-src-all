            "Groups": f"https://www.facebook.com/{username}/groups",
            "Music": f"https://www.facebook.com/{username}/music",
            "Movies": f"https://www.facebook.com/{username}/movies",
            "TV": f"https://www.facebook.com/{username}/tv",
            "Books": f"https://www.facebook.com/{username}/books",
            "Sports": f"https://www.facebook.com/{username}/sports",
            "Following": f"https://www.facebook.com/{username}/following",
            "Followers": f"https://www.facebook.com/{username}/followers",
            "Archive.org": f"https://web.archive.org/web/*/facebook.com/{username}",
            "Archive.org (Profile)": f"https://web.archive.org/web/2024/https://www.facebook.com/{username}",
            "Profile Pic (Direct)": f"https://graph.facebook.com/{username}/picture?type=large",
        }
        for name, url in urls.items():
            Log.detail(name, url)

        Log.subheader("Reverse Image Search (Profile Picture)")
        pic_url = f"https://graph.facebook.com/{username}/picture?type=large"
        reverse_img = {
            "Google Images": f"https://lens.google.com/uploadbyurl?url={quote(pic_url)}",
            "Yandex Images": f"https://yandex.com/images/search?rpt=imageview&url={quote(pic_url)}",
            "TinEye": f"https://tineye.com/search/?url={quote(pic_url)}",
        }
        for name, url in reverse_img.items():
            Log.detail(name, url)

        Log.subheader("Facebook Graph Search Dorks")
        dork_results = []
        for template, desc in GRAPH_DORKS_TEMPLATE:
            query = template.replace("{u}", username)
            url = f"https://www.google.com/search?q={quote_plus(query)}"
            Log.detail(desc, url)
            dork_results.append({"query": query, "desc": desc})

        Log.subheader("Cross-Platform Lookup")
        cross_results = []
        for name, url_template in CROSS_PLATFORMS:
            url = url_template.format(username)
            exists = self.http.check_exists(url)
            if exists:
                Log.success(f"{name}: {_c(C.GREEN, 'FOUND')} - {url}")
                cross_results.append({"platform": name, "url": url, "status": "found"})
            else:
                print(f"    {C.DARK}[x] {name}: not found{C.RST}")
                cross_results.append({"platform": name, "url": url, "status": "not_found"})

        return {
            "target": username,
            "type": "username",
            "urls": urls,
            "reverse_image_search": reverse_img,
            "dorks": dork_results,
            "cross_platform": cross_results,
            "timestamp": datetime.now(timezone.utc).isoformat(),
        }

    def investigate_id(self, fb_id):
        Log.header("FACEBOOK ID INTELLIGENCE")
        Log.info(f"Target ID: {_c(C.WHITE, fb_id)}")

        Log.subheader("ID-based URLs")
        urls = {
            "Profile": f"https://www.facebook.com/profile.php?id={fb_id}",
