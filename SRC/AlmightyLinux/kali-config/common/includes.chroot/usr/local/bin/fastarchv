#!/usr/bin/env python3
import os
import sys
import time
import json
import re
try:
    import requests
except ImportError:
    import sys; sys.exit("[!] Missing: requests")
try:
    import socks
except ImportError:
    import sys; sys.exit("[!] Missing: PySocks")
import socket
from datetime import datetime

RED = "\033[91m"
GREEN = "\033[92m"
CYAN = "\033[96m"
YELLOW = "\033[93m"
RESET = "\033[0m"
BOLD = "\033[1m"

# To maximize privacy over Tor, we blend in with the majority of Tor users:
# Using the exact Tor Browser User-Agent and removing randomized agents that create unique fingerprints.
TOR_USER_AGENT = "Mozilla/5.0 (Windows NT 10.0; rv:109.0) Gecko/20100101 Firefox/115.0"

def banner():
    print(f"""{CYAN}{BOLD}
