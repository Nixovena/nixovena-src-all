#!/usr/bin/env python3

# ================================================
#       Almighty System Update & Cleanup
# ================================================

import subprocess
import shutil
import os
import sys
import time

try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.prompt import Prompt
    from rich.text import Text
    from rich.align import Align
except ImportError:
    print("[!] python3-rich is required. Install with: sudo apt install python3-rich")
    sys.exit(1)

console = Console()

ASCII_BANNER = r"""
