def main_loop():
    main_banner()
    console.print("[bold green]Welcome to near2h4ck framework! Type 'help' for available commands.[/bold green]\n")
    
    while True:
        try:
            user_input = input(f"{Fore.CYAN}near2h4ck>> {Style.RESET_ALL}").strip()
            
            if not user_input:
                continue
                
            if user_input.lower() in ['exit', 'quit', 'q']:
                console.print("[bold green]Thanks for using near2h4ck framework![/bold green]")
                break
                
            if user_input.lower() == 'help':
                show_help()
                continue
                
            if user_input.lower() == 'clear':
                os.system('cls' if os.name == 'nt' else 'clear')
                main_banner()
                continue
            
            # System info command
            if user_input.lower() == 'info':
                SystemInfo.run()
                continue
            
            # Proxy commands
            if user_input.lower() == 'proxy-status':
                ProxyManager.status()
                continue
            
            if user_input.lower() == 'proxy-disable':
                ProxyManager.disable_proxy()
                continue
            
            if user_input.lower().startswith('proxy-enable'):
                parts = user_input.split()
                if len(parts) >= 4:
                    ProxyManager.enable_proxy(parts[1], parts[2], int(parts[3]))
                else:
                    ProxyManager.enable_proxy()
                continue
            
            if user_input.lower() == 'tor-check':
                is_tor, msg = check_tor_connection()
                if is_tor:
                    console.print(f"[green]✓ {msg}[/green]")
                else:
                    console.print(f"[yellow]⚠ {msg}[/yellow]")
                continue
            
            # Parse command and target
            parts = user_input.split()
            if len(parts) < 2:
                console.print("[red]Usage: <command> <target>[/red]")
                console.print("[yellow]Type 'help' for available commands[/yellow]")
                continue
                
            command = parts[0].lower()
            target = parts[1]
            
            run_module(command, target)
            
        except KeyboardInterrupt:
            console.print("\n[bold yellow]Use 'exit' to quit the framework[/bold yellow]")
        except EOFError:
            break
        except Exception as e:
            console.print(f"[bold red]Error: {str(e)}[/bold red]")

if __name__ == "__main__":
    if len(sys.argv) > 1:
        # Command line mode
        command = sys.argv[1].lower()
        if len(sys.argv) > 2:
            target = sys.argv[2]
            run_module(command, target)
        else:
            console.print("[red]Usage: python near2h4ck.py <command> <target>[/red]")
    else:
        # Interactive mode
        main_loop()