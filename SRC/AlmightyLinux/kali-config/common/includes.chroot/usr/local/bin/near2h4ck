                    indicators = [
                        'root:', 'bin/bash', 'uid=', 'gid=',
                        'volume serial number', 'directory of',
                        'windows', 'system32'
                    ]
                    
                    content_lower = response.text.lower()
                    for indicator in indicators:
                        if indicator in content_lower:
                            vulnerable.append({
                                'payload': payload,
                                'indicator': indicator,
                                'url': test_url
                            })
                            break
                except Exception:
                    continue
        except Exception:
            pass
        
        return vulnerable
    
