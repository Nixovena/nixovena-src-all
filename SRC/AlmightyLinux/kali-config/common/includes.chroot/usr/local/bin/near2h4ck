            'URLVoid': f'https://api.urlvoid.com/v1/pay-as-you-go/?key=dummy&host={domain}',
        }
        
        for source, url in sources.items():
            try:
                # Mock implementation - in reality you'd need API keys
                results[source] = "Clean"
            except Exception:
                results[source] = "Error"
        
        return results

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] Domain Reputation Check for: [cyan]{domain}[/cyan][/white]")
        
        results = DomainReputation.check_reputation_sources(domain)
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Source", style="cyan")
        table.add_column("Status", style="white")
        
        for source, status in results.items():
            color = "green" if status == "Clean" else "red" if status == "Malicious" else "yellow"
            table.add_row(source, f"[{color}]{status}[/{color}]")
        
        console.print(table)
        console.print("[white][*] Domain reputation check completed[/white]")

class FaviconHash:
    @staticmethod
    def get_favicon_hash(url, timeout=10):
        try:
            # Try common favicon paths
            favicon_paths = ['/favicon.ico', '/favicon.png', '/apple-touch-icon.png']
            
            for path in favicon_paths:
                favicon_url = url.rstrip('/') + path
                response = requests.get(favicon_url, timeout=timeout, verify=False)
                
                if response.status_code == 200:
                    # Calculate simple hash (in real implementation, use mmh3)
                    content_hash = hashlib.md5(response.content).hexdigest()
                    return content_hash, favicon_url
            
            return None, None
        except Exception:
            return None, None

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'http://' + target
        
        console.print(f"[white][*] Favicon Hash Analysis for: [cyan]{target}[/cyan][/white]")
        
        favicon_hash, favicon_url = FaviconHash.get_favicon_hash(target)
        
        if favicon_hash:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Field", style="cyan")
            table.add_column("Value", style="white")
            
            table.add_row("Favicon URL", favicon_url)
            table.add_row("MD5 Hash", favicon_hash)
            
            console.print(table)
        else:
            console.print("[yellow]No favicon found[/yellow]")

class SPFAnalysis:
    @staticmethod
    def get_txt_records(name, timeout=10):
        try:
            resolver = dns.resolver.Resolver()
            resolver.timeout = timeout
            answers = resolver.resolve(name, "TXT")
            return [str(r).strip('"') for r in answers]
        except Exception:
            return []

    @staticmethod
    def parse_spf(txt_records):
        for record in txt_records:
            if record.lower().startswith("v=spf1"):
                return record
        return None

    @staticmethod
    def parse_dmarc(txt_records):
        for record in txt_records:
            if record.lower().startswith("v=dmarc1"):
                parts = record.split(";")
                policy = "none"
                rua = "N/A"
                ruf = "N/A"
                pct = "100"
                
                for part in parts:
                    part = part.strip()
                    if part.startswith("p="):
                        policy = part.split("=", 1)[1]
                    elif part.startswith("rua="):
                        rua = part.split("=", 1)[1]
                    elif part.startswith("ruf="):
                        ruf = part.split("=", 1)[1]
                    elif part.startswith("pct="):
                        pct = part.split("=", 1)[1]
                
                return record, policy, rua, ruf, pct
        return None, "N/A", "N/A", "N/A", "N/A"

    @staticmethod
    def check_dkim_selectors(domain, timeout=10):
        selectors = ["default", "selector1", "selector2", "google", "mail", "smtp", "k1", "dkim"]
        results = []
        
        for selector in selectors:
            dkim_domain = f"{selector}._domainkey.{domain}"
            txt_records = SPFAnalysis.get_txt_records(dkim_domain, timeout)
            
            if txt_records:
                for record in txt_records:
                    if "v=DKIM1" in record or "k=" in record:
                        results.append((selector, "Found", record[:80] + "..." if len(record) > 80 else record))
                        break
                else:
                    results.append((selector, "Found", "TXT record exists"))
            else:
                results.append((selector, "Not Found", "N/A"))
        
        return results

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] SPF/DKIM/DMARC Analysis for: [cyan]{domain}[/cyan][/white]")
        
        # SPF Analysis
        spf_records = SPFAnalysis.get_txt_records(domain)
        spf_record = SPFAnalysis.parse_spf(spf_records)
        
        if spf_record:
            spf_table = Table(show_header=True, header_style="bold white")
            spf_table.add_column("SPF Record", style="green")
            spf_table.add_row(spf_record)
            console.print(spf_table)
        else:
            console.print("[yellow]No SPF record found[/yellow]")
        
        # DMARC Analysis
        dmarc_records = SPFAnalysis.get_txt_records(f"_dmarc.{domain}")
        dmarc_record, policy, rua, ruf, pct = SPFAnalysis.parse_dmarc(dmarc_records)
        
        if dmarc_record:
            dmarc_table = Table(show_header=True, header_style="bold white")
            dmarc_table.add_column("Policy", style="cyan")
            dmarc_table.add_column("RUA", style="green")
            dmarc_table.add_column("RUF", style="yellow")
            dmarc_table.add_column("PCT", style="white")
            dmarc_table.add_row(policy, rua, ruf, pct)
            console.print(dmarc_table)
        else:
            console.print("[yellow]No DMARC record found[/yellow]")
        
        # DKIM Analysis
        dkim_results = SPFAnalysis.check_dkim_selectors(domain)
        found_selectors = [r for r in dkim_results if r[1] == "Found"]
        
        if found_selectors:
            dkim_table = Table(show_header=True, header_style="bold white")
            dkim_table.add_column("Selector", style="cyan")
            dkim_table.add_column("Status", style="green")
            dkim_table.add_column("Record", style="white")
            
            for selector, status, record in found_selectors:
                dkim_table.add_row(selector, status, record)
            
            console.print(dkim_table)
        else:
            console.print("[yellow]No DKIM selectors found[/yellow]")

class QualityMetrics:
    @staticmethod
    def analyze_page_quality(url, timeout=10):
        try:
            start_time = time.time()
            response = requests.get(url, timeout=timeout, verify=False)
            response.raise_for_status()
            end_time = time.time()
            
            load_time = end_time - start_time
            page_size = len(response.content)
            
            soup = BeautifulSoup(response.content, 'html.parser')
            
            metrics = {
                'load_time': round(load_time, 2),
                'page_size': page_size,
                'status_code': response.status_code,
                'https': url.startswith('https://'),
                'compressed': response.headers.get('Content-Encoding') in ['gzip', 'br'],
                'mobile_friendly': bool(soup.find('meta', attrs={'name': 'viewport'})),
                'num_images': len(soup.find_all('img')),
                'num_scripts': len(soup.find_all('script')),
                'num_stylesheets': len(soup.find_all('link', rel='stylesheet')),
                'num_links': len(soup.find_all('a')),
                'has_title': bool(soup.find('title')),
                'has_meta_description': bool(soup.find('meta', attrs={'name': 'description'})),
            }
            
            return metrics
        except Exception:
            return None

    @staticmethod
    def get_quality_score(metrics):
        score = 0
        max_score = 10
        
        # Load time (2 points)
        if metrics['load_time'] < 2:
            score += 2
        elif metrics['load_time'] < 5:
            score += 1
        
        # HTTPS (1 point)
        if metrics['https']:
            score += 1
        
        # Compression (1 point)
        if metrics['compressed']:
            score += 1
        
        # Mobile friendly (1 point)
        if metrics['mobile_friendly']:
            score += 1
        
        # SEO basics (2 points)
        if metrics['has_title']:
            score += 1
        if metrics['has_meta_description']:
            score += 1
        
        # Page size (1 point)
        if metrics['page_size'] < 1024 * 1024:  # Less than 1MB
            score += 1
        
        # Resource optimization (1 point)
        if metrics['num_images'] + metrics['num_scripts'] + metrics['num_stylesheets'] < 50:
            score += 1
        
        return score, max_score

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'http://' + target
        
        console.print(f"[white][*] Quality Metrics Analysis for: [cyan]{target}[/cyan][/white]")
        
        metrics = QualityMetrics.analyze_page_quality(target)
        if not metrics:
            console.print("[red]Failed to analyze page quality[/red]")
            return
        
        score, max_score = QualityMetrics.get_quality_score(metrics)
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Metric", style="cyan")
        table.add_column("Value", style="white")
        table.add_column("Status", style="green")
        
        table.add_row("Load Time", f"{metrics['load_time']}s", "Good" if metrics['load_time'] < 3 else "Needs Improvement")
        table.add_row("Page Size", f"{metrics['page_size']:,} bytes", "Good" if metrics['page_size'] < 1024*1024 else "Large")
        table.add_row("HTTPS", "Yes" if metrics['https'] else "No", "Good" if metrics['https'] else "Needs HTTPS")
        table.add_row("Compressed", "Yes" if metrics['compressed'] else "No", "Good" if metrics['compressed'] else "Enable Compression")
        table.add_row("Mobile Friendly", "Yes" if metrics['mobile_friendly'] else "No", "Good" if metrics['mobile_friendly'] else "Add Viewport Meta")
        table.add_row("Images", str(metrics['num_images']), "Good" if metrics['num_images'] < 20 else "Many Images")
        table.add_row("Scripts", str(metrics['num_scripts']), "Good" if metrics['num_scripts'] < 10 else "Many Scripts")
        table.add_row("Stylesheets", str(metrics['num_stylesheets']), "Good" if metrics['num_stylesheets'] < 5 else "Many Stylesheets")
        
        console.print(table)
        
        score_color = "green" if score >= 8 else "yellow" if score >= 6 else "red"
        console.print(f"[white]Quality Score: [{score_color}]{score}/{max_score}[/{score_color}][/white]")

class SEOAbuseDetector:
    @staticmethod
    def check_suspicious_content(url, timeout=10):
        suspicious_keywords = ["casino", "viagra", "loan", "btc", "porn", "sex", "cheap", "free money"]
        suspicious_css = ["display:none", "visibility:hidden", "font-size:0", "opacity:0"]
        
        try:
            response = requests.get(url, timeout=timeout, verify=False)
            html = response.text.lower()
            
            keyword_matches = [kw for kw in suspicious_keywords if kw in html]
            css_matches = [css for css in suspicious_css if css in html]
            
            # Check for excessive links
            link_count = html.count('<a ')
            text_length = len(response.text)
            link_density = link_count / max(text_length, 1) * 1000  # Links per 1000 chars
            
            return {
                'suspicious_keywords': keyword_matches,
                'hidden_content': css_matches,
                'link_count': link_count,
                'link_density': round(link_density, 2),
                'text_length': text_length
            }
        except Exception:
            return None

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'http://' + target
        
        console.print(f"[white][*] SEO Abuse Detection for: [cyan]{target}[/cyan][/white]")
        
        results = SEOAbuseDetector.check_suspicious_content(target)
        if not results:
            console.print("[red]Failed to analyze content[/red]")
            return
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Check", style="cyan")
        table.add_column("Result", style="white")
        table.add_column("Status", style="green")
        
        # Suspicious keywords
        if results['suspicious_keywords']:
            table.add_row("Suspicious Keywords", ", ".join(results['suspicious_keywords']), "[red]Found[/red]")
        else:
            table.add_row("Suspicious Keywords", "None", "[green]Clean[/green]")
        
        # Hidden content
        if results['hidden_content']:
            table.add_row("Hidden Content", f"{len(results['hidden_content'])} techniques", "[red]Detected[/red]")
        else:
            table.add_row("Hidden Content", "None", "[green]Clean[/green]")
        
        # Link density
        status = "[red]High[/red]" if results['link_density'] > 10 else "[yellow]Medium[/yellow]" if results['link_density'] > 5 else "[green]Normal[/green]"
        table.add_row("Link Density", f"{results['link_density']} per 1000 chars", status)
        
        table.add_row("Total Links", str(results['link_count']), "[green]OK[/green]" if results['link_count'] < 100 else "[yellow]Many[/yellow]")
        
        console.print(table)

class PrivacyGDPR:
    @staticmethod
    def check_privacy_policies(base_url, timeout=10):
        policy_urls = {
            'Privacy Policy': ['/privacy-policy', '/privacy', '/privacy-statement'],
            'GDPR Compliance': ['/gdpr', '/gdpr-compliance', '/data-protection'],
            'Cookie Policy': ['/cookie-policy', '/cookies', '/cookie-consent']
        }
        
        results = {}
        for policy_type, paths in policy_urls.items():
            found = False
            for path in paths:
                try:
                    url = base_url.rstrip('/') + path
                    response = requests.head(url, timeout=timeout, verify=False)
                    if response.status_code == 200:
                        results[policy_type] = {'status': 'Found', 'url': url}
                        found = True
                        break
                except Exception:
                    continue
            
            if not found:
                results[policy_type] = {'status': 'Not Found', 'url': 'N/A'}
        
        return results

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'http://' + target
        
        console.print(f"[white][*] Privacy & GDPR Compliance Check for: [cyan]{target}[/cyan][/white]")
        
        results = PrivacyGDPR.check_privacy_policies(target)
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Policy Type", style="cyan")
        table.add_column("Status", style="white")
        table.add_column("URL", style="green")
        
        for policy_type, info in results.items():
            status_color = "green" if info['status'] == 'Found' else "red"
            table.add_row(policy_type, f"[{status_color}]{info['status']}[/{status_color}]", info['url'])
        
        console.print(table)

class SiteMapAnalyzer:
    @staticmethod
    def find_sitemaps(base_url, timeout=10):
        sitemap_paths = [
            '/sitemap.xml',
            '/sitemap_index.xml',
            '/sitemap/sitemap.xml',
            '/sitemap/sitemap-index.xml',
            '/robots.txt'  # Check robots.txt for sitemap references
        ]
        
        found_sitemaps = []
        for path in sitemap_paths:
            try:
                url = base_url.rstrip('/') + path
                response = requests.get(url, timeout=timeout, verify=False)
                if response.status_code == 200:
                    if path == '/robots.txt':
                        # Look for sitemap references in robots.txt
                        for line in response.text.splitlines():
                            if line.lower().startswith('sitemap:'):
                                sitemap_url = line.split(':', 1)[1].strip()
                                found_sitemaps.append(sitemap_url)
                    else:
                        found_sitemaps.append(url)
            except Exception:
                continue
        
        return found_sitemaps

    @staticmethod
    def parse_sitemap_urls(sitemap_url, timeout=10):
        try:
            response = requests.get(sitemap_url, timeout=timeout, verify=False)
            if response.status_code != 200:
                return []
            
            soup = BeautifulSoup(response.content, 'xml')
            urls = []
            
            # Check for sitemap index
            sitemap_tags = soup.find_all('sitemap')
            if sitemap_tags:
                for sitemap in sitemap_tags:
                    loc = sitemap.find('loc')
                    if loc:
                        urls.append(('Sitemap Index', loc.text, 'N/A', 'N/A'))
            else:
                # Parse URL entries
                url_tags = soup.find_all('url')
                for url_tag in url_tags:
                    loc = url_tag.find('loc')
                    lastmod = url_tag.find('lastmod')
                    changefreq = url_tag.find('changefreq')
                    priority = url_tag.find('priority')
                    
                    if loc:
                        urls.append((
                            'URL',
                            loc.text,
                            lastmod.text if lastmod else 'N/A',
                            changefreq.text if changefreq else 'N/A'
                        ))
            
            return urls
        except Exception:
            return []

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'http://' + target
        
        console.print(f"[white][*] Sitemap Analysis for: [cyan]{target}[/cyan][/white]")
        
        sitemaps = SiteMapAnalyzer.find_sitemaps(target)
        
        if not sitemaps:
            console.print("[yellow]No sitemaps found[/yellow]")
            return
        
        console.print(f"[green]Found {len(sitemaps)} sitemap(s)[/green]")
        
        for sitemap_url in sitemaps:
            console.print(f"\n[white]Analyzing: [cyan]{sitemap_url}[/cyan][/white]")
            urls = SiteMapAnalyzer.parse_sitemap_urls(sitemap_url)
            
            if urls:
                table = Table(show_header=True, header_style="bold white")
                table.add_column("Type", style="cyan")
                table.add_column("URL", style="green")
                table.add_column("Last Modified", style="yellow")
                table.add_column("Change Freq", style="white")
                
                for url_type, url, lastmod, changefreq in urls[:20]:  # Limit to first 20
                    table.add_row(url_type, url, lastmod, changefreq)
                
                console.print(table)
                if len(urls) > 20:
                    console.print(f"[yellow]... and {len(urls) - 20} more URLs[/yellow]")
            else:
                console.print("[yellow]No URLs found in sitemap[/yellow]")

class DNSDoHChecker:
    DEFAULT_PROVIDERS = {
        "Cloudflare": "https://cloudflare-dns.com/dns-query",
        "Google": "https://dns.google/resolve",
        "Quad9": "https://dns.quad9.net:5053/dns-query",
        "AdGuard": "https://dns.adguard.com/dns-query"
    }

    @staticmethod
    def query_doh(url, domain, qtype="A", timeout=10):
        params = {"name": domain, "type": qtype}
        headers = {"Accept": "application/dns-json"}
        start_time = time.time()
        
        try:
            response = requests.get(url, params=params, headers=headers, timeout=timeout, verify=False)
            latency = int((time.time() - start_time) * 1000)
            
            if response.ok:
                data = response.json()
                answers = [a.get("data") for a in data.get("Answer", []) if a.get("type") == (1 if qtype == "A" else 28)]
                return response.status_code, ",".join(answers) or "No records", latency
            return response.status_code, "Error", latency
        except Exception:
            return "ERR", "Connection failed", -1

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] DNS over HTTPS Check for: [cyan]{domain}[/cyan][/white]")
        
        results = []
        with Progress(SpinnerColumn(), TextColumn("Querying DoH providers..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(DNSDoHChecker.DEFAULT_PROVIDERS))
            
            for name, url in DNSDoHChecker.DEFAULT_PROVIDERS.items():
                code, records, latency = DNSDoHChecker.query_doh(url, domain)
                results.append((name, code, records, latency))
                prog.advance(task)
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Provider", style="cyan")
        table.add_column("Status", style="green")
        table.add_column("Records", style="yellow")
        table.add_column("Latency (ms)", style="white")
        
        for name, code, records, latency in results:
            status_color = "green" if code == 200 else "red"
            latency_str = str(latency) if latency >= 0 else "N/A"
            table.add_row(name, f"[{status_color}]{code}[/{status_color}]", records, latency_str)
        
        console.print(table)

class DNSCAAChecker:
    @staticmethod
    def check_caa_records(domain, timeout=10):
        try:
            resolver = dns.resolver.Resolver()
            resolver.timeout = timeout
            answers = resolver.resolve(domain, "CAA")
            
            records = []
            for record in answers:
                records.append({
                    'flags': record.flags,
                    'tag': record.tag,
                    'value': record.value
                })
            return records
        except Exception:
            return []

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] DNS CAA Records Check for: [cyan]{domain}[/cyan][/white]")
        
        zones = [domain, f"www.{domain}"]
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Zone", style="cyan")
        table.add_column("Flags", style="green")
        table.add_column("Tag", style="yellow")
        table.add_column("Value", style="white")
        
        total_records = 0
        for zone in zones:
            records = DNSCAAChecker.check_caa_records(zone)
            if records:
                for record in records:
                    table.add_row(zone, str(record['flags']), record['tag'], record['value'])
                    total_records += 1
            else:
                table.add_row(zone, "N/A", "N/A", "No CAA records found")
        
        console.print(table)
        console.print(f"[green]Found {total_records} CAA record(s)[/green]")

class GeoDNS:
    DEFAULT_RESOLVERS = [
        ("Google", "US", "8.8.8.8"),
        ("Google2", "US", "8.8.4.4"),
        ("Cloudflare", "US", "1.1.1.1"),
        ("Cloudflare2", "US", "1.0.0.1"),
        ("Quad9", "CH", "9.9.9.9"),
        ("OpenDNS", "US", "208.67.222.222"),
        ("Yandex", "RU", "77.88.8.8"),
        ("AdGuard", "CY", "94.140.14.14"),
        ("AliDNS", "CN", "223.5.5.5"),
        ("Baidu", "CN", "180.76.76.76")
    ]

    @staticmethod
    def resolve_with_server(server_ip, domain, timeout=10):
        try:
            resolver = dns.resolver.Resolver(configure=False)
            resolver.nameservers = [server_ip]
            resolver.timeout = timeout
            answers = resolver.resolve(domain, "A")
            return [str(answer) for answer in answers]
        except Exception:
            return []

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] Geographic DNS Analysis for: [cyan]{domain}[/cyan][/white]")
        
        results = []
        ip_distribution = defaultdict(list)
        
        with Progress(SpinnerColumn(), TextColumn("Querying global resolvers..."), BarColumn(), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(GeoDNS.DEFAULT_RESOLVERS))
            
            for name, country, server_ip in GeoDNS.DEFAULT_RESOLVERS:
                ips = GeoDNS.resolve_with_server(server_ip, domain)
                results.append((name, country, server_ip, ", ".join(ips) if ips else "No response"))
                
                for ip in ips:
                    ip_distribution[ip].append(name)
                
                prog.advance(task)
        
        # Display resolver results
        table1 = Table(show_header=True, header_style="bold white")
        table1.add_column("Resolver", style="cyan")
        table1.add_column("Country", style="green")
        table1.add_column("DNS IP", style="yellow")
        table1.add_column("Response", style="white")
        
        for name, country, server_ip, response in results:
            table1.add_row(name, country, server_ip, response)
        
        console.print(table1)
        
        # Display IP distribution
        if ip_distribution:
            table2 = Table(show_header=True, header_style="bold white")
            table2.add_column("IP Address", style="cyan")
            table2.add_column("Seen By", style="green")
            table2.add_column("Resolvers", style="white")
            
            for ip, resolvers in sorted(ip_distribution.items(), key=lambda x: len(x[1]), reverse=True):
                table2.add_row(ip, str(len(resolvers)), ", ".join(resolvers[:5]) + ("..." if len(resolvers) > 5 else ""))
            
            console.print(table2)

class HTMLCommentCrawler:
    @staticmethod
    def get_page_content(url, timeout=10):
        try:
            response = requests.get(url, timeout=timeout, verify=False, allow_redirects=True)
            return response.status_code, response.text, response.url
        except Exception:
            return "ERR", "", url

    @staticmethod
    def extract_comments(html):
        import re
        comment_pattern = re.compile(r'<!--(.*?)-->', re.DOTALL)
        comments = []
        
        suspicious_keywords = ["todo", "fixme", "api", "key", "secret", "password", "staging", "debug", "test", "internal"]
        
        for match in comment_pattern.finditer(html):
            comment_text = match.group(1).strip()
            if comment_text:
                is_suspicious = any(keyword in comment_text.lower() for keyword in suspicious_keywords)
                snippet = comment_text if len(comment_text) <= 200 else comment_text[:197] + "..."
                comments.append((snippet, "Suspicious" if is_suspicious else "Normal"))
        
        return comments

    @staticmethod
    def crawl_pages(domain, max_pages=10):
        pages = []
        base_url = f"https://{domain}"
        
        # Try to get the main page
        status, html, final_url = HTMLCommentCrawler.get_page_content(base_url)
        if status == "ERR":
            base_url = f"http://{domain}"
            status, html, final_url = HTMLCommentCrawler.get_page_content(base_url)
        
        if status != "ERR":
            pages.append((final_url, status, html))
            
            # Try some common pages
            common_paths = ['/about', '/contact', '/sitemap', '/robots.txt', '/index.html']
            for path in common_paths[:max_pages-1]:
                url = base_url.rstrip('/') + path
                status, html, final_url = HTMLCommentCrawler.get_page_content(url)
                if status not in ["ERR", 404]:
                    pages.append((final_url, status, html))
        
        return pages

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] HTML Comment Analysis for: [cyan]{domain}[/cyan][/white]")
        
        with Progress(SpinnerColumn(), TextColumn("Crawling pages..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=1)
            pages = HTMLCommentCrawler.crawl_pages(domain)
            prog.advance(task)
        
        all_comments = []
        for url, status, html in pages:
            if html:
                comments = HTMLCommentCrawler.extract_comments(html)
                for comment, flag in comments:
                    all_comments.append((url, comment, flag))
        
        if all_comments:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("URL", style="cyan")
            table.add_column("Comment", style="white")
            table.add_column("Flag", style="green")
            
            for url, comment, flag in all_comments:
                flag_color = "red" if flag == "Suspicious" else "green"
                table.add_row(url, comment, f"[{flag_color}]{flag}[/{flag_color}]")
            
            console.print(table)
            console.print(f"[green]Found {len(all_comments)} HTML comment(s)[/green]")
        else:
            console.print("[yellow]No HTML comments found[/yellow]")

class LazyLoadFinder:
    @staticmethod
    def extract_resources(html, base_url):
        import re
        from urllib.parse import urljoin, urlparse
        
        # Patterns for different types of resources
        static_pattern = re.compile(r'<(?:script|img|link)[^>]+(?:src|href)=["\']([^"\']+)["\']', re.I)
        lazy_pattern = re.compile(r'data-(?:src|href|lazy-src)=["\']([^"\']+)["\']', re.I)
        fetch_patterns = [
            re.compile(r'fetch\(["\']([^"\']+)["\']', re.I),
            re.compile(r'\$\.(?:get|post|ajax|load)\(["\']([^"\']+)["\']', re.I),
            re.compile(r'axios\.(?:get|post|put|delete)\(["\']([^"\']+)["\']', re.I),
        ]
        
        static_resources = []
        lazy_resources = []
        
        # Extract static resources
        for match in static_pattern.finditer(html):
            url = urljoin(base_url, match.group(1))
            if urlparse(url).netloc == urlparse(base_url).netloc:
                static_resources.append(url)
        
        # Extract lazy-loaded resources
        for match in lazy_pattern.finditer(html):
            url = urljoin(base_url, match.group(1))
            if urlparse(url).netloc == urlparse(base_url).netloc:
                lazy_resources.append(url)
        
        # Extract dynamic fetch resources
        for pattern in fetch_patterns:
            for match in pattern.finditer(html):
                url = urljoin(base_url, match.group(1))
                if urlparse(url).netloc == urlparse(base_url).netloc:
                    lazy_resources.append(url)
        
        return list(set(static_resources)), list(set(lazy_resources))

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'http://' + target
        
        console.print(f"[white][*] Lazy Load Resource Analysis for: [cyan]{target}[/cyan][/white]")
        
        try:
            response = requests.get(target, timeout=10, verify=False)
            if response.status_code != 200:
                console.print(f"[red]Error: HTTP {response.status_code}[/red]")
                return
            
            static_resources, lazy_resources = LazyLoadFinder.extract_resources(response.text, target)
            
            if static_resources or lazy_resources:
                table = Table(show_header=True, header_style="bold white")
                table.add_column("Type", style="cyan")
                table.add_column("URL", style="white")
                
                for url in static_resources[:20]:  # Limit to first 20
                    table.add_row("Static", url)
                
                for url in lazy_resources[:20]:  # Limit to first 20
                    table.add_row("Lazy/Dynamic", url)
                
                console.print(table)
                console.print(f"[green]Found {len(static_resources)} static and {len(lazy_resources)} lazy/dynamic resources[/green]")
            else:
                console.print("[yellow]No resources found[/yellow]")
                
        except Exception as e:
            console.print(f"[red]Error: {str(e)}[/red]")

class DNSHistory:
    @staticmethod
    def fetch_threatcrowd(domain, timeout=10):
        try:
            r = requests.get(f"https://www.threatcrowd.org/searchApi/v2/domain/report/?domain={domain}", timeout=timeout, verify=False)
            if r.status_code == 200:
                data = r.json()
                ips = data.get("ips", [])
                return [(ip, None, None, "ThreatCrowd") for ip in ips]
        except Exception:
            pass
        return []

    @staticmethod
    def fetch_hackertarget(domain, timeout=10):
        try:
            r = requests.get(f"https://api.hackertarget.com/dnslookup/?q={domain}", timeout=timeout, verify=False)
            if r.status_code == 200 and "error" not in r.text.lower():
                results = []
                for line in r.text.splitlines():
                    if "A\t" in line:
                        try:
                            ip = line.split("\t")[-1].strip()
                            results.append((ip, None, None, "HackerTarget"))
                        except Exception:
                            pass
                return results
        except Exception:
            pass
        return []

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] DNS History Lookup for: [cyan]{domain}[/cyan][/white]")
        
        all_records = []
        
        with Progress(SpinnerColumn(), TextColumn("Fetching DNS history..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=2)
            
            # ThreatCrowd
            records = DNSHistory.fetch_threatcrowd(domain)
            all_records.extend(records)
            prog.advance(task)
            
            # HackerTarget
            records = DNSHistory.fetch_hackertarget(domain)
            all_records.extend(records)
            prog.advance(task)
        
        if all_records:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("IP Address", style="cyan")
            table.add_column("First Seen", style="green")
            table.add_column("Last Seen", style="yellow")
            table.add_column("Source", style="white")
            
            for ip, first_seen, last_seen, source in all_records:
                table.add_row(
                    ip or "N/A",
                    str(first_seen) if first_seen else "Unknown",
                    str(last_seen) if last_seen else "Unknown",
                    source
                )
            
            console.print(table)
            console.print(f"[green]Found {len(all_records)} historical DNS record(s)[/green]")
        else:
            console.print("[yellow]No DNS history found[/yellow]")

class PeerMapper:
    @staticmethod
    def resolve_ips(domain, timeout=10):
        ips = []
        for rtype in ("A", "AAAA"):
            try:
                resolver = dns.resolver.Resolver()
                resolver.timeout = timeout
                answers = resolver.resolve(domain, rtype)
                ips.extend([str(r) for r in answers])
            except Exception:
                pass
        return list(set(ips))

    @staticmethod
    def ip_to_asn(ip, timeout=10):
        try:
            r = requests.get(f"https://api.bgpview.io/ip/{ip}", timeout=timeout, verify=False)
            if r.ok:
                prefixes = r.json().get("data", {}).get("prefixes", [])
                if prefixes:
                    return str(prefixes[0].get("asn", "Unknown"))
        except Exception:
            pass
        return "Unknown"

    @staticmethod
    def fetch_asn_peers(asn, timeout=10):
        try:
            r = requests.get(f"https://api.bgpview.io/asn/{asn}/peers", timeout=timeout, verify=False)
            if r.ok:
                peers = r.json().get("data", {}).get("peers", [])
                return [(f"AS{p.get('asn', 'Unknown')}", p.get('name', 'Unknown'), p.get('country_code', 'Unknown')) for p in peers]
        except Exception:
            pass
        return []

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] Network Peer Mapping for: [cyan]{domain}[/cyan][/white]")
        
        # Resolve IPs
        ips = PeerMapper.resolve_ips(domain)
        if not ips:
            console.print("[red]No IPs found for domain[/red]")
            return
        
        # Get ASN for first IP
        asn = PeerMapper.ip_to_asn(ips[0])
        if asn == "Unknown":
            console.print("[yellow]Could not determine ASN[/yellow]")
            return
        
        console.print(f"[white]Domain resolves to ASN: [cyan]AS{asn}[/cyan][/white]")
        
        # Get peers
        peers = PeerMapper.fetch_asn_peers(asn)
        
        if peers:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Peer ASN", style="cyan")
            table.add_column("Name", style="green")
            table.add_column("Country", style="yellow")
            
            for peer_asn, name, country in peers[:20]:  # Limit to first 20
                table.add_row(peer_asn, name, country)
            
            console.print(table)
            console.print(f"[green]Found {len(peers)} peer(s)[/green]")
        else:
            console.print("[yellow]No peers found[/yellow]")

class PixelTrackerFinder:
    @staticmethod
    def get_page_content(url, timeout=10):
        try:
            response = requests.get(url, timeout=timeout, verify=False, allow_redirects=True)
            return response.status_code, response.text, response.url
        except Exception:
            return "ERR", "", url

    @staticmethod
    def find_pixel_trackers(html, base_url):
        import re
        from urllib.parse import urljoin, urlparse
        
        # Patterns for tracking pixels
        img_pattern = re.compile(r"<img([^>]*)>", re.I)
        attr_pattern = re.compile(r'([a-zA-Z_:-]+)\s*=\s*["\']([^"\']*)["\']')
        
        tracker_signals = ["pixel", "track", "analytics", "beacon", "utm_", "ga(", "gtag(", "ads", "conversion"]
        
        trackers = []
        
        for img_match in img_pattern.finditer(html):
            attrs_text = img_match.group(1)
            attrs = dict(attr_pattern.findall(attrs_text))
            
            width = attrs.get("width", "")
            height = attrs.get("height", "")
            style = attrs.get("style", "").lower()
            src = attrs.get("src", "")
            
            if src:
                full_src = urljoin(base_url, src)
                tracker_type = "Unknown"
                
                # Check for 1x1 pixel
                if width == "1" and height == "1":
                    tracker_type = "1x1 Pixel"
                # Check for hidden elements
                elif "display:none" in style or "opacity:0" in style:
                    tracker_type = "Hidden Element"
                # Check for tracking signals
                elif any(signal in src.lower() for signal in tracker_signals):
                    tracker_type = "Tracking Pixel"
                # Check if external domain
                elif urlparse(full_src).netloc != urlparse(base_url).netloc:
                    tracker_type = "External Resource"
                
                if tracker_type != "Unknown":
                    trackers.append((full_src, tracker_type, f"{width}x{height}" if width and height else "Unknown"))
        
        return trackers

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'http://' + target
        
        console.print(f"[white][*] Pixel Tracker Analysis for: [cyan]{target}[/cyan][/white]")
        
        status, html, final_url = PixelTrackerFinder.get_page_content(target)
        if status == "ERR":
            console.print("[red]Failed to fetch page content[/red]")
            return
        
        trackers = PixelTrackerFinder.find_pixel_trackers(html, final_url)
        
        if trackers:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("URL", style="cyan")
            table.add_column("Type", style="yellow")
            table.add_column("Dimensions", style="green")
            
            for url, tracker_type, dimensions in trackers:
                table.add_row(url, tracker_type, dimensions)
            
            console.print(table)
            console.print(f"[green]Found {len(trackers)} potential tracker(s)[/green]")
        else:
            console.print("[yellow]No pixel trackers found[/yellow]")

class RDAPLookup:
    @staticmethod
    def fetch_rdap(endpoint, timeout=10):
        try:
            r = requests.get(endpoint, timeout=timeout, verify=False)
            if r.status_code == 200:
                return r.json()
        except Exception:
            pass
        return {}

    @staticmethod
    def parse_rdap_data(data):
        network_info = []
        entities_info = []
        events_info = []
        
        # Parse network information
        network = data.get("network", {})
        if network:
            network_info = [
                ("Handle", network.get("handle", "N/A")),
                ("Name", network.get("name", "N/A")),
                ("Type", network.get("type", "N/A")),
                ("Country", network.get("country", "N/A")),
                ("Start Address", network.get("startAddress", "N/A")),
                ("End Address", network.get("endAddress", "N/A")),
            ]
        
        # Parse entities
        for entity in data.get("entities", []):
            roles = ", ".join(entity.get("roles", []))
            vcard = entity.get("vcardArray", [[], []])[1] if entity.get("vcardArray") else []
            name = "N/A"
            emails = []
            
            for item in vcard:
                if len(item) >= 4:
                    if item[0] == "fn":
                        name = item[3]
                    elif item[0] == "email":
                        emails.append(item[3])
            
            entities_info.append((roles or "N/A", name, ", ".join(emails) or "N/A"))
        
        # Parse events
        for event in data.get("events", []):
            events_info.append((event.get("eventAction", "N/A"), event.get("eventDate", "N/A")))
        
        return network_info, entities_info, events_info

    @staticmethod
    def run(target):
        # Check if target is IP or domain
        try:
            import ipaddress
            ipaddress.ip_address(target)
            is_ip = True
        except Exception:
            is_ip = False
        
        if not is_ip:
            target = clean_domain_input(target)
            ip = resolve_to_ip(target)
            if not ip:
                console.print("[red]Could not resolve domain to IP[/red]")
                return
        else:
            ip = target
        
        console.print(f"[white][*] RDAP Lookup for: [cyan]{ip}[/cyan][/white]")
        
        # Try RDAP lookup
        rdap_url = f"https://rdap.org/ip/{ip}"
        data = RDAPLookup.fetch_rdap(rdap_url)
        
        if not data:
            console.print("[yellow]No RDAP data available[/yellow]")
            return
        
        network_info, entities_info, events_info = RDAPLookup.parse_rdap_data(data)
        
        # Display network information
        if network_info:
            net_table = Table(show_header=True, header_style="bold white")
            net_table.add_column("Field", style="cyan")
            net_table.add_column("Value", style="white")
            
            for field, value in network_info:
                net_table.add_row(field, value)
            
            console.print(net_table)
        
        # Display entities
        if entities_info:
            ent_table = Table(show_header=True, header_style="bold white")
            ent_table.add_column("Roles", style="cyan")
            ent_table.add_column("Name", style="green")
            ent_table.add_column("Emails", style="yellow")
            
            for roles, name, emails in entities_info:
                ent_table.add_row(roles, name, emails)
            
            console.print(ent_table)

class TXTRecords:
    @staticmethod
    def get_txt_records(domain, timeout=10):
        try:
            resolver = dns.resolver.Resolver()
            resolver.timeout = timeout
            answers = resolver.resolve(domain, "TXT")
            return [str(record).strip('"') for record in answers]
        except Exception:
            return []

    @staticmethod
    def analyze_txt_records(records):
        analysis = []
        
        for record in records:
            record_type = "Generic"
            
            if record.startswith("v=spf1"):
                record_type = "SPF"
            elif record.startswith("v=DMARC1"):
                record_type = "DMARC"
            elif record.startswith("v=DKIM1"):
                record_type = "DKIM"
            elif "google-site-verification" in record:
                record_type = "Google Verification"
            elif "MS=" in record:
                record_type = "Microsoft Verification"
            elif "_domainkey" in record:
                record_type = "Domain Key"
            elif record.startswith("facebook-domain-verification"):
                record_type = "Facebook Verification"
            
            analysis.append((record, record_type))
        
        return analysis

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] TXT Records Analysis for: [cyan]{domain}[/cyan][/white]")
        
        records = TXTRecords.get_txt_records(domain)
        
        if not records:
            console.print("[yellow]No TXT records found[/yellow]")
            return
        
        analysis = TXTRecords.analyze_txt_records(records)
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Record", style="white")
        table.add_column("Type", style="cyan")
        
        for record, record_type in analysis:
            # Truncate long records for display
            display_record = record if len(record) <= 80 else record[:77] + "..."
            table.add_row(display_record, record_type)
        
        console.print(table)
        console.print(f"[green]Found {len(records)} TXT record(s)[/green]")

class SSLAnalysis:
    @staticmethod
    def get_ssl_certificate(domain, port=443, timeout=10):
        try:
            import ssl
            import socket
            from datetime import datetime
            
            context = ssl.create_default_context()
            with socket.create_connection((domain, port), timeout=timeout) as sock:
                with context.wrap_socket(sock, server_hostname=domain) as ssock:
                    cert = ssock.getpeercert()
                    return cert
        except Exception as e:
            return None

    @staticmethod
    def analyze_certificate(cert_data):
        if not cert_data:
            return {}
        
        from datetime import datetime
        
        analysis = {}
        
        # Subject information
        subject = dict(x[0] for x in cert_data.get('subject', []))
        analysis['Common Name'] = subject.get('commonName', 'N/A')
        analysis['Organization'] = subject.get('organizationName', 'N/A')
        analysis['Country'] = subject.get('countryName', 'N/A')
        
        # Issuer information
        issuer = dict(x[0] for x in cert_data.get('issuer', []))
        analysis['Issuer'] = issuer.get('commonName', 'N/A')
        analysis['Issuer Organization'] = issuer.get('organizationName', 'N/A')
        
        # Validity dates
        try:
            not_before = datetime.strptime(cert_data['notBefore'], '%b %d %H:%M:%S %Y %Z')
            not_after = datetime.strptime(cert_data['notAfter'], '%b %d %H:%M:%S %Y %Z')
            analysis['Valid From'] = not_before.strftime('%Y-%m-%d %H:%M:%S')
            analysis['Valid Until'] = not_after.strftime('%Y-%m-%d %H:%M:%S')
            
            # Days until expiry
            days_left = (not_after - datetime.utcnow()).days
            analysis['Days Until Expiry'] = str(days_left)
            
            if days_left < 30:
                analysis['Expiry Status'] = 'Expires Soon'
            elif days_left < 0:
                analysis['Expiry Status'] = 'Expired'
            else:
                analysis['Expiry Status'] = 'Valid'
                
        except Exception:
            analysis['Valid From'] = 'N/A'
            analysis['Valid Until'] = 'N/A'
            analysis['Days Until Expiry'] = 'N/A'
            analysis['Expiry Status'] = 'Unknown'
        
        # Other details
        analysis['Serial Number'] = cert_data.get('serialNumber', 'N/A')
        analysis['Version'] = str(cert_data.get('version', 'N/A'))
        
        # Subject Alternative Names
        san_list = []
        for ext in cert_data.get('subjectAltName', []):
            if ext[0] == 'DNS':
                san_list.append(ext[1])
        analysis['Subject Alt Names'] = ', '.join(san_list) if san_list else 'None'
        
        return analysis

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] SSL Certificate Analysis for: [cyan]{domain}[/cyan][/white]")
        
        cert = SSLAnalysis.get_ssl_certificate(domain)
        if not cert:
            console.print("[red]Failed to retrieve SSL certificate[/red]")
            return
        
        analysis = SSLAnalysis.analyze_certificate(cert)
        
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Certificate Field", style="cyan")
        table.add_column("Value", style="white")
        
        for field, value in analysis.items():
            # Color code expiry status
            if field == 'Expiry Status':
                if value == 'Expired':
                    value = f"[red]{value}[/red]"
                elif value == 'Expires Soon':
                    value = f"[yellow]{value}[/yellow]"
                else:
                    value = f"[green]{value}[/green]"
            
            table.add_row(field, str(value))
        
        console.print(table)

class HTTPSecurityHeaders:
    SECURITY_HEADERS = {
        'Strict-Transport-Security': 'HSTS',
        'Content-Security-Policy': 'CSP',
        'X-Frame-Options': 'Clickjacking Protection',
        'X-Content-Type-Options': 'MIME Sniffing Protection',
        'X-XSS-Protection': 'XSS Protection',
        'Referrer-Policy': 'Referrer Policy',
        'Permissions-Policy': 'Feature Policy',
        'Cross-Origin-Opener-Policy': 'COOP',
        'Cross-Origin-Resource-Policy': 'CORP',
        'Access-Control-Allow-Origin': 'CORS Origin',
        'Access-Control-Allow-Credentials': 'CORS Credentials'
    }

    @staticmethod
    def get_security_headers(url, timeout=10):
        try:
            response = requests.get(url, timeout=timeout, verify=False, allow_redirects=True)
            return dict(response.headers), response.status_code
        except Exception as e:
            return {}, 0

    @staticmethod
    def analyze_security_headers(headers):
        analysis = {}
        
        for header, description in HTTPSecurityHeaders.SECURITY_HEADERS.items():
            value = headers.get(header)
            if value:
                analysis[description] = {'status': 'Present', 'value': value}
            else:
                analysis[description] = {'status': 'Missing', 'value': 'Not configured'}
        
        return analysis

    @staticmethod
    def check_vulnerabilities(headers):
        issues = []
        
        # Check HSTS
        hsts = headers.get('Strict-Transport-Security', '')
        if not hsts:
            issues.append('Missing HSTS header')
        elif 'max-age=0' in hsts:
            issues.append('HSTS disabled (max-age=0)')
        
        # Check CSP
        csp = headers.get('Content-Security-Policy', '')
        if not csp:
            issues.append('Missing Content Security Policy')
        elif "'unsafe-inline'" in csp:
            issues.append('CSP allows unsafe-inline')
        elif "'unsafe-eval'" in csp:
            issues.append('CSP allows unsafe-eval')
        
        # Check X-Frame-Options
        xfo = headers.get('X-Frame-Options', '').upper()
        if xfo not in ['DENY', 'SAMEORIGIN']:
            issues.append('Weak or missing X-Frame-Options')
        
        # Check X-Content-Type-Options
        xcto = headers.get('X-Content-Type-Options', '').lower()
        if xcto != 'nosniff':
            issues.append('Missing X-Content-Type-Options: nosniff')
        
        return issues

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] HTTP Security Headers Analysis for: [cyan]{target}[/cyan][/white]")
        
        headers, status_code = HTTPSecurityHeaders.get_security_headers(target)
        if status_code == 0:
            console.print("[red]Failed to fetch HTTP headers[/red]")
            return
        
        console.print(f"[white]HTTP Status: [green]{status_code}[/green][/white]")
        
        analysis = HTTPSecurityHeaders.analyze_security_headers(headers)
        
        # Display security headers
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Security Header", style="cyan")
        table.add_column("Status", style="white")
        table.add_column("Value", style="green")
        
        for header, info in analysis.items():
            status = info['status']
            value = info['value']
            
            # Color code status
            if status == 'Present':
                status_colored = f"[green]{status}[/green]"
            else:
                status_colored = f"[red]{status}[/red]"
            
            # Truncate long values
            if len(value) > 60:
                value = value[:57] + "..."
            
            table.add_row(header, status_colored, value)
        
        console.print(table)
        
        # Check for vulnerabilities
        issues = HTTPSecurityHeaders.check_vulnerabilities(headers)
        if issues:
            console.print(f"\n[red]Security Issues Found ({len(issues)}):[/red]")
            for i, issue in enumerate(issues, 1):
                console.print(f"[red]{i}. {issue}[/red]")
        else:
            console.print("\n[green]No major security issues found[/green]")

class JavaScriptAnalyzer:
    @staticmethod
    def extract_js_urls(html, base_url):
        import re
        from urllib.parse import urljoin
        
        script_pattern = re.compile(r"<script[^>]+src=['\"]([^'\"#]+)['\"]", re.I)
        js_urls = []
        
        for match in script_pattern.finditer(html):
            js_url = urljoin(base_url, match.group(1).strip())
            js_urls.append(js_url)
        
        return list(set(js_urls))

    @staticmethod
    def analyze_js_content(content):
        import re
        
        findings = {
            'urls': [],
            'emails': [],
            'secrets': [],
            'apis': []
        }
        
        # URL pattern
        url_pattern = re.compile(r"https?://[^\s\"'<>]+", re.I)
        findings['urls'] = url_pattern.findall(content)
        
        # Email pattern
        email_pattern = re.compile(r"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}", re.I)
        findings['emails'] = email_pattern.findall(content)
        
        # Secret patterns
        secret_patterns = [
            r"(?:AWS|AKIA|ASIA)[A-Z0-9]{16,}",
            r"AIza[0-9A-Za-z-_]{35}",
            r"xox[baprs]-[0-9a-zA-Z]{10,48}",
            r"sk_live_[0-9a-zA-Z]{24,}",
            r"(?:api[_-]?key|secret|token|bearer)[\"'=\s:]{1,10}[A-Za-z0-9_\-]{8,}"
        ]
        
        for pattern in secret_patterns:
            matches = re.findall(pattern, content, re.I)
            findings['secrets'].extend(matches)
        
        # API endpoint patterns
        api_pattern = re.compile(r"[\"'](/api/[^\"']*)[\"']", re.I)
        findings['apis'] = api_pattern.findall(content)
        
        return findings

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] JavaScript Security Analysis for: [cyan]{target}[/cyan][/white]")
        
        try:
            # Get main page
            response = requests.get(target, timeout=10, verify=False)
            if response.status_code != 200:
                console.print(f"[red]HTTP {response.status_code} error[/red]")
                return
            
            # Extract JavaScript URLs
            js_urls = JavaScriptAnalyzer.extract_js_urls(response.text, target)
            console.print(f"[white]Found {len(js_urls)} JavaScript file(s)[/white]")
            
            all_findings = {
                'urls': set(),
                'emails': set(),
                'secrets': set(),
                'apis': set()
            }
            
            # Analyze main page HTML
            main_findings = JavaScriptAnalyzer.analyze_js_content(response.text)
            for key in all_findings:
                all_findings[key].update(main_findings[key])
            
            # Analyze external JS files (limit to first 10)
            with Progress(SpinnerColumn(), TextColumn("Analyzing JS files..."), console=console, transient=True) as prog:
                task = prog.add_task("", total=min(len(js_urls), 10))
                
                for js_url in js_urls[:10]:
                    try:
                        js_response = requests.get(js_url, timeout=10, verify=False)
                        if js_response.status_code == 200:
                            js_findings = JavaScriptAnalyzer.analyze_js_content(js_response.text)
                            for key in all_findings:
                                all_findings[key].update(js_findings[key])
                    except Exception:
                        pass
                    prog.advance(task)
            
            # Display summary
            summary_table = Table(show_header=True, header_style="bold white")
            summary_table.add_column("Finding Type", style="cyan")
            summary_table.add_column("Count", style="green")
            
            summary_table.add_row("JavaScript Files", str(len(js_urls)))
            summary_table.add_row("URLs Found", str(len(all_findings['urls'])))
            summary_table.add_row("Email Addresses", str(len(all_findings['emails'])))
            summary_table.add_row("Potential Secrets", str(len(all_findings['secrets'])))
            summary_table.add_row("API Endpoints", str(len(all_findings['apis'])))
            
            console.print(summary_table)
            
            # Display detailed findings if any
            if any(len(findings) > 0 for findings in all_findings.values()):
                details_table = Table(show_header=True, header_style="bold white")
                details_table.add_column("Type", style="cyan")
                details_table.add_column("Value", style="white")
                
                for finding_type, findings in all_findings.items():
                    for finding in list(findings)[:5]:  # Limit to first 5 of each type
                        details_table.add_row(finding_type.title(), finding)
                
                console.print(details_table)
                
                if len(all_findings['secrets']) > 0:
                    console.print(f"[red]⚠️  Found {len(all_findings['secrets'])} potential secret(s)![/red]")
            
        except Exception as e:
            console.print(f"[red]Error during analysis: {str(e)}[/red]")

class CORSScanner:
    @staticmethod
    def test_cors_origin(url, origin, timeout=10):
        try:
            response = requests.get(
                url,
                headers={"Origin": origin},
                timeout=timeout,
                verify=False,
                allow_redirects=False
            )
            
            acao = response.headers.get("Access-Control-Allow-Origin")
            acac = response.headers.get("Access-Control-Allow-Credentials")
            vary = response.headers.get("Vary")
            
            return {
                'origin': origin,
                'status_code': response.status_code,
                'acao': acao,
                'acac': acac,
                'vary': vary
            }
        except Exception:
            return {
                'origin': origin,
                'status_code': 'ERROR',
                'acao': None,
                'acac': None,
                'vary': None
            }

    @staticmethod
    def classify_cors_config(origin, acao, acac, target_origin):
        if not acao:
            return "No CORS"
        
        acac_enabled = (acac or "").lower() == "true"
        
        if acao == "*":
            return "Wildcard + Credentials" if acac_enabled else "Wildcard"
        
        if acao.lower() == origin.lower():
            if origin == target_origin:
                return "Reflect Target + Creds" if acac_enabled else "Reflect Target"
            else:
                return "Reflect Other + Creds" if acac_enabled else "Reflect Other"
        
        if target_origin in acao:
            return "Subdomain Pattern + Creds" if acac_enabled else "Subdomain Pattern"
        
        return "Other Configuration"

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        from urllib.parse import urlparse
        
        console.print(f"[white][*] CORS Misconfiguration Scanner for: [cyan]{target}[/cyan][/white]")
        
        parsed = urlparse(target)
        target_origin = f"{parsed.scheme}://{parsed.netloc}"
        domain = parsed.netloc
        
        # Test origins
        test_origins = [
            target_origin,
            "https://evil.example.com",
            "http://evil.example.com",
            "null",
            f"https://sub.{domain}",
            f"http://{domain}",
            f"https://{domain}.evil.com"
        ]
        
        results = []
        
        with Progress(SpinnerColumn(), TextColumn("Testing CORS origins..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(test_origins))
            
            for origin in test_origins:
                result = CORSScanner.test_cors_origin(target, origin)
                classification = CORSScanner.classify_cors_config(
                    origin, result['acao'], result['acac'], target_origin
                )
                result['classification'] = classification
                results.append(result)
                prog.advance(task)
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Origin", style="cyan")
        table.add_column("ACAO", style="green")
        table.add_column("ACAC", style="yellow")
        table.add_column("Classification", style="white")
        table.add_column("Status", style="blue")
        
        vulnerabilities = []
        
        for result in results:
            acao = result['acao'] or "None"
            acac = "Yes" if result['acac'] == "true" else "No"
            classification = result['classification']
            status = str(result['status_code'])
            
            # Check for vulnerabilities
            if "Wildcard + Credentials" in classification:
                vulnerabilities.append("Wildcard CORS with credentials enabled")
            elif "Reflect Other + Creds" in classification:
                vulnerabilities.append("CORS reflects arbitrary origins with credentials")
            
            # Color code dangerous configurations
            if "Wildcard + Credentials" in classification or "Reflect Other + Creds" in classification:
                classification = f"[red]{classification}[/red]"
            elif "Wildcard" in classification or "Reflect" in classification:
                classification = f"[yellow]{classification}[/yellow]"
            else:
                classification = f"[green]{classification}[/green]"
            
            table.add_row(result['origin'], acao, acac, classification, status)
        
        console.print(table)
        
        if vulnerabilities:
            console.print(f"\n[red]CORS Vulnerabilities Found ({len(vulnerabilities)}):[/red]")
            for i, vuln in enumerate(vulnerabilities, 1):
                console.print(f"[red]{i}. {vuln}[/red]")
        else:
            console.print("\n[green]No CORS vulnerabilities detected[/green]")

class ClickjackingTester:
    @staticmethod
    def test_clickjacking_protection(url, timeout=10):
        try:
            response = requests.get(url, timeout=timeout, verify=False, allow_redirects=True)
            
            xfo = response.headers.get("X-Frame-Options", "")
            csp = response.headers.get("Content-Security-Policy", "")
            
            # Check X-Frame-Options
            xfo_protection = False
            if xfo.upper() in ["DENY", "SAMEORIGIN"]:
                xfo_protection = True
            
            # Check CSP frame-ancestors
            csp_protection = False
            if "frame-ancestors" in csp.lower():
                if "'none'" in csp.lower() or "'self'" in csp.lower():
                    csp_protection = True
            
            vulnerable = not (xfo_protection or csp_protection)
            
            return {
                'url': url,
                'xfo': xfo or "Not Set",
                'csp': csp[:60] + "..." if len(csp) > 60 else csp or "Not Set",
                'vulnerable': vulnerable,
                'status_code': response.status_code
            }
        except Exception:
            return {
                'url': url,
                'xfo': "Error",
                'csp': "Error",
                'vulnerable': True,
                'status_code': 'ERROR'
            }

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Clickjacking Protection Test for: [cyan]{target}[/cyan][/white]")
        
        # Test main page and common paths
        test_urls = [
            target,
            target.rstrip('/') + '/login',
            target.rstrip('/') + '/admin',
            target.rstrip('/') + '/dashboard'
        ]
        
        results = []
        vulnerable_count = 0
        
        with Progress(SpinnerColumn(), TextColumn("Testing pages..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(test_urls))
            
            for url in test_urls:
                result = ClickjackingTester.test_clickjacking_protection(url)
                results.append(result)
                if result['vulnerable']:
                    vulnerable_count += 1
                prog.advance(task)
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("URL", style="cyan")
        table.add_column("X-Frame-Options", style="green")
        table.add_column("CSP", style="yellow")
        table.add_column("Vulnerable", style="white")
        table.add_column("Status", style="blue")
        
        for result in results:
            vulnerable_text = "Yes" if result['vulnerable'] else "No"
            vulnerable_color = "red" if result['vulnerable'] else "green"
            
            table.add_row(
                result['url'],
                result['xfo'],
                result['csp'],
                f"[{vulnerable_color}]{vulnerable_text}[/{vulnerable_color}]",
                str(result['status_code'])
            )
        
        console.print(table)
        
        if vulnerable_count > 0:
            console.print(f"\n[red]⚠️  {vulnerable_count} page(s) vulnerable to clickjacking![/red]")
        else:
            console.print("\n[green]All tested pages are protected against clickjacking[/green]")

class CookieAnalyzer:
    @staticmethod
    def get_cookies(url, timeout=10):
        try:
            session = requests.Session()
            response = session.get(url, timeout=timeout, verify=False, allow_redirects=True)
            return list(session.cookies), response.status_code
        except Exception:
            return [], 0

    @staticmethod
    def analyze_cookie_security(cookies):
        analysis = []
        
        for cookie in cookies:
            issues = []
            
            # Check Secure flag
            if not cookie.secure:
                issues.append("Missing Secure flag")
            
            # Check HttpOnly flag
            if not hasattr(cookie, '_rest') or 'HttpOnly' not in cookie._rest:
                issues.append("Missing HttpOnly flag")
            
            # Check SameSite
            samesite = None
            if hasattr(cookie, '_rest') and cookie._rest:
                for key, value in cookie._rest.items():
                    if key.lower() == 'samesite':
                        samesite = value
                        break
            
            if not samesite:
                issues.append("Missing SameSite attribute")
            elif samesite.lower() == 'none' and not cookie.secure:
                issues.append("SameSite=None without Secure flag")
            
            # Classify cookie type
            cookie_type = "Other"
            name_lower = cookie.name.lower()
            if any(x in name_lower for x in ['session', 'sess', 'auth', 'token', 'jwt']):
                cookie_type = "Authentication"
            elif any(x in name_lower for x in ['ga', 'utm', 'fbp', 'track']):
                cookie_type = "Tracking"
            
            analysis.append({
                'name': cookie.name,
                'type': cookie_type,
                'domain': cookie.domain or "Current domain",
                'path': cookie.path or "/",
                'secure': cookie.secure,
                'httponly': hasattr(cookie, '_rest') and 'HttpOnly' in (cookie._rest or {}),
                'samesite': samesite or "Not set",
                'issues': issues,
                'value_length': len(cookie.value) if cookie.value else 0
            })
        
        return analysis

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Cookie Security Analysis for: [cyan]{target}[/cyan][/white]")
        
        cookies, status_code = CookieAnalyzer.get_cookies(target)
        if status_code == 0:
            console.print("[red]Failed to fetch cookies[/red]")
            return
        
        if not cookies:
            console.print("[yellow]No cookies found[/yellow]")
            return
        
        analysis = CookieAnalyzer.analyze_cookie_security(cookies)
        
        # Display cookie analysis
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Cookie Name", style="cyan")
        table.add_column("Type", style="green")
        table.add_column("Secure", style="yellow")
        table.add_column("HttpOnly", style="blue")
        table.add_column("SameSite", style="magenta")
        table.add_column("Issues", style="red")
        
        total_issues = 0
        
        for cookie_info in analysis:
            secure_text = "Yes" if cookie_info['secure'] else "No"
            httponly_text = "Yes" if cookie_info['httponly'] else "No"
            issues_text = f"{len(cookie_info['issues'])} issues" if cookie_info['issues'] else "None"
            
            total_issues += len(cookie_info['issues'])
            
            table.add_row(
                cookie_info['name'],
                cookie_info['type'],
                secure_text,
                httponly_text,
                cookie_info['samesite'],
                issues_text
            )
        
        console.print(table)
        
        # Display detailed issues
        if total_issues > 0:
            console.print(f"\n[red]Cookie Security Issues ({total_issues} total):[/red]")
            for cookie_info in analysis:
                if cookie_info['issues']:
                    console.print(f"[red]• {cookie_info['name']}: {', '.join(cookie_info['issues'])}[/red]")
        else:
            console.print("\n[green]No cookie security issues found[/green]")

class FormGrabber:
    @staticmethod
    def extract_forms(html, base_url):
        try:
            from bs4 import BeautifulSoup
        except ImportError:
            BeautifulSoup = None
        from urllib.parse import urljoin
        
        soup = BeautifulSoup(html, 'html.parser')
        forms = []
        
        for form in soup.find_all('form'):
            action = form.get('action', '') or base_url
            if action and not action.startswith(('http://', 'https://')):
                action = urljoin(base_url, action)
            
            method = form.get('method', 'GET').upper()
            enctype = form.get('enctype', 'application/x-www-form-urlencoded')
            
            # Extract form fields
            fields = []
            sensitive_fields = []
            
            for field in form.find_all(['input', 'textarea', 'select']):
                field_type = field.get('type', 'text').lower()
                field_name = field.get('name', '')
                field_id = field.get('id', '')
                
                fields.append({
                    'type': field_type,
                    'name': field_name,
                    'id': field_id
                })
                
                # Check for sensitive fields
                if any(keyword in (field_name + field_id).lower() for keyword in ['password', 'pass', 'pwd', 'secret', 'token', 'csrf', 'auth']):
                    sensitive_fields.append(field_name or field_id or f"unnamed_{field_type}")
            
            forms.append({
                'action': action,
                'method': method,
                'enctype': enctype,
                'fields': fields,
                'sensitive_fields': sensitive_fields,
                'field_count': len(fields)
            })
        
        return forms

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Form Analysis for: [cyan]{target}[/cyan][/white]")
        
        try:
            response = requests.get(target, timeout=10, verify=False)
            if response.status_code != 200:
                console.print(f"[red]HTTP {response.status_code} error[/red]")
                return
            
            forms = FormGrabber.extract_forms(response.text, target)
            
            if not forms:
                console.print("[yellow]No forms found[/yellow]")
                return
            
            # Display forms
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Action", style="cyan")
            table.add_column("Method", style="green")
            table.add_column("Fields", style="yellow")
            table.add_column("Sensitive Fields", style="red")
            table.add_column("Enctype", style="blue")
            
            total_sensitive = 0
            
            for form in forms:
                sensitive_text = ", ".join(form['sensitive_fields']) if form['sensitive_fields'] else "None"
                total_sensitive += len(form['sensitive_fields'])
                
                table.add_row(
                    form['action'],
                    form['method'],
                    str(form['field_count']),
                    sensitive_text,
                    form['enctype']
                )
            
            console.print(table)
            console.print(f"[green]Found {len(forms)} form(s) with {total_sensitive} sensitive field(s)[/green]")
            
            # Security recommendations
            security_issues = []
            for form in forms:
                if form['method'] == 'GET' and form['sensitive_fields']:
                    security_issues.append(f"Form with sensitive fields using GET method: {form['action']}")
                if 'password' in str(form['sensitive_fields']).lower() and not target.startswith('https://'):
                    security_issues.append(f"Password form over HTTP: {form['action']}")
            
            if security_issues:
                console.print(f"\n[red]Security Issues ({len(security_issues)}):[/red]")
                for issue in security_issues:
                    console.print(f"[red]• {issue}[/red]")
            
        except Exception as e:
            console.print(f"[red]Error during analysis: {str(e)}[/red]")

class ExposedAPIScanner:
    DEFAULT_API_PATHS = [
        "/api/", "/api/v1/", "/api/v2/", "/api/v3/", "/v1/", "/v2/", "/v3/",
        "/rest/", "/rest/v1/", "/graphql", "/api/graphql", "/ws", "/socket.io/",
        "/json", "/data", "/export", "/internal", "/admin/api/", "/mobileapi/",
        "/public/api/", "/status", "/health", "/metrics", "/openapi.json",
        "/swagger.json", "/api-docs", "/docs"
    ]

    @staticmethod
    def test_api_endpoint(base_url, path, timeout=10):
        url = base_url.rstrip('/') + path
        methods = ['GET', 'POST', 'OPTIONS']
        results = []
        
        for method in methods:
            try:
                if method == 'GET':
                    response = requests.get(url, timeout=timeout, verify=False, allow_redirects=False)
                elif method == 'POST':
                    response = requests.post(url, json={}, timeout=timeout, verify=False, allow_redirects=False)
                elif method == 'OPTIONS':
                    response = requests.options(url, timeout=timeout, verify=False, allow_redirects=False)
                
                # Check if response looks like API
                is_api = False
                content_type = response.headers.get('Content-Type', '').lower()
                if 'json' in content_type:
                    is_api = True
                elif response.text.strip().startswith(('{', '[')):
                    is_api = True
                
                # Calculate risk level
                risk = "Low"
                if response.status_code == 200 and is_api:
                    risk = "Medium"
                    # Check for CORS misconfig
                    acao = response.headers.get('Access-Control-Allow-Origin', '')
                    acac = response.headers.get('Access-Control-Allow-Credentials', '')
                    if acao == '*' and acac.lower() == 'true':
                        risk = "High"
                
                if response.status_code in [200, 201, 202] and is_api:
                    results.append({
                        'url': url,
                        'method': method,
                        'status': response.status_code,
                        'content_type': content_type,
                        'is_api': is_api,
                        'risk': risk,
                        'size': len(response.content)
                    })
            except Exception:
                continue
        
        return results

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Exposed API Scanner for: [cyan]{target}[/cyan][/white]")
        
        all_results = []
        
        with Progress(SpinnerColumn(), TextColumn("Scanning API endpoints..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(ExposedAPIScanner.DEFAULT_API_PATHS))
            
            for path in ExposedAPIScanner.DEFAULT_API_PATHS:
                results = ExposedAPIScanner.test_api_endpoint(target, path)
                all_results.extend(results)
                prog.advance(task)
        
        if not all_results:
            console.print("[yellow]No exposed APIs found[/yellow]")
            return
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("URL", style="cyan")
        table.add_column("Method", style="green")
        table.add_column("Status", style="yellow")
        table.add_column("Content Type", style="blue")
        table.add_column("Risk", style="white")
        table.add_column("Size", style="magenta")
        
        high_risk_count = 0
        
        for result in all_results:
            risk_color = "red" if result['risk'] == "High" else "yellow" if result['risk'] == "Medium" else "green"
            if result['risk'] == "High":
                high_risk_count += 1
            
            table.add_row(
                result['url'],
                result['method'],
                str(result['status']),
                result['content_type'],
                f"[{risk_color}]{result['risk']}[/{risk_color}]",
                f"{result['size']} bytes"
            )
        
        console.print(table)
        console.print(f"[green]Found {len(all_results)} exposed API endpoint(s)[/green]")
        
        if high_risk_count > 0:
            console.print(f"[red]⚠️  {high_risk_count} high-risk API endpoint(s) detected![/red]")

class FirewallDetector:
    FIREWALL_SIGNATURES = {
        'Cloudflare': ['cloudflare', 'cf-ray'],
        'Akamai': ['akamai', 'x-akamai'],
        'AWS Shield': ['x-amz-cf-id', 'x-amz-request-id'],
        'Sucuri': ['x-sucuri-id', 'sucuri'],
        'Imperva': ['x-cdn', 'imperva'],
        'F5 BIG-IP': ['f5', 'bigip'],
        'ModSecurity': ['mod_security', 'modsecurity']
    }

    @staticmethod
    def detect_firewall(url, timeout=10):
        detections = []
        
        try:
            # Test normal request
            response = requests.get(url, timeout=timeout, verify=False)
            headers = response.headers
            
            # Check headers for firewall signatures
            for firewall, signatures in FirewallDetector.FIREWALL_SIGNATURES.items():
                for sig in signatures:
                    for header_name, header_value in headers.items():
                        if sig.lower() in header_name.lower() or sig.lower() in header_value.lower():
                            detections.append(f"{firewall} (Header: {header_name})")
                            break
            
            # Check response body for firewall indicators
            body = response.text.lower()
            if 'access denied' in body or 'blocked' in body:
                detections.append("Generic WAF (Access Denied)")
            if 'captcha' in body:
                detections.append("CAPTCHA Challenge")
            
            # Test with suspicious payload
            try:
                malicious_response = requests.get(
                    url + "?test=<script>alert('xss')</script>",
                    timeout=timeout,
                    verify=False
                )
                if malicious_response.status_code in [403, 406, 501]:
                    detections.append("WAF Blocking (XSS Test)")
            except Exception:
                pass
            
            # Test blocked methods
            for method in ['TRACE', 'DELETE', 'PUT']:
                try:
                    method_response = requests.request(method, url, timeout=timeout, verify=False)
                    if method_response.status_code in [405, 501]:
                        detections.append(f"Method Filtering ({method} blocked)")
                        break
                except Exception:
                    continue
            
            return {
                'detections': detections,
                'status_code': response.status_code,
                'response_time': response.elapsed.total_seconds(),
                'server': headers.get('Server', 'Unknown')
            }
            
        except Exception as e:
            return {
                'detections': [f"Connection Error: {str(e)}"],
                'status_code': 0,
                'response_time': 0,
                'server': 'Unknown'
            }

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Firewall Detection for: [cyan]{target}[/cyan][/white]")
        
        with Progress(SpinnerColumn(), TextColumn("Detecting firewall..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=1)
            result = FirewallDetector.detect_firewall(target)
            prog.advance(task)
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Detection", style="cyan")
        table.add_column("Details", style="white")
        
        table.add_row("Server", result['server'])
        table.add_row("Status Code", str(result['status_code']))
        table.add_row("Response Time", f"{result['response_time']:.2f}s")
        
        if result['detections']:
            table.add_row("Firewall/WAF", f"{len(result['detections'])} detection(s)")
            console.print(table)
            
            console.print(f"\n[red]Firewall/WAF Detections ({len(result['detections'])}):[/red]")
            for i, detection in enumerate(result['detections'], 1):
                console.print(f"[red]{i}. {detection}[/red]")
        else:
            table.add_row("Firewall/WAF", "None detected")
            console.print(table)
            console.print("\n[green]No firewall or WAF detected[/green]")

class GitExposureChecker:
    GIT_PATHS = [
        "/.git/HEAD", "/.git/config", "/.git/index", "/.git/packed-refs",
        "/.git/description", "/.git/info/refs", "/.git/info/exclude",
        "/.git/logs/HEAD", "/.git/logs/refs/heads/master", "/.git/logs/refs/heads/main",
        "/.git/objects/info/packs", "/.git/refs/heads/master", "/.git/refs/heads/main",
        "/.git/refs/stash", "/.git/refs/remotes/origin/HEAD", "/.git/ORIG_HEAD",
        "/.git/FETCH_HEAD", "/.git/COMMIT_EDITMSG", "/.gitignore", "/.gitmodules"
    ]

    @staticmethod
    def check_git_exposure(base_url, path, timeout=10):
        url = base_url.rstrip('/') + path
        try:
            response = requests.get(url, timeout=timeout, verify=False, allow_redirects=False)
            return {
                'path': path,
                'status_code': response.status_code,
                'size': len(response.content),
                'exposed': response.status_code < 400 and len(response.content) > 0
            }
        except Exception:
            return {
                'path': path,
                'status_code': 'ERROR',
                'size': 0,
                'exposed': False
            }

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Git Repository Exposure Check for: [cyan]{target}[/cyan][/white]")
        
        results = []
        exposed_count = 0
        
        with Progress(SpinnerColumn(), TextColumn("Checking Git paths..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(GitExposureChecker.GIT_PATHS))
            
            for path in GitExposureChecker.GIT_PATHS:
                result = GitExposureChecker.check_git_exposure(target, path)
                results.append(result)
                if result['exposed']:
                    exposed_count += 1
                prog.advance(task)
        
        # Check for directory listing
        try:
            dir_response = requests.get(target.rstrip('/') + '/.git/', timeout=10, verify=False, allow_redirects=False)
            if dir_response.status_code == 200 and b"Index of" in dir_response.content:
                results.append({
                    'path': '/.git/ (directory listing)',
                    'status_code': 200,
                    'size': len(dir_response.content),
                    'exposed': True
                })
                exposed_count += 1
        except Exception:
            pass
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Path", style="cyan")
        table.add_column("Status", style="green")
        table.add_column("Size", style="yellow")
        table.add_column("Exposed", style="white")
        
        for result in results:
            if result['exposed']:
                exposed_text = "[red]Yes[/red]"
                status_color = "red" if result['status_code'] == 200 else "yellow"
            else:
                exposed_text = "[green]No[/green]"
                status_color = "green"
            
            table.add_row(
                result['path'],
                f"[{status_color}]{result['status_code']}[/{status_color}]",
                f"{result['size']} bytes",
                exposed_text
            )
        
        console.print(table)
        
        if exposed_count > 0:
            console.print(f"\n[red]⚠️  {exposed_count} Git file(s) exposed! This may leak source code and credentials![/red]")
        else:
            console.print("\n[green]No Git repository exposure detected[/green]")

class ExposedEnvChecker:
    ENV_FILES = [
        '.env', 'env', 'environment', '.env.php', 'config.php', 'config.yaml',
        'config.yml', 'config.json', 'config.ini', 'localsettings.php',
        'settings.php', 'db.php', 'database.php', 'wp-config.php',
