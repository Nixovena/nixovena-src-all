# Proxy Configuration
PROXY_CONFIG = {
    "enabled": False,
    "type": "socks5",  # socks5, socks4, http, https
    "host": "127.0.0.1",
    "port": 9050,  # Default Tor SOCKS port
    "username": None,
    "password": None
}

def get_proxy_dict():
    if not PROXY_CONFIG["enabled"]:
        return None
    
    proxy_type = PROXY_CONFIG["type"]
    host = PROXY_CONFIG["host"]
    port = PROXY_CONFIG["port"]
    
    if PROXY_CONFIG["username"] and PROXY_CONFIG["password"]:
        proxy_url = f"{proxy_type}://{PROXY_CONFIG['username']}:{PROXY_CONFIG['password']}@{host}:{port}"
    else:
        proxy_url = f"{proxy_type}://{host}:{port}"
    
    return {
        "http": proxy_url,
        "https": proxy_url
    }

def check_tor_connection():
    try:
        proxies = get_proxy_dict()
        if not proxies:
            return False, "Proxy not enabled"
        
        response = requests.get(
            "https://check.torproject.org/api/ip",
            proxies=proxies,
            timeout=10,
            verify=False
        )
        
        if response.ok:
            data = response.json()
            if data.get("IsTor"):
                return True, f"Connected via Tor - IP: {data.get('IP')}"
            else:
                return False, f"Not using Tor - IP: {data.get('IP')}"
    except Exception as e:
        return False, f"Connection failed: {str(e)}"
    
    return False, "Unknown error"

