# ── MODULE 1 ──────────────────────────────────────────────────
def mod_validate_address():
    box("MODULE 1 -- Address Validation (Multi-Chain)", C.GREEN)
    addr = input(f"  {C.YELLOW}Enter crypto address:{C.RESET} ").strip()
    if not addr:
        err("Address cannot be empty!"); return

    spinner("Analyzing address...")
    chains = detect_chain(addr)
    results = []

    checks = [
        ("Bitcoin",  validate_btc_address),
        ("Ethereum", validate_eth_address),
        ("Litecoin", validate_ltc_address),
        ("XRP",      validate_xrp_address),
        ("Dogecoin", validate_doge_address),
        ("TRON",     validate_trx_address),
        ("Solana",   validate_sol_address),
    ]

    print()
    for name, fn in checks:
        valid, detail = fn(addr)
        sym = f"{C.GREEN}[VALID]{C.RESET}" if valid else f"{C.RED}[--]{C.RESET}"
        print(f"  {sym}  {C.BOLD}{name:<12}{C.RESET}  {C.DIM}{detail}{C.RESET}")

    if chains:
        print(f"\n  {C.BG_GRN}{C.BOLD} RESULT {C.RESET} This address is valid on:")
        for c in chains:
            ok(c)
    else:
        print(f"\n  {C.BG_RED}{C.BOLD} RESULT {C.RESET} Not valid on any known network.")

    row("Address length", str(len(addr)))
    row("Prefix", addr[:4] + "...")

# ── MODULE 2 ──────────────────────────────────────────────────
def mod_check_eth_balance():
    box("MODULE 2 -- Ethereum Balance Query", C.GREEN)
    addr = input(f"  {C.YELLOW}ETH Address (0x...):{C.RESET} ").strip()
    valid, _ = validate_eth_address(addr)
    if not valid:
        err("Invalid ETH address!"); return

    spinner("Querying Etherscan...")
    data = eth_api("account", "balance", addr, "&tag=latest")
    if data and data.get("status") == "1":
        wei = int(data["result"])
        eth = wei / 1e18
        row("Address", addr)
        row("Balance (Wei)", f"{wei:,}")
        row("Balance (ETH)", f"{C.YELLOW}{eth:.8f} ETH{C.RESET}")
    else:
        warn("API did not respond. Balance unavailable.")
        info("Note: Add an Etherscan API key for real data.")
        row("Demo Balance", "0.00000000 ETH")
    row("Timestamp", datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"))

# ── MODULE 3 ──────────────────────────────────────────────────
def mod_check_btc_balance():
    box("MODULE 3 -- Bitcoin Balance Query", C.GREEN)
    addr = input(f"  {C.YELLOW}BTC Address:{C.RESET} ").strip()
    valid, atype = validate_btc_address(addr)
    if not valid:
        err(f"Invalid BTC address: {atype}"); return

    spinner("Querying Blockchain.info...")
    data = btc_api_balance(addr)
    if data:
        bal   = data.get("final_balance", 0) / 1e8
        recv  = data.get("total_received", 0) / 1e8
        sent  = data.get("total_sent", 0) / 1e8
        n_tx  = data.get("n_tx", 0)
        row("Address",       addr)
        row("Address Type",  atype)
        row("Current Balance",   f"{C.YELLOW}{bal:.8f} BTC{C.RESET}")
        row("Total Received",    f"{C.GREEN}+{recv:.8f} BTC{C.RESET}")
        row("Total Sent",        f"{C.RED}-{sent:.8f} BTC{C.RESET}")
        row("TX Count",          str(n_tx))
    else:
        warn("Could not reach Blockchain.info.")
        row("Address",      addr)
        row("Address Type", atype)

# ── MODULE 4 ──────────────────────────────────────────────────
def mod_check_privacy():
    box("MODULE 4 -- Address Privacy Analysis", C.MAGENTA)
    addr = input(f"  {C.YELLOW}Enter address:{C.RESET} ").strip()
    chains = detect_chain(addr)

    if not chains:
        err("Invalid address!"); return

    spinner("Running privacy analysis...")
    print()

    score = 100  # starting score

    # Public blockchain -30
    info("Blockchain Transparency:")
    row("  All transactions public?", f"{C.RED}YES{C.RESET}")
    row("  Transaction history traceable?", f"{C.RED}YES{C.RESET}")
    score -= 30

    # Address reuse analysis
    info("Address Reuse:")
    if "Bitcoin" in chains:
        data = btc_api_balance(addr)
        tx_count = data.get("n_tx", 0) if data else 0
        if tx_count > 5:
            row("  Multiple reuse detected", f"{C.RED}RISK ({tx_count} txs){C.RESET}")
            score -= 20
        else:
            row("  Reuse frequency", f"{C.GREEN}Low{C.RESET}")
    elif "Ethereum/EVM" in " ".join(chains):
        row("  EVM Address Reuse", f"{C.YELLOW}Could not verify (no API key){C.RESET}")

    # Privacy technologies
    info("Privacy Technologies:")
    row("  Monero (XMR)?",      f"{C.RED}No (different network){C.RESET}" if "Monero" not in chains else f"{C.GREEN}Yes - Private{C.RESET}")
    row("  Zcash (ZEC)?",       f"{C.RED}No{C.RESET}")
    row("  Tornado Cash Mix?",  f"{C.YELLOW}Could not detect{C.RESET}")
    row("  CoinJoin?",          f"{C.YELLOW}Could not detect{C.RESET}")

    # Network privacy
    info("Network Privacy:")
    row("  Tor/VPN recommended?", f"{C.YELLOW}YES (tracking risk){C.RESET}")
    row("  IP exposure risk?",    f"{C.RED}Possible{C.RESET}")
    score -= 10

    color = C.GREEN if score >= 70 else (C.YELLOW if score >= 40 else C.RED)
    print(f"\n  {C.BOLD}Privacy Score: {color}{score}/100{C.RESET}")
    if score >= 70:
        ok("Good privacy level")
    elif score >= 40:
        warn("Moderate privacy -- improvement recommended")
    else:
        err("Low privacy -- serious risk!")

    print(f"\n  {C.DIM}Recommendations:{C.RESET}")
    info("Use a different address per transaction")
    info("Access via Tor Browser or VPN")
    info("Consider privacy coins (XMR, ZEC)")
    info("Use CoinJoin or mixing services")

# ── MODULE 5 ──────────────────────────────────────────────────
def mod_tx_history():
    box("MODULE 5 -- Transaction History", C.CYAN)
    addr = input(f"  {C.YELLOW}BTC Address:{C.RESET} ").strip()
    valid, _ = validate_btc_address(addr)
    if not valid:
        err("Invalid BTC address!"); return

    spinner("Fetching recent transactions...")
    data = btc_api_tx(addr)
    if not data:
        warn("Could not retrieve data."); return

    txs = data.get("txs", [])[:10]
    if not txs:
        warn("No transactions found."); return

    print(f"\n  {C.BOLD}Last {len(txs)} Transactions:{C.RESET}\n")
    for i, tx in enumerate(txs, 1):
        h = tx.get("hash", "N/A")
        t = tx.get("time", 0)
        dt = datetime.datetime.fromtimestamp(t).strftime("%Y-%m-%d %H:%M") if t else "?"
        val_out = sum(o.get("value", 0) for o in tx.get("out", [])) / 1e8
        print(f"  {C.DIM}{i:>2}.{C.RESET} {C.CYAN}{h[:32]}...{C.RESET}")
        print(f"       {C.DIM}Date: {dt}  Value: {C.YELLOW}{val_out:.4f} BTC{C.RESET}")

# ── MODULE 6 ──────────────────────────────────────────────────
def mod_first_last_tx():
    box("MODULE 6 -- First & Last Transaction Dates", C.CYAN)
    addr = input(f"  {C.YELLOW}BTC Address:{C.RESET} ").strip()
    valid, _ = validate_btc_address(addr)
    if not valid:
        err("Invalid BTC address!"); return

    spinner("Querying transaction dates...")
    data = btc_api_tx(addr)
    if not data:
        warn("Could not retrieve data."); return

    txs  = data.get("txs", [])
    n_tx = data.get("n_tx", 0)
    if not txs:
        warn("No transactions found."); return

    times = [tx.get("time", 0) for tx in txs if tx.get("time")]
    if times:
        first_t = min(times)
        last_t  = max(times)
        first_dt = datetime.datetime.fromtimestamp(first_t).strftime("%Y-%m-%d %H:%M:%S")
        last_dt  = datetime.datetime.fromtimestamp(last_t).strftime("%Y-%m-%d %H:%M:%S")
        delta    = datetime.datetime.fromtimestamp(last_t) - datetime.datetime.fromtimestamp(first_t)

        row("Address",           addr)
        row("Total TX",          str(n_tx))
        row("First TX Date",     f"{C.GREEN}{first_dt}{C.RESET}")
        row("Last TX Date",      f"{C.YELLOW}{last_dt}{C.RESET}")
        row("Active Period",     f"{delta.days} days")

# ── MODULE 7 ──────────────────────────────────────────────────
def mod_address_type():
    box("MODULE 7 -- Address Type & Feature Detection", C.YELLOW)
    addr = input(f"  {C.YELLOW}ETH Address (0x...):{C.RESET} ").strip()
    valid, detail = validate_eth_address(addr)
    if not valid:
        err(f"Invalid ETH address: {detail}"); return

    spinner("Analyzing address type...")
    # Contract code check via etherscan
    data = eth_api("proxy", "eth_getCode", addr)
    is_contract = False
    if data and data.get("result") and data["result"] != "0x":
        is_contract = True

    row("Address",       addr)
    row("Format",        detail)
    if is_contract:
        row("Address Type",  f"{C.MAGENTA}SMART CONTRACT{C.RESET}")
        row("Has Code?",      f"{C.GREEN}YES{C.RESET}")
        info("This address is a smart contract (token, DEX, etc.)")
    else:
        row("Address Type",  f"{C.CYAN}EOA (Externally Owned Account){C.RESET}")
        row("Has Code?",      f"{C.RED}NO -- User wallet{C.RESET}")

    # Checksum
    lower = addr[2:].lower()
    try:
        import hashlib as hl
        kh = hl.new("sha3_256", lower.encode()).hexdigest()
        checksum = "0x" + "".join(
            c.upper() if int(kh[i], 16) >= 8 else c
            for i, c in enumerate(lower))
        row("EIP-55 Checksum", checksum)
    except:
        pass

# ── MODULE 8 ──────────────────────────────────────────────────
def mod_multi_chain_check():
    box("MODULE 8 -- Multi-Chain Asset Detection", C.CYAN)
    addr = input(f"  {C.YELLOW}Enter address:{C.RESET} ").strip()
    chains = detect_chain(addr)

    spinner("Scanning chains...")
    print(f"\n  {C.BOLD}Compatible Networks:{C.RESET}\n")

    all_chains = [
        ("Bitcoin",      "BTC",  "https://blockchain.info"),
        ("Ethereum",     "ETH",  "https://etherscan.io"),
        ("BNB Chain",    "BNB",  "https://bscscan.com"),
        ("Polygon",      "MATIC","https://polygonscan.com"),
        ("Avalanche",    "AVAX", "https://snowtrace.io"),
        ("Litecoin",     "LTC",  "https://blockchair.com/litecoin"),
        ("XRP",          "XRP",  "https://xrpscan.com"),
        ("Dogecoin",     "DOGE", "https://dogechain.info"),
        ("TRON",         "TRX",  "https://tronscan.org"),
        ("Solana",       "SOL",  "https://solscan.io"),
        ("Arbitrum",     "ARB",  "https://arbiscan.io"),
        ("Optimism",     "OP",   "https://optimistic.etherscan.io"),
        ("Fantom",       "FTM",  "https://ftmscan.com"),
        ("Cronos",       "CRO",  "https://cronoscan.com"),
    ]

    eth_based = "Ethereum/EVM (ETH, BNB, MATIC, AVAX...)" in chains
    btc_based = "Bitcoin" in chains

    for name, sym, explorer in all_chains:
        is_evm = name not in ["Bitcoin","Litecoin","XRP","Dogecoin","TRON","Solana"]
        compatible = (
            (is_evm and eth_based) or
            (name in chains) or
            (name == "BNB Chain" and eth_based) or
            (name in ["Arbitrum","Optimism","Fantom","Cronos"] and eth_based)
        )
        status = f"{C.GREEN}[OK]{C.RESET}" if compatible else f"{C.RED}[--]{C.RESET}"
        print(f"  {status}  {C.BOLD}{sym:<6}{C.RESET}  {name:<12}  {C.DIM}{explorer}{C.RESET}")

# ── MODULE 9 ──────────────────────────────────────────────────
def mod_risk_score():
    box("MODULE 9 -- Address Risk Score", C.RED)
    addr = input(f"  {C.YELLOW}Enter address:{C.RESET} ").strip()
    chains = detect_chain(addr)
    if not chains:
        err("Invalid address!"); return

    spinner("Calculating risk score...")
    print()

    risk = 0
    flags = []

    # Bitcoin analysis
    if "Bitcoin" in chains:
        data = btc_api_balance(addr)
        if data:
            n_tx   = data.get("n_tx", 0)
            bal    = data.get("final_balance", 0) / 1e8
            recv   = data.get("total_received", 0) / 1e8

            if n_tx > 100:
                risk += 20; flags.append("High transaction volume (>100 txs)")
            if bal > 10:
                risk += 15; flags.append(f"Large BTC balance ({bal:.2f} BTC)")
            if recv > 100:
                risk += 10; flags.append("High total received (>100 BTC)")
            if n_tx == 0:
                flags.append("No transactions -- clean address")

    # General address checks
    if addr.lower() in ["0x0000000000000000000000000000000000000000",
                         "0x000000000000000000000000000000000000dead"]:
        risk += 50; flags.append("BURN ADDRESS")

    # Known bad addresses (example)
    KNOWN_BAD = {
        "1Bad55bBadbadbadbadbadbadbad00000001": "Example bad address",
    }
    if addr in KNOWN_BAD:
        risk += 80; flags.append(f"BLACKLISTED: {KNOWN_BAD[addr]}")

    # Pattern analysis
    if re.search(r"(.)\1{6,}", addr[2:] if addr.startswith("0x") else addr):
        risk += 10; flags.append("Suspicious repeating character pattern")

    risk = min(risk, 100)

    if risk == 0:
        color, label = C.GREEN, "LOW RISK"
    elif risk < 40:
        color, label = C.YELLOW, "MEDIUM RISK"
    elif risk < 70:
        color, label = C.MAGENTA, "HIGH RISK"
    else:
        color, label = C.RED, "CRITICAL RISK"

    bar = "█" * (risk // 5) + "░" * (20 - risk // 5)
    print(f"  Risk Score:  {color}{bar} {risk}/100 -- {label}{C.RESET}\n")

    if flags:
        info("Risk Factors:")
        for f in flags:
            warn(f)
    else:
        ok("No known risk factors detected.")

# ── MODULE 10 ──────────────────────────────────────────────────
def mod_qr_code():
    box("MODULE 10 -- QR Code Generator (ASCII)", C.YELLOW)
    addr = input(f"  {C.YELLOW}Enter address:{C.RESET} ").strip()
    if not addr:
        err("Address is empty!"); return

    info(f"Address: {addr}")
    print()

    # Mini ASCII QR simulation (requires qrcode library for real QR)
    try:
        import subprocess
        result = subprocess.run(
            ["python3", "-c",
             f"import qrcode; qr=qrcode.QRCode(border=1); qr.add_data('{addr}'); qr.make(); "
             "import io; buf=io.StringIO(); qr.print_ascii(out=buf); print(buf.getvalue())"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0:
            print(result.stdout)
        else:
            raise Exception()
    except:
        # Fallback: simple representative QR
        warn("qrcode library not found -- showing representative view:")
        w = 21
        print("  ┌" + "─"*w + "┐")
        print("  │" + "█"*7 + " "*7 + "█"*7 + "│")
        print("  │" + "█ " + "█"*5 + " █ " + "█"*5 + " █│")
        # Generate 0/1 from address hash
        h = hashlib.md5(addr.encode()).hexdigest()
        for i in range(0, 10):
            row_bits = bin(int(h[i*2:i*2+2], 16))[2:].zfill(8)
            line = "  │" + "".join("█" if b=="1" else " " for b in row_bits*2)[:w] + "│"
            print(line)
        print("  │" + "█"*7 + " "*7 + "█"*7 + "│")
        print("  └" + "─"*w + "┘")
        print()
        info("pip install qrcode[pil]  ->  for real QR code")

    print(f"\n  {C.DIM}URI: crypto:{addr}{C.RESET}")

# ── MODULE 11 ──────────────────────────────────────────────────
def mod_address_converter():
    box("MODULE 11 -- Address Format Converter", C.CYAN)
    print(f"  {C.DIM}1) Fix ETH Checksum   2) Hex -> Base58   3) ETH -> Little-Endian{C.RESET}\n")
    choice = input(f"  {C.YELLOW}Choice:{C.RESET} ").strip()
    addr   = input(f"  {C.YELLOW}Address:{C.RESET} ").strip()

    if choice == "1":
        if not re.match(r"^0x[0-9a-fA-F]{40}$", addr):
            err("Invalid ETH address!"); return
        lower = addr[2:].lower()
        try:
            import hashlib as hl
            kh = hl.new("sha3_256", lower.encode()).hexdigest()
            checksum = "0x" + "".join(
                c.upper() if int(kh[i],16) >= 8 else c
                for i, c in enumerate(lower))
            row("Original",   addr)
            row("Lowercase",  "0x" + lower)
            row("EIP-55",     f"{C.GREEN}{checksum}{C.RESET}")
        except:
            err("Conversion error")

    elif choice == "2":
        try:
            hex_clean = addr.replace("0x","").replace(" ","")
            raw = bytes.fromhex(hex_clean)
            # Simple base58
            count = len(raw) - len(raw.lstrip(b'\x00'))
            n = int.from_bytes(raw, 'big')
            result = ""
            while n > 0:
                n, r = divmod(n, 58)
                result = BASE58_CHARS[r] + result
            result = "1" * count + result
            row("Hex Input",  addr)
            row("Base58",     f"{C.GREEN}{result}{C.RESET}")
        except:
            err("Invalid hex!")

    elif choice == "3":
        if not re.match(r"^0x[0-9a-fA-F]{40}$", addr):
            err("Invalid ETH address!"); return
        le = "0x" + bytes.fromhex(addr[2:])[::-1].hex()
        row("Original",      addr)
        row("Little-Endian", f"{C.GREEN}{le}{C.RESET}")

# ── MODULE 12 ──────────────────────────────────────────────────
def mod_gas_price():
    box("MODULE 12 -- Ethereum Gas Prices", C.YELLOW)
    spinner("Fetching gas prices...")

    data = http_get("https://api.etherscan.io/api?module=gastracker&action=gasoracle&apikey=YourApiKeyToken")
    if data and data.get("status") == "1":
        res = data["result"]
        row("Slow",     f"{C.GREEN}{res.get('SafeGasPrice','?')} Gwei{C.RESET}")
        row("Standard", f"{C.YELLOW}{res.get('ProposeGasPrice','?')} Gwei{C.RESET}")
        row("Fast",     f"{C.RED}{res.get('FastGasPrice','?')} Gwei{C.RESET}")
    else:
        # ETH gas fallback
        data2 = http_get("https://api.blocknative.com/gasprices/blockprices")
        if data2:
            info("Using Blocknative data")
        else:
            warn("Gas API unavailable -- demo values:")
            row("Slow",     f"{C.GREEN}15 Gwei{C.RESET}")
            row("Standard", f"{C.YELLOW}18 Gwei{C.RESET}")
            row("Fast",     f"{C.RED}22 Gwei{C.RESET}")

    # Cost estimates
    print(f"\n  {C.BOLD}Transfer Cost Estimate (ETH @ ~$3000):{C.RESET}")
    for speed, gwei in [("Slow", 15), ("Standard", 18), ("Fast", 22)]:
        cost_eth = gwei * 21000 * 1e-9
        cost_usd = cost_eth * 3000
        row(f"  ETH Transfer ({speed})", f"~${cost_usd:.2f} ({cost_eth:.5f} ETH)")

