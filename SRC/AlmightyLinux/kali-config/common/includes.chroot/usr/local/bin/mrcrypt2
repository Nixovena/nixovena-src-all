        row("Consensus",     "Proof of Stake (PoS)")
        row("Validators",    "~900,000+")
        row("Staking APR",   "~3.5%")
    else:
        err("Invalid selection!")

# ── MODULE 14 ──────────────────────────────────────────────────
def mod_token_balances():
    box("MODULE 14 -- ERC-20 Token Balances", C.GREEN)
    addr = input(f"  {C.YELLOW}ETH Address (0x...):{C.RESET} ").strip()
    valid, _ = validate_eth_address(addr)
    if not valid:
        err("Invalid ETH address!"); return

    spinner("Querying token balances...")
    data = eth_api("account", "tokentx", addr, "&startblock=0&endblock=99999999&sort=desc")
    if data and data.get("status") == "1":
        txs = data["result"][:20]
        tokens = {}
        for tx in txs:
            sym = tx.get("tokenSymbol", "?")
            name = tx.get("tokenName", "?")
            decimals = int(tx.get("tokenDecimal", 18))
            if sym not in tokens:
                tokens[sym] = {"name": name, "decimals": decimals}

        if tokens:
            row("Tokens Found", str(len(tokens)))
            print()
            for sym, info_d in list(tokens.items())[:15]:
                row(f"  {sym}", info_d["name"])
        else:
            warn("No token transactions found.")
    else:
        warn("API did not respond (API key may be required).")
        info("Demo token list:")
        for t in ["USDT -- Tether USD", "USDC -- USD Coin", "LINK -- Chainlink", "UNI -- Uniswap"]:
            ok(t)

# ── MODULE 15 ──────────────────────────────────────────────────
def mod_tx_count():
    box("MODULE 15 -- Transaction Count (Nonce)", C.CYAN)
    addr = input(f"  {C.YELLOW}ETH Address (0x...):{C.RESET} ").strip()
    valid, _ = validate_eth_address(addr)
    if not valid:
        err("Invalid ETH address!"); return

    spinner("Querying transaction count...")
    data = eth_api("proxy", "eth_getTransactionCount", addr, "&tag=latest")
    if data and data.get("result"):
        count_hex = data["result"]
        count = int(count_hex, 16)
        row("Address",      addr)
        row("Nonce (Hex)",  count_hex)
        row("TX Count",     f"{C.YELLOW}{count:,}{C.RESET}")
        if count == 0:
            info("This address has never sent a transaction (fresh wallet)")
        elif count < 10:
            info("Few transactions -- new wallet")
        elif count < 100:
            info("Moderate activity")
        else:
            info("High activity -- active wallet")
    else:
        warn("API did not respond.")

# ── MODULE 16 ──────────────────────────────────────────────────
def mod_decode_tx():
    box("MODULE 16 -- Transaction Hash Lookup", C.CYAN)
    txhash = input(f"  {C.YELLOW}TX Hash (0x...):{C.RESET} ").strip()
    if not re.match(r"^0x[0-9a-fA-F]{64}$", txhash):
        err("Invalid TX hash! (0x + 64 hex characters)"); return

    spinner("Fetching transaction details...")
    url = f"https://api.etherscan.io/api?module=proxy&action=eth_getTransactionByHash&txhash={txhash}&apikey={ETHERSCAN_KEY}"
    data = http_get(url)
    if data and data.get("result"):
        tx = data["result"]
        val = int(tx.get("value","0x0"), 16) / 1e18
        gas_p = int(tx.get("gasPrice","0x0"), 16) / 1e9
        row("TX Hash",       txhash)
        row("From",          tx.get("from","?"))
        row("To",            tx.get("to","?"))
        row("Value",         f"{C.YELLOW}{val:.6f} ETH{C.RESET}")
        row("Gas Price",     f"{gas_p:.2f} Gwei")
        row("Gas Limit",     str(int(tx.get("gas","0x0"),16)))
        row("Nonce",         str(int(tx.get("nonce","0x0"),16)))
        row("Block",         str(int(tx.get("blockNumber","0x0"),16)))
        inp = tx.get("input","0x")
        if inp != "0x" and len(inp) > 2:
            row("Input Data",    f"{inp[:20]}... ({len(inp)//2} bytes)")
            info("Input data present -- may be a smart contract call")
        else:
            row("Input Data", "Empty -- simple ETH transfer")
    else:
        warn("TX not found or API unavailable.")
        row("TX Hash", txhash)
        info("Check manually at etherscan.io")

# ── MODULE 17 ──────────────────────────────────────────────────
def mod_block_info():
    box("MODULE 17 -- Block Info Lookup", C.YELLOW)
    print(f"  {C.DIM}Enter block number (e.g. 19000000) or 'latest'{C.RESET}\n")
    block_in = input(f"  {C.YELLOW}Block:{C.RESET} ").strip() or "latest"

    spinner("Fetching block info...")
    if block_in.isdigit():
        block_hex = hex(int(block_in))
    else:
        block_hex = "latest"

    url = f"https://api.etherscan.io/api?module=proxy&action=eth_getBlockByNumber&tag={block_hex}&boolean=false&apikey={ETHERSCAN_KEY}"
    data = http_get(url)
    if data and data.get("result"):
        b = data["result"]
        ts = int(b.get("timestamp","0x0"), 16)
        dt = datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M:%S") if ts else "?"
        row("Block Number",   str(int(b.get("number","0x0"),16)))
        row("Hash",           b.get("hash","?"))
        row("Parent Hash",    (b.get("parentHash","?"))[:20]+"...")
        row("Timestamp",      dt)
        row("Gas Used",       f"{int(b.get('gasUsed','0x0'),16):,}")
        row("Gas Limit",      f"{int(b.get('gasLimit','0x0'),16):,}")
        row("TX Count",       str(len(b.get("transactions",[]))))
        row("Miner/Validator",b.get("miner","?"))
    else:
        warn("Could not retrieve block data.")
        info("Try with an API key or use etherscan.io")

# ── MODULE 18 ──────────────────────────────────────────────────
def mod_ens_lookup():
    box("MODULE 18 -- ENS / Domain Name Lookup", C.CYAN)
    ens = input(f"  {C.YELLOW}ENS name (e.g. vitalik.eth):{C.RESET} ").strip()
    if not ens.endswith(".eth"):
        ens += ".eth"

    spinner("Querying ENS...")
    # ENS API
    data = http_get(f"https://api.ensideas.com/ens/resolve/{ens}")
    if data and data.get("address"):
        row("ENS Name",   f"{C.GREEN}{ens}{C.RESET}")
        row("ETH Address",data.get("address","?"))
        row("Avatar",     data.get("avatar","None") or "None")
        row("Twitter",    data.get("twitter","None") or "None")
        row("Email",      data.get("email","None") or "None")
        row("Website",    data.get("url","None") or "None")
    else:
        # Fallback
        data2 = http_get(f"https://ensdata.net/{ens}")
        if data2 and data2.get("address"):
            row("ENS Name",   f"{C.GREEN}{ens}{C.RESET}")
            row("ETH Address",data2.get("address","?"))
        else:
            warn(f"No result found for {ens}.")
            info("ENS record may not exist or the service is unavailable.")

# ── MODULE 19 ──────────────────────────────────────────────────
def mod_blacklist_check():
    box("MODULE 19 -- Blacklist Check", C.RED)
    addr = input(f"  {C.YELLOW}Enter address:{C.RESET} ").strip()
    spinner("Scanning blacklists...")

    # Known blacklisted addresses (examples)
    BLACKLIST = {
        "0xd882cfc20f52f2599d84b8e8d58c7fb62cfe344": "Phishing",
        "0x7f268357a8c2552623316e2562d90e642bb538e5": "Lazarus Group (North Korea)",
        "0x8576acc5c05d6ce88f4e49bf65bdf0c62f91353c": "Tornado Cash related",
        "1bad1bad1bad1bad1bad1bad1bad1bad1bad1bad1": "Test blacklist entry",
    }

    found = addr.lower() in [k.lower() for k in BLACKLIST.keys()]
    matched_reason = None
    for k, v in BLACKLIST.items():
        if addr.lower() == k.lower():
            matched_reason = v

    sources = [
        ("OFAC SDN List",         "Checked",          not found),
        ("Etherscan Labels",      "Checked",          not found),
        ("Chainalysis (demo)",    "Limited access",   True),
        ("CryptoIntel DB",        "Checked",          not found),
        ("Community Blacklist",   "Checked",          not found),
    ]

    print()
    for src, status, clean in sources:
        sym = f"{C.GREEN}[CLEAN]{C.RESET}" if clean else f"{C.RED}[FOUND]{C.RESET}"
        print(f"  {sym}  {C.BOLD}{src:<25}{C.RESET}  {C.DIM}{status}{C.RESET}")

    print()
    if found and matched_reason:
        print(f"  {C.BG_RED}{C.BOLD} WARNING! {C.RESET} This address is blacklisted!")
        err(f"Reason: {matched_reason}")
        err("AVOID interacting with this address!")
    else:
        print(f"  {C.BG_GRN}{C.BOLD} CLEAN {C.RESET} Not found in known blacklists.")
        ok("Address not in any known bad lists")
        info("Note: This check does not provide 100% guarantee.")

# ── MODULE 20 ──────────────────────────────────────────────────
def mod_whale_detector():
    box("MODULE 20 -- Whale Activity Detector", C.MAGENTA)
    addr = input(f"  {C.YELLOW}BTC Address:{C.RESET} ").strip()
    valid, _ = validate_btc_address(addr)
    if not valid:
        err("Invalid BTC address!"); return

    spinner("Analyzing whale activity...")
    data = btc_api_balance(addr)
    if not data:
        warn("Could not retrieve data."); return

    bal   = data.get("final_balance", 0) / 1e8
    recv  = data.get("total_received", 0) / 1e8
    n_tx  = data.get("n_tx", 0)

    # Categorize
    if bal >= 1000:
        category, color = "[MEGA WHALE]", C.RED
    elif bal >= 100:
        category, color = "[WHALE]", C.MAGENTA
    elif bal >= 10:
        category, color = "[SHARK]", C.YELLOW
    elif bal >= 1:
        category, color = "[DOLPHIN]", C.CYAN
    else:
        category, color = "[SHRIMP]", C.GREEN

    row("Address",       addr)
    row("Balance",       f"{bal:.8f} BTC")
    row("Total Received",f"{recv:.8f} BTC")
    row("TX Count",      str(n_tx))
    row("Category",      f"{color}{C.BOLD}{category}{C.RESET}")

    print(f"\n  {C.DIM}BTC Whale Scale:{C.RESET}")
    for cat, thresh in [("Mega Whale",">= 1000 BTC"),("Whale",">= 100 BTC"),
                        ("Shark",">= 10 BTC"),("Dolphin",">= 1 BTC"),("Shrimp","< 1 BTC")]:
        mark = ">" if cat.split()[0].lower() in category.lower() else " "
        print(f"  {color if mark=='>' else C.DIM}{mark} {cat:<12} {thresh}{C.RESET}")

