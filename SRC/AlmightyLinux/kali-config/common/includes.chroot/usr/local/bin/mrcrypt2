MODULES = [
    ("Address Validation (Multi-Chain)",      mod_validate_address),
    ("Ethereum Balance Query",                mod_check_eth_balance),
    ("Bitcoin Balance Query",                 mod_check_btc_balance),
    ("Privacy Analysis",                      mod_check_privacy),
    ("Transaction History (BTC)",             mod_tx_history),
    ("First & Last TX Dates (BTC)",           mod_first_last_tx),
    ("Address Type Detection (ETH)",          mod_address_type),
    ("Multi-Chain Compatibility",             mod_multi_chain_check),
    ("Risk Score",                            mod_risk_score),
    ("QR Code Generator",                     mod_qr_code),
    ("Address Format Converter",              mod_address_converter),
    ("Gas Prices (ETH)",                      mod_gas_price),
    ("Blockchain Network Statistics",         mod_network_stats),
    ("ERC-20 Token Balances",                 mod_token_balances),
    ("Transaction Count / Nonce (ETH)",       mod_tx_count),
    ("Transaction Hash Lookup (ETH)",         mod_decode_tx),
    ("Block Info (ETH)",                      mod_block_info),
    ("ENS Domain Lookup",                     mod_ens_lookup),
    ("Blacklist Check",                       mod_blacklist_check),
    ("Whale Detector (BTC)",                  mod_whale_detector),
    ("Known Address Labels",                  mod_address_labels),
    ("Portfolio Value Calculator",            mod_portfolio_calculator),
    ("Historical Price Analysis",             mod_historical_price),
    ("Crypto Market Dominance",               mod_dominance_stats),
    ("Address Clustering Analysis (BTC)",     mod_address_clustering),
    ("Smart Contract Analysis (ETH)",         mod_smart_contract_check),
    ("DeFi Protocol Detection (ETH)",         mod_defi_exposure),
    ("Vanity Address Analysis",               mod_address_vanity_check),
    ("Export JSON Report",                    mod_export_report),
    ("Mempool & Pending TX (ETH)",            mod_mempool_check),
    ("Address Generation Info & Security",    mod_address_generator_info),
]

def main_menu():
    while True:
        banner()
        print(f"  {C.BOLD}{'─'*60}{C.RESET}")
        cols = 2
        for i in range(0, len(MODULES), cols):
            row1 = f"  {C.CYAN}{i+1:>2}.{C.RESET} {MODULES[i][0]}"
            if i+1 < len(MODULES):
                row2 = f"  {C.CYAN}{i+2:>2}.{C.RESET} {MODULES[i+1][0]}"
            else:
                row2 = ""
            print(f"{row1:<55}{row2}")

        print(f"\n  {C.CYAN}  0.{C.RESET} {C.RED}Exit{C.RESET}")
        print(f"  {C.BOLD}{'─'*60}{C.RESET}\n")

        try:
            choice = input(f"  {C.YELLOW}Select module [0-{len(MODULES)}]:{C.RESET} ").strip()
        except (KeyboardInterrupt, EOFError):
            print(f"\n\n  {C.DIM}Goodbye!{C.RESET}\n")
            break

        if choice == "0":
            print(f"\n  {C.CYAN}mrcrypt2 closed. Goodbye!{C.RESET}\n")
            break

        try:
            idx = int(choice) - 1
            if 0 <= idx < len(MODULES):
                try:
                    MODULES[idx][1]()
                except KeyboardInterrupt:
                    print(f"\n  {C.YELLOW}Module cancelled.{C.RESET}")
                except Exception as e:
                    err(f"Module error: {e}")
                pause()
            else:
                err(f"Invalid selection! Enter 1-{len(MODULES)}.")
                time.sleep(1)
        except ValueError:
            err("Please enter a number!")
            time.sleep(1)

if __name__ == "__main__":
    main_menu()