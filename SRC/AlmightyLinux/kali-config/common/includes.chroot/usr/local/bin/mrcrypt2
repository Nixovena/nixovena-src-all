def box(title: str, color: str = C.CYAN):
    w = 60
    print(f"\n{color}{'─'*w}{C.RESET}")
    print(f"{color}  {C.BOLD}{title}{C.RESET}")
    print(f"{color}{'─'*w}{C.RESET}")

def ok(msg):    print(f"  {C.GREEN}✔{C.RESET}  {msg}")
def warn(msg):  print(f"  {C.YELLOW}⚠{C.RESET}  {msg}")
def err(msg):   print(f"  {C.RED}✘{C.RESET}  {msg}")
def info(msg):  print(f"  {C.CYAN}ℹ{C.RESET}  {msg}")
def row(k, v, color=C.WHITE):
    print(f"  {C.DIM}{k:<30}{C.RESET} {color}{v}{C.RESET}")

def spinner(msg: str, duration: float = 0.8):
    frames = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
    end = time.time() + duration
    i = 0
    while time.time() < end:
        print(f"\r  {C.CYAN}{frames[i % len(frames)]}{C.RESET}  {msg}", end="", flush=True)
        time.sleep(0.08)
        i += 1
    print(f"\r  {C.GREEN}✔{C.RESET}  {msg}{' '*10}")

def pause():
    input(f"\n  {C.DIM}[Press Enter to continue...]{C.RESET}")

# ──────────────────────────────────────────────────────────────
# HTTP HELPER (stdlib only)
# ──────────────────────────────────────────────────────────────
def http_get(url: str, timeout: int = 10) -> Optional[dict]:
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "CryptoIntel/2.0"})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode())
    except Exception as e:
        return None

def http_get_text(url: str, timeout: int = 10) -> Optional[str]:
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "CryptoIntel/2.0"})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.read().decode()
    except Exception:
        return None

# ──────────────────────────────────────────────────────────────
# CRYPTO VALIDATION MATH
# ──────────────────────────────────────────────────────────────

BASE58_CHARS = "123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz"

def base58_decode(s: str) -> Optional[bytes]:
    try:
        n = 0
        for c in s:
            if c not in BASE58_CHARS:
                return None
            n = n * 58 + BASE58_CHARS.index(c)
        # Count leading zero bytes (leading '1' chars in Base58)
        pad = len(s) - len(s.lstrip("1"))
        # Convert number to bytes
        if n > 0:
            byte_len = (n.bit_length() + 7) // 8
            n_bytes = n.to_bytes(byte_len, "big")
        else:
            n_bytes = b""
        result = b"\x00" * pad + n_bytes
        # Bitcoin addresses must be exactly 25 bytes — pad if one byte short
        if len(result) == 24:
            result = b"\x00" + result
        return result
    except Exception:
        return None

def sha256d(data: bytes) -> bytes:
    return hashlib.sha256(hashlib.sha256(data).digest()).digest()

def validate_btc_address(addr: str) -> Tuple[bool, str]:
    """Bitcoin address validation (Legacy, P2SH, Bech32)"""
    # Bech32 (native segwit)
    if addr.lower().startswith(("bc1", "tb1")):
        if len(addr) >= 42 and len(addr) <= 62:
            charset = "qpzry9x8gf2tvdw0s3jn54khce6mua7l"
            hrp = "bc" if addr.lower().startswith("bc1") else "tb"
            data = addr[len(hrp)+1:].lower()
            if all(c in charset for c in data):
                return True, "Bech32 (Native SegWit / P2WPKH or P2WSH)"
        return False, "Invalid Bech32"
    # Legacy & P2SH
    decoded = base58_decode(addr)
    if not decoded or len(decoded) != 25:
        return False, "Invalid Base58"
    checksum = decoded[-4:]
    calc = sha256d(decoded[:-4])[:4]
    if checksum != calc:
        return False, "Checksum error"
    prefix = decoded[0]
    if prefix == 0x00:   return True, "P2PKH (Legacy)"
    if prefix == 0x05:   return True, "P2SH (SegWit compatible)"
    if prefix == 0x6f:   return True, "Testnet P2PKH"
    if prefix == 0xc4:   return True, "Testnet P2SH"
    return False, f"Unknown prefix: 0x{prefix:02X}"

def validate_eth_address(addr: str) -> Tuple[bool, str]:
    """Ethereum address validation + EIP-55 checksum"""
    if not re.match(r"^0x[0-9a-fA-F]{40}$", addr):
        return False, "Invalid format (0x + 40 hex)"
    lower = addr[2:].lower()
    h = hashlib.new("sha3_256") if hasattr(hashlib, "new") else None
    try:
        import hashlib as hl
        kh = hl.new("sha3_256", lower.encode()).hexdigest()
    except Exception:
        return True, "Valid Ethereum Address (EIP-55 could not be verified)"
    checksum = "0x" + "".join(
        c.upper() if int(kh[i], 16) >= 8 else c
        for i, c in enumerate(lower)
    )
    if addr == checksum:
        return True, "Valid Ethereum Address (EIP-55 Checksum OK)"
    elif addr == addr.lower() or addr == addr.upper():
        return True, "Valid Ethereum Address (no checksum)"
    else:
        return False, "EIP-55 Checksum error"

def validate_ltc_address(addr: str) -> Tuple[bool, str]:
    if addr.startswith(("ltc1", "LTC1")):
        return True, "Litecoin Bech32 (Native SegWit)"
    decoded = base58_decode(addr)
    if not decoded or len(decoded) != 25:
        return False, "Invalid Base58"
    checksum = decoded[-4:]
    calc = sha256d(decoded[:-4])[:4]
    if checksum != calc:
        return False, "Checksum error"
    prefix = decoded[0]
    if prefix == 0x30: return True, "Litecoin P2PKH (L...)"
    if prefix == 0x05: return True, "Litecoin P2SH (3...)"
    if prefix == 0x32: return True, "Litecoin P2SH (M...)"
    return False, f"Unknown Litecoin prefix: 0x{prefix:02X}"

def validate_xrp_address(addr: str) -> Tuple[bool, str]:
    XRP_ALPHA = "rpshnaf39wBUDNEGHJKLM4PQRST7VWXYZ2bcdeCg65jkm8oFqi1tuvAxyz"
    if not addr.startswith("r") or len(addr) < 25 or len(addr) > 35:
        return False, "Invalid XRP format"
    if all(c in XRP_ALPHA for c in addr):
        return True, "Valid XRP (Ripple) Address"
    return False, "Invalid XRP characters"

def validate_doge_address(addr: str) -> Tuple[bool, str]:
    decoded = base58_decode(addr)
    if not decoded or len(decoded) != 25:
        return False, "Invalid Base58"
    checksum = decoded[-4:]
    calc = sha256d(decoded[:-4])[:4]
    if checksum != calc:
        return False, "Checksum error"
    prefix = decoded[0]
    if prefix == 0x1e: return True, "Dogecoin P2PKH (D...)"
    if prefix == 0x16: return True, "Dogecoin P2SH"
    return False, f"Unknown Doge prefix: 0x{prefix:02X}"

def validate_trx_address(addr: str) -> Tuple[bool, str]:
    if not addr.startswith("T") or len(addr) != 34:
        return False, "Invalid TRON format (T + 33 chars)"
    decoded = base58_decode(addr)
    if not decoded or len(decoded) != 25:
        return False, "Invalid Base58"
    if decoded[0] != 0x41:
        return False, f"Invalid TRON prefix: 0x{decoded[0]:02X}"
    checksum = decoded[-4:]
    calc = sha256d(decoded[:-4])[:4]
    if checksum == calc:
        return True, "Valid TRON (TRX) Address"
    return False, "Checksum error"

def validate_sol_address(addr: str) -> Tuple[bool, str]:
    SOL_CHARS = "123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz"
    if len(addr) < 32 or len(addr) > 44:
        return False, "Invalid Solana length (32-44 chars)"
    if all(c in SOL_CHARS for c in addr):
        return True, "Valid Solana Address"
    return False, "Invalid Solana characters"

def detect_chain(addr: str) -> List[str]:
    chains = []
    # ETH addresses always start with 0x — exclusive to EVM chains
    if addr.startswith(("0x", "0X")):
        if validate_eth_address(addr)[0]:
            chains.append("Ethereum/EVM (ETH, BNB, MATIC, AVAX...)")
        return chains
    # Non-EVM chains
    if validate_btc_address(addr)[0]: chains.append("Bitcoin")
    if validate_ltc_address(addr)[0]: chains.append("Litecoin")
    if validate_xrp_address(addr)[0]: chains.append("XRP Ripple")
    if validate_doge_address(addr)[0]: chains.append("Dogecoin")
    if validate_trx_address(addr)[0]: chains.append("TRON")
    # Solana: only if nothing else matched (base58 overlaps with BTC/XRP)
    if not chains and validate_sol_address(addr)[0]:
        chains.append("Solana")
    return chains

# ──────────────────────────────────────────────────────────────
# API HELPERS
# ──────────────────────────────────────────────────────────────

ETHERSCAN_KEY = "YourApiKeyToken"   # Free key at etherscan.io

def eth_api(module, action, address, extra="", apikey=ETHERSCAN_KEY):
    url = (f"https://api.etherscan.io/api?module={module}&action={action}"
           f"&address={address}{extra}&apikey={apikey}")
    return http_get(url)

def btc_api_balance(addr):
    return http_get(f"https://blockchain.info/rawaddr/{addr}?limit=0")

def btc_api_tx(addr):
    return http_get(f"https://blockchain.info/rawaddr/{addr}?limit=10")

