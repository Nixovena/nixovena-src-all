        "0x7a250d5630b4cf539739df2c5dacb4c659f2488d": ("Uniswap V2 Router",   "DEX"),
        "0xe592427a0aece92de3edee1f18e0157c05861564": ("Uniswap V3 Router",   "DEX"),
        "0x00000000219ab540356cbb839cbe05303d7705fa": ("ETH2 Deposit",        "Staking"),
        "0x0000000000000000000000000000000000000000": ("Null Address",         "System"),
        "0x000000000000000000000000000000000000dead": ("Burn Address",         "Burn"),
        "1A1zP1eP5QGefi2DMPTfTL5SLmv7Divf": ("Genesis Block",         "Bitcoin First Block"),
        "12c6DSiU4Rq3P4ZxziKxzrL5LmMBrzjrJX": ("Mt.Gox Old Wallet",   "Historical"),
    }

    addr_lower = addr.lower()
    found = None
    for known_addr, (name, category) in LABELS.items():
        if addr_lower == known_addr.lower():
            found = (name, category)
            break

    if found:
        print(f"\n  {C.BG_BLU}{C.BOLD} LABEL FOUND {C.RESET}")
        row("Address",  addr)
        row("Name",     f"{C.GREEN}{C.BOLD}{found[0]}{C.RESET}")
        row("Category", f"{C.YELLOW}{found[1]}{C.RESET}")
    else:
        warn("No known label found for this address.")
        info("Check at etherscan.io/address/" + addr)
        info("Use labels.json to expand the database")

# ── MODULE 22 ──────────────────────────────────────────────────
def mod_portfolio_calculator():
    box("MODULE 22 -- Portfolio Value Calculator", C.GREEN)
    print(f"  {C.DIM}Enter your coins and amounts (leave blank to finish){C.RESET}\n")

    portfolio = []
    while True:
        coin = input(f"  {C.YELLOW}Coin symbol (e.g. BTC, ETH):{C.RESET} ").strip().upper()
        if not coin:
            break
        try:
            amount = float(input(f"  {C.YELLOW}Amount:{C.RESET} ").strip())
        except:
            err("Invalid amount!"); continue
        portfolio.append((coin, amount))

    if not portfolio:
        warn("Portfolio is empty!"); return

    spinner("Fetching prices...")

    # Coingecko API
    ids_map = {
        "BTC":"bitcoin","ETH":"ethereum","BNB":"binancecoin",
        "SOL":"solana","XRP":"ripple","ADA":"cardano","DOT":"polkadot",
        "DOGE":"dogecoin","AVAX":"avalanche-2","MATIC":"matic-network",
        "LINK":"chainlink","UNI":"uniswap","LTC":"litecoin","TRX":"tron",
        "ATOM":"cosmos","ALGO":"algorand","FTM":"fantom","NEAR":"near",
    }

    coin_ids = [ids_map.get(c,"") for c,_ in portfolio if ids_map.get(c)]
    prices = {}

    if coin_ids:
        ids_str = ",".join([i for i in coin_ids if i])
        data = http_get(f"https://api.coingecko.com/api/v3/simple/price?ids={ids_str}&vs_currencies=usd,eur")
        if data:
            for coin, amount in portfolio:
                cid = ids_map.get(coin,"")
                if cid and cid in data:
                    prices[coin] = data[cid]

    print(f"\n  {C.BOLD}{'Coin':<8} {'Amount':>12} {'USD Price':>12} {'Value (USD)':>14}{C.RESET}")
    print(f"  {'─'*52}")
    total_usd = 0
    for coin, amount in portfolio:
        if coin in prices:
            usd_p = prices[coin].get("usd", 0)
            val   = amount * usd_p
            total_usd += val
            print(f"  {C.CYAN}{coin:<8}{C.RESET} {amount:>12.4f} {C.YELLOW}${usd_p:>11,.2f}{C.RESET} {C.GREEN}${val:>13,.2f}{C.RESET}")
        else:
            print(f"  {C.CYAN}{coin:<8}{C.RESET} {amount:>12.4f} {C.DIM}{'No price':>12}{C.RESET} {'?':>14}")

    print(f"  {'─'*52}")
    print(f"  {C.BOLD}{'TOTAL':<8} {'':>12} {'':>12} {C.GREEN}${total_usd:>13,.2f}{C.RESET}")

# ── MODULE 23 ──────────────────────────────────────────────────
def mod_historical_price():
    box("MODULE 23 -- Historical Price Analysis", C.GREEN)
    coin = input(f"  {C.YELLOW}Coin symbol (e.g. BTC, ETH):{C.RESET} ").strip().upper()
    days = input(f"  {C.YELLOW}How many days (7/30/90/365):{C.RESET} ").strip()

    ids_map = {
        "BTC":"bitcoin","ETH":"ethereum","BNB":"binancecoin",
        "SOL":"solana","XRP":"ripple","DOGE":"dogecoin","LTC":"litecoin"
    }
    cid = ids_map.get(coin)
    if not cid:
        err(f"No data available for {coin}!"); return

    spinner("Fetching historical price data...")
    url = f"https://api.coingecko.com/api/v3/coins/{cid}/market_chart?vs_currency=usd&days={days}"
    data = http_get(url)
    if not data or "prices" not in data:
        warn("Could not retrieve data."); return

    prices = data["prices"]
    if not prices:
        warn("Price data is empty!"); return

    vals  = [p[1] for p in prices]
    high  = max(vals)
    low   = min(vals)
    first = vals[0]
    last  = vals[-1]
    chg   = ((last - first) / first) * 100
    avg   = sum(vals) / len(vals)

    row("Coin",          coin)
    row("Period",        f"{days} days")
    row("Current Price", f"{C.YELLOW}${last:,.2f}{C.RESET}")
    row("Start Price",   f"${first:,.2f}")
    row("High",          f"{C.GREEN}${high:,.2f}{C.RESET}")
    row("Low",           f"{C.RED}${low:,.2f}{C.RESET}")
    row("Average",       f"${avg:,.2f}")
    chg_col = C.GREEN if chg >= 0 else C.RED
    row("Change",        f"{chg_col}{chg:+.2f}%{C.RESET}")

    # Small ASCII chart
    print(f"\n  {C.BOLD}Price Chart (last {min(len(vals),40)} points):{C.RESET}")
    sample = vals[::max(1, len(vals)//40)][:40]
    mn, mx = min(sample), max(sample)
    rng = mx - mn or 1
    rows_ = 6
    chart = []
    for row_i in range(rows_, 0, -1):
        threshold = mn + (rng * row_i / rows_)
        line = "  "
        for v in sample:
            line += "█" if v >= threshold else " "
        chart.append(line)
    for i, line in enumerate(chart):
        color = C.GREEN if i > rows_//2 else C.RED
        print(f"{color}{line}{C.RESET}")
    print(f"  {C.DIM}└{'─'*len(sample)}{C.RESET}")

# ── MODULE 24 ──────────────────────────────────────────────────
def mod_dominance_stats():
    box("MODULE 24 -- Crypto Market Dominance", C.YELLOW)
    spinner("Fetching global market data...")
    data = http_get("https://api.coingecko.com/api/v3/global")
    if data and "data" in data:
        d = data["data"]
        mc    = d.get("total_market_cap", {}).get("usd", 0)
        vol   = d.get("total_volume", {}).get("usd", 0)
        dom   = d.get("market_cap_percentage", {})
        coins = d.get("active_cryptocurrencies", 0)

        row("Total Market Cap", f"{C.YELLOW}${mc:,.0f}{C.RESET}")
        row("24h Volume",          f"${vol:,.0f}")
        row("Active Coins",  f"{coins:,}")
        print(f"\n  {C.BOLD}Dominance:{C.RESET}")
        for coin, pct in sorted(dom.items(), key=lambda x: -x[1])[:8]:
            bar = "█" * int(pct / 3)
            print(f"  {C.CYAN}{coin.upper():<6}{C.RESET}  {C.YELLOW}{pct:>5.1f}%{C.RESET}  {bar}")
    else:
        warn("Could not retrieve global data.")
        info("Check at coingecko.com")

# ── MODULE 25 ──────────────────────────────────────────────────
def mod_address_clustering():
    box("MODULE 25 -- Address Clustering Analysis", C.MAGENTA)
    addr = input(f"  {C.YELLOW}BTC Address:{C.RESET} ").strip()
    valid, _ = validate_btc_address(addr)
    if not valid:
        err("Invalid BTC address!"); return

    spinner("Analyzing related addresses...")
    data = btc_api_tx(addr)
    if not data:
        warn("Could not retrieve data."); return

    related = set()
    txs = data.get("txs", [])[:5]

    for tx in txs:
        # Input addresses (usually same owner)
        for inp in tx.get("inputs", []):
            prev = inp.get("prev_out", {})
            a = prev.get("addr","")
            if a and a != addr:
                related.add(a)
        # Output addresses
        for out in tx.get("out", []):
            a = out.get("addr","")
            if a and a != addr:
                related.add(a)

    row("Source Address",    addr)
    row("TXs Analyzed",      str(len(txs)))
    row("Related Addresses", str(len(related)))

    if related:
        print(f"\n  {C.BOLD}Related Addresses (Cluster):{C.RESET}")
        for i, rel_addr in enumerate(list(related)[:10], 1):
            print(f"  {C.DIM}{i:>2}.{C.RESET}  {C.CYAN}{rel_addr}{C.RESET}")
        if len(related) > 10:
            info(f"... and {len(related)-10} more addresses")
    else:
        info("No related addresses detected")

    print(f"\n  {C.DIM}Note: Shared input addresses typically belong to the same wallet.{C.RESET}")

# ── MODULE 26 ──────────────────────────────────────────────────
def mod_smart_contract_check():
    box("MODULE 26 -- Smart Contract Analysis", C.CYAN)
    addr = input(f"  {C.YELLOW}ETH Contract Address (0x...):{C.RESET} ").strip()
    valid, _ = validate_eth_address(addr)
    if not valid:
        err("Invalid ETH address!"); return

    spinner("Analyzing contract...")

    # Bytecode check
    code_data = eth_api("proxy", "eth_getCode", addr)
    has_code = code_data and code_data.get("result","0x") != "0x"

    # ABI
    abi_data = eth_api("contract", "getabi", addr)
    has_abi   = abi_data and abi_data.get("status") == "1"

    # Source
    src_data = eth_api("contract", "getsourcecode", addr)
    has_src   = src_data and src_data.get("status") == "1"

    row("Address",      addr)
    row("Has Code?",    f"{C.GREEN}YES -- Smart Contract{C.RESET}" if has_code else f"{C.RED}NO -- EOA{C.RESET}")

    if has_abi:
        row("ABI",      f"{C.GREEN}Available (Verified){C.RESET}")
    else:
        row("ABI",      f"{C.YELLOW}Not found{C.RESET}")

    if has_src and src_data.get("result"):
        src = src_data["result"][0] if isinstance(src_data["result"], list) else {}
        row("Contract Name",  src.get("ContractName","?") or "Unverified")
        row("Compiler",       src.get("CompilerVersion","?") or "?")
        row("License",        src.get("LicenseType","None") or "None")
        row("Verified?",      f"{C.GREEN}YES{C.RESET}" if src.get("ABI","") != "Contract source code not verified" else f"{C.RED}NO{C.RESET}")
    else:
        row("Source Code",    f"{C.YELLOW}Unverified or no API key{C.RESET}")

    row("Explorer",     f"https://etherscan.io/address/{addr}")

# ── MODULE 27 ──────────────────────────────────────────────────
def mod_defi_exposure():
    box("MODULE 27 -- DeFi Protocol Detection", C.GREEN)
    addr = input(f"  {C.YELLOW}ETH Address (0x...):{C.RESET} ").strip()
    valid, _ = validate_eth_address(addr)
    if not valid:
        err("Invalid ETH address!"); return

    spinner("Scanning DeFi positions...")

    # Known DeFi contract addresses
    DEFI = {
        "0x7a250d5630b4cf539739df2c5dacb4c659f2488d": ("Uniswap V2",   "DEX"),
        "0xe592427a0aece92de3edee1f18e0157c05861564": ("Uniswap V3",   "DEX"),
        "0xd9e1ce17f2641f24ae83637ab66a2cca9c378b9f": ("SushiSwap",    "DEX"),
        "0x3d9819210a31b4961b30ef54be2aed79b9c9cd3b": ("Compound",     "Lending"),
        "0x7fc66500c84a76ad7e9c93437bfc5ac33e2ddae9": ("Aave",         "Lending"),
        "0x9d25057e62939d3408406975ad75ffe834da4cdd": ("Yearn Finance", "Yield"),
        "0xc00e94cb662c3520282e6f5717214004a7f26888": ("Compound COMP","Governance"),
    }

    # Detect DeFi from token TXs
    data = eth_api("account", "txlist", addr, "&startblock=0&endblock=99999999&sort=desc&page=1&offset=50")
    found_protocols = set()

    if data and data.get("status") == "1":
        for tx in data["result"][:50]:
            to_addr = tx.get("to","").lower()
            if to_addr in [k.lower() for k in DEFI.keys()]:
                for k, v in DEFI.items():
                    if k.lower() == to_addr:
                        found_protocols.add(v)

    print(f"\n  {C.BOLD}Known DeFi Protocols:{C.RESET}\n")
    for k, (name, category) in DEFI.items():
        found = (name, category) in found_protocols
        sym = f"{C.GREEN}[INTERACTED]{C.RESET}" if found else f"{C.DIM}--{C.RESET}"
        print(f"  {sym}  {C.BOLD}{name:<15}{C.RESET}  {C.DIM}{category}{C.RESET}")

    if not found_protocols:
        warn("No DeFi interaction found in last 50 TXs (API key may be required)")

# ── MODULE 28 ──────────────────────────────────────────────────
def mod_address_vanity_check():
    box("MODULE 28 -- Vanity Address Analysis", C.YELLOW)
    addr = input(f"  {C.YELLOW}Enter address:{C.RESET} ").strip()
    if not addr:
        err("Address is empty!"); return

    spinner("Running vanity analysis...")
    clean = addr[2:] if addr.startswith("0x") else addr

    # Leading pattern
    leading = len(clean) - len(clean.lstrip("0"))
    # Trailing pattern
    trailing = len(clean) - len(clean.rstrip("0"))
    # Palindrome
    is_palindrome = clean.lower() == clean.lower()[::-1]
    # Repeat characters
    repeats = max(len(list(g)) for _, g in __import__('itertools').groupby(clean.lower()))
    # Special words
    WORDS = ["dead","beef","cafe","face","babe","code","feed","deed","abba","ace"]
    found_words = [w for w in WORDS if w in clean.lower()]
    # Hex readability
    readable = sum(1 for c in clean.lower() if c.isalpha())

    row("Address",          addr)
    row("Length",           str(len(addr)))
    row("Leading Zeros",    str(leading))
    row("Trailing Zeros",   str(trailing))
    row("Max Repeating",    f"{repeats}x")
    row("Palindrome?",      f"{C.GREEN}YES{C.RESET}" if is_palindrome else "No")
    row("Words Found",      ", ".join(found_words) if found_words else "None")
    row("Letter Ratio",     f"{readable/len(clean)*100:.1f}%")

    vanity_score = (leading * 5 + trailing * 3 + len(found_words) * 10 +
                    (20 if repeats >= 6 else 0))
    color = C.GREEN if vanity_score > 30 else (C.YELLOW if vanity_score > 10 else C.WHITE)
    row("Vanity Score",     f"{color}{vanity_score}/100{C.RESET}")
    if vanity_score > 30:
        ok("This is likely a custom-generated vanity address!")
    else:
        info("Appears to be a standard randomly generated address")

# ── MODULE 29 ──────────────────────────────────────────────────
def mod_export_report():
    box("MODULE 29 -- Export Address Report (JSON)", C.GREEN)
    addr = input(f"  {C.YELLOW}Enter address:{C.RESET} ").strip()
    if not addr:
        err("Address is empty!"); return

    spinner("Preparing report...")
    chains = detect_chain(addr)
    now    = datetime.datetime.now().isoformat()

    report = {
        "meta": {
            "tool":       "CryptoIntel v2.0",
            "generated":  now,
            "address":    addr,
        },
        "validation": {},
        "chains":     chains,
        "btc_data":   None,
        "eth_data":   None,
        "risk":       "unknown",
        "labels":     [],
    }

    # BTC
    if "Bitcoin" in chains:
        data = btc_api_balance(addr)
        if data:
            report["btc_data"] = {
                "balance_btc":        data.get("final_balance",0) / 1e8,
                "total_received_btc": data.get("total_received",0) / 1e8,
                "total_sent_btc":     data.get("total_sent",0) / 1e8,
                "n_tx":               data.get("n_tx",0),
            }

    filename = f"crypto_report_{addr[:10]}_{int(time.time())}.json"
    with open(filename, "w", encoding="utf-8") as f:
        json.dump(report, f, ensure_ascii=False, indent=2)

    ok(f"Report saved: {C.YELLOW}{filename}{C.RESET}")
    row("Address", addr)
    row("Chain",   ", ".join(chains) if chains else "Unknown")
    row("Date",    now)
    info(f"cat {filename}  ->  to view the report")

# ── MODULE 30 ──────────────────────────────────────────────────
def mod_mempool_check():
    box("MODULE 30 -- Mempool & Pending TX Analysis", C.CYAN)
    addr = input(f"  {C.YELLOW}ETH Address (0x...):{C.RESET} ").strip()
    valid, _ = validate_eth_address(addr)
    if not valid:
        err("Invalid ETH address!"); return

    spinner("Querying mempool...")
    data = eth_api("account", "txlistinternal", addr, "&startblock=0&endblock=99999999&sort=desc&page=1&offset=10")

    print()
    info("Pending TXs (latest unconfirmed transactions):")
    if data and data.get("status") == "1" and data.get("result"):
        for tx in data["result"][:5]:
            val = int(tx.get("value","0")) / 1e18
            row(f"  TX {tx.get('hash','?')[:16]}...", f"{val:.4f} ETH")
    else:
        warn("No pending transactions found or API unavailable.")
        info("Alternative: https://etherscan.io/txsPending")

    # Gas suggestions
    print(f"\n  {C.BOLD}Mempool Gas Suggestions:{C.RESET}")
    row("  Low priority",    "<= 15 Gwei  -> ~30min+ wait")
    row("  Medium priority", "15-25 Gwei  -> ~1-5min wait")
    row("  High priority",   "> 25 Gwei   -> ~15sec-1min wait")
    row("  Fast (MEV)",      "Base + 2 Gwei priority -> instant")
    info("Real mempool: https://mempool.space (BTC) or blocknative.com (ETH)")

# ── MODULE 31 ──────────────────────────────────────────────
def mod_address_generator_info():
    box("MODULE 31 -- Address Generation Info & Security", C.MAGENTA)
    print(f"  {C.DIM}Which network?{C.RESET}")
    print(f"  {C.DIM}1) Bitcoin   2) Ethereum   3) General{C.RESET}\n")
    choice = input(f"  {C.YELLOW}Choice:{C.RESET} ").strip()

    if choice == "1":
        info("Bitcoin Address Generation Process:")
        steps = [
            ("1. Private Key",   "Generate a 256-bit random number"),
            ("2. Public Key",    "ECDSA secp256k1 curve: G * privkey"),
            ("3. SHA256",        "Hash the public key with SHA256"),
            ("4. RIPEMD160",     "Hash the SHA256 output with RIPEMD160"),
            ("5. Network Byte",  "Prepend 0x00 for mainnet"),
            ("6. Checksum",      "First 4 bytes of SHA256(SHA256(payload))"),
            ("7. Base58Check",   "Base58 encode -> Bitcoin Address"),
        ]
        for k, v in steps:
            row(k, v)

    elif choice == "2":
        info("Ethereum Address Generation Process:")
        steps = [
            ("1. Private Key",   "256-bit random number (within secp256k1 range)"),
            ("2. Public Key",    "ECDSA secp256k1 -> 64-byte uncompressed pubkey"),
            ("3. Keccak-256",    "Keccak-256 hash of the public key"),
            ("4. Last 20 bytes", "Last 20 bytes of hash -> 40 hex characters"),
            ("5. 0x Prefix",     "Prepend 0x"),
            ("6. EIP-55",        "Keccak-256-based mixed-case checksum"),
        ]
        for k, v in steps:
            row(k, v)

    print(f"\n  {C.BOLD}{C.RED}Security Warnings:{C.RESET}")
    warn("NEVER share your private key!")
    warn("Do NOT use online key generators!")
    warn("Store your seed phrase physically in a secure location")
    warn("Use a hardware wallet (Ledger, Trezor)")
    ok("Trusted sources: bitcoin.org, ethereum.org")

