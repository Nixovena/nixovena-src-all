    # Default headers
    headers = headers_list[0]
    count = 1
    timeout = 15

    @staticmethod
    def get_random_headers():
        return random.choice(Engine.headers_list)

    @staticmethod
    def make_request(url, proxies=None, headers=None, timeout=None, retries=2):
        if headers is None:
            headers = Engine.get_random_headers()
        if proxies is None:
            proxies = Engine.proxy
        if timeout is None:
            timeout = Engine.timeout
            
        for attempt in range(retries):
            try:
                response = requests.get(url, proxies=proxies, headers=headers, timeout=timeout)
                return response
            except requests.exceptions.Timeout:
                if attempt < retries - 1:
                    print(Utils.YELLOW + "[!]" + Utils.WHITE + f" Request timed out, retrying ({attempt + 1}/{retries})...")
                    sleep(2 ** attempt)
                else:
                    print(Utils.RED + "[!]" + Utils.WHITE + f" Request timed out after {retries} attempts: {url[:60]}")
            except requests.exceptions.ConnectionError:
                if attempt < retries - 1:
                    print(Utils.YELLOW + "[!]" + Utils.WHITE + f" Connection error, retrying ({attempt + 1}/{retries})...")
                    sleep(2 ** attempt)
                else:
                    print(Utils.RED + "[!]" + Utils.WHITE + f" Connection failed after {retries} attempts: {url[:60]}")
            except requests.exceptions.RequestException as e:
                print(Utils.RED + "[!]" + Utils.WHITE + " Request failed: {}".format(str(e)))
                return None
        return None

    @staticmethod
    def encoding(report, name):
        quest = safe_int_input(
            Utils.BLUE + "\n[?]" + Utils.WHITE + "Do you want to encode the {} report? (1)Yes (2)No".format(name) + Utils.RED + "\n\n[:NODERAT:]" + Utils.WHITE + "-->",
            min_val=1, max_val=2
        )
        if quest == 1:
            EncodedFile = report.replace(".txt", ".Dk")
            try:
                with open(report, "r") as f:
                    reader = f.read()
                print(Utils.GREEN + "\n[+]" +
                          Utils.WHITE + "Encoding report...")
                sleep(2)
                encodingString = reader.encode("utf-8")
                Base64_Byte = base64.b64encode(encodingString)
                FinalString = Base64_Byte.decode("utf-8")
                with open(EncodedFile, "w", encoding="ascii") as f:
                    f.write(FinalString)
                print(Utils.YELLOW + "[v]" + Utils.WHITE +
                          "Report Encoded: {}".format(Utils.GREEN + os.path.basename(EncodedFile)))
                os.remove(report)
                print(Utils.GREEN + "\n[+]" + Utils.WHITE + "Report saved in: {}".format(
                    Utils.GREEN + EncodedFile))
            except OSError as e:
                print(Utils.RED + "[!]" + Utils.WHITE + f" Encoding failed: {e}")
        else:
            print(Utils.GREEN + "\n[+]" + Utils.WHITE + "Report saved in: {}".format(
                Utils.GREEN + report))
                
