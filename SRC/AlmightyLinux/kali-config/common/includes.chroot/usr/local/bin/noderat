    RED = "\033[31m"
    GREEN = "\033[32m"
    BLUE = "\033[94m"
    WHITE = "\033[97m"
    RESET = "\033[0m"

    @staticmethod
    def Clear_Screen():
        os.system("cls" if os.name == "nt" else "clear")

