#!/bin/bash
# =============================================================================
# Hardenwing — Hide Hardware Info
# =============================================================================
# Restricts unprivileged access to hardware-identifying information such as 
# /proc/cpuinfo, /proc/bus, /proc/scsi, and /sys. This prevents hardware 
# fingerprinting and mitigates certain hardware-specific local exploits.
# =============================================================================

set -e

echo "[*] Hardenwing: Hiding hardware info from unprivileged users..."

# 1. Restrict standard /proc hardware endpoints
for i in /proc/cpuinfo /proc/bus /proc/scsi; do
    if [ -e "$i" ]; then
        chmod og-rwx "$i" 2>/dev/null || true
    fi
done

# 2. Restrict /sys (sysfs exposes deep hardware and debug info)
if [ -e /sys ]; then
    # Restrict permissions on all root-level sysfs directories
    for i in /sys/* /sys/fs/*; do
        chmod o-rwx "$i" 2>/dev/null || true
    done

    # Re-allow minimal directory traversal needed by userspace utilities
    # (polkit requires stat access to /sys/fs/cgroup to function properly)
    chmod o+rx /sys /sys/fs 2>/dev/null || true
    
    # If SELinux is used, its userspace utilities need access to /sys/fs/selinux
    if [ -d /sys/fs/selinux ]; then
        chmod o+rx /sys /sys/fs /sys/fs/selinux 2>/dev/null || true
    fi
fi

echo "[✓] Hardware info successfully hidden."
