menu hshift 0
menu width 82

menu title Welcome to Lengtoolkit Live Boot Menu
include stdmenu.cfg

background_image /boot/grub/splash.png

label live-@FLAVOUR@-lengtoolkit
        menu label ^Lengtoolkit (@FLAVOUR@) Live
        menu default
        linux @LINUX@
        initrd @INITRD@
        append @APPEND_LIVE@ loglevel=0 locales=en_US.UTF-8

label live-@FLAVOUR@-debug
        menu label ^Lengtoolkit (@FLAVOUR@) Debug
        menu default
        linux @LINUX@
        initrd @INITRD@
        append @APPEND_LIVE@ loglevel=7 locales=en_US.UTF-8

menu begin advanced
	menu title Advanced options for Lengtoolkit
	include stdmenu.cfg

	label live-@FLAVOUR@-failsafe
		menu label ^Lengtoolkit (@FLAVOUR@ failsafe)
		linux @LINUX@
		initrd @INITRD@
		append @APPEND_LIVE_FAILSAFE@

	label hdt
		menu label ^Hardware Detection Tool (HDT)
		com32 hdt.c32

	label memtest
		menu label ^Memory Diagnostic Tool (memtest86+)
		linux /live/memtest

	label mainmenu
		menu label ^Back..
		menu exit

menu end
