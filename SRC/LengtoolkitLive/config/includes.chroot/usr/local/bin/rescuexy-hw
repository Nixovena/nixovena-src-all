#!/usr/bin/env python3
import os
import subprocess
import sys

def print_header(text):
    print(f"\033[1;36m{'='*60}")
    print(f" {text.center(58)}")
    print(f"{'='*60}\033[0m")

def get_cmd_output(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT).decode().strip()
    except:
        return "N/A"

def main():
    if os.getuid() != 0:
        print("\033[0;31mRoot required!\033[0m")
        sys.exit(1)

    print_header("RESCUEXY HW")
    print("\033[1;33m[ CPU ]\033[0m")
    print(f"Model: {get_cmd_output(\"lscpu | grep 'Model name:' | cut -d: -f2\")}")
    print(f"Cores: {get_cmd_output('nproc')}")
    temp = get_cmd_output("sensors | grep 'Package id 0:' | awk '{print $4}'")
    if temp: print(f"Temp: {temp}")

    print("\n\033[1;33m[ RAM ]\033[0m")
    print(get_cmd_output("free -h | grep Mem: | awk '{print \"Total: \" $2 \" | Used: \" $3 \" | Free: \" $4}'"))

    print("\n\033[1;33m[ DISKS ]\033[0m")
    print(get_cmd_output("lsblk -do NAME,SIZE,MODEL,TRAN | grep disk"))

    print("\n\033[1;33m[ PCI ]\033[0m")
    print(f"VGA: {get_cmd_output('lspci | grep -i vga | cut -d: -f3')}")
    print(f"NET: {get_cmd_output('lspci | grep -i network | cut -d: -f3')}")

if __name__ == "__main__":
    main()
