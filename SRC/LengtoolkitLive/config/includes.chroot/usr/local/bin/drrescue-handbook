SCAN NETWORKS:
  sudo iw wlan0 scan | grep -E 'SSID|signal'
  nmcli device wifi list

MONITOR MODE:
  sudo ip link set wlan0 down
  sudo iw wlan0 set monitor control
  sudo ip link set wlan0 up

DRIVER INFO:
  lspci -k | grep -A3 Network
  modinfo <driver_name>"
