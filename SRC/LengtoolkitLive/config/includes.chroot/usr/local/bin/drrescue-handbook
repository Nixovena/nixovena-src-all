======================

8.1 IP Configuration & Management
---------------------------------
SHOW CONFIGURATION:
  ip addr show                           # All interfaces
  ip -4 addr show                        # IPv4 only
  ip -6 addr show                        # IPv6 only
  ip link show                           # Link layer info
  ip -s link show eth0                   # Statistics

CONFIGURE IP:
  sudo ip addr add 192.168.1.100/24 dev eth0
  sudo ip addr del 192.168.1.100/24 dev eth0
  sudo ip link set eth0 up
  sudo ip link set eth0 down

ROUTING:
  ip route show                          # Show routes
  ip route get 8.8.8.8                   # Route to destination
  sudo ip route add default via 192.168.1.1
  sudo ip route add 10.0.0.0/8 via 192.168.1.254
  sudo ip route del default

ARP/NEIGHBOUR TABLE:
  ip neigh show                          # ARP table
  sudo ip neigh flush all                # Clear ARP cache
  sudo ip neigh add 192.168.1.1 lladdr aa:bb:cc:dd:ee:ff dev eth0

8.2 NetworkManager CLI (nmcli)
------------------------------
CONNECTION STATUS:
  nmcli general status                   # Overall status
  nmcli connection show                  # All connections
  nmcli device status                    # Device status

WIFI MANAGEMENT:
  nmcli device wifi list                 # Scan networks
  nmcli device wifi connect SSID password PASSWORD
  nmcli connection down 'WiFi Name'
  nmcli connection up 'WiFi Name'

CREATE CONNECTIONS:
  nmcli con add con-name 'Static' type ethernet ifname eth0 \\
    ip4 192.168.1.100/24 gw4 192.168.1.1
  nmcli con mod 'Static' ipv4.dns '8.8.8.8 8.8.4.4'
  nmcli con up 'Static'

HOTSPOT:
  nmcli device wifi hotspot ssid MyHotspot password MyPassword

8.3 DNS Troubleshooting
-----------------------
RESOLUTION TESTS:
  dig google.com                         # Full DNS query
  dig +short google.com                  # Just IP
  dig @8.8.8.8 google.com                # Specific server
  nslookup google.com                    # Alternative
  host google.com                        # Simple lookup

REVERSE DNS:
  dig -x 8.8.8.8                         # PTR record
  host 8.8.8.8                           # Simple reverse

DNS CACHE:
  systemd-resolve --flush-caches         # Systemd
  sudo systemctl restart systemd-resolved
  sudo resolvectl statistics             # Cache stats

CONFIGURATION:
  cat /etc/resolv.conf                   # Current DNS
  resolvectl status                      # Systemd-resolved status

8.4 Firewall Management
-----------------------
IPTABLES BASICS:
  sudo iptables -L -v -n                 # List all rules
  sudo iptables -L -t nat                # NAT table
  sudo iptables -F                       # Flush all rules
  sudo iptables -A INPUT -p tcp --dport 22 -j ACCEPT
  sudo iptables -A INPUT -j DROP

SAVE/RESTORE:
  sudo iptables-save > /tmp/iptables.rules
  sudo iptables-restore < /tmp/iptables.rules

NFTABLES:
  sudo nft list ruleset                  # Show all rules
  sudo nft flush ruleset                 # Clear all

UFW (Uncomplicated Firewall):
  sudo ufw status verbose
  sudo ufw enable/disable
  sudo ufw allow 22/tcp
  sudo ufw deny from 192.168.1.100

8.5 Port Scanning (nmap)
------------------------
BASIC SCANS:
  nmap 192.168.1.1                       # Default scan
  nmap -p 1-65535 192.168.1.1            # All ports
  nmap -p 22,80,443 192.168.1.1          # Specific ports
  nmap -sU -p 53,67,68 192.168.1.1       # UDP ports

NETWORK DISCOVERY:
  nmap -sn 192.168.1.0/24                # Ping sweep
  nmap -sP 192.168.1.0/24                # Host discovery

SERVICE/OS DETECTION:
  nmap -sV 192.168.1.1                   # Service versions
  nmap -O 192.168.1.1                    # OS detection
  nmap -A 192.168.1.1                    # Aggressive scan

STEALTH SCANS:
  sudo nmap -sS 192.168.1.1              # SYN scan
  sudo nmap -sN 192.168.1.1              # NULL scan

8.6 Packet Capture & Analysis
-----------------------------
TCPDUMP:
  sudo tcpdump -i eth0                   # All traffic
  sudo tcpdump -i any                    # All interfaces
  sudo tcpdump -i eth0 port 80           # HTTP only
  sudo tcpdump -i eth0 host 192.168.1.1  # Specific host
  sudo tcpdump -i eth0 -w capture.pcap   # Save to file
  sudo tcpdump -r capture.pcap           # Read from file
  sudo tcpdump -i eth0 -n -c 100         # Capture 100 packets

TSHARK (CLI Wireshark):
  tshark -i eth0                         # Capture
  tshark -r capture.pcap                 # Read file
  tshark -i eth0 -f 'port 443'           # Capture filter
  tshark -r file.pcap -Y 'http.request'  # Display filter

8.7 Connection Testing
----------------------
PING VARIANTS:
  ping -c 4 google.com                   # 4 pings
  ping -i 0.2 google.com                 # Fast ping
  ping -s 1472 -M do google.com          # MTU test

TRACEROUTE:
  traceroute google.com                  # ICMP
  traceroute -T -p 443 google.com        # TCP
  mtr google.com                         # Live trace

PORT TESTING:
  nc -zv 192.168.1.1 22                  # Check port
  nc -zv 192.168.1.1 1-1000              # Port range
  telnet 192.168.1.1 80                  # Test connection

BANDWIDTH:
  iperf3 -s                              # Server mode
  iperf3 -c server_ip                    # Client test

8.8 Wireless Troubleshooting
----------------------------
INTERFACE INFO:
  iw dev                                 # Wireless devices
  iw wlan0 info                          # Interface details
  iw wlan0 link                          # Connection status
