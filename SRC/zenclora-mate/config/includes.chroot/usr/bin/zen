def _zenthub_print_banner():
    banner = """
 ███████╗███████╗███╗   ██╗████████╗██╗  ██╗██╗   ██╗██████╗ 
 ╚══███╔╝██╔════╝████╗  ██║╚══██╔══╝██║  ██║██║   ██║██╔══██╗
   ███╔╝ █████╗  ██╔██╗ ██║   ██║   ███████║██║   ██║██████╔╝
  ███╔╝  ██╔══╝  ██║╚██╗██║   ██║   ██╔══██║██║   ██║██╔══██╗
 ███████╗███████╗██║ ╚████║   ██║   ██║  ██║╚██████╔╝██████╔╝
 ╚══════╝╚══════╝╚═╝  ╚═══╝   ╚═╝   ╚═╝  ╚═╝ ╚═════╝ ╚═════╝ """
    console.print(Panel(
        Align.center(Text(banner, style="bold cyan") + Text("\n\nZenclora Flatpak Store", style="bold white")),
        border_style="bright_blue", box=box.DOUBLE
    ))

def _zenthub_get_installed():
    try:
        res = subprocess.run(["flatpak", "list", "--columns=application"], capture_output=True, text=True)
        return res.stdout.strip().split("\n")
    except:
        return []

def _zenthub_show_categories():
    cats = sorted(list(set(app["cat"] for app in _ZENTHUB_PACKAGES)))
    table = Table(box=box.ROUNDED, border_style="cyan", title="Categories", title_style="bold magenta")
    table.add_column("#", style="bold yellow")
    table.add_column("Category", style="bold white")
    table.add_column("App Count", justify="center")

    for i, cat in enumerate(cats, 1):
        count = sum(1 for app in _ZENTHUB_PACKAGES if app["cat"] == cat)
        table.add_row(str(i), cat, str(count))

    console.print(table)
    return cats

def _zenthub_show_app_list(apps, title="Applications"):
    installed = _zenthub_get_installed()
    table = Table(box=box.ROUNDED, border_style="blue", title=title, title_style="bold cyan", expand=True)
    table.add_column("ID", style="bold yellow", width=4)
    table.add_column("Application Name", style="bold white")
    table.add_column("Category", style="dim magenta")
    table.add_column("Status", justify="center")

    for i, app in enumerate(apps, 1):
        status = "[bold green]Installed[/]" if app["id"] in installed else "[dim]Available[/]"
        table.add_row(str(i), app["name"], app["cat"], status)

    console.print(table)

def _zenthub_run_cmd(cmd, name):
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        transient=True,
    ) as progress:
        progress.add_task(description=f"Processing {name}...", total=None)
        if "-y" not in cmd: cmd += " -y"
        return subprocess.run(cmd, shell=True)

def _zenthub_handle_app_selection(app_list, title):
    while True:
        console.clear()
        _zenthub_print_banner()
        _zenthub_show_app_list(app_list, title)

        choice = Prompt.ask("\n[bold cyan]Enter # to Install/Uninstall or 'b' to go back[/]").lower()

        if choice == 'b':
            break
        elif choice.isdigit():
            idx = int(choice)
            if 1 <= idx <= len(app_list):
                app = app_list[idx-1]
                installed = _zenthub_get_installed()

                if app["id"] in installed:
                    if Confirm.ask(f"[bold red]Uninstall {app['name']}?[/]"):
                        _zenthub_run_cmd(f"flatpak uninstall {app['id']}", app["name"])
                else:
                    _zenthub_run_cmd(f"flatpak install flathub {app['id']}", app["name"])
                Prompt.ask("\nDone. Press Enter.")
            else:
                console.print("[bold red]Invalid index.[/]")
                Prompt.ask("Press Enter.")

def cmd_zenthub():
    if shutil.which("flatpak") is None:
        console.print(Panel(
            "[bold red]Flatpak is not installed![/]\n\n"
            "[white]Please install flatpak first run :[/] [bold cyan]sudo zen install flatpak[/]",
            title="[bold red]Error[/]",
            border_style="red",
            box=box.DOUBLE
        ))
        return

    while True:
        console.clear()
        _zenthub_print_banner()

        cats = _zenthub_show_categories()
        console.print("\n[dim](Select # to view category, 's' to search, 'c' for cleanup, 'q' to quit)[/]")

        choice = Prompt.ask("\n[bold cyan]Choice[/]").lower()

        if choice == 'q':
            break
        elif choice == 'c':
            console.print(Panel("[bold cyan]Cleaning up unused Flatpak runtimes...[/]", border_style="blue"))
            subprocess.run("flatpak uninstall --unused -y", shell=True)
            Prompt.ask("\nDone. Press Enter.")
        elif choice == 's':
            query = Prompt.ask("[bold cyan]Search[/]").lower()
            results = [app for app in _ZENTHUB_PACKAGES if query in app["name"].lower() or query in app["id"].lower()]
            if results:
                _zenthub_handle_app_selection(results, f"Search Results: '{query}'")
            else:
                console.print("[bold red]No results.[/]")
                Prompt.ask("Press Enter.")
        elif choice.isdigit():
            idx = int(choice)
            if 1 <= idx <= len(cats):
                cat_name = cats[idx-1]
                cat_apps = [app for app in _ZENTHUB_PACKAGES if app["cat"] == cat_name]
                _zenthub_handle_app_selection(cat_apps, f"Category: {cat_name}")
            else:
                console.print("[bold red]Invalid index.[/]")
                Prompt.ask("Press Enter.")

OLLAMA_API = "http://127.0.0.1:11434"
OLLAMA_POPULAR_MODELS = [
    ("llama3.1", "Meta Llama 3.1 8B", "4.7 GB"),
    ("llama3.2", "Meta Llama 3.2 3B", "2.0 GB"),
    ("mistral", "Mistral 7B Instruct", "4.1 GB"),
    ("gemma2", "Google Gemma 2 9B", "5.5 GB"),
    ("qwen2.5", "Qwen 2.5 7B", "4.7 GB"),
    ("phi3", "Microsoft Phi-3 Mini", "2.3 GB"),
    ("deepseek-coder-v2", "DeepSeek Coder V2", "8.9 GB"),
    ("codellama", "Code Llama 7B", "3.8 GB"),
    ("llava", "LLaVA Vision 7B", "4.7 GB"),
    ("nomic-embed-text", "Nomic Embed Text", "274 MB"),
]

class _OllamaManager:
    def __init__(self):
        self.installed = False
        self.server_running = False
        self._check_ollama()

    def _check_ollama(self):
        self.installed = shutil.which("ollama") is not None
        if self.installed:
            self.server_running = self._is_server_running()

    def _is_server_running(self):
        try:
            import urllib.request
            req = urllib.request.Request(f"{OLLAMA_API}/api/tags", method="GET")
            req.add_header("User-Agent", "ZEN/2.0")
            response = urllib.request.urlopen(req, timeout=5)
            return response.status == 200
        except Exception:
            return False

    def _get_api_json(self, endpoint):
        try:
            import urllib.request
            req = urllib.request.Request(f"{OLLAMA_API}{endpoint}", method="GET")
            req.add_header("User-Agent", "ZEN/2.0")
            response = urllib.request.urlopen(req, timeout=10)
            return json.loads(response.read().decode())
        except Exception:
            return None

    def _ensure_server(self):
        if not self.installed:
            console.print("[bold red]Ollama is not installed.[/]")
            console.print("[cyan]Install with: sudo zen install ollama[/]")
            return False
        if not self.server_running:
            console.print("[yellow]Ollama server is not running.[/]")
            if Confirm.ask("[cyan]Start Ollama service now?[/]"):
                try:
                    subprocess.run(["systemctl", "start", "ollama"], check=True, timeout=10)
                    time.sleep(2)
                    self.server_running = self._is_server_running()
                    if self.server_running:
                        console.print("[green]Ollama server started![/]")
                        return True
                except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
                    console.print("[cyan]Trying direct start...[/]")
                    subprocess.Popen(["ollama", "serve"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                    time.sleep(3)
                    self.server_running = self._is_server_running()
                    if self.server_running:
                        console.print("[green]Ollama server started![/]")
                        return True
                console.print("[red]Could not start Ollama server.[/]")
                return False
            return False
        return True

    def show_header(self):
        console.clear()
        header_text = f"""
[bold magenta] ██████╗ ██╗     ██╗      █████╗ ███╗   ███╗ █████╗ [/bold magenta]
[bold magenta]██╔═══██╗██║     ██║     ██╔══██╗████╗ ████║██╔══██╗[/bold magenta]
[bold magenta]██║   ██║██║     ██║     ███████║██╔████╔██║███████║[/bold magenta]
[bold magenta]██║   ██║██║     ██║     ██╔══██║██║╚██╔╝██║██╔══██║[/bold magenta]
[bold magenta]╚██████╔╝███████╗███████╗██║  ██║██║ ╚═╝ ██║██║  ██║[/bold magenta]
[bold magenta] ╚═════╝ ╚══════╝╚══════╝╚═╝  ╚═╝╚═╝     ╚═╝╚═╝  ╚═╝[/bold magenta]
        """
        console.print(Align.center(header_text))
        if self.installed:
            if self.server_running:
                status = "[bold green]● ONLINE[/bold green]"
            else:
                status = "[bold yellow]● SERVER STOPPED[/bold yellow]"
        else:
            status = "[bold red]● NOT INSTALLED[/bold red]"
        console.print(Align.center(f"Status: {status} | [dim]Zenclora AI Infrastructure v{ZEN_VERSION}[/dim]"))
        console.print("")

    def list_local_models(self):
        if not self._ensure_server():
            return []
        data = self._get_api_json("/api/tags")
        if not data or "models" not in data:
            try:
                result = subprocess.run(["ollama", "list"], capture_output=True, text=True, timeout=15)
                if result.returncode != 0:
                    console.print("[red]Could not list models.[/]")
                    return []
                lines = result.stdout.strip().split("\n")[1:]
                table = Table(title="Installed Ollama Models", border_style="magenta", box=box.ROUNDED)
                table.add_column("NAME", style="cyan")
                table.add_column("ID", style="dim")
                table.add_column("SIZE", style="green")
                table.add_column("MODIFIED", style="yellow")
                model_names = []
                for line in lines:
                    parts = line.split()
                    if len(parts) >= 4:
                        name = parts[0]
                        model_names.append(name)
                        table.add_row(name, parts[1], parts[2] + " " + parts[3], " ".join(parts[4:]))
                console.print(table)
                return model_names
            except (subprocess.TimeoutExpired, FileNotFoundError):
                console.print("[red]Failed to query Ollama.[/]")
                return []
        models = data["models"]
        table = Table(title="Installed Ollama Models", border_style="magenta", box=box.ROUNDED)
        table.add_column("#", style="bold yellow", width=4)
        table.add_column("Name", style="cyan")
        table.add_column("Size", style="green")
        table.add_column("Quantization", style="dim")
        table.add_column("Family", style="dim")
        table.add_column("Parameters", style="yellow")
        model_names = []
        for i, model in enumerate(models, 1):
            name = model.get("name", "unknown")
            model_names.append(name)
            size_bytes = model.get("size", 0)
            size_str = f"{size_bytes / (1024**3):.1f} GB" if size_bytes > 1e9 else f"{size_bytes / (1024**2):.0f} MB"
            details = model.get("details", {})
            quant = details.get("quantization_level", "N/A")
            family = details.get("family", "N/A")
            params = details.get("parameter_size", "N/A")
            table.add_row(str(i), name, size_str, quant, family, params)
        console.print(table)
        return model_names

    def show_model_info(self):
        models = self.list_local_models()
        if not models:
            return
        model_name = Prompt.ask("\n[cyan]Enter model name for details[/]", choices=models)
        try:
            import urllib.request
            req_data = json.dumps({"name": model_name}).encode()
            req = urllib.request.Request(f"{OLLAMA_API}/api/show", data=req_data, method="POST")
            req.add_header("Content-Type", "application/json")
            req.add_header("User-Agent", "ZEN/2.0")
            response = urllib.request.urlopen(req, timeout=10)
            data = json.loads(response.read().decode())
            table = Table(title=f"Model: {model_name}", border_style="cyan", box=box.ROUNDED)
            table.add_column("Property", style="bold white")
            table.add_column("Value", style="cyan")
            details = data.get("details", {})
            table.add_row("Family", details.get("family", "N/A"))
            table.add_row("Parameters", details.get("parameter_size", "N/A"))
            table.add_row("Quantization", details.get("quantization_level", "N/A"))
            table.add_row("Format", details.get("format", "N/A"))
            template = data.get("template", "")
            if template:
                table.add_row("Template", template[:100] + "..." if len(template) > 100 else template)
            system = data.get("system", "")
            if system:
                table.add_row("System Prompt", system[:100] + "..." if len(system) > 100 else system)
            license_text = data.get("license", "")
            if license_text:
                table.add_row("License", license_text[:80] + "..." if len(license_text) > 80 else license_text)
            console.print(table)
        except Exception as e:
            console.print(f"[red]Could not get model info: {e}[/]")

    def run_model(self):
        models = self.list_local_models()
        if not models:
            console.print("[yellow]No models found. Pull one first![/]")
            return
        model_name = Prompt.ask("\n[cyan]Enter model name to run[/]", choices=models)
        console.print(f"[green]Starting {model_name}... (Type /bye to quit)[/]")
        try:
            subprocess.run(["ollama", "run", model_name])
        except KeyboardInterrupt:
            console.print("\n[cyan]Chat ended.[/]")
        except FileNotFoundError:
            console.print("[red]Ollama binary not found.[/]")

    def pull_model(self):
        if not self._ensure_server():
            return
        console.print(Panel("[bold cyan]Pull Model from Library[/]", border_style="cyan"))
        table = Table(title="Popular Models", border_style="dim", box=box.SIMPLE)
        table.add_column("#", style="bold yellow", width=4)
        table.add_column("Model", style="cyan")
        table.add_column("Description", style="white")
        table.add_column("Size", style="green")
        for i, (name, desc, size) in enumerate(OLLAMA_POPULAR_MODELS, 1):
            table.add_row(str(i), name, desc, size)
        console.print(table)
        console.print("[dim]Or enter any model name from ollama.com/library[/]")
        choice = Prompt.ask("\n[cyan]Enter # or model name[/]")
        if choice.isdigit() and 1 <= int(choice) <= len(OLLAMA_POPULAR_MODELS):
            model_name = OLLAMA_POPULAR_MODELS[int(choice) - 1][0]
        else:
            model_name = choice.strip()
        if not model_name:
            console.print("[red]No model name provided.[/]")
            return
        data = self._get_api_json("/api/tags")
        if data:
            existing = [m.get("name", "") for m in data.get("models", [])]
            if model_name in existing or f"{model_name}:latest" in existing:
                if not Confirm.ask(f"[yellow]{model_name} is already installed. Re-pull?[/]"):
                    return
        console.print(f"[cyan]Pulling {model_name}...[/]")
        try:
            subprocess.run(["ollama", "pull", model_name])
            console.print(f"[green]{model_name} pull complete![/]")
        except KeyboardInterrupt:
            console.print("[yellow]Pull interrupted.[/]")
        except FileNotFoundError:
            console.print("[red]Ollama binary not found.[/]")

    def import_gguf(self):
        console.print(Panel(
            "[bold yellow]GGUF Import Wizard[/]\nImport a local .gguf file to create an Ollama model.",
            border_style="yellow"
        ))
        gguf_path = Prompt.ask("[cyan]Enter full path to .gguf file[/]")
        if not gguf_path:
            console.print("[red]Path is required.[/]")
            return
        gguf_path = os.path.expanduser(gguf_path.strip("\"'"))
        if not os.path.exists(gguf_path):
            console.print(f"[red]File not found: {gguf_path}[/]")
            return
        if not gguf_path.endswith(".gguf"):
            console.print("[yellow]File does not have .gguf extension. Continuing anyway...[/]")
        file_size = os.path.getsize(gguf_path)
        console.print(f"[dim]  File size: {file_size / (1024**3):.2f} GB[/]")
        model_name = Prompt.ask("[cyan]Name for this model[/]")
        if not model_name:
            console.print("[red]Model name is required.[/]")
            return
        model_name = model_name.lower().replace(" ", "-")
        system_prompt = ""
        if Confirm.ask("[cyan]Add a custom system prompt?[/]", default=False):
            system_prompt = Prompt.ask("[cyan]Enter system prompt[/]")
        modelfile_content = f'FROM {gguf_path}\n'
        if system_prompt:
            modelfile_content += f'SYSTEM """{system_prompt}"""\n'
        modelfile_path = f"/tmp/_zen_modelfile_{model_name}"
        try:
            with open(modelfile_path, "w") as f:
                f.write(modelfile_content)
            console.print(f"[cyan]Creating Ollama model '{model_name}'...[/]")
            result = subprocess.run(["ollama", "create", model_name, "-f", modelfile_path], timeout=300)
            if result.returncode == 0:
                console.print(f"[green]Model '{model_name}' created successfully![/]")
            else:
                console.print("[red]Model creation failed.[/]")
        except subprocess.TimeoutExpired:
            console.print("[red]Operation timed out.[/]")
        except Exception as e:
            console.print(f"[red]Failed to import GGUF: {e}[/]")
        finally:
            if os.path.exists(modelfile_path):
                os.remove(modelfile_path)

    def remove_model(self):
        models = self.list_local_models()
        if not models:
            console.print("[cyan]No models to remove.[/]")
            return
        model_name = Prompt.ask("\n[red]Enter model name to REMOVE[/]", choices=models)
        if Confirm.ask(f"[yellow]Are you sure you want to delete {model_name}?[/]"):
            try:
                result = subprocess.run(["ollama", "rm", model_name], check=True, timeout=30)
                console.print(f"[green]{model_name} removed.[/]")
            except subprocess.CalledProcessError:
                console.print(f"[red]Failed to remove {model_name}.[/]")
            except subprocess.TimeoutExpired:
                console.print("[red]Operation timed out.[/]")
            time.sleep(1)

    def server_management(self):
        console.print(Panel("[bold cyan]Ollama Service Management[/]", border_style="cyan"))
        self.server_running = self._is_server_running()
        status = "[bold green]● Running[/bold green]" if self.server_running else "[bold red]● Stopped[/bold red]"
        console.print(f"  Status: {status}")
        console.print("\n  1. Start service")
        console.print("  2. Stop service")
        console.print("  3. Restart service")
        console.print("  4. Enable on boot")
        console.print("  5. Disable on boot")
        console.print("  6. View logs")
        console.print("  0. Back")
        choice = Prompt.ask("\n[cyan]Select[/]", choices=["0", "1", "2", "3", "4", "5", "6"], default="0")
        service_cmds = {"1": "start", "2": "stop", "3": "restart", "4": "enable", "5": "disable"}
        if choice in service_cmds:
            action = service_cmds[choice]
            try:
                subprocess.run(["systemctl", action, "ollama"], check=True, timeout=15)
                console.print(f"[green]Ollama service {action}ed.[/]")
                time.sleep(1)
                self.server_running = self._is_server_running()
            except subprocess.CalledProcessError:
                console.print(f"[red]Failed to {action} Ollama service. Try with sudo.[/]")
            except subprocess.TimeoutExpired:
                console.print("[red]Operation timed out.[/]")
        elif choice == "6":
            try:
                subprocess.run(["journalctl", "-u", "ollama", "-n", "50", "--no-pager"], timeout=15)
            except (subprocess.TimeoutExpired, FileNotFoundError):
                console.print("[red]Could not retrieve logs.[/]")

    def copy_model(self):
        models = self.list_local_models()
        if not models:
            return
        source = Prompt.ask("\n[cyan]Source model name[/]", choices=models)
        dest = Prompt.ask("[cyan]New model name[/]")
        if not dest:
            console.print("[red]Destination name is required.[/]")
            return
        try:
            subprocess.run(["ollama", "cp", source, dest], check=True, timeout=60)
            console.print(f"[green]Model copied: {source} → {dest}[/]")
        except subprocess.CalledProcessError:
            console.print("[red]Failed to copy model.[/]")
        except subprocess.TimeoutExpired:
            console.print("[red]Operation timed out.[/]")

def cmd_ai_ollama_embedded():

    mgr = _OllamaManager()
    while True:
        mgr._check_ollama()
        mgr.show_header()
        menu = Panel(
            "[bold cyan]1.[/bold cyan] List Installed Models\n"
            "[bold cyan]2.[/bold cyan] Model Details (Info)\n"
            "[bold cyan]3.[/bold cyan] Run a Model (Interactive Chat)\n"
            "[bold cyan]4.[/bold cyan] Pull New Model (from Library)\n"
            "[bold cyan]5.[/bold cyan] Import GGUF Model (Create Local)\n"
            "[bold cyan]6.[/bold cyan] Copy/Clone Model\n"
            "[bold cyan]7.[/bold cyan] Remove a Model\n"
            "[bold yellow]--- Service ---[/bold yellow]\n"
            "[bold cyan]8.[/bold cyan] Server Management\n"
            "[bold cyan]9.[/bold cyan] Exit",
            title="[bold white on magenta] OLLAMA MANAGER [/bold white on magenta]",
            border_style="magenta",
            padding=(1, 2)
        )
        console.print(Align.center(menu))
        choice = Prompt.ask("\n[cyan]Select Action[/]", choices=[str(i) for i in range(1, 10)], default="1")
        actions = {
            "1": lambda: (mgr.list_local_models(), Prompt.ask("\nPress Enter to return")),
            "2": lambda: (mgr.show_model_info(), Prompt.ask("\nPress Enter to return")),
            "3": lambda: (mgr.run_model(), Prompt.ask("\nPress Enter to return")),
            "4": lambda: (mgr.pull_model(), Prompt.ask("\nPress Enter to return")),
            "5": lambda: (mgr.import_gguf(), Prompt.ask("\nPress Enter to return")),
            "6": lambda: (mgr.copy_model(), Prompt.ask("\nPress Enter to return")),
            "7": lambda: mgr.remove_model(),
            "8": lambda: (mgr.server_management(), Prompt.ask("\nPress Enter to return")),
        }
        if choice == "9":
            console.print("[cyan]Exiting Ollama Manager...[/]")
            break
        elif choice in actions:
            try:
                actions[choice]()
            except KeyboardInterrupt:
                console.print("\n[yellow]Operation cancelled.[/]")
            except Exception as e:
                console.print(f"\n[red]Unexpected error: {e}[/]")
                Prompt.ask("\nPress Enter to continue")

class _ZenAIToolkit:
    def __init__(self):
        self._docker_installed = None
        self._hf_installed = None
        self._gpu_support = None
        self._gpu_name = None
        self._check_dependencies()

    def _check_dependencies(self):
        try:
            result = subprocess.run(["docker", "--version"], capture_output=True, text=True, timeout=10)
            self._docker_installed = result.returncode == 0
        except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
            self._docker_installed = False
        try:
            result = subprocess.run(["huggingface-cli", "version"], capture_output=True, text=True, timeout=10)
            self._hf_installed = result.returncode == 0
        except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
            self._hf_installed = False
        try:
            result = subprocess.run(["nvidia-smi", "--query-gpu=name", "--format=csv,noheader"], capture_output=True, text=True, timeout=10)
            if result.returncode == 0 and result.stdout.strip():
                self._gpu_support = True
                self._gpu_name = result.stdout.strip().split('\n')[0]
            else:
                self._gpu_support = False
        except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
            self._gpu_support = False

    def show_header(self):
        console.clear()
        header_text = f"""
[bold cyan]███████╗███████╗███╗   ██╗     █████╗ ██╗[/bold cyan]
[bold cyan]╚══███╔╝██╔════╝████╗  ██║    ██╔══██╗██║[/bold cyan]
[bold cyan]  ███╔╝ █████╗  ██╔██╗ ██║    ███████║██║[/bold cyan]
[bold cyan] ███╔╝  ██╔══╝  ██║╚██╗██║    ██╔══██║██║[/bold cyan]
[bold cyan]███████╗███████╗██║ ╚████║    ██║  ██║██║[/bold cyan]
[bold cyan]╚══════╝╚══════╝╚═╝  ╚═══╝    ╚═╝  ╚═╝╚═╝[/bold cyan]
[bold blue]           AI/ML CLI TOOLKIT v{ZEN_VERSION}[/bold blue]
        """
        console.print(Align.center(header_text))
        status_parts = []
        status_parts.append(f"Docker: {'[green]OK[/green]' if self._docker_installed else '[red]N/A[/red]'}")
        gpu_label = f"[green]{self._gpu_name}[/green]" if self._gpu_support else "[yellow]CPU Only[/yellow]"
        status_parts.append(f"GPU: {gpu_label}")
        status_parts.append(f"HF-CLI: {'[green]OK[/green]' if self._hf_installed else '[red]N/A[/red]'}")
        console.print(Align.center(f"[dim]{' │ '.join(status_parts)}[/dim]"))
        console.print(Align.center("[italic dim]Zenclora AI Pipeline Toolkit[/italic dim]"))
        console.print("")

    def _require_docker(self):
        if not self._docker_installed:
            console.print("[bold red]Docker is not installed or not running.[/]")
            console.print("[cyan]Install Docker: sudo zen install docker[/]")
            return False
        return True

    def _require_hf(self):
        if not self._hf_installed:
            console.print("[bold red]huggingface-cli is not installed.[/]")
            console.print("[cyan]Install with: pip install -U huggingface_hub[/]")
            return False
        return True

    def _safe_input(self, prompt_text, default=None, validate_path=False):
        value = Prompt.ask(prompt_text, default=default)
        if value:
            value = value.strip()
        if validate_path and value:
            value = os.path.expanduser(value)
        return value

    def monitor_hardware(self):
        console.print(Panel("[bold yellow]Hardware Monitoring[/]", border_style="yellow"))
        if self._gpu_support:
            console.print("\n[cyan]GPU Information:[/]")
            try:
                subprocess.run(["nvidia-smi"], timeout=30)
            except subprocess.TimeoutExpired:
                console.print("[red]nvidia-smi timed out[/]")
            except Exception as e:
                console.print(f"[red]Error accessing GPU: {e}[/]")
        else:
            console.print("[yellow]No NVIDIA GPU detected. CPU-only mode.[/]")
        console.print("\n[cyan]Memory (RAM):[/]")
        try:
            subprocess.run(["free", "-h"], timeout=10)
        except (FileNotFoundError, subprocess.TimeoutExpired):
            console.print("[yellow]Could not read memory info[/]")
        console.print("\n[cyan]Storage (AI-relevant paths):[/]")
        ai_paths = [
            ("Home", os.path.expanduser("~")),
            ("Models Cache", os.path.expanduser("~/.cache/huggingface")),
            ("/opt/models", "/opt/models"),
        ]
        table = Table(box=box.SIMPLE, border_style="dim")
        table.add_column("Location", style="cyan")
        table.add_column("Used", style="yellow")
        table.add_column("Free", style="green")
        for label, path in ai_paths:
            if os.path.exists(path):
                try:
                    stat = shutil.disk_usage(path)
                    used = f"{stat.used / (1024**3):.1f} GB"
                    free = f"{stat.free / (1024**3):.1f} GB"
                    table.add_row(f"{label} ({path})", used, free)
                except OSError:
                    pass
        console.print(table)

    def init_ai_project(self):
        console.print(Panel("[bold cyan]AI Project Initializer[/]", border_style="cyan"))
        project_name = self._safe_input("[cyan]Enter new project name[/]", default="my_ai_project")
        if not project_name:
            console.print("[red]Project name is required.[/]")
            return
        project_name = project_name.replace(" ", "_").replace("/", "_")
        if os.path.exists(project_name):
            if not Confirm.ask(f"[yellow]Directory '{project_name}' already exists. Continue?[/]"):
                return
        directories = [
            f"{project_name}/data/raw", f"{project_name}/data/processed", f"{project_name}/data/external",
            f"{project_name}/notebooks", f"{project_name}/models/checkpoints", f"{project_name}/models/exports",
            f"{project_name}/src", f"{project_name}/src/utils", f"{project_name}/configs",
            f"{project_name}/logs", f"{project_name}/tests",
        ]
        try:
            for d in directories:
                os.makedirs(d, exist_ok=True)
            with open(f"{project_name}/requirements.txt", "w") as f:
                f.write("# Core ML\ntorch\ntorchvision\ntorchaudio\n# Transformers\ntransformers\ndatasets\ntokenizers\naccelerate\n# Data Science\npandas\nnumpy\nscikit-learn\nmatplotlib\nseaborn\n# Notebooks\njupyter\nipywidgets\n# Utilities\ntqdm\npyyaml\npython-dotenv\nrich\n")
            with open(f"{project_name}/README.md", "w") as f:
                f.write(f"# {project_name}\n\nAI/ML Project generated by ZEN AI Toolkit.\n\n## Structure\n```\n├── data/          # Raw, processed, external datasets\n├── notebooks/     # Jupyter notebooks\n├── models/        # Checkpoints and exports\n├── src/           # Source code\n├── configs/       # Configuration files\n├── logs/          # Training logs\n└── tests/         # Unit tests\n```\n")
            with open(f"{project_name}/.gitignore", "w") as f:
                f.write("# Data\ndata/raw/\ndata/external/\n*.csv\n*.parquet\n\n# Models\nmodels/checkpoints/\n*.pt\n*.bin\n*.safetensors\n*.gguf\n*.onnx\n\n# Environment\n.env\n*.env\n.ai-env/\nvenv/\n__pycache__/\n\n# Logs\nlogs/\n*.log\nwandb/\nruns/\n\n# Notebooks\n.ipynb_checkpoints/\n\n# IDE\n.vscode/\n.idea/\n")
            with open(f"{project_name}/configs/default.yaml", "w") as f:
                f.write("# Default training configuration\nmodel:\n  name: null\n  pretrained: true\n\ntraining:\n  epochs: 10\n  batch_size: 32\n  learning_rate: 0.001\n  optimizer: adamw\n  scheduler: cosine\n\ndata:\n  train_split: 0.8\n  val_split: 0.1\n  test_split: 0.1\n")
            console.print(f"[green]Project '{project_name}' scaffolded successfully![/]")
            console.print(f"[dim]  Created {len(directories)} directories and config files[/]")
        except PermissionError:
            console.print("[red]Permission denied creating project directory.[/]")
        except OSError as e:
            console.print(f"[red]Failed to create project: {e}[/]")

    def install_ai_system_packages(self):
        console.print(Panel("[bold cyan]Install AI/ML System Packages[/]", border_style="cyan"))
        pkgs = [
            "python3-torch", "python3-torchvision", "python3-torchaudio",
            "python3-xgboost", "python3-sklearn", "python3-pandas", "python3-numpy"
        ]
        console.print("[cyan]The following packages will be installed:[/]")
        for p in pkgs:
            console.print(f"  [white]- {p}[/]")
        console.print()
        if not Confirm.ask("[yellow]Proceed with installation?[/]"):
            return
        cmd = "sudo apt install -y " + " ".join(pkgs)
        console.print(f"[cyan]Running: {cmd}[/]")
        try:
            result = subprocess.run(cmd, shell=True)
            if result.returncode == 0:
                console.print("[green]AI/ML system packages installed successfully![/]")
            else:
                console.print("[red]Installation failed. Check your package sources.[/]")
        except KeyboardInterrupt:
            console.print("[yellow]Installation interrupted.[/]")

    def setup_venv(self):
        console.print(Panel("[bold green]Python AI VENV Setup[/]", border_style="green"))
        venv_name = self._safe_input("[cyan]Virtual environment name[/]", default=".ai-env")
        if not venv_name:
            console.print("[red]Environment name is required.[/]")
            return
        console.print("[cyan]Select framework:[/]")
        console.print("  1. PyTorch (GPU/CPU)")
        console.print("  2. TensorFlow")
        console.print("  3. JAX")
        console.print("  4. Base Data Science (no DL framework)")
        framework = Prompt.ask("[cyan]Choice[/]", choices=["1", "2", "3", "4"], default="1")
        console.print(f"[cyan]Creating venv '{venv_name}'...[/]")
        try:
            subprocess.run([sys.executable, "-m", "venv", venv_name], check=True, timeout=60)
            pip_path = os.path.join(venv_name, "bin", "pip")
            packages = ["jupyter", "pandas", "numpy", "matplotlib", "scikit-learn", "seaborn", "tqdm", "rich"]
            if framework == "1":
                packages.extend(["torch", "torchvision", "torchaudio", "transformers", "accelerate"])
            elif framework == "2":
                packages.extend(["tensorflow", "keras"])
            elif framework == "3":
                packages.extend(["jax", "jaxlib", "flax", "optax"])
            console.print("[cyan]Upgrading pip...[/]")
            subprocess.run([pip_path, "install", "--upgrade", "pip"], check=True, timeout=120)
            console.print(f"[cyan]Installing {len(packages)} packages...[/]")
            console.print(f"[dim]  {', '.join(packages)}[/]")
            subprocess.run([pip_path, "install"] + packages, check=True)
            console.print(f"[green]VENV setup complete![/]")
            console.print(f"[cyan]Activate with: source {venv_name}/bin/activate[/]")
        except subprocess.CalledProcessError as e:
            console.print(f"[red]VENV setup failed: {e}[/]")
        except subprocess.TimeoutExpired:
            console.print("[red]Operation timed out.[/]")
        except Exception as e:
            console.print(f"[red]Unexpected error: {e}[/]")

    def docker_jupyter_launch(self):
        console.print(Panel("[bold magenta]Launch AI Docker Container[/]", border_style="magenta"))
        if not self._require_docker():
            return
        gpu_flag = ""
        if self._gpu_support:
            if Confirm.ask("[yellow]Use GPU acceleration (--gpus all)?[/]"):
                gpu_flag = "--gpus all "
        console.print("[cyan]Select container image:[/]")
        console.print("  1. PyTorch (Official)")
        console.print("  2. TensorFlow (GPU)")
        console.print("  3. Jupyter Data Science")
        console.print("  4. Custom Image")
        c_choice = Prompt.ask("Selection", choices=["1", "2", "3", "4"], default="1")
        images = {"1": "pytorch/pytorch:latest", "2": "tensorflow/tensorflow:latest-gpu", "3": "jupyter/datascience-notebook"}
        if c_choice == "4":
            image = self._safe_input("[cyan]Enter Docker image name[/]")
            if not image:
                console.print("[red]Image name is required.[/]")
                return
        else:
            image = images[c_choice]
        pwd = os.getcwd()
        port = self._safe_input("[cyan]Port mapping[/]", default="8888")
        cmd = f'docker run -it --rm {gpu_flag}-p {port}:8888 -v "{pwd}:/workspace" -w /workspace {image} bash'
        console.print(f"[yellow]Running: {cmd}[/]")
        try:
            os.system(cmd)
        except KeyboardInterrupt:
            console.print("[cyan]Container session ended.[/]")

    def download_kaggle_dataset(self):
        console.print(Panel("[bold cyan]Kaggle Dataset Downloader[/]", border_style="cyan"))
        if not shutil.which("kaggle"):
            console.print("[red]Kaggle CLI not found.[/]")
            console.print("[cyan]Install with: pip install kaggle[/]")
            console.print("[cyan]Then configure: ~/.kaggle/kaggle.json[/]")
            return
        kaggle_json = os.path.expanduser("~/.kaggle/kaggle.json")
        if not os.path.exists(kaggle_json):
            console.print("[yellow]Kaggle credentials not found at ~/.kaggle/kaggle.json[/]")
            console.print("[cyan]Download your API token from https://www.kaggle.com/settings[/]")
            return
        dataset_id = self._safe_input("[cyan]Enter Kaggle Dataset (e.g. zillow/zecon)[/]")
        if not dataset_id:
            console.print("[red]Dataset ID is required.[/]")
            return
        out_dir = self._safe_input("[cyan]Output directory[/]", default="./data")
        os.makedirs(out_dir, exist_ok=True)
        unzip_flag = "--unzip" if Confirm.ask("[yellow]Unzip after downloading?[/]") else ""
        cmd = f"kaggle datasets download {dataset_id} -p {out_dir} {unzip_flag}"
        console.print(f"[cyan]Running: {cmd}[/]")
        try:
            result = subprocess.run(cmd, shell=True, timeout=None)
            if result.returncode == 0:
                console.print(f"[green]Dataset downloaded to {out_dir}![/]")
            else:
                console.print("[red]Download failed. Check dataset ID and credentials.[/]")
        except KeyboardInterrupt:
            console.print("[yellow]Download interrupted.[/]")

    def serve_model_tgi(self):
        console.print(Panel("[bold green]Serve HF Model via TGI (Docker)[/]", border_style="green"))
        if not self._require_docker():
            return
        model_id = self._safe_input("[cyan]Enter HF Model ID (e.g. mistralai/Mistral-7B-Instruct-v0.2)[/]")
        if not model_id:
            console.print("[red]Model ID is required.[/]")
            return
        gpu_args = ""
        if self._gpu_support and Confirm.ask("[yellow]Use native GPU?[/]"):
            gpu_args = "--gpus all"
        default_cache = os.path.expanduser("~/.cache/huggingface/hub")
        volume_path = self._safe_input("[cyan]Local HF cache path to mount[/]", default=default_cache)
        port = self._safe_input("[cyan]Port to serve API on[/]", default="8080")
        cmd = f'docker run {gpu_args} --shm-size 1g -p {port}:80 -v "{volume_path}:/data" ghcr.io/huggingface/text-generation-inference:latest --model-id {model_id}'
        console.print(f"[yellow]Running: {cmd}[/]")
        console.print("[dim]Press Ctrl+C to stop the server.[/]")
        try:
            os.system(cmd)
        except KeyboardInterrupt:
            console.print("[cyan]Server stopped.[/]")

    def setup_git_lfs(self):
        console.print(Panel("[bold cyan]Git LFS (Large File Storage) Tracker[/]", border_style="cyan"))
        if not shutil.which("git"):
            console.print("[red]Git is not installed.[/]")
            return
        try:
            subprocess.run(["git", "lfs", "install"], check=True, timeout=30)
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
            console.print("[red]Git LFS is not installed. Install with: apt install git-lfs[/]")
            return
        if Confirm.ask("[cyan]Track common ML files (*.safetensors, *.bin, *.gguf, *.pt, *.h5) in this repo?[/]"):
            extensions = ["*.safetensors", "*.bin", "*.gguf", "*.pt", "*.h5", "*.onnx", "*.pth"]
            for ext in extensions:
                subprocess.run(["git", "lfs", "track", ext], timeout=10)
            subprocess.run(["git", "add", ".gitattributes"], timeout=10)
            console.print(f"[green]Git LFS configured! Tracking {len(extensions)} extensions.[/]")

    def freeze_requirements(self):
        console.print(Panel("[bold yellow]Generate requirements.txt[/]", border_style="yellow"))
        if Confirm.ask("[cyan]Generate requirements.txt from current pip environment?[/]"):
            try:
                result = subprocess.run([sys.executable, "-m", "pip", "freeze"], capture_output=True, text=True, timeout=30)
                if result.returncode == 0:
                    with open("requirements.txt", "w") as f:
                        f.write(result.stdout)
                    line_count = len(result.stdout.strip().split('\n'))
                    console.print(f"[green]requirements.txt generated ({line_count} packages)[/]")
                else:
                    console.print(f"[red]pip freeze failed: {result.stderr}[/]")
            except subprocess.TimeoutExpired:
                console.print("[red]Operation timed out.[/]")
            except OSError as e:
                console.print(f"[red]Failed to write requirements.txt: {e}[/]")

    def quantize_gguf(self):
        console.print(Panel("[bold magenta]GGUF Model Quantization (llama.cpp Docker)[/]", border_style="magenta"))
        if not self._require_docker():
            return
        model_path = self._safe_input("[cyan]Local folder containing GGUF[/]", default=os.getcwd(), validate_path=True)
        if not os.path.isdir(model_path):
            console.print(f"[red]Directory not found: {model_path}[/]")
            return
        input_gguf = self._safe_input("[cyan]Input GGUF filename (e.g. model-F16.gguf)[/]")
        if not input_gguf:
            console.print("[red]Input filename is required.[/]")
            return
        input_path = os.path.join(model_path, input_gguf)
        if not os.path.isfile(input_path):
            console.print(f"[red]File not found: {input_path}[/]")
            return
        output_gguf = self._safe_input("[cyan]Output GGUF filename (e.g. model-Q4_K_M.gguf)[/]")
        if not output_gguf:
            console.print("[red]Output filename is required.[/]")
            return
        console.print("\n[cyan]Quantization Methods:[/]")
        console.print("  Q4_K_M  - Good balance of quality and size")
        console.print("  Q5_K_M  - Higher quality, larger size")
        console.print("  Q8_0    - Near-lossless, largest size")
        method = Prompt.ask("[cyan]Method[/]", choices=["Q4_K_M", "Q5_K_M", "Q8_0"], default="Q4_K_M")
        cmd = f'docker run --rm -v "{model_path}:/models" ghcr.io/ggerganov/llama.cpp:full --run quantize /models/{input_gguf} /models/{output_gguf} {method}'
        console.print(f"[yellow]Running: {cmd}[/]")
        try:
            os.system(cmd)
            output_path = os.path.join(model_path, output_gguf)
            if os.path.exists(output_path):
                size = os.path.getsize(output_path)
                console.print(f"[green]Quantization complete! Output: {output_gguf} ({size / (1024**3):.2f} GB)[/]")
        except KeyboardInterrupt:
            console.print("[yellow]Quantization interrupted.[/]")

    def launch_comfyui(self):
        console.print(Panel("[bold magenta]ComfyUI (Stable Diffusion) Docker Launcher[/]", border_style="magenta"))
        if not self._require_docker():
            return
        comfy_dir = self._safe_input("[cyan]Local folder for ComfyUI data[/]", default=os.path.join(os.getcwd(), "comfyui_data"), validate_path=True)
        os.makedirs(comfy_dir, exist_ok=True)
        gpu_args = "--gpus all" if self._gpu_support else ""
        port = self._safe_input("[cyan]Port for ComfyUI[/]", default="8188")
        console.print("[cyan]Starting ComfyUI Server...[/]")
        cmd = f'docker run -it --rm {gpu_args} -p {port}:8188 -v "{comfy_dir}:/root/ComfyUI" yanwk/comfyui-boot:latest'
        console.print(f"[yellow]Running: {cmd}[/]")
        try:
            os.system(cmd)
        except KeyboardInterrupt:
            console.print("[cyan]ComfyUI stopped.[/]")

    def launch_axolotl_trainer(self):
        console.print(Panel("[bold yellow]LLM Fine-Tuning Environment (Axolotl)[/]", border_style="yellow"))
        if not self._require_docker():
            return
        console.print("[cyan]This will start an Axolotl workspace via Docker for fine-tuning LLMs.[/]")
        workspace_dir = self._safe_input("[cyan]Local workspace folder[/]", default=os.path.join(os.getcwd(), "axolotl_workspace"), validate_path=True)
        os.makedirs(workspace_dir, exist_ok=True)
        gpu_args = "--gpus all" if self._gpu_support else ""
        cmd = f'docker run --rm -it {gpu_args} -v "{workspace_dir}:/workspace" winglian/axolotl:main-latest bash'
        console.print(f"[yellow]Running: {cmd}[/]")
        try:
            os.system(cmd)
        except KeyboardInterrupt:
            console.print("[cyan]Axolotl session ended.[/]")

    def export_onnx(self):
        console.print(Panel("[bold cyan]Export HF Model to ONNX (Optimum CLI)[/]", border_style="cyan"))
        model_id = self._safe_input("[cyan]Source HF Model ID or Local Path[/]")
        if not model_id:
            console.print("[red]Model ID is required.[/]")
            return
        out_dir = self._safe_input("[cyan]Output folder for ONNX model[/]", default="./onnx_model")
        task = self._safe_input("[cyan]Task (e.g. text-generation, feature-extraction)[/]", default="text-generation")
        console.print("[cyan]Exporting via optimum-cli. Requires 'optimum[exporters]'.[/]")
        if Confirm.ask("[yellow]Attempt to install/upgrade optimum first?[/]"):
            try:
                subprocess.run([sys.executable, "-m", "pip", "install", "optimum[exporters]"], timeout=300)
            except subprocess.TimeoutExpired:
                console.print("[red]Installation timed out.[/]")
                return
        cmd = f"optimum-cli export onnx --model {model_id} --task {task} {out_dir}/"
        console.print(f"[yellow]Running: {cmd}[/]")
        try:
            os.system(cmd)
        except KeyboardInterrupt:
            console.print("[yellow]Export interrupted.[/]")

    def format_to_jsonl(self):
        console.print(Panel("[bold green]Dataset Formatter (CSV to JSONL)[/]", border_style="green"))
        console.print("[cyan]Converts CSV to JSON Lines (.jsonl) format for LLM fine-tuning.[/]")
        input_csv = self._safe_input("[cyan]Path to input .csv file[/]", validate_path=True)
        if not input_csv or not os.path.exists(input_csv):
            console.print("[red]File not found![/]")
            return
        output_jsonl = self._safe_input("[cyan]Path for output .jsonl[/]", default=input_csv.replace(".csv", ".jsonl"))
        try:
            import pandas as pd
            df = pd.read_csv(input_csv)
            df.to_json(output_jsonl, orient="records", lines=True, force_ascii=False)
            console.print(f"[green]Converted {len(df)} rows to {output_jsonl}![/]")
            console.print(f"[dim]Columns: {', '.join(df.columns.tolist())}[/]")
        except ImportError:
            console.print("[red]Pandas is required. Install with: pip install pandas[/]")
        except Exception as e:
            console.print(f"[red]Conversion failed: {e}[/]")

    def gpu_stress_test(self):
        console.print(Panel("[bold red]GPU Stress Test (PyTorch)[/]", border_style="red"))
        if not self._gpu_support:
            console.print("[red]No NVIDIA GPU detected. Cannot run stress test.[/]")
            return
        if not Confirm.ask("[yellow]This will heavily load your GPU. Continue?[/]"):
            return
        script_content = '''
import torch
import time

print(f"PyTorch Version: {torch.__version__}")
if not torch.cuda.is_available():
    print("CUDA is NOT available. Test aborted.")
    exit(1)

gpu_name = torch.cuda.get_device_name(0)
vram = torch.cuda.get_device_properties(0).total_mem / (1024**3)
print(f"GPU: {gpu_name} ({vram:.1f} GB VRAM)")

size = 12000
print(f"Creating two {size}x{size} matrices on GPU...")
a = torch.randn(size, size, device="cuda")
b = torch.randn(size, size, device="cuda")

print("Warmup (5 iterations)...")
for _ in range(5):
    torch.matmul(a, b)
torch.cuda.synchronize()

print("Stress Test (10 iterations)...")
start = time.time()
for i in range(10):
    torch.matmul(a, b)
    torch.cuda.synchronize()
    print(f"  Iteration {i+1}/10 - GPU Temp: N/A")
elapsed = time.time() - start

print(f"\\nCompleted in {elapsed:.3f}s")
print(f"Avg iteration: {elapsed/10:.3f}s")
print("GPU is stable.")
del a, b
torch.cuda.empty_cache()
'''
        script_path = "/tmp/_zen_gpu_stress.py"
        try:
            with open(script_path, "w") as f:
                f.write(script_content)
            os.system(f"{sys.executable} {script_path}")
        except Exception as e:
            console.print(f"[red]Stress test failed: {e}[/]")
        finally:
            if os.path.exists(script_path):
                os.remove(script_path)

