def t(key):
    lang = load_settings().get("language", "en")
    return T.get(key, {}).get(lang, T.get(key, {}).get("en", key))

def load_settings() -> dict:
    try:
        with open(SETTINGS_FILE, "r") as f:
            return json.load(f)
    except:
        return {"language": "en"}

def save_settings(settings):
    os.makedirs(SETTINGS_DIR, exist_ok=True)
    with open(SETTINGS_FILE, "w") as f:
        json.dump(settings, f, indent=2)

def first_run_setup():
    if os.path.exists(SETTINGS_FILE):
        return
    console.print(Panel(
        "[bold magenta]Welcome to ZEN Package Manager v2.0[/]\n"
        "[dim]Willkommen - Bienvenue - Bienvenido[/]",
        border_style="bright_magenta", box=box.DOUBLE
    ))
    console.print()
    if os.geteuid() != 0:
        console.print(Panel(
            "[bold red]WARNING:[/] Please ensure you run ZPM with [bold yellow]sudo[/] privileges.\n"
            "Otherwise, your language selection cannot be saved to the system files.",
            border_style="red"
        ))
        console.print()
    tbl = Table(title="Select Language", box=box.ROUNDED, border_style="cyan")
    tbl.add_column("#", style="bold yellow", width=4)
    tbl.add_column("Language", style="bold white", min_width=12)
    tbl.add_column("Code", style="dim", min_width=4)
    for i, (code, name) in enumerate(LANGS.items(), 1):
        tbl.add_row(str(i), name, code)
    console.print(tbl)
    console.print()
    choice = IntPrompt.ask("[bold cyan]Enter number[/]", default=1)
    codes = list(LANGS.keys())
    lang = codes[min(choice - 1, len(codes) - 1)]
    settings = {"language": lang}
    try:
        save_settings(settings)
        console.print(f"\n[bold green][+][/] Language set to [bold]{LANGS[lang]}[/]\n")
    except PermissionError:
        console.print(f"\n[bold yellow][!][/] Run with sudo to save settings to {SETTINGS_FILE}\n")

def cmd_settings():
    settings = load_settings()
    console.print(Panel(f"[bold cyan]{t('settings')}[/]", border_style="cyan", box=box.DOUBLE))
    console.print(f"  [bold]Language:[/] {LANGS.get(settings.get('language','en'),'English')}\n")
    tbl = Table(box=box.ROUNDED, border_style="cyan")
    tbl.add_column("#", style="bold yellow", width=4)
    tbl.add_column("Language", style="bold white", min_width=12)
    for i, (code, name) in enumerate(LANGS.items(), 1):
        marker = " <" if code == settings.get("language") else ""
        tbl.add_row(str(i), f"{name}{marker}")
    console.print(tbl)
    choice = IntPrompt.ask(f"\n[bold cyan]{t('select_language')}[/]", default=1)
    codes = list(LANGS.keys())
    lang = codes[min(choice - 1, len(codes) - 1)]
    settings["language"] = lang
    try:
        save_settings(settings)
        console.print(f"\n[bold green][+][/] {t('language_changed')} [bold]{LANGS[lang]}[/]\n")
    except PermissionError:
        console.print(f"\n[bold red][-][/] {t('requires_root')}\n")

def require_root():
    if os.geteuid() != 0:
        console.print(f"\n[bold red][-][/] {t('requires_root')}\n")
        sys.exit(1)

def run(cmd, check=True, show=True):
    return subprocess.run(cmd, shell=True, check=check,
                          **({} if show else {"capture_output": True, "text": True}))

def run_quiet(cmd):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True)

def print_banner():
    banner = """
 ███████╗███████╗███╗   ██╗
 ╚══███╔╝██╔════╝████╗  ██║
   ███╔╝ █████╗  ██╔██╗ ██║
  ███╔╝  ██╔══╝  ██║╚██╗██║
 ███████╗███████╗██║ ╚████║
 ╚══════╝╚══════╝╚═╝  ╚═══╝"""
    console.print(Panel(
        Align.center(Text(banner, style="bold magenta") + Text(f"\n\n{t('banner_title')} v{ZEN_VERSION}", style="bold white")),
        border_style="bright_magenta", box=box.DOUBLE
    ))

