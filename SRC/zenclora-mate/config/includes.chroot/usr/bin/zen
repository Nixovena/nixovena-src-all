@ext("install_vencord")
def _(_=None):
    import os
    user = os.environ.get("SUDO_USER")
    if not user:
        console.print("[bold red][-] Vencord installer requires a normal user. Run via 'sudo zen install vencord' from a non-root account.[/]")
        return
    run("curl -sS https://vencord.dev/install.sh -o /tmp/vencord-install.sh", show=False)
    run(f"sudo -u {user} sh /tmp/vencord-install.sh", check=False)
    run("rm -f /tmp/vencord-install.sh", show=False)

@ext("remove_vencord")
def _(_=None):
    import os
    user = os.environ.get("SUDO_USER")
    if not user:
        console.print("[bold red][-] Vencord uninstaller requires a normal user. Run via 'sudo zen remove vencord' from a non-root account.[/]")
        return
    run("curl -sS https://vencord.dev/install.sh -o /tmp/vencord-install.sh", show=False)
    run(f"sudo -u {user} sh /tmp/vencord-install.sh -uninstall", check=False)
    run("rm -f /tmp/vencord-install.sh", show=False)


