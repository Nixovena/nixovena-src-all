_APICHAT_CONFIG_FILE = os.path.expanduser("~/.apichat_config.json")
_APICHAT_HISTORY_DIR = os.path.expanduser("~/.apichat_history")
_APICHAT_CONNECT_TIMEOUT = 10
_APICHAT_READ_TIMEOUT = 120
_APICHAT_MAX_RETRIES = 3
_APICHAT_RETRY_DELAY = 2
os.makedirs(_APICHAT_HISTORY_DIR, exist_ok=True)

class _ApiChatCLI:
    def __init__(self):
        self.config = self._load_config()
        self.history = []
        self.system_prompt = "You are ApiChat, a highly intelligent assistant."
        self._session = None

    def _init_session(self):
        if self._session is None:
            try:
                import requests
                self._session = requests.Session()
                self._session.headers.update({"Content-Type": "application/json"})
            except ImportError:
                console.print("[red]python3-requests not installed![/] Run: [cyan]sudo apt install python3-requests[/]")
                return False
        return True

    def _load_config(self):
        default_cfg = {
            "api_key": "", "api_base": "https://api.openai.com/v1",
            "model": "gpt-4", "temperature": 0.7, "max_tokens": 4096, "stream": True,
        }
        if os.path.exists(_APICHAT_CONFIG_FILE):
            try:
                with open(_APICHAT_CONFIG_FILE, "r") as f:
                    saved = json.load(f)
                return {**default_cfg, **saved}
            except (json.JSONDecodeError, OSError):
                console.print("[yellow]Config file corrupted, using defaults.[/]")
        return default_cfg

    def _save_config(self):
        try:
            with open(_APICHAT_CONFIG_FILE, "w") as f:
                json.dump(self.config, f, indent=2)
            os.chmod(_APICHAT_CONFIG_FILE, 0o600)
        except PermissionError:
            console.print("[red]Could not save config (permission denied).[/]")
        except OSError as e:
            console.print(f"[red]Could not save config: {e}[/]")

    def show_header(self):
        console.clear()
        header = f"""
[bold magenta] █████╗ ██████╗ ██╗ ██████╗██╗  ██╗ █████╗ ████████╗[/bold magenta]
[bold magenta]██╔══██╗██╔══██╗██║██╔════╝██║  ██║██╔══██╗╚══██╔══╝[/bold magenta]
[bold magenta]███████║██████╔╝██║██║     ███████║███████║   ██║   [/bold magenta]
[bold magenta]██╔══██║██╔═══╝ ██║██║     ██╔══██║██╔══██║   ██║   [/bold magenta]
[bold magenta]██║  ██║██║     ██║╚██████╗██║  ██║██║  ██║   ██║   [/bold magenta]
[bold magenta]╚═╝  ╚═╝╚═╝     ╚═╝ ╚═════╝╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝   [/bold magenta]
[bold cyan]           TERMINAL-AI v{ZEN_VERSION}[/bold cyan]
        """
        console.print(Align.center(header))
        status = (
            f"[dim]Endpoint: {self.config.get('api_base')} │ "
            f"Model: {self.config.get('model')} │ "
            f"Stream: {'ON' if self.config.get('stream') else 'OFF'}[/dim]"
        )
        console.print(Align.center(status))
        console.print("")

    def _check_connection(self):
        if not self._init_session():
            return False
        api_base = self.config.get("api_base", "")
        try:
            resp = self._session.get(f"{api_base}/models", headers=self._get_headers(), timeout=_APICHAT_CONNECT_TIMEOUT)
            return resp.status_code in (200, 401, 403)
        except Exception:
            return False

    def _get_headers(self):
        headers = {"Content-Type": "application/json"}
        api_key = self.config.get("api_key", "")
        if api_key and api_key not in ("local", ""):
            headers["Authorization"] = f"Bearer {api_key}"
        return headers

    def print_help(self):
        table = Table(title="Slash Commands", box=box.ROUNDED, border_style="yellow", title_style="bold yellow")
        table.add_column("Command", style="bold white", min_width=20)
        table.add_column("Description", style="dim")
        commands = [
            ("/quit", "Exit the chat interface"), ("/clear", "Clear conversation history"),
            ("/sys <prompt>", "Change the system prompt"), ("/file <path>", "Read a file and add to context"),
            ("/exec <cmd>", "Run a terminal command and feed output to AI"),
            ("/multi", "Enter multi-line mode (type 'EOF' to send)"),
            ("/export", "Export chat history to Markdown file"),
            ("/save <name>", "Save conversation state"), ("/load <name>", "Load a previously saved session"),
            ("/sessions", "List all saved sessions"), ("/model <name>", "Switch model on the fly"),
            ("/tokens", "Show token usage statistics"), ("/help", "Show this command list"),
        ]
        for cmd, desc in commands:
            table.add_row(cmd, desc)
        console.print(table)

    def export_chat(self):
        if not self.history:
            console.print("[red]No history to export.[/]")
            return
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = f"chat_export_{timestamp}.md"
        try:
            with open(filename, "w", encoding="utf-8") as f:
                f.write(f"# Chat Export ({timestamp})\n\n")
                f.write(f"**Model**: {self.config['model']} | **Endpoint**: {self.config['api_base']}\n\n")
                for msg in self.history:
                    role = msg["role"]
                    if role == "assistant": role_label = "**AI**"
                    elif role == "user": role_label = "**You**"
                    else: role_label = "**System**"
                    f.write(f"### {role_label}\n{msg['content']}\n\n---\n\n")
            console.print(f"[green]Chat exported to {filename}[/]")
        except OSError as e:
            console.print(f"[red]Failed to export: {e}[/]")

    def _list_sessions(self):
        console.print(Panel("[bold cyan]Saved Sessions[/]", border_style="cyan"))
        try:
            files = sorted(os.listdir(_APICHAT_HISTORY_DIR))
            if not files:
                console.print("  [dim]No saved sessions.[/]")
                return
            table = Table(box=box.SIMPLE, border_style="dim")
            table.add_column("Session", style="cyan")
            table.add_column("Size", style="dim")
            table.add_column("Modified", style="dim")
            for f in files:
                if f.endswith(".json"):
                    fp = os.path.join(_APICHAT_HISTORY_DIR, f)
                    stat = os.stat(fp)
                    size = f"{stat.st_size / 1024:.1f} KB"
                    modified = datetime.fromtimestamp(stat.st_mtime).strftime("%Y-%m-%d %H:%M")
                    table.add_row(f.replace(".json", ""), size, modified)
            console.print(table)
        except OSError:
            console.print("[red]Could not read session directory.[/]")

    def handle_slash_command(self, text):
        cmd_parts = text.split(" ", 1)
        cmd = cmd_parts[0].lower()
        args = cmd_parts[1].strip() if len(cmd_parts) > 1 else ""
        if cmd in ["/quit", "/exit", "/q"]:
            return "break"
        elif cmd == "/clear":
            self.history = [{"role": "system", "content": self.system_prompt}]
            self.show_header()
            console.print("[cyan]Context history cleared. Starting fresh![/]")
            return "continue"
        elif cmd == "/help":
            self.print_help()
            return "continue"
        elif cmd == "/sys":
            if args:
                self.system_prompt = args
                if self.history and self.history[0]["role"] == "system":
                    self.history[0]["content"] = args
                else:
                    self.history.insert(0, {"role": "system", "content": args})
                console.print(f"[green]System persona updated: '{args}'[/]")
            else:
                console.print(f"[cyan]Current persona: {self.system_prompt}[/]")
            return "continue"
        elif cmd == "/file":
            if not args:
                console.print("[red]Usage: /file <path>[/]")
                return "continue"
            filepath = os.path.expanduser(args)
            if not os.path.exists(filepath):
                console.print(f"[red]File not found: {filepath}[/]")
                return "continue"
            try:
                with open(filepath, "r", encoding="utf-8", errors="replace") as f:
                    content = f.read()
                max_chars = 50000
                if len(content) > max_chars:
                    content = content[:max_chars]
                    console.print(f"[yellow]File truncated to {max_chars} characters.[/]")
                console.print(f"[cyan] Loaded {len(content)} characters from '{filepath}'[/]")
                self.history.append({"role": "user", "content": f"Here is the content of the file '{filepath}':\n```\n{content}\n```\nAnalyze this and wait for my instruction."})
                console.print("[green]File added to context. Ask the AI about it.[/]")
            except PermissionError:
                console.print(f"[red]Permission denied: {filepath}[/]")
            except OSError as e:
                console.print(f"[red]Could not read file: {e}[/]")
            return "continue"
        elif cmd == "/exec":
            if not args:
                console.print("[red]Usage: /exec <command>[/]")
                return "continue"
            console.print(f"[yellow]Executing: {args}[/]")
            try:
                result = subprocess.run(args, shell=True, capture_output=True, text=True, timeout=60)
                output = result.stdout.strip() or result.stderr.strip()
                if not output:
                    output = "(no output)"
                max_chars = 10000
                if len(output) > max_chars:
                    output = output[:max_chars] + "\n... (truncated)"
                console.print(f"[dim]Captured {len(output)} chars - sending to AI...[/]")
                self.history.append({"role": "user", "content": f"I ran `{args}` on my terminal. Output:\n```\n{output}\n```\nPlease analyze it."})
                return "call_api"
            except subprocess.TimeoutExpired:
                console.print("[red]Command timed out after 60s.[/]")
            except Exception as e:
                console.print(f"[red]Execution failed: {e}[/]")
            return "continue"
        elif cmd == "/export":
            self.export_chat()
            return "continue"
        elif cmd == "/save":
            if not args:
                args = "session_" + datetime.now().strftime("%Y%m%d_%H%M%S")
            filepath = os.path.join(_APICHAT_HISTORY_DIR, f"{args}.json")
            try:
                with open(filepath, "w", encoding="utf-8") as f:
                    json.dump({"history": self.history, "system_prompt": self.system_prompt, "model": self.config.get("model"), "saved_at": datetime.now().isoformat()}, f, indent=2, ensure_ascii=False)
                console.print(f"[green]Session saved as '{args}'[/]")
            except OSError as e:
                console.print(f"[red]Failed to save session: {e}[/]")
            return "continue"
        elif cmd == "/load":
            if not args:
                self._list_sessions()
                console.print("[cyan]Usage: /load <session_name>[/]")
                return "continue"
            filepath = os.path.join(_APICHAT_HISTORY_DIR, f"{args}.json")
            if os.path.exists(filepath):
                try:
                    with open(filepath, "r", encoding="utf-8") as f:
                        data = json.load(f)
                    if isinstance(data, list):
                        self.history = data
                    elif isinstance(data, dict):
                        self.history = data.get("history", [])
                        self.system_prompt = data.get("system_prompt", self.system_prompt)
                    self.show_header()
                    console.print(f"[green]Session '{args}' restored! ({len(self.history)} messages)[/]")
                except (json.JSONDecodeError, OSError) as e:
                    console.print(f"[red]Failed to load session: {e}[/]")
            else:
                console.print(f"[red]Session '{args}' not found.[/]")
            return "continue"
        elif cmd == "/sessions":
            self._list_sessions()
            return "continue"
        elif cmd == "/model":
            if args:
                self.config["model"] = args
                self._save_config()
                console.print(f"[green]Model switched to: {args}[/]")
            else:
                console.print(f"[cyan]Current model: {self.config.get('model')}[/]")
            return "continue"
        elif cmd == "/tokens":
            msg_count = len([m for m in self.history if m["role"] != "system"])
            console.print(f"[cyan]Messages in context: {msg_count}[/]")
            total_chars = sum(len(m["content"]) for m in self.history)
            console.print(f"[cyan]Estimated tokens: ~{total_chars // 4}[/]")
            return "continue"
        return False

    def chat_loop(self):
        if not self._init_session():
            return
        api_key = self.config.get("api_key", "")
        api_base = self.config.get("api_base", "")
        if not api_key and not api_base.startswith("http://127.0.0.1"):
            console.print("[red]No API key configured! Go to Main Menu -> Configure API first.[/]")
            input("Press Enter to continue...")
            return
        self.show_header()
        if not self.history:
            console.print("[cyan]Quick Personas:[/]")
            console.print("  1. Default AI Assistant")
            console.print("  2. Senior Software Engineer")
            console.print("  3. Linux SysAdmin")
            console.print("  4. Security Analyst")
            console.print("  5. Custom")
            p_choice = Prompt.ask("Select Persona", choices=["1", "2", "3", "4", "5"], default="1")
            personas = {
                "2": "You are a Senior Software Engineer. Provide clean, optimized code without filler text.",
                "3": "You are a Linux/Unix Systems Administrator. Focus on terminal commands, pipelines, and technical solutions.",
                "4": "You are a Cybersecurity Analyst. Focus on security implications, vulnerabilities, and hardening.",
            }
            if p_choice == "5":
                self.system_prompt = Prompt.ask("[cyan]Enter your custom system prompt[/]")
            elif p_choice in personas:
                self.system_prompt = personas[p_choice]
            self.history.append({"role": "system", "content": self.system_prompt})
            console.print("[cyan]Type '/help' for available commands.[/]\n")
        while True:
            call_api_now = False
            try:
                console.print("\n[bold green]You[/bold green] [dim](/help for commands)[/dim]")
                user_input = Prompt.ask("❯")
                if not user_input or not user_input.strip():
                    continue
                if user_input.lower() == "/multi":
                    console.print("[cyan]Multi-line mode. Type 'EOF' on empty line to send.[/]")
                    lines = []
                    while True:
                        try:
                            line = input()
                        except EOFError:
                            break
                        if line.strip().upper() == "EOF":
                            break
                        lines.append(line)
                    user_input = "\n".join(lines)
                    if not user_input.strip():
                        continue
                    console.print("[dim]Multi-line payload compiled.[/]")
                if user_input.startswith("/"):
                    cmd_action = self.handle_slash_command(user_input)
                    if cmd_action == "break":
                        break
                    if cmd_action == "continue":
                        continue
                    if cmd_action == "call_api":
                        call_api_now = True
                if not call_api_now and not user_input.startswith("/"):
                    self.history.append({"role": "user", "content": user_input})
                    call_api_now = True
                if call_api_now:
                    self._make_api_call()
            except KeyboardInterrupt:
                console.print("\n[cyan]Use /quit to exit.[/]")
            except Exception as e:
                console.print(f"\n[red]Error in chat loop: {e}[/]")

    def _make_api_call(self):
        import requests
        headers = self._get_headers()
        use_stream = self.config.get("stream", True)
        payload = {
            "model": self.config["model"], "messages": self.history,
            "stream": use_stream, "temperature": self.config.get("temperature", 0.7),
        }
        max_tokens = self.config.get("max_tokens")
        if max_tokens:
            payload["max_tokens"] = max_tokens
        console.print("\n[bold magenta]ApiChat[/bold magenta]")
        for attempt in range(_APICHAT_MAX_RETRIES):
            try:
                if use_stream:
                    self._stream_response(headers, payload)
                else:
                    self._sync_response(headers, payload)
                return
            except requests.ConnectionError:
                console.print(f"[red]Connection failed (attempt {attempt + 1}/{_APICHAT_MAX_RETRIES})[/]")
            except requests.Timeout:
                console.print(f"[red]Request timed out (attempt {attempt + 1}/{_APICHAT_MAX_RETRIES})[/]")
            except requests.HTTPError as e:
                status_code = e.response.status_code if e.response else 0
                if status_code == 429:
                    wait = min(_APICHAT_RETRY_DELAY * (2 ** attempt), 30)
                    console.print(f"[yellow]Rate limited. Waiting {wait}s...[/]")
                    time.sleep(wait)
                elif status_code in (401, 403):
                    console.print("[red]Authentication failed. Check your API key.[/]")
                    if self.history and self.history[-1]["role"] == "user":
                        self.history.pop()
                    return
                elif status_code >= 500:
                    console.print(f"[red]Server error ({status_code}). Retrying...[/]")
                else:
                    console.print(f"[red]HTTP error: {e}[/]")
                    if self.history and self.history[-1]["role"] == "user":
                        self.history.pop()
                    return
            except Exception as e:
                console.print(f"[red]Unexpected error: {e}[/]")
                if self.history and self.history[-1]["role"] == "user":
                    self.history.pop()
                return
            if attempt < _APICHAT_MAX_RETRIES - 1:
                wait = _APICHAT_RETRY_DELAY * (2 ** attempt)
                time.sleep(wait)
        console.print("[red]All retry attempts failed.[/]")
        if self.history and self.history[-1]["role"] == "user":
            self.history.pop()

    def _stream_response(self, headers, payload):
        url = f"{self.config['api_base']}/chat/completions"
        resp = self._session.post(url, headers=headers, json=payload, timeout=(_APICHAT_CONNECT_TIMEOUT, _APICHAT_READ_TIMEOUT), stream=True)
        resp.raise_for_status()
        full_content = []
        sys.stdout.write("\n")
        for line in resp.iter_lines(decode_unicode=True):
            if not line:
                continue
            if line.startswith("data: "):
                data_str = line[6:]
                if data_str.strip() == "[DONE]":
                    break
                try:
                    data = json.loads(data_str)
                    delta = data.get("choices", [{}])[0].get("delta", {})
                    content = delta.get("content", "")
                    if content:
                        sys.stdout.write(content)
                        sys.stdout.flush()
                        full_content.append(content)
                except json.JSONDecodeError:
                    continue
        sys.stdout.write("\n\n")
        ai_reply = "".join(full_content)
        if ai_reply:
            self.history.append({"role": "assistant", "content": ai_reply})

    def _sync_response(self, headers, payload):
        from rich.markdown import Markdown as RichMarkdown
        payload["stream"] = False
        url = f"{self.config['api_base']}/chat/completions"
        console.print("[dim]Processing...[/]", end="\r")
        resp = self._session.post(url, headers=headers, json=payload, timeout=(_APICHAT_CONNECT_TIMEOUT, _APICHAT_READ_TIMEOUT))
        sys.stdout.write("\033[K")
        resp.raise_for_status()
        data = resp.json()
        ai_reply = data.get("choices", [{}])[0].get("message", {}).get("content", "")
        usage = data.get("usage", {})
        tokens = ""
        if usage:
            tokens = f"  [italic dim](Tokens: {usage.get('total_tokens', 'N/A')})[/italic dim]"
        if ai_reply:
            console.print(Panel(RichMarkdown(ai_reply), border_style="magenta", padding=(1, 2)))
            if tokens:
                console.print(Align.right(tokens))
            self.history.append({"role": "assistant", "content": ai_reply})

    def configure(self):
        console.print(Panel("[bold cyan]AI Provider Configuration[/]", border_style="cyan"))
        table = Table(box=box.SIMPLE, border_style="cyan")
        table.add_column("#", style="bold yellow", width=4)
        table.add_column("Provider", style="bold white")
        table.add_column("Endpoint", style="dim")
        providers = [
            ("1", "OpenAI (GPT-4o, etc.)", "api.openai.com"),
            ("2", "Groq (Llama3, Mixtral)", "api.groq.com"),
            ("3", "GitHub Models / Azure", "Custom endpoint"),
            ("4", "Local (Ollama / LM Studio)", "127.0.0.1"),
            ("5", "Custom Endpoint", "Any URL"),
        ]
        for num, name, endpoint in providers:
            table.add_row(num, name, endpoint)
        console.print(table)
        provider = Prompt.ask("\n[cyan]Select Provider[/]", choices=["1", "2", "3", "4", "5"], default="1")
        if provider == "1":
            self.config["api_base"] = "https://api.openai.com/v1"
            self.config["model"] = Prompt.ask("[cyan]Model (e.g. gpt-4o, gpt-4o-mini)[/]", default="gpt-4o")
            self.config["api_key"] = Prompt.ask("[cyan]API Key[/]", password=True)
        elif provider == "2":
            self.config["api_base"] = "https://api.groq.com/openai/v1"
            self.config["model"] = Prompt.ask("[cyan]Model[/]", default="llama3-70b-8192")
            self.config["api_key"] = Prompt.ask("[cyan]Groq API Key[/]", password=True)
        elif provider == "3":
            self.config["api_base"] = Prompt.ask("[cyan]Full Endpoint URL[/]")
            self.config["model"] = Prompt.ask("[cyan]Model/Deployment Name[/]")
            self.config["api_key"] = Prompt.ask("[cyan]API Token[/]", password=True)
        elif provider == "4":
            port = Prompt.ask("[cyan]Port (11434=Ollama, 1234=LM Studio)[/]", default="11434")
            self.config["api_base"] = f"http://127.0.0.1:{port}/v1"
            self.config["model"] = Prompt.ask("[cyan]Model tag (e.g. llama3)[/]", default="llama3")
            self.config["api_key"] = "local"
        else:
            self.config["api_base"] = Prompt.ask("[cyan]API Base URL (e.g. https://api.xxx/v1)[/]")
            self.config["model"] = Prompt.ask("[cyan]Model name[/]")
            self.config["api_key"] = Prompt.ask("[cyan]Bearer Token[/]", password=True)
        self.config["stream"] = Confirm.ask("[cyan]Enable streaming responses?[/]", default=True)
        self._save_config()
        console.print("[green]Configuration saved![/]")
        if Confirm.ask("[cyan]Test connection now?[/]", default=True):
            if self._check_connection():
                console.print("[green]✓ Connection successful![/]")
            else:
                console.print("[yellow]⚠ Could not reach the endpoint. Check your settings.[/]")

def cmd_ai_apichat_embedded():

    app = _ApiChatCLI()
    while True:
        app.show_header()
        menu = Panel(
            "[bold cyan]1.[/bold cyan] Start Chat Session\n"
            "[bold cyan]2.[/bold cyan] Configure API Provider\n"
            "[bold cyan]3.[/bold cyan] Manage Saved Sessions\n"
            "[bold cyan]4.[/bold cyan] Connection Test\n"
            "[bold cyan]5.[/bold cyan] Exit",
            title="[bold white on dim] APICHAT CLI [/bold white on dim]",
            border_style="cyan",
            padding=(1, 2)
        )
        console.print(Align.center(menu))
        choice = Prompt.ask("\n[cyan]Select[/]", choices=["1", "2", "3", "4", "5"], default="1")
        if choice == "1":
            app.chat_loop()
        elif choice == "2":
            app.configure()
            Prompt.ask("\nPress Enter to continue")
        elif choice == "3":
            app._list_sessions()
            Prompt.ask("\nPress Enter to continue")
        elif choice == "4":
            console.print("[cyan]Testing connection...[/]")
            if app._check_connection():
                console.print("[green]✓ API endpoint is reachable![/]")
            else:
                console.print("[red]✗ Cannot reach API endpoint.[/]")
            Prompt.ask("\nPress Enter to continue")
        elif choice == "5":
            console.print("[cyan]Goodbye![/]")
            break

