@ext("install_nvidia-driver")
def _(_=None):
    run("apt install -y linux-headers-amd64")
    run('echo "blacklist nouveau" | sudo tee /etc/modprobe.d/blacklist-nouveau.conf')
    run('echo "options nouveau modeset=0" | sudo tee -a /etc/modprobe.d/blacklist-nouveau.conf')
    run("update-initramfs -u")
    run("apt update && apt install -y nvidia-driver nvidia-cuda-toolkit")
    console.print(f"[bold yellow][!] {t('reboot_required')}[/]")

@ext("remove_nvidia-driver")
