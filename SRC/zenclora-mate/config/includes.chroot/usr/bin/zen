    run("""echo "deb https://packages.adoptium.net/artifactory/deb trixie main" | sudo tee /etc/apt/sources.list.d/adoptium.list""", show=False)
    run("apt update", check=False, show=False)
    run("apt install -y temurin-25-jdk")

@ext("remove_temurin")
def _(_=None):
    run("apt remove -y temurin-25-jdk", check=False)
    run("rm -f /etc/apt/sources.list.d/adoptium.list /etc/apt/trusted.gpg.d/adoptium.gpg")
    run("apt update", check=False)

