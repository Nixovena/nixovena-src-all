def _fj_get_yes_no(prompt):
    while True:
        response = input(f"{_FJ_YELLOW}{prompt} (Y/N): {_FJ_NC}").lower()
        if response.startswith('y'):
            return True
        if response.startswith('n'):
            return False
        print(f"{_FJ_RED}Please answer Y or N.{_FJ_NC}")

def _fj_build_command(app_path):
    cmd = ["firejail"]

    print(f"{_FJ_CYAN}┌─────────────────────────────────────────────────────────────────┐{_FJ_NC}")
    print(f"{_FJ_CYAN}│                    SANDBOX CONFIGURATION                        │{_FJ_NC}")
    print(f"{_FJ_CYAN}└─────────────────────────────────────────────────────────────────┘{_FJ_NC}")
    print()

    if _fj_get_yes_no("Allow network access?"):
        print(f"{_FJ_GREEN}[+] Network access: ENABLED{_FJ_NC}")
    else:
        cmd.append("--net=none")
        print(f"{_FJ_RED}[-] Network access: DISABLED{_FJ_NC}")

    if _fj_get_yes_no("Isolate from home directory?"):
        cmd.append("--private")
        print(f"{_FJ_RED}[-] Home directory: ISOLATED{_FJ_NC}")
    else:
        print(f"{_FJ_GREEN}[+] Home directory: ACCESSIBLE{_FJ_NC}")

    if _fj_get_yes_no("Use temporary filesystem for /tmp?"):
        cmd.append("--private-tmp")
        print(f"{_FJ_YELLOW}[~] Temporary filesystem: ENABLED{_FJ_NC}")

    if _fj_get_yes_no("Disable sound access?"):
        cmd.append("--nosound")
        print(f"{_FJ_RED}[-] Sound access: DISABLED{_FJ_NC}")

    if _fj_get_yes_no("Disable 3D acceleration?"):
        cmd.append("--no3d")
        print(f"{_FJ_RED}[-] 3D acceleration: DISABLED{_FJ_NC}")

    if _fj_get_yes_no("Disable webcam access?"):
        cmd.append("--novideo")
        print(f"{_FJ_RED}[-] Webcam access: DISABLED{_FJ_NC}")

    if _fj_get_yes_no("Make filesystem read-only?"):
        cmd.append("--read-only=~")
        print(f"{_FJ_YELLOW}[~] Filesystem: READ-ONLY{_FJ_NC}")

    if _fj_get_yes_no("Enable seccomp syscall filtering?"):
        cmd.append("--seccomp")
        print(f"{_FJ_GREEN}[+] Seccomp filtering: ENABLED{_FJ_NC}")

    if _fj_get_yes_no("Enable AppArmor confinement?"):
        cmd.append("--apparmor")
        print(f"{_FJ_GREEN}[+] AppArmor: ENABLED{_FJ_NC}")

    custom_profile = input(f"{_FJ_YELLOW}Enter custom Firejail profile (or press Enter to skip): {_FJ_NC}").strip()
    if custom_profile:
        if os.path.exists(f"/etc/firejail/{custom_profile}.profile"):
            cmd.append(f"--profile={custom_profile}")
            print(f"{_FJ_GREEN}[+] Custom profile: {custom_profile}{_FJ_NC}")
        else:
            print(f"{_FJ_RED}[!] Profile not found: {custom_profile}{_FJ_NC}")

    cmd.append(app_path)

    print()
    print(f"{_FJ_PURPLE}═══════════════════════════════════════════════════════════════════════════{_FJ_NC}")
    print(f"{_FJ_WHITE}Final command: {_FJ_CYAN}{' '.join(cmd)}{_FJ_NC}")
    print(f"{_FJ_PURPLE}═══════════════════════════════════════════════════════════════════════════{_FJ_NC}")
    print()

    if _fj_get_yes_no("Execute this command?"):
        print(f"{_FJ_GREEN}[+] Launching application in sandbox...{_FJ_NC}")
        print(f"{_FJ_YELLOW}[i] Press Ctrl+C to return to menu{_FJ_NC}")
        print()
        try:
            subprocess.run(cmd)
        except KeyboardInterrupt:
            print(f"\n{_FJ_YELLOW}[i] Application closed.{_FJ_NC}")
    else:
        print(f"{_FJ_YELLOW}[i] Command cancelled.{_FJ_NC}")

def _fj_launch_application():
    print(f"{_FJ_CYAN}┌─────────────────────────────────────────────────────────────────┐{_FJ_NC}")
    print(f"{_FJ_CYAN}│                    APPLICATION LAUNCHER                         │{_FJ_NC}")
    print(f"{_FJ_CYAN}└─────────────────────────────────────────────────────────────────┘{_FJ_NC}")
    print()
    app_path = input(f"{_FJ_YELLOW}Enter the full path to application/script: {_FJ_NC}").strip()
    if not app_path:
        print(f"{_FJ_RED}[!] No application path provided.{_FJ_NC}")
        return
    if not os.path.exists(app_path) and not shutil.which(app_path):
        print(f"{_FJ_RED}[!] Application not found: {app_path}{_FJ_NC}")
        return
    _fj_build_command(app_path)

def _fj_quick_launch():
    print(f"{_FJ_CYAN}┌─────────────────────────────────────────────────────────────────┐{_FJ_NC}")
    print(f"{_FJ_CYAN}│                      QUICK PRESETS                              │{_FJ_NC}")
    print(f"{_FJ_CYAN}├─────────────────────────────────────────────────────────────────┤{_FJ_NC}")
    print(f"{_FJ_CYAN}│{_FJ_NC} {_FJ_GREEN}1.{_FJ_NC} {_FJ_WHITE}Maximum Security (No network, isolated, read-only){_FJ_NC}           {_FJ_CYAN}│{_FJ_NC}")
    print(f"{_FJ_CYAN}│{_FJ_NC} {_FJ_GREEN}2.{_FJ_NC} {_FJ_WHITE}Internet Browser (Network enabled, private home){_FJ_NC}             {_FJ_CYAN}│{_FJ_NC}")
    print(f"{_FJ_CYAN}│{_FJ_NC} {_FJ_GREEN}3.{_FJ_NC} {_FJ_WHITE}Office Application (No network, home access){_FJ_NC}                 {_FJ_CYAN}│{_FJ_NC}")
    print(f"{_FJ_CYAN}│{_FJ_NC} {_FJ_GREEN}4.{_FJ_NC} {_FJ_WHITE}Media Player (No network, limited access){_FJ_NC}                    {_FJ_CYAN}│{_FJ_NC}")
    print(f"{_FJ_CYAN}│{_FJ_NC} {_FJ_GREEN}5.{_FJ_NC} {_FJ_WHITE}Development Tool (Network, home, full access){_FJ_NC}                {_FJ_CYAN}│{_FJ_NC}")
    print(f"{_FJ_CYAN}│{_FJ_NC} {_FJ_GREEN}0.{_FJ_NC} {_FJ_RED}Back to Main Menu{_FJ_NC}                                            {_FJ_CYAN}│{_FJ_NC}")
    print(f"{_FJ_CYAN}└─────────────────────────────────────────────────────────────────┘{_FJ_NC}")
    print()

    preset_choice = input(f"{_FJ_YELLOW}Select preset: {_FJ_NC}").strip()
    if preset_choice == '0': return

    app_path = input(f"{_FJ_YELLOW}Enter application path: {_FJ_NC}").strip()
    if not app_path:
        print(f"{_FJ_RED}[!] No application path provided.{_FJ_NC}")
        return

    presets = {
        "1": (f"{_FJ_RED}[MAXIMUM SECURITY] Launching with strictest settings...{_FJ_NC}",
              ["firejail", "--net=none", "--private", "--private-tmp", "--nosound", "--no3d", "--novideo", "--read-only=~", "--seccomp", "--apparmor"]),
        "2": (f"{_FJ_BLUE}[BROWSER MODE] Launching with internet access...{_FJ_NC}",
              ["firejail", "--private", "--private-tmp", "--nosound", "--seccomp", "--apparmor"]),
        "3": (f"{_FJ_GREEN}[OFFICE MODE] Launching for document editing...{_FJ_NC}",
              ["firejail", "--net=none", "--private-tmp", "--nosound", "--no3d", "--novideo", "--seccomp"]),
        "4": (f"{_FJ_PURPLE}[MEDIA MODE] Launching media player...{_FJ_NC}",
              ["firejail", "--net=none", "--private", "--private-tmp", "--no3d", "--seccomp"]),
        "5": (f"{_FJ_CYAN}[DEVELOPMENT MODE] Launching with development access...{_FJ_NC}",
              ["firejail", "--private-tmp", "--seccomp"])
    }

    if preset_choice in presets:
        msg, cmd = presets[preset_choice]
        print(msg)
        cmd.append(app_path)
        try:
            subprocess.run(cmd)
        except KeyboardInterrupt:
            print(f"\n{_FJ_YELLOW}[i] Application closed.{_FJ_NC}")
    else:
        print(f"{_FJ_RED}[!] Invalid choice.{_FJ_NC}")

def _fj_list_sandboxes():
    print(f"{_FJ_CYAN}┌─────────────────────────────────────────────────────────────────┐{_FJ_NC}")
    print(f"{_FJ_CYAN}│                    ACTIVE SANDBOXES                             │{_FJ_NC}")
    print(f"{_FJ_CYAN}└─────────────────────────────────────────────────────────────────┘{_FJ_NC}")
    print()
    subprocess.run(["firejail", "--list"])

def _fj_kill_sandbox():
    print(f"{_FJ_CYAN}┌─────────────────────────────────────────────────────────────────┐{_FJ_NC}")
    print(f"{_FJ_CYAN}│                    KILL SANDBOX                                 │{_FJ_NC}")
    print(f"{_FJ_CYAN}└─────────────────────────────────────────────────────────────────┘{_FJ_NC}")
    print()
    print(f"{_FJ_YELLOW}Active sandboxes:{_FJ_NC}")
    subprocess.run(["firejail", "--list"])
    print()
    pid_input = input(f"{_FJ_YELLOW}Enter PID to kill (or 'all' to kill all): {_FJ_NC}").strip()
    if pid_input == "all":
        if _fj_get_yes_no("Kill ALL sandbox processes?"):
            subprocess.run(["firejail", "--shutdown"])
            print(f"{_FJ_GREEN}[+] All sandboxes terminated.{_FJ_NC}")
    elif pid_input.isdigit():
        if _fj_get_yes_no(f"Kill sandbox with PID {pid_input}?"):
            subprocess.run(["firejail", f"--shutdown={pid_input}"])
            print(f"{_FJ_GREEN}[+] Sandbox {pid_input} terminated.{_FJ_NC}")
    else:
        print(f"{_FJ_RED}[!] Invalid PID.{_FJ_NC}")

def _fj_show_profiles():
    print(f"{_FJ_CYAN}┌─────────────────────────────────────────────────────────────────┐{_FJ_NC}")
    print(f"{_FJ_CYAN}│                   FIREJAIL PROFILES                             │{_FJ_NC}")
    print(f"{_FJ_CYAN}└─────────────────────────────────────────────────────────────────┘{_FJ_NC}")
    print()
    if os.path.exists("/etc/firejail"):
        print(f"{_FJ_GREEN}Available profiles in /etc/firejail (first 20):{_FJ_NC}")
        profiles = [f.replace(".profile", "") for f in os.listdir("/etc/firejail") if f.endswith(".profile")]
        for p in sorted(profiles)[:20]:
            print(p)
        print()
        print(f"{_FJ_YELLOW}[i] Use profile name (without .profile extension) in custom configuration{_FJ_NC}")
    else:
        print(f"{_FJ_RED}[!] Firejail profiles directory not found.{_FJ_NC}")

def _fj_show_system_info():
    print(f"{_FJ_CYAN}┌─────────────────────────────────────────────────────────────────┐{_FJ_NC}")
    print(f"{_FJ_CYAN}│                   SYSTEM INFORMATION                            │{_FJ_NC}")
    print(f"{_FJ_CYAN}└─────────────────────────────────────────────────────────────────┘{_FJ_NC}")
    print()
    print(f"{_FJ_GREEN}Firejail Version:{_FJ_NC}")
    subprocess.run(["firejail", "--version"])
    print(f"\n{_FJ_GREEN}Kernel Version:{_FJ_NC}")
    print(os.uname().release)
    print(f"\n{_FJ_GREEN}Available Namespaces:{_FJ_NC}")
    namespaces = ["pid", "net", "mnt", "user"]
    for ns in namespaces:
        if os.path.exists(f"/proc/self/ns/{ns}"):
            print(f"{_FJ_GREEN}✓{_FJ_NC} {ns} namespace")
    print(f"\n{_FJ_GREEN}Security Features:{_FJ_NC}")
    if os.path.exists("/sys/kernel/security/apparmor/profiles"):
        print(f"{_FJ_GREEN}✓{_FJ_NC} AppArmor enabled")
    else:
        print(f"{_FJ_RED}✗{_FJ_NC} AppArmor not available")
    try:
        with open("/proc/self/status", "r") as f:
            if "seccomp" in f.read().lower():
                print(f"{_FJ_GREEN}✓{_FJ_NC} Seccomp available")
            else:
                print(f"{_FJ_RED}✗{_FJ_NC} Seccomp not available")
    except: pass

def cmd_zenjails_embedded():
    if not _fj_check_env():
        return
    while True:
        _fj_show_banner()
        _fj_show_menu()
        choice = input(f"{_FJ_YELLOW}Select an option: {_FJ_NC}").strip()
        if choice == "1": _fj_launch_application()
        elif choice == "2": _fj_quick_launch()
        elif choice == "3": _fj_list_sandboxes()
        elif choice == "4": _fj_kill_sandbox()
        elif choice == "5": _fj_show_profiles()
        elif choice == "6": _fj_show_system_info()
        elif choice == "0":
            print(f"{_FJ_GREEN}[+] Thank you for using Zenjails!{_FJ_NC}")
            print(f"{_FJ_CYAN}[i] Stay secure!{_FJ_NC}")
            break
        else:
            print(f"{_FJ_RED}[!] Invalid option.{_FJ_NC}")
        print()
        input(f"{_FJ_YELLOW}Press Enter to continue...{_FJ_NC}")

NFTABLES_CONF = "/etc/nftables.conf"
NFTABLES_BACKUP_DIR = "/etc/zpm/firewall-backups"
NFTABLES_PROFILES_DIR = "/etc/zpm/firewall-profiles"

_NFT_PROFILE_HOME = '''#!/usr/sbin/nft -f
# ZEN Firewall - Home Profile
# Basic protection for desktop/home use
flush ruleset

table inet zen_firewall {
    chain input {
        type filter hook input priority 0; policy drop;

        # Allow established/related connections
        ct state established,related accept

        # Allow loopback
        iif "lo" accept

        # Allow ICMP/ICMPv6
        ip protocol icmp accept
        ip6 nexthdr icmpv6 accept

        # Allow DHCPv4 client
        udp dport 68 accept

        # Allow mDNS
        udp dport 5353 accept

        # Allow SSH
        tcp dport 22 accept

        # Allow Samba/local file sharing
        tcp dport {139, 445} accept
        udp dport {137, 138} accept

        # Allow KDE Connect
        tcp dport 1714-1764 accept
        udp dport 1714-1764 accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}
'''

_NFT_PROFILE_OFFICE = '''#!/usr/sbin/nft -f
# ZEN Firewall - Office Profile
# Workplace protection with printer and file sharing support
flush ruleset

table inet zen_firewall {
    chain input {
        type filter hook input priority 0; policy drop;

        # Allow established/related, drop invalid
        ct state established,related accept
        ct state invalid drop

        # Allow loopback
        iif "lo" accept

        # Rate-limited ICMP/ICMPv6
        ip protocol icmp limit rate 10/second accept
        ip6 nexthdr icmpv6 limit rate 10/second accept

        # Allow DHCPv4 client
        udp dport 68 accept

        # Allow mDNS (printer/device discovery)
        udp dport 5353 accept

        # Allow SSH
        tcp dport 22 accept

        # Allow IPP/CUPS printing
        tcp dport 631 accept
        udp dport 631 accept

        # Allow Samba/SMB file sharing
        tcp dport {139, 445} accept
        udp dport {137, 138} accept

        # Allow Avahi/UPnP (network device discovery)
        udp dport 1900 accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}
'''

_NFT_PROFILE_HARDENED = '''#!/usr/sbin/nft -f
# ZEN Firewall - Hardened Profile
# Maximum security - minimal attack surface
flush ruleset

table inet zen_firewall {
    set bruteforce_v4 {
        type ipv4_addr
        flags dynamic,timeout
        timeout 15m
    }

    chain input {
        type filter hook input priority 0; policy drop;

        # Drop known bad states immediately
        ct state invalid drop

        # Drop fragmented packets
        ip frag-off & 0x1fff != 0 drop

        # Allow established/related only
        ct state established,related accept

        # Allow loopback
        iif "lo" accept

        # Strict rate-limited ICMP (2/sec max)
        ip protocol icmp icmp type echo-request limit rate 2/second accept
        ip protocol icmp icmp type { destination-unreachable, time-exceeded, parameter-problem } accept

        # Strict rate-limited ICMPv6
        ip6 nexthdr icmpv6 icmpv6 type echo-request limit rate 2/second accept
        ip6 nexthdr icmpv6 icmpv6 type { destination-unreachable, packet-too-big, time-exceeded, parameter-problem, nd-neighbor-solicit, nd-neighbor-advert, nd-router-solicit, nd-router-advert } accept

        # Allow DHCP client
        udp dport 68 accept

        # SSH with strict brute-force protection (3 attempts per minute)
        tcp dport 22 ct state new ip saddr @bruteforce_v4 drop
        tcp dport 22 ct state new limit rate 3/minute accept
        tcp dport 22 ct state new add @bruteforce_v4 { ip saddr }
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy drop;

        # Allow established/related
        ct state established,related accept

        # Allow loopback
        oif "lo" accept

        # Allow DNS (TCP+UDP)
        tcp dport 53 accept
        udp dport 53 accept

        # Allow HTTP/HTTPS
        tcp dport {80, 443} accept

        # Allow SSH outbound
        tcp dport 22 accept

        # Allow NTP (time sync)
        udp dport 123 accept

        # Allow DHCP client
        udp dport 67 accept

        # Allow ICMP outbound
        ip protocol icmp accept
        ip6 nexthdr icmpv6 accept
    }
}
'''

_NFT_PROFILE_GAMING = '''#!/usr/sbin/nft -f
# ZEN Firewall - Gaming Profile
# Permissive profile optimized for online gaming
flush ruleset

table inet zen_firewall {
    chain input {
        type filter hook input priority 0; policy drop;

        # Allow established/related
        ct state established,related accept

        # Allow loopback
        iif "lo" accept

        # Allow ICMP (needed for game servers)
        ip protocol icmp accept
        ip6 nexthdr icmpv6 accept

        # Allow DHCP
        udp dport 68 accept

        # Allow mDNS
        udp dport 5353 accept

        # Steam
        tcp dport {27015-27050} accept
        udp dport {27000-27100, 4380} accept

        # Discord
        udp dport {50000-65535} accept

        # Game voice chat (Mumble, TeamSpeak)
        tcp dport {64738, 9987} accept
        udp dport {64738, 9987} accept

        # KDE Connect
        tcp dport 1714-1764 accept
        udp dport 1714-1764 accept

        # Samba
        tcp dport {139, 445} accept

        # SSH
        tcp dport 22 accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}
'''

_NFT_PROFILES = {
    "1": ("Home", _NFT_PROFILE_HOME),
    "2": ("Office", _NFT_PROFILE_OFFICE),
    "3": ("Gaming", _NFT_PROFILE_GAMING),
    "4": ("Hardened", _NFT_PROFILE_HARDENED),
}

def _fw_ensure_nft():
    r = subprocess.run("command -v nft", shell=True, capture_output=True)
    if r.returncode != 0:
        console.print("[bold yellow][!] nftables is not installed.[/]")
        if Confirm.ask("[cyan]Install nftables now?[/]", default=True):
            run("apt update && apt install -y nftables", check=True)
            run("systemctl enable nftables.service", check=False)
        else:
            return False
    return True

def _fw_backup():
    os.makedirs(NFTABLES_BACKUP_DIR, exist_ok=True)
    if os.path.exists(NFTABLES_CONF):
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        dst = f"{NFTABLES_BACKUP_DIR}/nftables.conf.bak_{ts}"
        shutil.copy2(NFTABLES_CONF, dst)
        return dst
    return None

def _fw_get_status():
    r = subprocess.run("systemctl is-active nftables.service", shell=True, capture_output=True, text=True)
    svc = r.stdout.strip()
    r2 = subprocess.run("nft list ruleset 2>/dev/null", shell=True, capture_output=True, text=True)
    ruleset = r2.stdout.strip() if r2.returncode == 0 else ""
    profile = "None"
    try:
        with open("/etc/zpm/firewall-profile.state", "r") as f:
            saved_profile = f.read().strip()
    except:
        saved_profile = None

    if saved_profile and saved_profile in ["Home", "Office", "Gaming", "Hardened"]:
        profile = saved_profile
    elif "zen_firewall" in ruleset:
        profile = "Custom"

    return svc, profile, ruleset

def _fw_show_status():
    svc, profile, ruleset = _fw_get_status()
    status_color = "green" if svc == "active" else "red"
    status_icon = "●" if svc == "active" else "○"

    panel_content = Text()
    panel_content.append(f"  {status_icon} Service:  ", style="bold white")
    panel_content.append(f"{svc.upper()}\n", style=f"bold {status_color}")
    panel_content.append("  Profile:  ", style="bold white")
    panel_content.append(f"{profile}\n", style="bold cyan")

    r = subprocess.run("nft list ruleset 2>/dev/null | grep -c 'chain'", shell=True, capture_output=True, text=True)
    chains = r.stdout.strip() if r.returncode == 0 else "0"
    r2 = subprocess.run("nft list ruleset 2>/dev/null | grep -cE '(accept|drop|reject)'", shell=True, capture_output=True, text=True)
    rules = r2.stdout.strip() if r2.returncode == 0 else "0"
    panel_content.append(f"  Chains:   ", style="bold white")
    panel_content.append(f"{chains}\n", style="yellow")
    panel_content.append(f"  Rules:    ", style="bold white")
    panel_content.append(rules, style="yellow")

    console.print(Panel(panel_content, title="[bold cyan]Firewall Status[/]", border_style="cyan", box=box.ROUNDED))

def _fw_show_rules():
    r = subprocess.run("nft list ruleset 2>/dev/null", shell=True, capture_output=True, text=True)
    if r.returncode == 0 and r.stdout.strip():
        console.print(Panel(r.stdout.strip(), title="[bold cyan]Current Ruleset[/]", border_style="dim cyan", box=box.ROUNDED))
    else:
        console.print("[yellow]No active rules.[/]")

def _fw_apply_profile(key):
    name, content = _NFT_PROFILES[key]
    bak = _fw_backup()
    if bak:
        console.print(f"  [dim]Backup saved: {bak}[/]")
    with open(NFTABLES_CONF, "w") as f:
        f.write(content)
    r = subprocess.run("nft -f /etc/nftables.conf", shell=True, capture_output=True, text=True)
    if r.returncode == 0:
        console.print(f"\n[bold green]  ✓ Profile '{name}' applied successfully![/]")
        import os
        os.makedirs("/etc/zpm", exist_ok=True)
        with open("/etc/zpm/firewall-profile.state", "w") as f:
            f.write(name)
        run("systemctl enable nftables.service", check=False, show=False)
        run("systemctl restart nftables.service", check=False, show=False)
    else:
        console.print(f"[bold red]  ✗ Failed to apply profile![/]")
        if r.stderr:
            console.print(f"[red]  {r.stderr.strip()}[/]")

def _fw_enable():
    run("systemctl enable nftables.service", check=False, show=False)
    run("systemctl start nftables.service", check=False, show=False)
    r = subprocess.run("nft -f /etc/nftables.conf 2>/dev/null", shell=True, capture_output=True, text=True)
    if r.returncode == 0:
        console.print("[bold green]  ✓ Firewall enabled and started![/]")
    else:
        console.print("[bold green]  ✓ Firewall service started![/]")
        console.print("[yellow]  ! No profile loaded. Apply a profile first.[/]")

def _fw_disable():
    run("nft flush ruleset", check=False, show=False)
    run("systemctl stop nftables.service", check=False, show=False)
    run("systemctl disable nftables.service", check=False, show=False)
    console.print("[bold yellow]  ⚠ Firewall disabled. System is unprotected.[/]")

def _fw_add_custom_port():
    proto = Prompt.ask("  Protocol", choices=["tcp", "udp", "both"], default="tcp")
    port = Prompt.ask("  Port number or range (e.g. 8080 or 3000-3100)")
    port = port.strip()
    if not port:
        console.print("[red]  No port specified.[/]")
        return
    cmds = []
    if proto in ("tcp", "both"):
        cmds.append(f"nft add rule inet zen_firewall input tcp dport {{{port}}} accept")
    if proto in ("udp", "both"):
        cmds.append(f"nft add rule inet zen_firewall input udp dport {{{port}}} accept")
    for c in cmds:
        r = subprocess.run(c, shell=True, capture_output=True, text=True)
        if r.returncode != 0:
            console.print(f"[red]  ✗ Failed: {r.stderr.strip()}[/]")
            return
    console.print(f"[green]  ✓ Port {port}/{proto} opened (runtime only).[/]")
    console.print("[dim]  To persist, save rules or re-apply profile with edits.[/]")

def _fw_save_runtime():
    bak = _fw_backup()
    if bak:
        console.print(f"  [dim]Backup: {bak}[/]")
    r = subprocess.run("nft list ruleset", shell=True, capture_output=True, text=True)
    if r.returncode == 0 and r.stdout.strip():
        with open(NFTABLES_CONF, "w") as f:
            f.write("#!/usr/sbin/nft -f\nflush ruleset\n\n")
            f.write(r.stdout)
        console.print("[green]  ✓ Current rules saved to /etc/nftables.conf[/]")
    else:
        console.print("[red]  ✗ No rules to save.[/]")

def _fw_restore_backup():
    if not os.path.exists(NFTABLES_BACKUP_DIR):
        console.print("[yellow]  No backups found.[/]")
        return
    backups = sorted([f for f in os.listdir(NFTABLES_BACKUP_DIR) if f.startswith("nftables.conf.bak_")], reverse=True)
    if not backups:
        console.print("[yellow]  No backups found.[/]")
        return
    tbl = Table(box=box.ROUNDED, border_style="cyan")
    tbl.add_column("#", style="bold yellow", width=4)
    tbl.add_column("Backup File", style="white")
    tbl.add_column("Date", style="dim")
    for i, b in enumerate(backups[:10], 1):
        ts = b.replace("nftables.conf.bak_", "")
        tbl.add_row(str(i), b, ts)
    console.print(tbl)
    choice = IntPrompt.ask("  Select backup", default=1)
    idx = min(choice, len(backups)) - 1
    src = os.path.join(NFTABLES_BACKUP_DIR, backups[idx])
    shutil.copy2(src, NFTABLES_CONF)
    subprocess.run("nft -f /etc/nftables.conf", shell=True, capture_output=True)
    run("systemctl restart nftables.service", check=False, show=False)
    console.print(f"[green]  ✓ Restored from {backups[idx]}[/]")

def cmd_firewall_embedded():
    require_root()
    if not _fw_ensure_nft():
        return

    _FW_BANNER = """
 ███████╗██╗██████╗ ███████╗██╗    ██╗ █████╗ ██╗     ██╗
 ██╔════╝██║██╔══██╗██╔════╝██║    ██║██╔══██╗██║     ██║
 █████╗  ██║██████╔╝█████╗  ██║ █╗ ██║███████║██║     ██║
 ██╔══╝  ██║██╔══██╗██╔══╝  ██║███╗██║██╔══██║██║     ██║
 ██║     ██║██║  ██║███████╗╚███╔███╔╝██║  ██║███████╗███████╗
 ╚═╝     ╚═╝╚═╝  ╚═╝╚══════╝ ╚══╝╚══╝ ╚═╝  ╚═╝╚══════╝╚══════╝"""

    while True:
        os.system('clear')
        console.print(Panel(
            Align.center(Text(_FW_BANNER, style="bold red") + Text("\n\nZEN Firewall Manager • nftables", style="bold white")),
            border_style="bright_red", box=box.DOUBLE
        ))
        console.print()
        _fw_show_status()
        console.print()

        menu = Table(box=box.ROUNDED, border_style="bright_red", show_header=False, padding=(0, 0))
        menu.add_column("", style="bold yellow", width=4)
        menu.add_column("", style="bold white", min_width=30)
        menu.add_column("", style="dim")
        menu.add_row("1", " Enable Firewall", "Start and enable nftables service")
        menu.add_row("2", " Disable Firewall", "Stop and flush all rules")
        menu.add_row("3", " Show Status", "Detailed firewall status")
        menu.add_row("4", " Show Rules", "Display current ruleset")
        menu.add_row("5", "Apply Home Profile", "Basic desktop protection")
        menu.add_row("6", "Apply Office Profile", "Workplace with printers & file sharing")
        menu.add_row("7", "Apply Gaming Profile", "Permissive for online gaming")
        menu.add_row("8", "Apply Hardened Profile", "Maximum security, minimal surface")
        menu.add_row("9", "Open Custom Port", "Add port to current rules")
        menu.add_row("10", "Save Current Rules", "Persist runtime rules to disk")
        menu.add_row("11", "Restore Backup", "Restore from previous config")
        menu.add_row("0", "Back", "Return to security menu")
        console.print(menu)
        console.print()

        choice = Prompt.ask("[bold red]>[/] [bold white]Select option[/]")
        choice = choice.strip()
        console.print()

        if choice == "1":
            _fw_enable()
        elif choice == "2":
            if Confirm.ask("[yellow]  Disable firewall? System will be unprotected.[/]", default=False):
                _fw_disable()
        elif choice == "3":
            _fw_show_status()
        elif choice == "4":
            _fw_show_rules()
        elif choice == "5":
            if Confirm.ask("[cyan]  Apply Home profile? Current rules will be replaced.[/]", default=True):
                _fw_apply_profile("1")
        elif choice == "6":
            if Confirm.ask("[cyan]  Apply Office profile? Current rules will be replaced.[/]", default=True):
                _fw_apply_profile("2")
        elif choice == "7":
            if Confirm.ask("[cyan]  Apply Gaming profile? Current rules will be replaced.[/]", default=True):
                _fw_apply_profile("3")
        elif choice == "8":
            if Confirm.ask("[yellow]  Apply Hardened profile? Outbound traffic will also be restricted.[/]", default=False):
                _fw_apply_profile("4")
        elif choice == "9":
            _fw_add_custom_port()
        elif choice == "10":
            _fw_save_runtime()
        elif choice == "11":
            _fw_restore_backup()
        elif choice == "0":
            console.print("[bold green]  ✓ Stay protected![/]")
            break
        else:
            console.print("[red]  Invalid option.[/]")

        console.print()
        Prompt.ask("[dim]Press Enter to continue[/]")

def cmd_security(args):
    if not args:
        console.print(Panel(f"[bold cyan]{t('security_tools')}[/]", border_style="cyan", box=box.DOUBLE))
        tbl = Table(box=box.ROUNDED, border_style="red")
        tbl.add_column(t("command"), style="bold green")
        tbl.add_column(t("description"), style="white")
        for cmd, desc in [("jails",t("sec_zenjails")),("usbguard",t("sec_usbguard")),("checksum",t("sec_checksum")),("firewall",t("sec_firewall"))]:
            tbl.add_row(cmd, desc)
        console.print(tbl)
        console.print(f"\n  [dim]{t('usage')}: zen security <tool>[/]\n")
        return
    tool = args[0]
    if tool in ("jails", "zenjails"): cmd_zenjails_embedded()
    elif tool in ("usbguard", "usb"): cmd_usbguard_embedded()
    elif tool in ("checksum",): cmd_checksum_embedded()
    elif tool in ("firewall", "fw"): cmd_firewall_embedded()
    else:
        console.print(f"[bold red][-][/] {t('unknown_security_tool')}: {tool}")
        console.print("[dim]Available: jails, usbguard, checksum, firewall[/]")

