HF_LLM_STORE_DIR = "/opt/models/huggingface"

def _llmstore_banner():
    console.print(Panel(
        Align.center(Text("HuggingFace LLM Store", style="bold cyan")),
        border_style="bright_blue", box=box.DOUBLE
    ))

def _llmstore_check_hf():
    if shutil.which("hf") or shutil.which("huggingface-cli"):
        return True
    console.print("[bold yellow][!] HuggingFace CLI not found. Installing...[/]")
    try:
        subprocess.run([sys.executable, "-m", "pip", "install", "-U", "huggingface_hub[cli]"], check=True, timeout=120)
        return True
    except Exception:
        console.print(Panel("[white]Failed to install HuggingFace CLI.\nInstall manually:[/] [bold cyan]pip install huggingface_hub[cli][/]", title="[bold red]Error[/]", border_style="red"))
        return False

def _llmstore_show_models(models, title="Available Models"):
    table = Table(title=title, box=box.ROUNDED, border_style="bright_cyan", show_lines=True, title_style="bold magenta")
    table.add_column("#", style="bold yellow", width=4, justify="center")
    table.add_column("Model", style="bold white", min_width=20)
    table.add_column("Category", style="bold magenta", width=8, justify="center")
    table.add_column("Size", style="green", width=10, justify="center")
    table.add_column("Description", style="dim white")
    for i, m in enumerate(models, 1):
        table.add_row(str(i), m["name"], m["cat"], m["size"], m["desc"])
    console.print(table)

def _llmstore_download(model):
    if not _llmstore_check_hf():
        return
    dest = os.path.join(HF_LLM_STORE_DIR, model["repo"].replace("/", "_"))
    os.makedirs(dest, exist_ok=True)
    console.print(f"\n  [bold cyan]Model:[/] {model['name']}")
    console.print(f"  [bold cyan]Repo:[/] {model['repo']}")
    console.print(f"  [bold cyan]Size:[/] {model['size']}")
    console.print(f"  [bold cyan]Destination:[/] {dest}\n")
    hf_cmd = "hf" if shutil.which("hf") else "huggingface-cli"
    try:
        # Use os.system to allow hf-cli to pipe progress bars directly to the terminal without freezing
        ret = os.system(f"{hf_cmd} download {model['repo']} --local-dir {dest}")
        if ret == 0:
            console.print(f"\n  [bold green][+] Model downloaded to {dest}[/]")
        else:
            console.print(Panel(
                f"[white]Could not download[/] [bold]{model['name']}[/]\n"
                f"[white]Check the repo ID and your authentication.[/]\n\n"
                f"[dim]Tip: Run [bold]hf login[/bold] to authenticate with HuggingFace.[/]",
                title="[bold red]Download Failed[/]", border_style="red"
            ))
    except KeyboardInterrupt:
        console.print("\n[bold yellow][!] Download interrupted.[/]")
    except FileNotFoundError:
        console.print(Panel("[white]HuggingFace CLI not found in PATH.[/]\n[dim]Install with: pip install huggingface_hub[cli][/]", title="[bold red]Error[/]", border_style="red"))

def _llmstore_list_downloaded():
    if not os.path.isdir(HF_LLM_STORE_DIR):
        console.print("[dim]  No models downloaded yet.[/]")
        return
    entries = [e for e in os.listdir(HF_LLM_STORE_DIR) if os.path.isdir(os.path.join(HF_LLM_STORE_DIR, e))]
    if not entries:
        console.print("[dim]  No models downloaded yet.[/]")
        return
    table = Table(title="Downloaded Models", box=box.ROUNDED, border_style="green", title_style="bold green")
    table.add_column("#", style="bold yellow", width=4)
    table.add_column("Model", style="bold white")
    table.add_column("Size", style="green", justify="right")
    for i, name in enumerate(sorted(entries), 1):
        path = os.path.join(HF_LLM_STORE_DIR, name)
        try:
            total = sum(os.path.getsize(os.path.join(dp, f)) for dp, _, fns in os.walk(path) for f in fns)
            size_str = f"{total / (1024**3):.2f} GB"
        except OSError:
            size_str = "N/A"
        table.add_row(str(i), name, size_str)
    console.print(table)
    return entries

def _llmstore_remove():
    entries = _llmstore_list_downloaded()
    if not entries:
        return
    choice = Prompt.ask("\n[red]Enter # to delete or 'b' to go back[/]")
    if choice.lower() == 'b':
        return
    if choice.isdigit() and 1 <= int(choice) <= len(entries):
        name = sorted(entries)[int(choice) - 1]
        if Confirm.ask(f"[bold red]Delete {name}?[/]"):
            shutil.rmtree(os.path.join(HF_LLM_STORE_DIR, name), ignore_errors=True)
            console.print(f"[bold green][+] Removed: {name}[/]")

def cmd_ai_llmstore():
    while True:
        console.clear()
        _llmstore_banner()
        cats = sorted(set(m["cat"] for m in HF_LLM_STORE_MODELS))
        console.print("\n  [dim](Select: # to browse category, 'a' for all, 'd' for downloaded, 'r' to remove, 'c' for custom, 'q' to quit)[/]\n")
        cat_table = Table(box=box.SIMPLE, border_style="cyan")
        cat_table.add_column("#", style="bold yellow", width=4)
        cat_table.add_column("Category", style="bold white")
        cat_table.add_column("Models", style="dim", justify="center")
        for i, cat in enumerate(cats, 1):
            count = sum(1 for m in HF_LLM_STORE_MODELS if m["cat"] == cat)
            cat_table.add_row(str(i), cat, str(count))
        console.print(cat_table)
        choice = Prompt.ask("\n[bold cyan]Choice[/]").lower().strip()
        if choice == 'q':
            break
        elif choice == 'a':
            _llmstore_browse(HF_LLM_STORE_MODELS, "All Models")
        elif choice == 'd':
            _llmstore_list_downloaded()
            Prompt.ask("\nPress Enter")
        elif choice == 'r':
            _llmstore_remove()
            Prompt.ask("\nPress Enter")
        elif choice == 'c':
            if not _llmstore_check_hf():
                Prompt.ask("\nPress Enter"); continue
            repo = Prompt.ask("[cyan]Enter HuggingFace repo ID (e.g. user/model-name)[/]")
            if repo:
                custom = {"name": repo.split("/")[-1], "repo": repo, "size": "Unknown", "cat": "Custom", "desc": "User-specified model"}
                _llmstore_download(custom)
            Prompt.ask("\nPress Enter")
        elif choice.isdigit() and 1 <= int(choice) <= len(cats):
            cat_name = cats[int(choice) - 1]
            filtered = [m for m in HF_LLM_STORE_MODELS if m["cat"] == cat_name]
            _llmstore_browse(filtered, f"Category: {cat_name}")

def _llmstore_browse(models, title):
    while True:
        console.clear()
        _llmstore_banner()
        _llmstore_show_models(models, title)
        choice = Prompt.ask("\n[bold cyan]Enter # to download or 'b' to go back[/]").lower().strip()
        if choice == 'b':
            break
        if choice.isdigit() and 1 <= int(choice) <= len(models):
            model = models[int(choice) - 1]
            if Confirm.ask(f"[cyan]Download {model['name']} ({model['size']})?[/]"):
                _llmstore_download(model)
            Prompt.ask("\nPress Enter to continue")

def cmd_ai(args):
    if not args:
        console.print(Panel(f"[bold cyan]{t('ai_tools')}[/]", border_style="cyan", box=box.DOUBLE))
        tbl = Table(box=box.ROUNDED, border_style="blue")
        tbl.add_column(t("command"), style="bold green")
        tbl.add_column(t("description"), style="white")
        for cmd, desc in [("ollama",t("ai_ollama")),("toolkit",t("ai_toolkit")),("apichat",t("ai_apichat")),("llm-store",t("ai_llmstore"))]:
            tbl.add_row(cmd, desc)
        console.print(tbl)
        console.print(f"\n  [dim]{t('usage')}: zen ai <tool>[/]\n")
        return
    tool = args[0]
    if tool in ("ollama", "ollama-manager"): cmd_ai_ollama_embedded()
    elif tool in ("toolkit", "ai-toolkit"): cmd_ai_toolkit_embedded()
    elif tool in ("apichat", "chat"): cmd_ai_apichat_embedded()
    elif tool in ("llm-store", "llmstore", "store"): cmd_ai_llmstore()
    else:
        console.print(f"[bold red][-][/] {t('unknown_ai_tool')}: {tool}")
        console.print("[dim]Available: ollama, toolkit, apichat, llm-store[/]")

