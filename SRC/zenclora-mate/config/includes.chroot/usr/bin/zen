    elif choice == 3:
        q = Prompt.ask("[cyan]Package name[/]")
        run(f"dpkg -s {q}", check=False)
    elif choice == 4:
        console.print("\n  [bold yellow]Recently Installed:[/]")
        run("grep ' install ' /var/log/dpkg.log 2>/dev/null | tail -20 | awk '{print $1, $2, $4}'", check=False)
    elif choice == 5:
        run("echo \"  Total installed: $(dpkg -l | grep -c '^ii')\"", check=False)
    elif choice == 6:
        console.print("\n  [bold yellow]Top 20 Largest Packages:[/]")
        run("dpkg-query -Wf '${Installed-Size}\\t${Package}\\n' | sort -rn | head -20 | awk '{printf \"    %8.2f MB  %s\\n\", $1/1024, $2}'", check=False)

def system_logs():
    console.print(Panel(f"[bold cyan]{t('log_viewer')}[/]", border_style="cyan"))
    opts = ["System Logs (Recent)","Kernel Logs","Boot Logs","Auth/Security Logs","Application Logs","Live Log Stream","Journal Disk Usage","Clear Old Logs"]
    for i,o in enumerate(opts,1):
        console.print(f"  [bold yellow]{i}.[/] {o}")
    choice = IntPrompt.ask("\n[cyan]Select[/]", default=1)
    if choice == 1:
        run("journalctl -n 100 --no-pager", check=False)
    elif choice == 2:
        run("journalctl -k -n 100 --no-pager", check=False)
    elif choice == 3:
        run("journalctl -b --no-pager | head -100", check=False)
    elif choice == 4:
        run("journalctl _COMM=sudo -n 50 --no-pager 2>/dev/null || cat /var/log/auth.log 2>/dev/null | tail -50", check=False)
    elif choice == 5:
        app = Prompt.ask("[cyan]Application/service name[/]")
        run(f"journalctl -u {app} -n 100 --no-pager", check=False)
    elif choice == 6:
        console.print("  [dim]Press Ctrl+C to stop...[/]")
        run("journalctl -f", check=False)
    elif choice == 7:
        run("journalctl --disk-usage", check=False)
    elif choice == 8:
        require_root()
        days = Prompt.ask("[cyan]Clear logs older than how many days?[/]", default="7")
        run(f"journalctl --vacuum-time={days}d", check=False)
        console.print(f"[bold green][+] Old logs cleared![/]")

def system_hostname():
    require_root()
    console.print(Panel(f"[bold cyan]{t('hostname_manager')}[/]", border_style="cyan"))
    cur_hostname = run_quiet("hostname").stdout.strip()
    console.print(f"  [bold]{t('current_hostname')}:[/] {cur_hostname}\n")
    new_hostname = Prompt.ask(f"[cyan]{t('enter_new_hostname')}[/]")
    if not new_hostname:
        console.print(f"[bold red][-] {t('no_hostname_provided')}[/]"); return
    
    if Confirm.ask(f"[yellow]{t('confirm_hostname_change').format(new_hostname=new_hostname)}[/]"):
        run(f"hostnamectl set-hostname {new_hostname}")
        run(f"sed -i 's/{cur_hostname}/{new_hostname}/g' /etc/hosts")
        console.print(f"\n[bold green][+] {t('hostname_changed_success').format(new_hostname=new_hostname)}[/]")
        if Confirm.ask(f"[bold yellow][?] {t('reboot_now')}[/]"):
            console.print(f"[bold cyan][*] {t('rebooting')}[/]")
            run("reboot")

def cmd_tools(args):
    if not args:
        console.print(Panel(f"[bold cyan]{t('tools')}[/]", border_style="cyan", box=box.DOUBLE))
        console.print(f"  [bold green]formatusb[/]     - {t('format_usb_desc')}")
        console.print(f"  [bold green]debinstaller[/]  - {t('deb_installer_desc')}")
        console.print(f"  [bold green]filemanager[/]   - {t('file_manager_desc')}")
        console.print(f"\n  [dim]{t('usage')}: zen tools <tool>[/]\n")
        return
    if args[0] == "formatusb":
        require_root()
        console.print(Panel(f"[bold red]{t('usb_formatter')}[/]", border_style="red"))
        run("lsblk -d -o NAME,SIZE,TYPE,VENDOR,MODEL | grep disk", check=False)
        dev = Prompt.ask("[cyan]Enter device name (e.g. sdb)[/]")
        if not os.path.exists(f"/dev/{dev}"):
            console.print("[bold red]✗ Device not found![/]"); return
        fs_map = {"1":"vfat","2":"ntfs","3":"ext4","4":"exfat"}
        console.print("  1. FAT32  2. NTFS  3. ext4  4. exFAT")
        fs = fs_map.get(Prompt.ask("[cyan]Filesystem[/]", default="1"), "vfat")
        label = Prompt.ask("[cyan]Label[/]", default="ZEN_USB")
        if Prompt.ask("[bold red]Type FORMAT to confirm[/]") != "FORMAT":
            return
        run(f"umount /dev/{dev}* 2>/dev/null", check=False)
        run(f"parted -s /dev/{dev} mklabel msdos")
        run(f"parted -s /dev/{dev} mkpart primary 1MiB 100%")
        fmt_cmd = {"vfat":f'mkfs.vfat -F 32 -n "{label}"',"ntfs":f'mkfs.ntfs -f -L "{label}"',
                   "ext4":f'mkfs.ext4 -L "{label}"',"exfat":f'mkfs.exfat -n "{label}"'}
        run(f"{fmt_cmd[fs]} /dev/{dev}1")
        console.print(f"\n[bold green][+] {t('usb_formatted')}[/]\n")
    elif args[0] == "debinstaller":
        require_root()
        console.print(Panel(f"[bold cyan]{t('deb_installer')}[/]", border_style="cyan"))
        console.print("  [bold yellow]1.[/] Install from file")
        console.print("  [bold yellow]2.[/] Install from URL")
        console.print("  [bold yellow]3.[/] List Recently Installed")
        choice = IntPrompt.ask("[cyan]Select[/]", default=1)
        if choice == 1:
            path = Prompt.ask("[cyan]Enter path to .deb file[/]")
            if not os.path.isfile(path):
                console.print("[bold red][-] File not found![/]"); return
            run(f"dpkg -i '{path}' || apt-get install -f -y")
        elif choice == 2:
            url = Prompt.ask("[cyan]Enter URL of .deb file[/]")
            run(f"wget -O /tmp/zen_install.deb '{url}' && dpkg -i /tmp/zen_install.deb || apt-get install -f -y")
            run("rm -f /tmp/zen_install.deb", check=False)
        elif choice == 3:
            console.print("\n  [bold yellow]Recently installed .deb packages:[/]")
            run("grep 'status installed' /var/log/dpkg.log 2>/dev/null | tail -20", check=False)
    elif args[0] == "filemanager":
        console.print(Panel(f"[bold cyan]{t('file_manager')}[/]", border_style="cyan"))
        opts = ["Change Permissions","Change Ownership","Find Files","Find Large Files","Delete Files"]
        for i,o in enumerate(opts,1):
            console.print(f"  [bold yellow]{i}.[/] {o}")
        choice = IntPrompt.ask("[cyan]Select[/]", default=1)
        if choice == 1:
            path = Prompt.ask("[cyan]File/directory path[/]")
            run(f"ls -la '{path}'", check=False)
            perms = Prompt.ask("[cyan]Enter permission (e.g. 755)[/]")
            recursive = Confirm.ask("[cyan]Apply recursively?[/]", default=False)
            require_root()
            flag = "-R " if recursive else ""
            run(f"chmod {flag}{perms} '{path}'")
        elif choice == 2:
            path = Prompt.ask("[cyan]File/directory path[/]")
            owner = Prompt.ask("[cyan]New owner (user:group)[/]")
            recursive = Confirm.ask("[cyan]Apply recursively?[/]", default=False)
            require_root()
            flag = "-R " if recursive else ""
            run(f"chown {flag}{owner} '{path}'")
        elif choice == 3:
            sdir = Prompt.ask("[cyan]Directory to search[/]", default="/")
            pattern = Prompt.ask("[cyan]Filename pattern (e.g. *.log)[/]")
            run(f"find '{sdir}' -name '{pattern}' 2>/dev/null | head -50", check=False)
        elif choice == 4:
            sdir = Prompt.ask("[cyan]Directory to search[/]", default="/")
            size = Prompt.ask("[cyan]Minimum size in MB[/]", default="100")
            run(f"find '{sdir}' -type f -size +{size}M -exec ls -lh {{}} \\; 2>/dev/null | head -30", check=False)
        elif choice == 5:
            path = Prompt.ask("[cyan]File/directory path to delete[/]")
            if not os.path.exists(path):
                console.print("[bold red][-] Path not found![/]"); return
            console.print(f"\n  [bold]Target:[/] {path}")
            if os.path.isdir(path):
                r = run_quiet(f"find '{path}' -type f 2>/dev/null | wc -l")
                console.print(f"  [bold]Type:[/] Directory ({r.stdout.strip()} files)")
            else:
                r = run_quiet(f"ls -lh '{path}' | awk '{{print $5}}'")
                console.print(f"  [bold]Type:[/] File ({r.stdout.strip()})")
            console.print("\n  [bold red]WARNING: This action cannot be undone![/]")
            if Prompt.ask("[bold red]Type DELETE to confirm[/]") == "DELETE":
                require_root()
                run(f"rm -rf '{path}'")
                console.print(f"[bold green][+] Deleted: {path}[/]")
            else:
                console.print("[dim]Operation cancelled.[/]")
    else:
        console.print(f"[bold red][-][/] {t('unknown_tool')}: {args[0]}")

def _checksum_calc(filepath, algo_func):
    h = algo_func()
    try:
        with open(filepath, "rb") as f:
            while True:
                c = f.read(65536)
                if not c: break
                h.update(c)
        return h.hexdigest()
    except Exception as e:
        console.print(f"[bold red]Error: {e}[/]"); return None

def cmd_checksum_embedded():
    ALGOS = {"1":("MD5",hashlib.md5),"2":("SHA1",hashlib.sha1),"3":("SHA256",hashlib.sha256),"4":("SHA512",hashlib.sha512)}
    def pick_algo():
        console.print("\n[cyan]1.[/] MD5  [cyan]2.[/] SHA1  [cyan]3.[/] SHA256  [cyan]4.[/] SHA512")
        c = Prompt.ask("Algorithm", choices=["1","2","3","4"], default="3")
        return ALGOS[c]
    while True:
        console.print(Panel("[bold cyan]Checksum Manager[/]", border_style="cyan"))
        console.print("  [yellow]1.[/] Calculate  [yellow]2.[/] Verify  [yellow]3.[/] Compare  [yellow]0.[/] Back")
        c = Prompt.ask("Select", choices=["0","1","2","3"], default="1")
        if c == "0": break
        elif c == "1":
            name, func = pick_algo()
            path = Prompt.ask("File path")
            path = os.path.expanduser(path.strip().strip("\"'"))
            if not os.path.isfile(path): console.print("[red]Not found![/]"); continue
            h = _checksum_calc(path, func)
            if h: console.print(f"\n[green]{name}:[/] [white]{h}[/]")
        elif c == "2":
            name, func = pick_algo()
            path = Prompt.ask("File path")
            path = os.path.expanduser(path.strip().strip("\"'"))
            if not os.path.isfile(path): console.print("[red]Not found![/]"); continue
            expected = Prompt.ask(f"Expected {name}").strip().lower()
            actual = _checksum_calc(path, func)
            if actual:
                if actual == expected: console.print("[bold green]✓ MATCH[/]")
                else: console.print(f"[bold red]✗ MISMATCH[/]\n  Expected: {expected}\n  Actual:   {actual}")
        elif c == "3":
            name, func = pick_algo()
            f1 = os.path.expanduser(Prompt.ask("File 1").strip().strip("\"'"))
            f2 = os.path.expanduser(Prompt.ask("File 2").strip().strip("\"'"))
            if not os.path.isfile(f1) or not os.path.isfile(f2): console.print("[red]File not found![/]"); continue
            h1, h2 = _checksum_calc(f1, func), _checksum_calc(f2, func)
            if h1 and h2:
                if h1 == h2: console.print("[bold green]✓ IDENTICAL[/]")
                else: console.print("[bold red]✗ DIFFERENT[/]")
        Prompt.ask("\nPress Enter")

USBGUARD_POLICY_FILE = "/etc/usbguard/rules.conf"
USBGUARD_POLICY_BACKUP = "/etc/usbguard/rules.conf.bak"

def _usbguard_run_cmd(cmd, shell=False, check=False):
    try:
        result = subprocess.run(cmd, shell=shell, check=check, text=True, capture_output=True)
        return result
    except subprocess.CalledProcessError as e:
        print(f"Error executing command: {e}")
        return e

def _usbguard_install():
    if subprocess.run("command -v usbguard", shell=True, capture_output=True).returncode == 0:
        print("USBGuard is already installed.")
    else:
        print("Installing USBGuard...")
        if subprocess.run("sudo apt update && sudo apt install -y usbguard", shell=True).returncode == 0:
            print("USBGuard installed successfully.")
        else:
            print("Failed to install USBGuard.")

def _usbguard_install_usbutils():
    if subprocess.run("command -v lsusb", shell=True, capture_output=True).returncode == 0:
        print("usbutils is already installed.")
    else:
        print("Installing usbutils...")
        if subprocess.run("sudo apt update && sudo apt install -y usbutils", shell=True).returncode == 0:
            print("usbutils installed successfully.")
        else:
            print("Failed to install usbutils.")

def _usbguard_generate_policy():
    print(f"WARNING: This will overwrite {USBGUARD_POLICY_FILE} with default deny policy!")
    confirm = input("Are you sure? (y/n): ")
    if confirm.lower() == 'y':
        res = subprocess.run("sudo usbguard generate-policy -X -t block", shell=True, capture_output=True, text=True)
        if res.returncode == 0:
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            subprocess.run(f"sudo cp {USBGUARD_POLICY_FILE} {USBGUARD_POLICY_BACKUP}_{timestamp}", shell=True, stderr=subprocess.DEVNULL)
            with open("/tmp/usbguard.rules.tmp", "w") as f:
                f.write(res.stdout)
            subprocess.run(f"sudo mv /tmp/usbguard.rules.tmp {USBGUARD_POLICY_FILE}", shell=True)
            print(f"Policy generated with default deny and saved to {USBGUARD_POLICY_FILE}")
            subprocess.run("sudo systemctl restart usbguard.service", shell=True)
        else:
            print("Failed to generate policy.")
    else:
        print("Aborted.")

def _usbguard_show_policy():
    if os.path.exists(USBGUARD_POLICY_FILE):
        print(f"Current USBGuard policy ({USBGUARD_POLICY_FILE}):")
        print("-" * 50)
        subprocess.run(f"sudo cat {USBGUARD_POLICY_FILE}", shell=True)
    else:
        print(f"Policy file not found: {USBGUARD_POLICY_FILE}")

def _usbguard_backup_policy():
    if os.path.exists(USBGUARD_POLICY_FILE):
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_file = f"{USBGUARD_POLICY_BACKUP}_{timestamp}"
        subprocess.run(f"sudo cp {USBGUARD_POLICY_FILE} {backup_file}", shell=True)
        print(f"Policy backed up to {backup_file}")
    else:
        print(f"Policy file not found: {USBGUARD_POLICY_FILE}")

def _usbguard_restore_policy():
    print("Available backups:")
    subprocess.run(f"ls -1 {USBGUARD_POLICY_BACKUP}_* 2>/dev/null", shell=True)
    backup_file = input("Enter full path of backup file to restore: ")
    if os.path.exists(backup_file):
        subprocess.run(f"sudo cp {backup_file} {USBGUARD_POLICY_FILE}", shell=True)
        print(f"Policy restored from {backup_file}")
        subprocess.run("sudo systemctl restart usbguard.service", shell=True)
    else:
        print("Backup file not found or invalid.")

def _usbguard_toggle_default_policy():
    if not os.path.exists(USBGUARD_POLICY_FILE):
        print(f"Policy file not found: {USBGUARD_POLICY_FILE}")
        return
    res = subprocess.run(f"sudo grep -q '^allow' {USBGUARD_POLICY_FILE}", shell=True)
    if res.returncode == 0:
        print("Switching default policy to DENY ALL...")
        subprocess.run(f"sudo sed -i 's/^allow/block/' {USBGUARD_POLICY_FILE}", shell=True)
        print("Default policy set to DENY all devices.")
    else:
        print("Switching default policy to ALLOW ALL...")
        subprocess.run(f"sudo sed -i 's/^block/allow/' {USBGUARD_POLICY_FILE}", shell=True)
        print("Default policy set to ALLOW all devices.")
    print("Restarting usbguard service...")
    subprocess.run("sudo systemctl restart usbguard.service", shell=True)

def _usbguard_edit_rules():
    if os.path.exists(USBGUARD_POLICY_FILE):
        subprocess.run(f"sudo nano {USBGUARD_POLICY_FILE}", shell=True)
        print("Restarting usbguard service to apply changes...")
        subprocess.run("sudo systemctl restart usbguard.service", shell=True)
    else:
        print(f"Policy file not found: {USBGUARD_POLICY_FILE}")

def _usbguard_rules_guide():
    os.system('clear')
    guide = """
USBGuard daemon configuration file options

Option                      Description
--------------------------------------------------------------
RuleFile=path               Specifies the file from which USBGuard daemon
                            loads the policy rules and writes new rules
                            received via IPC interface.

ImplicitPolicyTarget=target Defines how USB devices that do not match
                            any rule in the policy are handled. Target
                            can be allow, block, or reject (logically
                            removing the device node from the system).

PresentDevicePolicy=policy  Defines how already connected USB devices
                            are handled when the daemon starts. Policy
                            can be allow, block, reject, keep (preserve
                            current device state), or apply-policy
                            (evaluate rules for each device).

PresentControllerPolicy=policy
                            Defines how already connected USB controller
                            devices are handled when the daemon starts.
                            Can be allow, block, reject, keep, or
                            apply-policy.

InsertedDevicePolicy=policy Defines how devices connected after the daemon
                            has started are handled. Can be block, reject,
                            or apply-policy.

RestoreControllerDeviceState=boolean
                            Determines if USBGuard daemon restores
                            controller device attributes to their state
                            before shutdown during startup.

DeviceManagerBackend=backend
                            Specifies which device manager backend is used.
                            Can be uevent (default) or umockdev.

IPCAllowedUsers=username [username ...]
                            List of user names allowed to connect via IPC.

IPCAllowedGroups=groupname [groupname ...]
                            List of groups allowed to connect via IPC.

IPCAccessControlFiles=path  Location of files defining IPC access control.

DeviceRulesWithPort=boolean Enables creating device-specific rules
                            including "via-port" attribute.

AuditBackend=backend        Specifies audit backend for USBGuard events.
                            Can be FileAudit or LinuxAudit.

AuditFilePath=filepath      Path to the audit log file (required if
                            AuditBackend is FileAudit).
"""
    print(guide)
    input("Press Enter to return to menu...")

def cmd_usbguard_embedded():
    while True:
        os.system('clear')
        print("================ USBGuard Manager ================")
        print("1) Install USBGuard")
        print("2) Install usbutils")
        print("3) Enable USBGuard service (does NOT start)")
        print("4) Disable USBGuard service")
        print("5) Start USBGuard service")
        print("6) Stop USBGuard service")
        print("7) Restart USBGuard service")
        print("8) Service status")
        print("9) List USB devices (lsusb)")
        print("10) List USB devices (usb-devices)")
        print("11) List blocked USB devices")
        print("12) Temporarily allow USB device")
        print("13) Permanently allow USB device")
        print("14) Generate USBGuard policy from current devices (default deny)")
        print("15) Show current USBGuard policy")
        print("16) Backup current USBGuard policy")
        print("17) Restore USBGuard policy from backup")
        print("18) Toggle default policy (allow all / deny all)")
        print("19) Edit USBGuard rules.conf")
        print("20) USBGuard Rules Guide")
        print("0) Exit")
        print("==================================================")

        opt = input("Select an option: ")

        if opt == "1":
            _usbguard_install()
        elif opt == "2":
            _usbguard_install_usbutils()
        elif opt == "3":
            if subprocess.run("sudo systemctl enable usbguard.service", shell=True).returncode == 0:
                print("usbguard service enabled (not started).")
            else:
                print("Failed to enable usbguard service.")
        elif opt == "4":
            if subprocess.run("sudo systemctl disable usbguard.service", shell=True).returncode == 0:
                print("usbguard service disabled.")
            else:
                print("Failed to disable usbguard service.")
        elif opt == "5":
            if subprocess.run("sudo systemctl start usbguard.service", shell=True).returncode == 0:
                print("usbguard service started.")
            else:
                print("Failed to start usbguard service.")
        elif opt == "6":
            if subprocess.run("sudo systemctl stop usbguard.service", shell=True).returncode == 0:
                print("usbguard service stopped.")
            else:
                print("Failed to stop usbguard service.")
        elif opt == "7":
            if subprocess.run("sudo systemctl restart usbguard.service", shell=True).returncode == 0:
                print("usbguard service restarted.")
            else:
                print("Failed to restart usbguard service.")
        elif opt == "8":
            subprocess.run("sudo systemctl status usbguard.service", shell=True)
        elif opt == "9":
            subprocess.run("lsusb", shell=True)
        elif opt == "10":
            subprocess.run("usb-devices", shell=True)
        elif opt == "11":
            subprocess.run("sudo usbguard list-devices -b", shell=True)
        elif opt == "12":
            dev_id = input("Enter device ID to allow temporarily: ")
            subprocess.run(f"sudo usbguard allow-device {dev_id}", shell=True)
        elif opt == "13":
            dev_id = input("Enter device ID to allow permanently: ")
            subprocess.run(f"sudo usbguard allow-device {dev_id} -p", shell=True)
        elif opt == "14":
            _usbguard_generate_policy()
        elif opt == "15":
            _usbguard_show_policy()
        elif opt == "16":
            _usbguard_backup_policy()
        elif opt == "17":
            _usbguard_restore_policy()
        elif opt == "18":
            _usbguard_toggle_default_policy()
        elif opt == "19":
            _usbguard_edit_rules()
        elif opt == "20":
            _usbguard_rules_guide()
        elif opt == "0":
            break
        else:
            print("Invalid option, please try again.")

        print()
        input("Press Enter to continue...")

_FJ_RED = '\033[0;31m'
_FJ_GREEN = '\033[0;32m'
_FJ_YELLOW = '\033[1;33m'
_FJ_BLUE = '\033[0;34m'
_FJ_PURPLE = '\033[0;35m'
_FJ_CYAN = '\033[0;36m'
_FJ_WHITE = '\033[1;37m'
_FJ_NC = '\033[0m'

def _fj_check_env():
    if not shutil.which("firejail"):
        print(f"{_FJ_RED}[!] Firejail is not installed! This tool requires firejail to function.{_FJ_NC}")
        resp = input(f"{_FJ_YELLOW}Would you like to install it now? (Y/N): {_FJ_NC}").strip().lower()
        if resp.startswith('y'):
            print(f"{_FJ_CYAN}[i] Installing firejail...{_FJ_NC}")
            try:
                subprocess.run(["sudo", "apt", "update"], check=True)
                subprocess.run(["sudo", "apt", "install", "-y", "firejail"], check=True)
                print(f"{_FJ_GREEN}[+] Firejail installed successfully!{_FJ_NC}")
            except subprocess.CalledProcessError:
                print(f"{_FJ_RED}[!] Failed to install firejail. Please install it manually.{_FJ_NC}")
                return False
        else:
            print(f"{_FJ_RED}[!] Firejail is required. Exiting.{_FJ_NC}")
            return False
    return True

