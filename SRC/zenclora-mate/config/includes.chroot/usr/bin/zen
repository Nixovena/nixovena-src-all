def install_pack(name):
    info = PACKAGES[name]
    pkgs = info["pkgs"]
    console.print(f"  [cyan]Packages: {pkgs}[/]\n")
    if name == "gaming-pack":
        run("dpkg --add-architecture i386")
    run("apt update")
    run(f"apt install -y {pkgs}")

def remove_pack(name):
    pkgs = PACKAGES[name]["pkgs"]
    run(f"apt remove -y {pkgs}", check=False)
    run("apt autoremove -y")

EXTERNAL_INSTALLERS = {}

def ext(name):
    def decorator(fn):
        EXTERNAL_INSTALLERS[name] = fn
        return fn
    return decorator

@ext("install_steam")
def _(_=None):
    run("dpkg --add-architecture i386", show=False)
    run("curl -s http://repo.steampowered.com/steam/archive/stable/steam.gpg | sudo tee /usr/share/keyrings/steam.gpg > /dev/null", show=False)
    run("""sudo tee /etc/apt/sources.list.d/steam-stable.list <<'EOF'
deb [arch=amd64,i386 signed-by=/usr/share/keyrings/steam.gpg] https://repo.steampowered.com/steam/ stable steam
deb-src [arch=amd64,i386 signed-by=/usr/share/keyrings/steam.gpg] https://repo.steampowered.com/steam/ stable steam
EOF""", show=False)
    run("apt update")
    run("apt install -y mesa-vulkan-drivers libglx-mesa0:i386 mesa-vulkan-drivers:i386 libgl1-mesa-dri:i386")
    run("apt install -y steam-launcher")

@ext("remove_steam")
def _(_=None):
    run("apt remove -y steam-launcher", check=False)
    run("rm -f /etc/apt/sources.list.d/steam-stable.list /usr/share/keyrings/steam.gpg")
    run("apt update", check=False)

@ext("install_brave")
def _(_=None):
    run("curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg", show=False)
    run('echo "deb [signed-by=/usr/share/keyrings/brave-browser-archive-keyring.gpg] https://brave-browser-apt-release.s3.brave.com/ stable main" | sudo tee /etc/apt/sources.list.d/brave-browser-release.list > /dev/null', show=False)
    run("apt update && apt install -y brave-browser")
    run("rm -f /usr/share/applications/com.brave.Browser.desktop", check=False)

@ext("remove_brave")
def _(_=None):
    run("apt remove -y brave-browser", check=False)
    run("rm -f /etc/apt/sources.list.d/brave-browser-release.list /usr/share/keyrings/brave-browser-archive-keyring.gpg")
    run("apt update", check=False)

@ext("install_chrome")
def _(_=None):
    run("wget -q -O- https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor -o /usr/share/keyrings/google-chrome.gpg", show=False)
    run('echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" | sudo tee /etc/apt/sources.list.d/google-chrome.list > /dev/null', show=False)
    run("apt update && apt install -y google-chrome-stable")

@ext("remove_chrome")
def _(_=None):
    run("apt remove -y google-chrome-stable", check=False)
