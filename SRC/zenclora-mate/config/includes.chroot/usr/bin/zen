def cmd_install(packages):
    if not packages:
        console.print(f"[bold red][-][/] Usage: zen install <package> [package...]")
        sys.exit(1)
    for p in packages:
        if p not in PACKAGES:
            console.print(f"[bold red][-][/] {t('unknown_package')}: {p}")
            sys.exit(1)
    require_root()
    print_banner()
    for p in packages:
        console.print(Panel(f"[bold green]{t('install')}: {p}[/]", border_style="green"))
        info = PACKAGES[p]
        if info.get("type") in ("external", "extrepo"):
            fn = EXTERNAL_INSTALLERS.get(f"install_{p}")
            if fn:
                try:
                    fn()
                except subprocess.CalledProcessError as e:
                    console.print(f"[bold red][-][/] {t('error')}: {e}")
                    continue
            else: console.print(f"[bold red][-][/] {t('no_installer')} {p}")
        else:
            install_pack(p)
        console.print(f"[bold green][+] {t('installation_success')}[/]\n")

def cmd_remove(packages):
    if not packages:
        console.print(f"[bold red][-][/] Usage: zen remove <package> [package...]")
        sys.exit(1)
    for p in packages:
        if p not in PACKAGES:
            console.print(f"[bold red][-][/] {t('unknown_package')}: {p}")
            sys.exit(1)
    require_root()
    print_banner()
    for p in packages:
        console.print(Panel(f"[bold red]{t('remove')}: {p}[/]", border_style="red"))
        info = PACKAGES[p]
        if info.get("type") in ("external", "extrepo"):
            fn = EXTERNAL_INSTALLERS.get(f"remove_{p}")
            if fn: fn()
        else:
            remove_pack(p)
        console.print(f"[bold green][+] {t('removal_success')}[/]\n")
    run("apt autoremove -y", show=False)

def cmd_update():
    require_root()
    print_banner()
    console.print(Panel(f"[bold blue]{t('updating_system')}[/]", border_style="blue"))
    steps = [
        (t("update_repos"), "apt update"),
        (t("upgrade_pkgs"), "apt upgrade -y"),
        (t("full_upgrade"), "apt full-upgrade -y"),
        (t("update_cleanup"), "apt autoremove -y && apt autoclean -y"),
    ]
    for i, (desc, cmd) in enumerate(steps, 1):
        console.print(f"\n  [bold cyan][{i}/{len(steps)}][/] {desc}")
        run(cmd)
    if shutil.which("flatpak"):
        console.print(f"\n  [bold cyan][+][/] {t('flatpak_update')}")
        run("flatpak update -y", check=False)
    if shutil.which("snap"):
        console.print(f"\n  [bold cyan][+][/] {t('snap_refresh')}")
        run("snap refresh", check=False)
    console.print(f"\n[bold green][+] {t('success')}![/]\n")

def cmd_list():
    print_banner()
    console.print()
    categories = {}
    for name, info in PACKAGES.items():
        cat = info["cat"]
        categories.setdefault(cat, []).append(name)

    tbl = Table(title=t("available_packages"), box=box.ROUNDED, border_style="bright_magenta",
                show_lines=True, title_style="bold magenta")
    tbl.add_column(t("category"), style="bold yellow", min_width=14)
    tbl.add_column(t("packages"), style="white")
    tbl.add_column(t("info"), style="dim")

    for cat, pkgs in categories.items():
        pkg_list = ", ".join(pkgs)
        details: str = ""
        pkg_type = PACKAGES[pkgs[0]].get("type", "") if pkgs else ""
        for p in pkgs:
            if "pkgs" in PACKAGES[p]:
                details += f"[dim]{p}: {PACKAGES[p]['pkgs']}[/]\n"
        if details:
            info_text = "[dim]apt repo[/]"
        elif pkg_type == "extrepo":
            info_text = "[dim]external-repo[/]"
        else:
            info_text = "[dim]external-repo[/]"
        tbl.add_row(t("cat_" + cat), pkg_list, info_text)
    console.print(tbl)
    console.print()

def cmd_system(args):
    if not args:
        console.print(Panel(f"[bold cyan]{t('sys_utilities')}[/]", border_style="cyan", box=box.DOUBLE))
        cmds = {
            "dns": t("sys_dns"), "zram": t("sys_zram"),
            "net": t("sys_net"), "cleanup": t("sys_cleanup"),
            "optimize": t("sys_optimize"), "mitigations": t("sys_mitigations"),
            "info": t("sys_info"), "services": t("sys_services"),
            "packages": t("sys_packages"), "logs": t("sys_logs"),
            "netfix": t("sys_netfix"), "aptfix": t("sys_aptfix"),
            "hostname": t("sys_hostname"),
        }
        tbl = Table(box=box.ROUNDED, border_style="cyan")
        tbl.add_column(t("command"), style="bold green")
        tbl.add_column(t("description"), style="white")
        for cmd, desc in cmds.items():
            tbl.add_row(cmd, desc)
        console.print(tbl)
        console.print(f"\n  [dim]{t('usage')}: zen system <command>[/]\n")
        return

    action = args[0]
    if action == "dns":
        system_dns()
    elif action == "cleanup":
        require_root()
        console.print(Panel(f"[bold cyan]{t('system_cleanup')}[/]", border_style="cyan"))
        for step, cmd in [("1/5","apt-get autoremove -y"),("2/5","apt-get autoclean -y"),("3/5","apt-get clean"),("4/5","journalctl --vacuum-time=2d"),("5/5","sync")]:
            console.print(f"  [cyan][{step}][/] {cmd.split()[0]}")
            run(cmd, check=False)
        console.print(f"\n[bold green][+] {t('cleanup_complete')}[/]\n")
    elif action == "optimize":
        require_root()
        console.print(Panel(f"[bold cyan]{t('system_optimize')}[/]", border_style="cyan"))
        steps = [
            ("1/6", "Syncing filesystem...", "sync"),
            ("2/6", "Clearing memory caches...", "echo 3 > /proc/sys/vm/drop_caches"),
            ("3/6", "Clearing temporary files...", "rm -rf /tmp/* /var/tmp/*"),
            ("4/6", "Clearing thumbnail caches...", "find /home -path '*/.cache/thumbnails/*' -delete 2>/dev/null"),
            ("5/6", "Flushing network buffers...", "ip -s -s neigh flush all"),
            ("6/6", "Running TRIM on SSDs...", "fstrim -av"),
        ]
        for step, desc, cmd in steps:
            console.print(f"  [cyan][{step}][/] {desc}")
            run(cmd, check=False)
        console.print(f"\n[bold green][+] {t('success')}![/]\n")
        run("free -h", check=False)
    elif action == "info":
        system_info()
    elif action == "net":
        system_net()
    elif action == "mitigations":
        system_mitigations()
    elif action == "services":
        system_services()
    elif action == "packages":
        system_packages()
    elif action == "logs":
        system_logs()
    elif action == "netfix":
        require_root()
        console.print(Panel(f"[bold red]{t('network_reset')}[/]", border_style="red"))
        if not Confirm.ask(f"[yellow]{t('network_reset_confirm')}[/]"):
            return
        steps = [
            ("1/6", "Flushing iptables...", ["iptables -F","iptables -X","iptables -t nat -F","iptables -t nat -X","iptables -P INPUT ACCEPT","iptables -P FORWARD ACCEPT","iptables -P OUTPUT ACCEPT"]),
            ("2/6", "Resetting nftables...", ["nft flush ruleset"]),
            ("3/6", "Clearing DNS cache...", ["systemctl restart systemd-resolved","resolvectl flush-caches"]),
            ("4/6", "Unlocking resolv.conf...", ["chattr -i /etc/resolv.conf","rm -f /etc/NetworkManager/conf.d/99-zen-dns.conf"]),
            ("5/6", "Flushing routing cache...", ["ip route flush cache","ip -s -s neigh flush all"]),
            ("6/6", "Restarting network...", ["systemctl restart NetworkManager","systemctl restart networking"]),
        ]
        for step, desc, cmds_list in steps:
            console.print(f"  [cyan][{step}][/] {desc}")
            for cmd in cmds_list:
                run(cmd, check=False)
        console.print(f"\n[bold green][+] {t('network_reset_complete')}[/]\n")
    elif action == "aptfix":
        require_root()
        console.print(Panel(f"[bold yellow]{t('apt_repair')}[/]", border_style="yellow"))
        steps = [
            ("1/6", "Checking for package locks...", "fuser /var/lib/dpkg/lock-frontend 2>/dev/null && killall apt apt-get dpkg 2>/dev/null; rm -f /var/lib/dpkg/lock-frontend /var/lib/apt/lists/lock /var/cache/apt/archives/lock /var/lib/dpkg/lock"),
            ("2/6", "Checking broken packages...", "dpkg --audit"),
            ("3/6", "Configuring pending packages...", "dpkg --configure -a"),
            ("4/6", "Fixing broken installs...", "apt-get install -f -y"),
            ("5/6", "Cleaning package cache...", "apt-get clean && apt-get autoclean"),
            ("6/6", "Updating package lists...", "apt-get update --fix-missing"),
        ]
        for step, desc, cmd in steps:
            console.print(f"  [cyan][{step}][/] {desc}")
            run(cmd, check=False)
        console.print(f"\n[bold green][+] {t('success')}![/]\n")
    elif action == "zram":
        system_zram()
    elif action == "hostname":
        system_hostname()
    else:
        console.print(f"[bold red][-][/] {t('unknown_action')}: {action}")

def system_dns():
    require_root()
    console.print(Panel(f"[bold cyan]{t('dns_config')}[/]", border_style="cyan"))
    dns_opts = [("Google","8.8.8.8","8.8.4.4"),("Cloudflare","1.1.1.1","1.0.0.1"),("Quad9","9.9.9.9","149.112.112.112"),
                ("AdGuard","94.140.14.14","94.140.15.15"),("OpenDNS","208.67.222.222","208.67.220.220")]
    for i,(name,d1,d2) in enumerate(dns_opts,1):
        console.print(f"  [bold yellow]{i}.[/] {name} ({d1})")

    console.print(f"  [bold yellow]{len(dns_opts)+1}.[/] Restore Backup / Reset")

    choice = IntPrompt.ask("\n[cyan]Select Option[/]", default=1)

    if 1 <= choice <= len(dns_opts):
        name,d1,d2 = dns_opts[choice-1]
        run("chattr -i /etc/resolv.conf", check=False)
        run("mkdir -p /etc/NetworkManager/conf.d")
        run("""cat > /etc/NetworkManager/conf.d/99-zen-dns.conf <<'EOF'\n[main]\ndns=none\nEOF""")
        run(f'echo -e "nameserver {d1}\\nnameserver {d2}" > /etc/resolv.conf')
        run("chattr +i /etc/resolv.conf", check=False)
        run("systemctl restart NetworkManager", check=False)
        console.print(f"\n[bold green][+] DNS set to {name}![/]\n")
    elif choice == len(dns_opts)+1:
        run("chattr -i /etc/resolv.conf", check=False)
        run("rm -f /etc/NetworkManager/conf.d/99-zen-dns.conf", check=False)
        run("systemctl restart NetworkManager", check=False)
        console.print(f"\n[bold green][+] DNS Reset to Default / NetworkManager![/]\n")

def system_zram():
    console.print(Panel(f"[bold cyan]{t('zram_manager')}[/]", border_style="cyan"))
    opts = ["Install ZRAM","Enable","Disable","Status","About"]
    for i,o in enumerate(opts,1):
        console.print(f"  [bold yellow]{i}.[/] {o}")
    choice = IntPrompt.ask("[cyan]Select[/]", default=1)
    if choice == 1:
        require_root(); run("apt update && apt install -y zram-tools")
    elif choice == 2:
        require_root(); run("systemctl enable zramswap && systemctl start zramswap")
        console.print("[bold green][+] ZRAM enabled![/]")
    elif choice == 3:
        require_root(); run("systemctl stop zramswap && systemctl disable zramswap")
        console.print("[bold green][+] ZRAM disabled![/]")
    elif choice == 4:
        r = run_quiet("systemctl is-active zramswap")
        if r.stdout.strip() == "active":
            console.print("[bold green][+] ZRAM is ACTIVE[/]")
            run("zramctl", check=False)
        else:
            console.print("[bold yellow][!] ZRAM is INACTIVE[/]")
    elif choice == 5:
        console.print("\n  ZRAM creates a compressed block device in RAM for swap.")
        console.print("  Benefits:")
        console.print("    - Faster than disk-based swap")
        console.print("    - Extends SSD lifespan by reducing writes")
        console.print("    - Effective memory compression\n")

def system_info():
    console.print(Panel(f"[bold cyan]{t('system_info')}[/]", border_style="cyan", box=box.DOUBLE))
    sections = {
        "OPERATING SYSTEM": {
            "Distro": "cat /etc/os-release | grep PRETTY_NAME | cut -d'\"' -f2",
            "Kernel": "uname -r", "Architecture": "uname -m",
            "Hostname": "hostname", "Uptime": "uptime -p",
        },
        "CPU": {
            "Model": "grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2",
            "Cores": "nproc",
            "Threads": "grep -c processor /proc/cpuinfo",
            "Governor": "cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo N/A",
            "Load Avg": "cat /proc/loadavg | awk '{print $1, $2, $3}'",
        },
        "MEMORY": {
            "RAM": "free -h | awk '/Mem:/{print $2\" total, \"$3\" used, \"$7\" avail\"}'" ,
            "Swap": "free -h | awk '/Swap:/{print $2\" total, \"$3\" used\"}'" ,
        },
        "STORAGE": {
            "Root": "df -h / | awk 'NR>1{print $2\" total, \"$3\" used (\"$5\"), \"$4\" free\"}'" ,
        },
        "NETWORK": {
            "Interfaces": "ip -4 -br addr show | grep -v lo | awk '{print $1, $3}'",
            "Gateway": "ip route | grep default | awk '{print $3}'",
            "DNS": "grep nameserver /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}'",
        },
        "SECURITY": {
            "Firewall": "systemctl is-active ufw 2>/dev/null || systemctl is-active firewalld 2>/dev/null || echo inactive",
            "AppArmor": "systemctl is-active apparmor 2>/dev/null || echo inactive",
        },
    }
    for section, cmds in sections.items():
        tbl = Table(title=section, box=box.ROUNDED, border_style="cyan", title_style="bold yellow")
        tbl.add_column("", style="bold white", min_width=14)
        tbl.add_column("", style="white")
        for label, cmd in cmds.items():
            r = run_quiet(cmd)
            tbl.add_row(label, r.stdout.strip())
        console.print(tbl)
        console.print()

def system_net():
    console.print(Panel(f"[bold cyan]{t('network_info')}[/]", border_style="cyan"))
    console.print("  [bold yellow]Local Interfaces[/]")
    run("ip -4 -br addr show | awk '{printf \"    %-15s %s\\n\", $1, $3}'", check=False)
    console.print("\n  [bold yellow]Gateway[/]")
    run("ip route | grep default | awk '{printf \"    %s via %s\\n\", $3, $5}'", check=False)
    console.print("\n  [bold yellow]DNS Servers[/]")
    run("grep nameserver /etc/resolv.conf 2>/dev/null | awk '{print \"    \" $0}'", check=False)
    console.print("\n  [bold yellow]Network Stats[/]")
    run("echo \"    Active Connections: $(ss -tun 2>/dev/null | grep -c ESTAB || echo 0)\"", check=False)
    run("echo \"    Listening Ports: $(ss -tln 2>/dev/null | grep -c LISTEN || echo 0)\"", check=False)
    console.print()

def system_mitigations():
    require_root()
    r = run_quiet("grep -q 'boot=live' /proc/cmdline 2>/dev/null")
    if r.returncode == 0:
        console.print(Panel("[bold red]Cannot configure mitigations in Live Mode![/]", border_style="red"))
        return
    console.print(Panel(f"[bold cyan]{t('cpu_mitigations')}[/]", border_style="cyan"))
    r = run_quiet("grep -q 'mitigations=off' /proc/cmdline")
    if r.returncode == 0:
        console.print("  Status: [bold yellow]OFF (Performance)[/]")
    else:
        console.print("  Status: [bold green]AUTO (Default)[/]")
    console.print("\n  [bold yellow][!][/] Disabling mitigations improves performance but reduces security.\n")
    console.print("  [bold yellow]1.[/] Enable (Auto)")
    console.print("  [bold yellow]2.[/] Disable (Performance)")
    choice = IntPrompt.ask("\n[cyan]Select[/]", default=1)
    grub_d = "/etc/default/grub.d/10-mitigations.cfg"
    if choice == 1:
        run("mkdir -p /etc/default/grub.d")
        run(f"""cat > {grub_d} <<'EOF'
EOF""")
        run("sed -i 's/ *mitigations=[a-z]*//g' /etc/default/grub", check=False)
        run("update-grub")
        console.print("\n[bold green][+] Mitigations set to AUTO. Reboot required![/]\n")
    elif choice == 2:
        run("mkdir -p /etc/default/grub.d")
        run(f"""cat > {grub_d} <<'EOF'
GRUB_CMDLINE_LINUX_DEFAULT="$GRUB_CMDLINE_LINUX_DEFAULT mitigations=off"
EOF""")
        run("sed -i 's/ *mitigations=[a-z]*//g' /etc/default/grub", check=False)
        run("update-grub")
        console.print("\n[bold yellow][!] Mitigations DISABLED. Reboot required![/]\n")

def system_services():
    console.print(Panel(f"[bold cyan]{t('service_manager')}[/]", border_style="cyan"))
    svc = Prompt.ask("[cyan]Enter service name (e.g. nginx, docker)[/]")
    if not svc:
        console.print("[bold red][-] No service name provided.[/]"); return
    r = run_quiet(f"systemctl cat {svc}")
    if r.returncode != 0:
        console.print(f"[bold red][-] Service '{svc}' not found.[/]"); return
    status = run_quiet(f"systemctl is-active {svc}").stdout.strip()
    enabled = run_quiet(f"systemctl is-enabled {svc}").stdout.strip()
    console.print(f"\n  [bold]Service:[/] {svc}")
    console.print(f"  [bold]Status:[/] {status}")
    console.print(f"  [bold]Enabled:[/] {enabled}\n")
    actions = ["Start","Stop","Restart","Enable","Disable","Mask","Unmask","Status (detailed)","View Logs"]
    for i,a in enumerate(actions,1):
        console.print(f"  [bold yellow]{i}.[/] {a}")
    choice = IntPrompt.ask("\n[cyan]Select action[/]", default=1)
    action_map = {1:"start",2:"stop",3:"restart",4:"enable",5:"disable",6:"mask",7:"unmask"}
    if choice in action_map:
        require_root()
        run(f"systemctl {action_map[choice]} {svc}")
        console.print(f"[bold green][+] Service {svc} {action_map[choice]}ed![/]")
    elif choice == 8:
        run(f"systemctl status {svc} --no-pager", check=False)
    elif choice == 9:
        run(f"journalctl -u {svc} -n 50 --no-pager", check=False)

