    run('echo "deb [signed-by=/usr/share/keyrings/mullvad-keyring.asc arch=$(dpkg --print-architecture)] https://repository.mullvad.net/deb/stable stable main" | sudo tee /etc/apt/sources.list.d/mullvad.list > /dev/null', show=False)
    run("apt update && apt install -y mullvad-vpn")

@ext("remove_mullvad-vpn")
def _(_=None):
    run("apt remove -y mullvad-vpn", check=False)
    r = run_quiet("dpkg -l | grep '^ii  mullvad-browser'")
    if r.returncode != 0:
        run("rm -f /etc/apt/sources.list.d/mullvad.list /usr/share/keyrings/mullvad-keyring.asc")
        run("apt update", check=False)

