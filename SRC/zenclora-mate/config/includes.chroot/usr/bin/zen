    tbl = Table(title=t("commands"), box=box.ROUNDED, border_style="bright_magenta", title_style="bold magenta")
    tbl.add_column(t("command"), style="bold green", min_width=30)
    tbl.add_column(t("description"), style="white")
    cmds = [
        ("zen install <packages...>", t("help_install")),
        ("zen remove <packages...>", t("help_remove")),
        ("zen update", t("help_update")),
        ("zen list", t("help_list")),
        ("zen system <action>", t("help_system")),
        ("zen tools <tool>", t("help_tools")),
        ("zen security/sec <tool>", t("help_security")),
        ("zen ai <tool>", t("help_ai")),
        ("zen zenthub", t("help_zenthub")),
        ("zen zpt <action>", "APT frontend"),
        ("zen settings", t("help_settings")),
        ("zen help", t("help_help")),
    ]
    for cmd, desc in cmds:
        tbl.add_row(cmd, desc)
    console.print(tbl)
    console.print()

def _zpt_banner():
    banner = """
 ███████╗██████╗ ████████╗
 ╚══███╔╝██╔══██╗╚══██╔══╝
   ███╔╝ ██████╔╝   ██║
  ███╔╝  ██╔═══╝    ██║
 ███████╗██║        ██║
 ╚══════╝╚═╝        ╚═╝"""
    console.print(Panel(
        Align.center(Text(banner, style="bold magenta") + Text("\n\nZPT - APT Frontend", style="bold white")),
        border_style="bright_magenta", box=box.DOUBLE
    ))

def _zpt_search(query):
    _zpt_banner()
    console.print(Panel(f"[bold cyan]Searching: {query}[/]", border_style="cyan"))
    result = subprocess.run(f"apt-cache search {query}", shell=True, capture_output=True, text=True)
    if result.returncode != 0 or not result.stdout.strip():
        console.print(f"[bold yellow][!] No results found for '{query}'[/]")
        return
    lines = result.stdout.strip().split("\n")
    table = Table(title=f"Search Results: '{query}' ({len(lines)} found)", box=box.ROUNDED,
                  border_style="cyan", title_style="bold cyan", show_lines=False)
    table.add_column("#", style="bold yellow", width=5)
    table.add_column("Package", style="bold green", min_width=20)
    table.add_column("Description", style="white")
    display = lines[:50]
    for i, line in enumerate(display, 1):
        parts = line.split(" - ", 1)
        pkg = parts[0].strip()
        desc = parts[1].strip() if len(parts) > 1 else ""
        table.add_row(str(i), pkg, desc)
    console.print(table)
    if len(lines) > 50:
        console.print(f"\n  [dim]Showing 50 of {len(lines)} results.[/]")
    console.print()
    choice = Prompt.ask("\n[bold cyan]Enter # to install or 'q' to quit[/]", default="q").strip()
    if choice.isdigit() and 1 <= int(choice) <= len(display):
        pkg_name = display[int(choice) - 1].split(" - ", 1)[0].strip()
        if Confirm.ask(f"[cyan]Install {pkg_name}?[/]"):
            require_root()
            run(f"apt install -y {pkg_name}")
            console.print(f"[bold green][+] {t('installation_success')}[/]")

def _zpt_install(packages):
    if not packages:
        _zpt_banner()
        console.print("[bold red][-] Usage: zpt install <package> [package...][/]")
        sys.exit(1)
    require_root()
    _zpt_banner()
    pkg_str = " ".join(packages)
    console.print(Panel(f"[bold green]Installing: {pkg_str}[/]", border_style="green"))
    run("apt update", show=False, check=False)
    run(f"apt install -y {pkg_str}")
    console.print(f"\n[bold green][+] {t('installation_success')}[/]\n")

def _zpt_remove(packages):
    if not packages:
        _zpt_banner()
        console.print("[bold red][-] Usage: zpt remove <package> [package...][/]")
        sys.exit(1)
    require_root()
    _zpt_banner()
    pkg_str = " ".join(packages)
    console.print(Panel(f"[bold red]Removing: {pkg_str}[/]", border_style="red"))
    run(f"apt remove -y {pkg_str}")
    run("apt autoremove -y", show=False)
    console.print(f"\n[bold green][+] {t('removal_success')}[/]\n")

def _zpt_help():
    _zpt_banner()
    console.print()
    tbl = Table(box=box.ROUNDED, border_style="bright_magenta", title_style="bold magenta")
    tbl.add_column("Command", style="bold green", min_width=30)
    tbl.add_column("Description", style="white")
    tbl.add_row("zpt install <packages...>", "Install packages via APT")
    tbl.add_row("zpt remove <packages...>", "Remove packages via APT")
    tbl.add_row("zpt search <query>", "Search APT repositories")
    tbl.add_row("zpt help", "Show this help")
    console.print(tbl)
    console.print()

def cmd_zpt(args):
    if not args:
        _zpt_help()
        return
    action = args[0]
    rest = args[1:]
    if action == "install":
        _zpt_install(rest)
    elif action in ("remove", "uninstall"):
        _zpt_remove(rest)
    elif action == "search":
        if not rest:
            _zpt_banner()
            query = Prompt.ask("[bold cyan]Search query[/]")
            if query:
                _zpt_search(query)
        else:
            _zpt_search(" ".join(rest))
    elif action in ("help", "--help", "-h"):
        _zpt_help()
    else:
        console.print(f"[bold red][-] Unknown zpt command: {action}[/]")
        _zpt_help()

class ZenApp:
    def run(self, args):
        first_run_setup()
        if not args:
            cmd_help(); return
        cmd = args[0]
        rest = args[1:]
        cmds = {
            "install": lambda: cmd_install(rest),
            "remove": lambda: cmd_remove(rest),
            "uninstall": lambda: cmd_remove(rest),
            "update": cmd_update,
            "upgrade": cmd_update,
            "list": cmd_list,
            "ls": cmd_list,
            "system": lambda: cmd_system(rest),
            "sys": lambda: cmd_system(rest),
            "tools": lambda: cmd_tools(rest),
            "tool": lambda: cmd_tools(rest),
            "security": lambda: cmd_security(rest),
            "sec": lambda: cmd_security(rest),
            "ai": lambda: cmd_ai(rest),
            "zpt": lambda: cmd_zpt(rest),
            "zenthub": cmd_zenthub,
            "hub": cmd_zenthub,
            "settings": cmd_settings,
            "help": cmd_help,
            "--help": cmd_help,
            "-h": cmd_help,
            "version": lambda: console.print(f"Zen Package Manager v{ZEN_VERSION}"),
            "--version": lambda: console.print(f"Zen Package Manager v{ZEN_VERSION}"),
            "-v": lambda: console.print(f"Zen Package Manager v{ZEN_VERSION}"),
        }
        fn = cmds.get(cmd)
        if fn:
            fn() if callable(fn) else None
        else:
            console.print(f"[bold red][-][/] {t('unknown_command')}: {cmd}")
            console.print("[dim]Run 'zen help' for usage information.[/]")
            sys.exit(1)

if __name__ == "__main__":
    import sys
    script_name = os.path.basename(sys.argv[0]).replace(".py", "")
    if script_name == "zpt":
        cmd_zpt(sys.argv[1:])
    else:
        app = ZenApp()
        app.run(sys.argv[1:])
