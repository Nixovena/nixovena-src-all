#!/usr/bin/env python3

import json
import sys
import os
import termios
import tty
import argparse
from datetime import datetime
from pathlib import Path

from rich.console import Console
from rich.table import Table
from rich.panel import Panel
from rich.prompt import Prompt, Confirm
from rich.text import Text
from rich.align import Align
from rich.live import Live
from rich.layout import Layout
from rich import box
from rich.theme import Theme
from rich.rule import Rule
from rich.padding import Padding

NOTES_FILE = Path.home() / ".notes_data.json"

CUSTOM_THEME = Theme({
    "info":       "cyan",
    "success":    "bold green",
    "warning":    "yellow",
    "error":      "bold red",
    "title":      "bold magenta",
    "tag":        "bold cyan",
    "note_id":    "bold yellow",
    "timestamp":  "dim cyan",
    "selected":   "bold black on cyan",
    "header":     "bold white on dark_magenta",
    "footer":     "dim white",
    "key":        "bold cyan",
    "muted":      "dim white",
})

console = Console(theme=CUSTOM_THEME)


def load_notes() -> list:
    if not NOTES_FILE.exists():
        return []
    with open(NOTES_FILE, "r", encoding="utf-8") as f:
        return json.load(f)


def save_notes(notes: list) -> None:
    with open(NOTES_FILE, "w", encoding="utf-8") as f:
        json.dump(notes, f, ensure_ascii=False, indent=2)


def get_next_id(notes: list) -> int:
    if not notes:
        return 1
    return max(n["id"] for n in notes) + 1


def format_ts(ts: str) -> str:
    return datetime.fromisoformat(ts).strftime("%Y-%m-%d %H:%M")


def read_key() -> str:
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)
        if ch == "\x1b":
            ch2 = sys.stdin.read(1)
            ch3 = sys.stdin.read(1)
            return ch + ch2 + ch3
        return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def clear():
    os.system("clear")


def draw_header(title: str = "  Notes"):
    console.print(Panel(
        Align.center(f"[bold white]{title}[/bold white]"),
        border_style="magenta",
        box=box.HEAVY,
        padding=(0, 2),
    ))


def draw_footer(hints: list[tuple[str, str]]):
    parts = "   ".join(f"[key]{k}[/key] [muted]{v}[/muted]" for k, v in hints)
    console.print(Rule(style="dim magenta"))
    console.print(Align.center(parts))


def input_multiline(prompt_text: str, default: str = "") -> str:
    if default:
        console.print(f"[muted]Current:[/muted]\n{default}\n")
    console.print(f"[cyan]{prompt_text}:[/cyan] [muted](Alt+Enter to finish)[/muted]")

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)

    lines = []
    current_line = []

    try:
        tty.setraw(fd)
        while True:
            ch = sys.stdin.read(1)

            if ch == "\x1b":
                next_ch = sys.stdin.read(1)
                if next_ch == "\r" or next_ch == "\n":
                    lines.append("".join(current_line))
                    break
                elif next_ch == "[":
                    sys.stdin.read(1)
                else:
                    current_line.append(ch)
                    current_line.append(next_ch)
            elif ch in ("\r", "\n"):
                lines.append("".join(current_line))
                current_line = []
                sys.stdout.write("\r\n")
                sys.stdout.flush()
            elif ch in ("\x7f", "\x08"):
                if current_line:
                    current_line.pop()
                    sys.stdout.write("\b \b")
                    sys.stdout.flush()
            elif ch == "\x03":
                raise KeyboardInterrupt
            elif ch == "\x04":
                lines.append("".join(current_line))
                break
            else:
                current_line.append(ch)
                sys.stdout.write(ch)
                sys.stdout.flush()
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)

    while lines and lines[-1] == "":
        lines.pop()
    result = "\n".join(lines)
    return result if result else default


def screen_add_note():
    clear()
    draw_header("  Add Note")
    console.print()

    title = Prompt.ask("[cyan]Title[/cyan]")
    if not title.strip():
        console.print("[error]Title cannot be empty.[/error]")
        console.input("\n[muted]Press Enter to go back...[/muted]")
        return

    content = input_multiline("Content")

    raw_tags = Prompt.ask("[cyan]Tags[/cyan] [muted](comma-separated, optional)[/muted]", default="")
    tags = [t.strip() for t in raw_tags.split(",") if t.strip()]

    notes = load_notes()
    note = {
        "id": get_next_id(notes),
        "title": title.strip(),
        "content": content,
        "tags": tags,
        "created_at": datetime.now().isoformat(),
        "updated_at": datetime.now().isoformat(),
    }
    notes.append(note)
    save_notes(notes)

    console.print()
    console.print(Panel(
        f"[success]✓ Note saved![/success]  [note_id]#{note['id']}[/note_id] [bold]{note['title']}[/bold]",
        border_style="green", box=box.ROUNDED,
    ))
    console.input("\n[muted]Press Enter to continue...[/muted]")


def screen_manage_tags(note: dict):
    while True:
        clear()
        draw_header(f"  Tags — Note #{note['id']}")
        console.print()
        console.print(f"[bold white]{note['title']}[/bold white]\n")

        tags = note.get("tags", [])

        if tags:
            table = Table(box=box.SIMPLE, show_header=False, padding=(0, 1))
            table.add_column("idx", style="note_id", width=4, justify="right")
            table.add_column("tag", style="tag")
            for i, t in enumerate(tags):
                table.add_row(str(i + 1), f"#{t}")
            console.print(table)
        else:
            console.print("[muted]No tags yet.[/muted]")

        console.print()
        draw_footer([("A", "Add tag"), ("D+num", "Delete (e.g. D1)"), ("Q / ←", "Back")])
        console.print()

        k = read_key()

        if k.lower() in ("q", "\x1b[d"):
            break
        elif k.lower() == "a":
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, termios.tcgetattr(sys.stdin.fileno()))
            console.print()
            new_tag = Prompt.ask("[cyan]New tag[/cyan]").strip()
            if new_tag and new_tag not in tags:
                tags.append(new_tag)
                note["tags"] = tags
                note["updated_at"] = datetime.now().isoformat()
                notes = load_notes()
                for i, n in enumerate(notes):
                    if n["id"] == note["id"]:
                        notes[i] = note
                        break
                save_notes(notes)
                console.print(f"[success]✓ Tag #{new_tag} added.[/success]")
        elif k.lower() == "d":
            if not tags:
                continue
            fd = sys.stdin.fileno()
            old = termios.tcgetattr(fd)
            try:
                tty.setraw(fd)
                num_ch = sys.stdin.read(1)
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
            if num_ch.isdigit():
                idx = int(num_ch) - 1
                if 0 <= idx < len(tags):
                    removed = tags.pop(idx)
                    note["tags"] = tags
                    note["updated_at"] = datetime.now().isoformat()
                    notes = load_notes()
                    for i, n in enumerate(notes):
                        if n["id"] == note["id"]:
                            notes[i] = note
                            break
                    save_notes(notes)
                    console.print(f"\n[success]✓ Tag #{removed} removed.[/success]")


def screen_view_note(note: dict):
    clear()
    draw_header(f"  Note #{note['id']}")
    console.print()

    meta = Text()
    meta.append(f"#{note['id']}  ", style="note_id")
    meta.append(note["title"], style="bold white")
    tags = note.get("tags", [])
    if tags:
        meta.append("  ")
        for t in tags:
            meta.append(f"#{t} ", style="tag")
    meta.append(f"\nCreated: {format_ts(note['created_at'])}", style="timestamp")
    if note["created_at"] != note["updated_at"]:
        meta.append(f"  ·  Updated: {format_ts(note['updated_at'])}", style="timestamp")

    console.print(Panel(meta, border_style="magenta", box=box.ROUNDED, padding=(0, 1)))
    console.print(Panel(
        note["content"] or "[muted](empty)[/muted]",
        border_style="dim", box=box.SIMPLE, padding=(1, 2),
    ))

    draw_footer([("E", "Edit"), ("T", "Tags"), ("D", "Delete"), ("Q / ←", "Back")])
    console.print()

    while True:
        k = read_key().lower()
        if k in ("q", "\x1b[d"):
            return None
        if k == "e":
            return "edit"
        if k == "t":
            return "tags"
        if k == "d":
            return "delete"


def screen_edit_note(note: dict):
    clear()
    draw_header(f"  Edit Note #{note['id']}")
    console.print()
    console.print("[muted](Leave blank to keep current value)[/muted]\n")

    new_title = Prompt.ask("[cyan]Title[/cyan]", default=note["title"])
    new_content = input_multiline("Content", default=note["content"])
    current_tags = ", ".join(note.get("tags", []))
    raw_tags = Prompt.ask("[cyan]Tags[/cyan]", default=current_tags)
    new_tags = [t.strip() for t in raw_tags.split(",") if t.strip()] if raw_tags.strip() else []

    note["title"] = new_title or note["title"]
    note["content"] = new_content
    note["tags"] = new_tags
    note["updated_at"] = datetime.now().isoformat()

    notes = load_notes()
    for i, n in enumerate(notes):
        if n["id"] == note["id"]:
            notes[i] = note
            break
    save_notes(notes)

    console.print()
    console.print(f"[success]✓ Note #{note['id']} updated.[/success]")
    console.input("\n[muted]Press Enter to continue...[/muted]")


def screen_delete_note(note: dict) -> bool:
    clear()
    draw_header("  Delete Note")
    console.print()
    console.print(Panel(
        f"[warning]Delete [note_id]#{note['id']}[/note_id]: [bold]{note['title']}[/bold]?[/warning]",
        border_style="red", box=box.ROUNDED,
    ))
    confirmed = Confirm.ask("\n[bold red]Are you sure?[/bold red]", default=False)
    if confirmed:
        notes = load_notes()
        notes = [n for n in notes if n["id"] != note["id"]]
        save_notes(notes)
        console.print(f"\n[success]✓ Deleted.[/success]")
        console.input("\n[muted]Press Enter to continue...[/muted]")
        return True
    console.print("[info]Cancelled.[/info]")
    console.input("\n[muted]Press Enter to continue...[/muted]")
    return False


def screen_search() -> str:
    clear()
    draw_header("  Search")
    console.print()
    query = Prompt.ask("[cyan]Search[/cyan]")
    return query.strip()


def screen_export():
    clear()
    draw_header("  Export Notes")
    console.print()
    output = Prompt.ask("[cyan]Output file path[/cyan]", default="notes_export.txt")
    tag_filter = Prompt.ask("[cyan]Filter by tag[/cyan] [muted](optional)[/muted]", default="")

    notes = load_notes()
    if tag_filter.strip():
        notes = [n for n in notes if tag_filter.strip().lower() in [t.lower() for t in n.get("tags", [])]]

    lines = []
    for note in sorted(notes, key=lambda x: x["created_at"]):
        lines.append(f"# {note['title']}")
        lines.append(f"ID: {note['id']}  |  Created: {format_ts(note['created_at'])}")
        if note.get("tags"):
            lines.append(f"Tags: {', '.join('#' + t for t in note['tags'])}")
        lines.append("")
        lines.append(note["content"])
        lines.append("\n" + "─" * 60 + "\n")

    Path(output).write_text("\n".join(lines), encoding="utf-8")
    console.print()
    console.print(f"[success]✓ Exported {len(notes)} note(s) to [bold]{output}[/bold][/success]")
    console.input("\n[muted]Press Enter to continue...[/muted]")


def screen_tags():
    clear()
    draw_header("  Tags")
    notes = load_notes()
    tag_counts: dict = {}
    for note in notes:
        for t in note.get("tags", []):
            tag_counts[t] = tag_counts.get(t, 0) + 1

    console.print()
    if not tag_counts:
        console.print("[warning]No tags found.[/warning]")
    else:
        table = Table(box=box.ROUNDED, border_style="cyan", header_style="bold cyan", show_lines=True)
        table.add_column("Tag", style="bold cyan")
        table.add_column("Notes", style="note_id", justify="right")
        for t, c in sorted(tag_counts.items(), key=lambda x: x[1], reverse=True):
            table.add_row(f"#{t}", str(c))
        console.print(table)

    draw_footer([("Q / ←", "Back")])
    console.print()
    while True:
        k = read_key().lower()
        if k in ("q", "\x1b[d", "\x1b[c", "\r", " "):
            return


def build_notes_table(notes: list, selected: int, filter_text: str = "") -> Panel:
    table = Table(
        box=box.SIMPLE_HEAD,
        border_style="magenta",
        header_style="bold magenta",
        show_lines=False,
        expand=True,
        padding=(0, 1),
    )
    table.add_column("", width=2, justify="center")
    table.add_column("ID", style="note_id", width=5, justify="center")
    table.add_column("Title", style="bold white", min_width=22)
    table.add_column("Tags", style="tag", min_width=14)
    table.add_column("Preview", style="muted", min_width=28)
    table.add_column("Date", style="timestamp", width=17, justify="right")

    for i, note in enumerate(notes):
        cursor = "▶" if i == selected else " "
        tags_str = " ".join(f"#{t}" for t in note.get("tags", []))
        preview = note["content"].replace("\n", " ")[:50]
        if len(note["content"]) > 50:
            preview += "…"

        row_style = "selected" if i == selected else ""
        table.add_row(
            cursor,
            str(note["id"]),
            note["title"],
            tags_str or "—",
            preview or "—",
            format_ts(note["created_at"]),
            style=row_style,
        )

    count_str = f"{len(notes)} note{'s' if len(notes) != 1 else ''}"
    filter_str = f"  [muted]filter: \"{filter_text}\"[/muted]" if filter_text else ""
    title_str = f"[title]  Notes[/title]  [muted]({count_str})[/muted]{filter_str}"

    return Panel(table, title=title_str, border_style="magenta", box=box.ROUNDED, padding=(0, 0))


def screen_main_menu():
    MAIN_ITEMS = [
        (" All Notes",     "list"),
        (" Add Note",     "add"),
        (" Search",       "search"),
        (" Tags",         "tags"),
        (" Export",       "export"),
        (" Quit",         "quit"),
    ]

    selected = 0

    while True:
        clear()
        console.print()
        console.print(Align.center("[bold magenta]N O T E S[/bold magenta]"))
        console.print(Align.center("[muted]A minimal CLI note manager[/muted]"))
        console.print()

        for i, (label, _) in enumerate(MAIN_ITEMS):
            if i == selected:
                console.print(Align.center(f"[selected]  {label}  [/selected]"))
            else:
                console.print(Align.center(f"[muted]  {label}  [/muted]"))

        console.print()
        draw_footer([("↑↓", "Navigate"), ("Enter", "Select"), ("Q", "Quit")])
        console.print()

        k = read_key()

        if k == "\x1b[A":
            selected = (selected - 1) % len(MAIN_ITEMS)
        elif k == "\x1b[B":
            selected = (selected + 1) % len(MAIN_ITEMS)
        elif k in ("\r", "\n", " "):
            action = MAIN_ITEMS[selected][1]
            if action == "quit":
                return
            elif action == "list":
                screen_notes_list()
            elif action == "add":
                screen_add_note()
            elif action == "search":
                q = screen_search()
                if q:
                    screen_notes_list(filter_text=q)
            elif action == "tags":
                screen_tags()
            elif action == "export":
                screen_export()
        elif k.lower() == "q":
            return


def screen_notes_list(filter_text: str = ""):
    selected = 0

    while True:
        all_notes = load_notes()
        notes = sorted(all_notes, key=lambda x: x["created_at"], reverse=True)

        if filter_text:
            q = filter_text.lower()
            notes = [n for n in notes if q in n["title"].lower() or q in n["content"].lower()
                     or any(q in t.lower() for t in n.get("tags", []))]

        clear()
        console.print()

        if not notes:
            console.print(Panel(
                Align.center("[warning]No notes found.[/warning]"),
                border_style="yellow", box=box.ROUNDED,
            ))
            draw_footer([("A", "Add new"), ("Q / ←", "Back")])
            console.print()
            k = read_key().lower()
            if k in ("q", "\x1b[d"):
                return
            if k == "a":
                screen_add_note()
            continue

        if selected >= len(notes):
            selected = len(notes) - 1

        console.print(build_notes_table(notes, selected, filter_text))
        console.print()
        draw_footer([
            ("↑↓", "Navigate"),
            ("Enter", "View"),
            ("A", "Add"),
            ("/", "Search"),
            ("Q / ←", "Back"),
        ])
        console.print()

        k = read_key()

        if k == "\x1b[A":
            selected = max(0, selected - 1)
        elif k == "\x1b[B":
            selected = min(len(notes) - 1, selected + 1)
        elif k in ("\r", "\n"):
            note = notes[selected]
            while True:
                action = screen_view_note(note)
                if action == "edit":
                    screen_edit_note(note)
                    note = next((n for n in load_notes() if n["id"] == note["id"]), None)
                    if not note:
                        break
                elif action == "tags":
                    screen_manage_tags(note)
                    note = next((n for n in load_notes() if n["id"] == note["id"]), note)
                elif action == "delete":
                    deleted = screen_delete_note(note)
                    if deleted:
                        if selected >= 1:
                            selected -= 1
                        break
                else:
                    break
        elif k.lower() == "a":
            screen_add_note()
        elif k == "/":
            q = screen_search()
            if q:
                screen_notes_list(filter_text=q)
                return
        elif k.lower() in ("q", "\x1b[d"):
            return


def main():
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("command", nargs="?", default=None)
    parser.add_argument("args", nargs="*")
    parsed, _ = parser.parse_known_args()

    if parsed.command is None:
        screen_main_menu()
    elif parsed.command == "list":
        screen_notes_list()
    elif parsed.command == "add":
        screen_add_note()
    elif parsed.command == "search":
        q = " ".join(parsed.args) if parsed.args else screen_search()
        screen_notes_list(filter_text=q)
    elif parsed.command == "tags":
        screen_tags()
    elif parsed.command == "export":
        screen_export()
    else:
        console.print(f"[error]Unknown command: {parsed.command}[/error]")
        sys.exit(1)


if __name__ == "__main__":
    main()