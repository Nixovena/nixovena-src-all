/* =============================================================================
 * Hardenwing OS — Flatpak Polkit Hardening
 * =============================================================================
 * forces Flatpak to ALWAYS ask for administrator authentication (sudo/root) 
 * before installing, updating, or modifying any software. This prevents 
 * unprivileged users or malware from silently installing malicious Flatpak 
 * applications in the background.
 * ============================================================================= */

polkit.addRule(function(action, subject) {
    if (action.id.indexOf("org.freedesktop.Flatpak.") == 0) {
        return polkit.Result.AUTH_ADMIN_KEEP;
    }
});
