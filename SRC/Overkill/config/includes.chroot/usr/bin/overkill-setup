def apply_dark_palette(app: QApplication):
    app.setStyle(QStyleFactory.create("Fusion"))
    pal = QPalette()
    bg = QColor(BG)
    bg_panel = QColor(BG_PANEL)
    bg_input = QColor(BG_INPUT)
    text = QColor(TEXT)
    text_dim = QColor(TEXT_DIM)
    neon = QColor(NEON)
    border = QColor(BORDER)

    pal.setColor(QPalette.ColorRole.Window, bg)
    pal.setColor(QPalette.ColorRole.WindowText, text)
    pal.setColor(QPalette.ColorRole.Base, bg_input)
    pal.setColor(QPalette.ColorRole.AlternateBase, bg_panel)
    pal.setColor(QPalette.ColorRole.ToolTipBase, bg_panel)
    pal.setColor(QPalette.ColorRole.ToolTipText, neon)
    pal.setColor(QPalette.ColorRole.Text, text)
    pal.setColor(QPalette.ColorRole.Button, bg_panel)
    pal.setColor(QPalette.ColorRole.ButtonText, text)
    pal.setColor(QPalette.ColorRole.BrightText, QColor(DANGER))
    pal.setColor(QPalette.ColorRole.Link, neon)
    pal.setColor(QPalette.ColorRole.Highlight, neon)
    pal.setColor(QPalette.ColorRole.HighlightedText, bg)
    pal.setColor(QPalette.ColorRole.PlaceholderText, text_dim)
    pal.setColor(QPalette.ColorRole.Mid, border)
    pal.setColor(QPalette.ColorRole.Dark, bg)
    pal.setColor(QPalette.ColorRole.Light, bg_panel)
    pal.setColor(QPalette.ColorRole.Shadow, bg)

    # Disabled state
    disabled = text_dim
    for role in (
        QPalette.ColorRole.WindowText, QPalette.ColorRole.Text,
        QPalette.ColorRole.ButtonText, QPalette.ColorRole.HighlightedText,
    ):
        pal.setColor(QPalette.ColorGroup.Disabled, role, disabled)

    app.setPalette(pal)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def read_edition_conf():
    path = Path("/usr/share/edition/edition.conf")
    data = {"EDITION": "", "DATE": "", "TUNING": ""}
    if path.is_file():
        try:
            for line in path.read_text().splitlines():
                if "=" in line:
                    k, v = line.split("=", 1)
                    data[k.strip()] = v.strip().strip('"')
        except Exception:
            pass
    return data


def gather_system_info() -> dict:
    info = {}
    # OS
    os_name = "Unknown"
    try:
        with open("/etc/os-release") as f:
            for line in f:
                if line.startswith("PRETTY_NAME="):
                    os_name = line.split("=", 1)[1].strip().strip('"')
                    break
    except Exception:
        pass
    info["OS"] = os_name
    # Kernel
    try:
        info["Kernel"] = subprocess.check_output(["uname", "-r"], text=True).strip()
    except Exception:
        info["Kernel"] = "Unknown"
    # Architecture
    try:
        info["Architecture"] = subprocess.check_output(["uname", "-m"], text=True).strip()
    except Exception:
        info["Architecture"] = "Unknown"
    # Hostname
    try:
        info["Hostname"] = Path("/etc/hostname").read_text().strip()
    except Exception:
        info["Hostname"] = "Unknown"
    # Uptime
    try:
        with open("/proc/uptime") as f:
            up_s = float(f.read().split()[0])
            h, rem = divmod(up_s, 3600)
            m, _ = divmod(rem, 60)
            info["Uptime"] = f"{int(h)}h {int(m)}m"
    except Exception:
        info["Uptime"] = "Unknown"
    # CPU
    cpu = "Unknown"
    try:
        with open("/proc/cpuinfo") as f:
            for line in f:
                if line.startswith("model name"):
                    cpu = line.split(":", 1)[1].strip()
                    break
    except Exception:
        pass
    info["CPU"] = cpu
    # RAM
    try:
        total = avail = 0
        with open("/proc/meminfo") as f:
            for line in f:
                if line.startswith("MemTotal:"):
                    total = int(line.split()[1]) // 1024
                elif line.startswith("MemAvailable:"):
                    avail = int(line.split()[1]) // 1024
        info["RAM"] = f"{avail} MB free / {total} MB total"
    except Exception:
        info["RAM"] = "Unknown"
    # Disk
    try:
        st = os.statvfs("/")
        total = (st.f_blocks * st.f_frsize) / (1024 ** 3)
        free  = (st.f_bavail * st.f_frsize) / (1024 ** 3)
        used  = total - free
        info["Disk (/)"] = f"{used:.1f} GB used / {total:.1f} GB total"
    except Exception:
        info["Disk (/)"] = "Unknown"
    # Session
    info["Session"] = os.environ.get("XDG_SESSION_TYPE", "?") or "?"
    info["Desktop"] = os.environ.get("XDG_CURRENT_DESKTOP", "?") or "?"
    return info


# ---------------------------------------------------------------------------
# Action card widget
# ---------------------------------------------------------------------------
class ActionCard(QFrame):
    triggered = pyqtSignal(object)

    def __init__(self, title, description, button_label, payload, danger=False, primary=True):
        super().__init__()
        self.setObjectName("Card")
        self.payload = payload

        lay = QVBoxLayout(self)
        lay.setContentsMargins(14, 12, 14, 12)
        lay.setSpacing(6)

        t = QLabel(title)
        t.setObjectName("CardTitle")
        t.setWordWrap(True)
        d = QLabel(description)
        d.setObjectName("CardDesc")
        d.setWordWrap(True)

        btn = QPushButton(button_label)
        if danger:
            btn.setObjectName("Danger")
        elif primary:
            btn.setObjectName("Primary")
        btn.clicked.connect(lambda: self.triggered.emit(self.payload))

        lay.addWidget(t)
        lay.addWidget(d)
        lay.addStretch(1)
        lay.addWidget(btn)


