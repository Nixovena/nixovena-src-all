# ==============================================================================
# CORE INSTALL FUNCTIONS
# ==============================================================================

install_packages_and_tuning() {
    local edition_name="$1"
    local apt_list="$2"
    local flat_list="$3"
    local tuning_type="$4"

    # Verify if an edition is already installed
    get_installed_edition
    if [ -n "$CURRENT_EDITION" ]; then
        echo -e "${RED}${BOLD}[BLOCKED] '${CURRENT_EDITION}' is already installed on this system!${NC}"
        echo -e "${YELLOW}Only one edition can be installed at a time. Please uninstall the current edition first.${NC}"
        pause_prompt
        return
    fi

    echo -e "${CYAN}${BOLD}[INSTALL] Beginning installation of ${edition_name}... Please wait.${NC}"
    echo -e "${GOLD}----------------------------------------------------------------------------${NC}"

    # 1. Install APT Packages
    if [ -n "$apt_list" ]; then
        echo -e "${CYAN}[APT] Updating repositories and installing packages...${NC}"
        apt-get update
        apt-get install -y $apt_list
        if [ $? -ne 0 ]; then
            echo -e "${RED}[WARNING] Failed to install some APT packages. Continuing...${NC}"
        else
            echo -e "${GREEN}[APT] Packages installed successfully.${NC}"
        fi
    fi

    # 2. Setup Flatpaks
    if [ -n "$flat_list" ]; then
        prepare_flatpak
        echo -e "${CYAN}[FLATPAK] Installing applications...${NC}"
        for app in $flat_list; do
            echo -e "${CYAN}[FLATPAK] Installing: $app${NC}"
            flatpak install -y flathub $app
        done
        echo -e "${GREEN}[FLATPAK] Applications installed successfully.${NC}"
    fi

    # 3. Apply Tuning Optimizations
    case "$tuning_type" in
        "gaming")
            apply_sysctl_tuning "$GAMING_SYSCTL_TUNING"
            apply_grub_tuning \
                "mitigations=off transparent_hugepage=never nowatchdog split_lock_detect=off threadirqs preempt=full" \
                "" \
                "false"
            ;;
        "hardened-nofw")
            # Hardened profile WITHOUT the nftables firewall (e.g. for
            # cryptocurrency wallets that need full inbound P2P connectivity).
            apply_sysctl_tuning "$HARDENED_SYSCTL_TUNING"
            apply_modprobe_blacklist "$HARDENED_BLACKLISTS"
            apply_grub_tuning \
                "rd.emergency=halt rd.shell=0" \
                "slab_nomerge init_on_alloc=1 init_on_free=1 page_alloc.shuffle=1 pti=on randomize_kstack_offset=on vsyscall=none debugfs=off kfence.sample_interval=100 vdso32=0 cfi=kcfi efi_pstore.pstore_disable=1 erst_disable bdev_allow_write_mounted=0 proc_mem.force_override=never iommu=on iommu.passthrough=0 iommu.strict=0 random.trust_cpu=off random.trust_bootloader=off extra_latent_entropy lockdown=integrity mitigations=full spectre_v2=on spectre_bhi=on kpti=1 spec_store_bypass_disable=on ssbd=force-on l1tf=full mds=full tsx=off tsx_async_abort=full kvm.nx_huge_pages=force l1d_flush=on mmio_stale_data=full retbleed=auto kvm.mitigate_smt_rsb=1 spec_rstack_overflow=ibpb gather_data_sampling=on reg_file_data_sampling=on indirect_target_selection=force vmscape=force" \
                "true"
            ;;
        "hardened")
            apply_sysctl_tuning "$HARDENED_SYSCTL_TUNING"
            apply_modprobe_blacklist "$HARDENED_BLACKLISTS"
            apply_nftables "$HARDENED_NFTABLES"
            apply_grub_tuning \
                "rd.emergency=halt rd.shell=0" \
                "slab_nomerge init_on_alloc=1 init_on_free=1 page_alloc.shuffle=1 pti=on randomize_kstack_offset=on vsyscall=none debugfs=off kfence.sample_interval=100 vdso32=0 cfi=kcfi efi_pstore.pstore_disable=1 erst_disable bdev_allow_write_mounted=0 proc_mem.force_override=never iommu=on iommu.passthrough=0 iommu.strict=0 random.trust_cpu=off random.trust_bootloader=off extra_latent_entropy lockdown=integrity mitigations=full spectre_v2=on spectre_bhi=on kpti=1 spec_store_bypass_disable=on ssbd=force-on l1tf=full mds=full tsx=off tsx_async_abort=full kvm.nx_huge_pages=force l1d_flush=on mmio_stale_data=full retbleed=auto kvm.mitigate_smt_rsb=1 spec_rstack_overflow=ibpb gather_data_sampling=on reg_file_data_sampling=on indirect_target_selection=force vmscape=force" \
                "true"
            ;;
        "multimedia")
            apply_sysctl_tuning "$MULTIMEDIA_SYSCTL_TUNING"
            apply_grub_tuning \
                "mitigations=auto transparent_hugepage=madvise nowatchdog threadirqs preempt=full" \
                "" \
                "false"
            ;;
        "ai")
            apply_sysctl_tuning "$AI_SYSCTL_TUNING"
            apply_grub_tuning \
                "mitigations=auto transparent_hugepage=always nowatchdog numa_balancing=disable" \
                "" \
                "false"
            ;;
        "none")
            echo -e "${YELLOW}[TUNING] No system optimizations are required for this edition.${NC}"
            ;;
    esac

    # 4. Save Installation Log
    save_edition_info "$edition_name" "$tuning_type"

    echo -e "${GREEN}${BOLD}SUCCESS: ${edition_name} and related optimizations applied successfully!${NC}"
    echo -e "${YELLOW}${BOLD}NOTICE: Please reboot your system to fully apply all changes.${NC}"
    pause_prompt
}

# ==============================================================================
# SYSTEM MANAGEMENT OPTIONS
# ==============================================================================

# Option 14: System Update
sys_update() {
    echo -e "${CYAN}[SYSTEM UPDATE] Updating package databases and upgrading packages...${NC}"
    apt-get update
    apt-get dist-upgrade -y
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}[SYSTEM UPDATE] System successfully upgraded.${NC}"
    else
        echo -e "${RED}[ERROR] Failed to upgrade the system.${NC}"
    fi
    pause_prompt
}

# Option 15: Install Package
pkg_install() {
    echo -e "${CYAN}[INSTALL PACKAGE] Enter package name(s) to install:${NC}"
    read -p "Package name(s): " pkgs
    if [ -z "$pkgs" ]; then
        echo -e "${YELLOW}[WARNING] No package name entered.${NC}"
    else
        apt-get install -y $pkgs
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}[INSTALL PACKAGE] Packages installed successfully.${NC}"
        else
            echo -e "${RED}[ERROR] Failed to install packages.${NC}"
        fi
    fi
    pause_prompt
}

# Option 16: Remove Package
pkg_remove() {
    echo -e "${CYAN}[REMOVE PACKAGE] Enter package name(s) to purge:${NC}"
    read -p "Package name(s): " pkgs
    if [ -z "$pkgs" ]; then
        echo -e "${YELLOW}[WARNING] No package name entered.${NC}"
    else
        apt-get purge -y $pkgs
        apt-get autoremove -y
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}[REMOVE PACKAGE] Packages purged successfully.${NC}"
        else
            echo -e "${RED}[ERROR] Failed to purge packages.${NC}"
        fi
    fi
    pause_prompt
}

# Option 17: Clean System
sys_clean() {
    echo -e "${CYAN}[CLEAN SYSTEM] Cleaning system caches and temporary files...${NC}"
    
    # APT cache cleanup
    echo -e "${CYAN}[CLEAN] Cleaning APT caches...${NC}"
    apt-get clean
    apt-get autoclean
    apt-get autoremove -y
    
    # Systemd journal cleanup
    if command -v journalctl &> /dev/null; then
        echo -e "${CYAN}[CLEAN] Vacuuming systemd journal logs to 1 day...${NC}"
        journalctl --vacuum-time=1d
    fi
    
    # Temp folders cleanup
    echo -e "${CYAN}[CLEAN] Clearing /tmp and /var/tmp directories...${NC}"
    rm -rf /tmp/* /var/tmp/*
    
    echo -e "${GREEN}[CLEAN SYSTEM] System cleaned successfully.${NC}"
    pause_prompt
}

# Option 18: Change DNS
change_dns() {
    while true; do
        clear
        echo -e "${GOLD}============================================================================${NC}"
        echo -e "${CYAN}${BOLD}                          CHANGE SYSTEM DNS CONFIGURATION                  ${NC}"
        echo -e "${GOLD}============================================================================${NC}"
        echo -e "  ${GOLD}1)${NC} Cloudflare DNS (1.1.1.1 / 1.0.0.1)"
        echo -e "  ${GOLD}2)${NC} Google DNS (8.8.8.8 / 8.8.4.4)"
        echo -e "  ${GOLD}3)${NC} Quad9 DNS (9.9.9.9 / 149.112.112.112)"
        echo -e "  ${GOLD}4)${NC} Custom DNS Configuration"
        echo -e "  ${GOLD}B)${NC} Back to Main Menu"
        echo -e "${GOLD}============================================================================${NC}"
        read -p "Select choice [1-4, B]: " dns_choice

        case "$dns_choice" in
            1)
                echo -e "${CYAN}[DNS] Applying Cloudflare DNS...${NC}"
                apply_dns "1.1.1.1" "1.0.0.1"
                echo -e "${GREEN}[DNS] Cloudflare DNS applied successfully.${NC}"
                sleep 2
                break
                ;;
            2)
                echo -e "${CYAN}[DNS] Applying Google DNS...${NC}"
                apply_dns "8.8.8.8" "8.8.4.4"
                echo -e "${GREEN}[DNS] Google DNS applied successfully.${NC}"
                sleep 2
                break
                ;;
            3)
                echo -e "${CYAN}[DNS] Applying Quad9 DNS...${NC}"
                apply_dns "9.9.9.9" "149.112.112.112"
                echo -e "${GREEN}[DNS] Quad9 DNS applied successfully.${NC}"
                sleep 2
                break
                ;;
            4)
                echo -e "${CYAN}[DNS] Custom DNS Setup:${NC}"
                read -p "Primary DNS Server: " primary_dns
                read -p "Secondary DNS Server (Optional): " secondary_dns
                if [ -n "$primary_dns" ]; then
                    apply_dns "$primary_dns" "$secondary_dns"
                    echo -e "${GREEN}[DNS] Custom DNS applied successfully.${NC}"
                else
                    echo -e "${RED}[ERROR] Primary DNS cannot be empty.${NC}"
                fi
                sleep 2
                break
                ;;
            [bB])
                break
                ;;
            *)
                echo -e "${RED}[WARNING] Invalid choice! Select 1-4 or B.${NC}"
                sleep 2
                ;;
        esac
    done
}

# Option 19: Change Hostname
change_hostname() {
    local current_hn=$(cat /etc/hostname)
    echo -e "${CYAN}[HOSTNAME] Current Hostname: ${GOLD}${current_hn}${NC}"
    read -p "Enter new hostname: " new_hn
    if [ -z "$new_hn" ]; then
        echo -e "${YELLOW}[WARNING] Hostname cannot be empty.${NC}"
    else
        # Apply hostnamectl
        if command -v hostnamectl &> /dev/null; then
            hostnamectl set-hostname "$new_hn"
        else
            hostname "$new_hn"
        fi
        
        # Write to /etc/hostname
        echo "$new_hn" > /etc/hostname
        
        # Update /etc/hosts
        sed -i "s/\b${current_hn}\b/${new_hn}/g" /etc/hosts
        
        echo -e "${GREEN}[HOSTNAME] Hostname changed to '${new_hn}' successfully.${NC}"
    fi
    pause_prompt
}

# Option 20: Browser Installer
install_browser() {
    while true; do
        clear
        echo -e "${GOLD}============================================================================${NC}"
        echo -e "${CYAN}${BOLD}                          BROWSER INSTALLATION MANAGER                      ${NC}"
        echo -e "${GOLD}============================================================================${NC}"
