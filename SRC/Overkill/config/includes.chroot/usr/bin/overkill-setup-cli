apply_dns() {
    local primary="$1"
    local secondary="$2"
    # Prevent NetworkManager from overwriting resolv.conf
    mkdir -p /etc/NetworkManager/conf.d
    printf '[main]\ndns=none\nsystemd-resolved=false\n' > /etc/NetworkManager/conf.d/90-dns-manual.conf
    # Write resolv.conf
    printf "nameserver %s\n" "$primary" > /etc/resolv.conf
    [ -n "$secondary" ] && printf "nameserver %s\n" "$secondary" >> /etc/resolv.conf
    # Reload NetworkManager so it respects the new conf
    systemctl restart NetworkManager 2>/dev/null || true
}

set_dns_preset() {
    case "$1" in
        cloudflare) apply_dns "1.1.1.1" "1.0.0.1" ;;
        google)     apply_dns "8.8.8.8" "8.8.4.4" ;;
        quad9)      apply_dns "9.9.9.9" "149.112.112.112" ;;
        custom)
            local primary="$2"
            local secondary="$3"
            if [ -z "$primary" ]; then
                echo -e "${RED}[ERROR] Primary DNS required.${NC}"
                return 1
            fi
            apply_dns "$primary" "$secondary"
            ;;
        *)
            echo -e "${RED}[ERROR] Unknown DNS preset: $1${NC}"
            return 1
            ;;
    esac
    echo -e "${GREEN}[DNS] Configuration applied successfully.${NC}"
}

set_hostname_value() {
    local new_hn="$1"
    local current_hn=$(cat /etc/hostname)
    if [ -z "$new_hn" ]; then
        echo -e "${RED}[ERROR] Hostname required.${NC}"
        return 1
    fi
    if command -v hostnamectl &> /dev/null; then
        hostnamectl set-hostname "$new_hn"
    else
        hostname "$new_hn"
    fi
    echo "$new_hn" > /etc/hostname
    sed -i "s/\b${current_hn}\b/${new_hn}/g" /etc/hosts
    echo -e "${GREEN}[HOSTNAME] Hostname changed to '${new_hn}'.${NC}"
}

install_browser_by_id() {
    case "$1" in
        1) apt-get update && apt-get install -y firefox-esr ;;
        2) prepare_flatpak && flatpak install -y flathub com.brave.Browser ;;
        3) prepare_flatpak && flatpak install -y flathub org.torproject.torbrowser-launcher ;;
        4) prepare_flatpak && flatpak install -y flathub net.mullvad.MullvadBrowser ;;
        5) prepare_flatpak && flatpak install -y flathub org.garudalinux.firedragon ;;
        6) prepare_flatpak && flatpak install -y flathub app.zen_browser.zen ;;
        7) prepare_flatpak && flatpak install -y flathub one.ablaze.floorp ;;
        8) prepare_flatpak && flatpak install -y flathub net.waterfox.waterfox ;;
        9) prepare_flatpak && flatpak install -y flathub com.opera.opera-gx ;;
        10) prepare_flatpak && flatpak install -y flathub com.vivaldi.Vivaldi ;;
        11) apt-get update && apt-get install -y chromium ;;
        12) apt-get update && apt-get install -y falkon ;;
        *) echo -e "${RED}[ERROR] Unknown browser id: $1${NC}"; return 1 ;;
    esac
}

remove_browser_by_id() {
    case "$1" in
        1) apt-get purge -y firefox-esr && apt-get autoremove -y ;;
        2) flatpak uninstall -y com.brave.Browser 2>/dev/null || true ;;
        3) flatpak uninstall -y org.torproject.torbrowser-launcher 2>/dev/null || true ;;
        4) flatpak uninstall -y net.mullvad.MullvadBrowser 2>/dev/null || true ;;
        5) flatpak uninstall -y org.garudalinux.firedragon 2>/dev/null || true ;;
        6) flatpak uninstall -y app.zen_browser.zen 2>/dev/null || true ;;
        7) flatpak uninstall -y one.ablaze.floorp 2>/dev/null || true ;;
        8) flatpak uninstall -y net.waterfox.waterfox 2>/dev/null || true ;;
        9) flatpak uninstall -y com.opera.opera-gx 2>/dev/null || true ;;
        10) flatpak uninstall -y com.vivaldi.Vivaldi 2>/dev/null || true ;;
        11) apt-get purge -y chromium && apt-get autoremove -y ;;
        12) apt-get purge -y falkon && apt-get autoremove -y ;;
        *) echo -e "${RED}[ERROR] Unknown browser id: $1${NC}"; return 1 ;;
    esac
    echo -e "${GREEN}[BROWSER] Removal finished.${NC}"
}

# ==============================================================================
# DEB / FLATPAK / NVIDIA / ZRAM / LOG HELPERS (used by the GUI front-end)
# ==============================================================================

install_deb_file() {
    local path="$1"
    if [ -z "$path" ]; then
        echo -e "${RED}[ERROR] No .deb path provided.${NC}"; return 1
    fi
    if [ ! -f "$path" ]; then
        echo -e "${RED}[ERROR] File not found: $path${NC}"; return 1
    fi
    echo -e "${CYAN}[DEB] Installing $path...${NC}"
    dpkg -i "$path"
    apt-get install -f -y
    echo -e "${GREEN}[DEB] Installation finished.${NC}"
}

install_flatpak_app() {
    local appid="$1"
    if [ -z "$appid" ]; then
        echo -e "${RED}[ERROR] No Flatpak application id provided.${NC}"; return 1
    fi
    prepare_flatpak
    echo -e "${CYAN}[FLATPAK] Installing ${appid} from flathub...${NC}"
    flatpak install -y flathub "$appid"
}

remove_flatpak_app() {
    local appid="$1"
    if [ -z "$appid" ]; then
        echo -e "${RED}[ERROR] No Flatpak application id provided.${NC}"; return 1
    fi
    echo -e "${CYAN}[FLATPAK] Removing ${appid}...${NC}"
    flatpak uninstall -y "$appid"
    flatpak uninstall --unused -y || true
}

list_flatpak_apps() {
    if ! command -v flatpak &> /dev/null; then
        echo "(flatpak not installed)"
        return 0
    fi
    flatpak list --app --columns=name,application,version 2>/dev/null || true
}

install_nvidia_drivers() {
    echo -e "${CYAN}[NVIDIA] Scanning for NVIDIA GPU...${NC}"
    if lspci 2>/dev/null | grep -i nvidia >/dev/null; then
        echo -e "${GREEN}[NVIDIA] NVIDIA GPU detected.${NC}"
    else
        echo -e "${YELLOW}[NVIDIA] No NVIDIA GPU detected. Proceeding anyway...${NC}"
    fi
    local kernel
    kernel=$(uname -r)
    apt-get update
    apt-get install -y nvidia-driver nvidia-smi "linux-headers-${kernel}"
    echo -e "${GREEN}[NVIDIA] Drivers installed. A reboot is required to load them.${NC}"
}

zram_manage() {
    local action="$1"
    case "$action" in
        install)
            apt-get update
            apt-get install -y zram-tools
            ;;
        enable)
            systemctl enable zramswap
            systemctl start zramswap
            ;;
        disable)
            systemctl stop zramswap || true
            systemctl disable zramswap || true
            ;;
        status)
            if systemctl is-active --quiet zramswap; then
                echo "STATUS: ACTIVE"
            else
                echo "STATUS: INACTIVE"
            fi
            echo
            if command -v zramctl &> /dev/null; then
                zramctl 2>/dev/null || true
            fi
            swapon --show 2>/dev/null || true
            ;;
        *)
            echo -e "${RED}[ERROR] Unknown zram action: $action${NC}"
            echo "Usage: zram {install|enable|disable|status}"
            return 1
            ;;
    esac
}

view_system_log() {
    local kind="$1"
    local lines="${2:-300}"
    case "$kind" in
        system)
            journalctl -n "$lines" --no-pager
            ;;
        boot)
            journalctl -b -n "$lines" --no-pager
            ;;
        kernel)
            dmesg --color=never | tail -n "$lines"
            ;;
        xorg)
            if [ -f /var/log/Xorg.0.log ]; then
                tail -n "$lines" /var/log/Xorg.0.log
            else
                echo "(Xorg log not found — likely a Wayland session)"
            fi
            ;;
        apt)
            if [ -f /var/log/apt/history.log ]; then
                tail -n "$lines" /var/log/apt/history.log
            else
                echo "(APT log not found)"
            fi
            ;;
        dpkg)
            tail -n "$lines" /var/log/dpkg.log 2>/dev/null || echo "(dpkg log not found)"
            ;;
        *)
            echo -e "${RED}[ERROR] Unknown log type: $kind${NC}"
            echo "Available: system, boot, kernel, xorg, apt, dpkg"
            return 1
            ;;
    esac
}

