# ==============================================================================
# NON-INTERACTIVE DISPATCHER (used by the PyQt6 GUI front-end)
# ==============================================================================

run_subcommand() {
    local cmd="$1"; shift
    case "$cmd" in
        status)
            get_installed_edition
            echo "EDITION=${CURRENT_EDITION}"
            echo "DATE=${CURRENT_DATE}"
            echo "TUNING=${CURRENT_TUNING}"
            ;;
        install-edition)
            install_edition_by_id "$1"
            ;;
        uninstall-edition)
            uninstall_edition
            ;;
        sys-update)
            sys_update
            ;;
        sys-clean)
            sys_clean
            ;;
        pkg-install)
            if [ "$#" -eq 0 ]; then
                echo -e "${RED}[ERROR] No packages provided.${NC}"; return 1
            fi
            apt-get update && apt-get install -y "$@"
            ;;
        pkg-remove)
            if [ "$#" -eq 0 ]; then
                echo -e "${RED}[ERROR] No packages provided.${NC}"; return 1
            fi
            apt-get purge -y "$@" && apt-get autoremove -y
            ;;
        set-dns)
            set_dns_preset "$@"
            ;;
        set-hostname)
            set_hostname_value "$1"
            ;;
        install-browser)
            install_browser_by_id "$1"
            ;;
        remove-browser)
            remove_browser_by_id "$1"
            ;;
        install-deb)
            install_deb_file "$1"
            ;;
        install-flatpak)
            install_flatpak_app "$1"
            ;;
        remove-flatpak)
            remove_flatpak_app "$1"
            ;;
        list-flatpak)
            list_flatpak_apps
            ;;
        install-nvidia)
            install_nvidia_drivers
            ;;
        zram)
            zram_manage "$1"
            ;;
        view-log)
            view_system_log "$1" "${2:-300}"
            ;;
        *)
            echo -e "${RED}[ERROR] Unknown subcommand: $cmd${NC}"
            echo "Available: status install-edition <id> uninstall-edition sys-update sys-clean pkg-install <pkgs...> pkg-remove <pkgs...> set-dns <preset> [primary] [secondary] set-hostname <name> install-browser <id> install-deb <path> install-flatpak <id> remove-flatpak <id> list-flatpak install-nvidia zram {install|enable|disable|status} view-log {system|boot|kernel|xorg|apt|dpkg} [lines]"
            return 1
            ;;
    esac
}

# Run Script
check_root
if [ "$#" -gt 0 ]; then
    export NONINTERACTIVE=1
    run_subcommand "$@"
    exit $?
fi
main_menu
