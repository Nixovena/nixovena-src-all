# Hardened nftables configuration text
HARDENED_NFTABLES='#!/usr/sbin/nft -f

flush ruleset

table inet firewall {
    set bogon_ipv4 {
        type ipv4_addr; flags interval;
        elements = {
            0.0.0.0/8,
            100.64.0.0/10,
            169.254.0.0/16,
            192.0.0.0/24,
            192.0.2.0/24,
            198.18.0.0/15,
            198.51.100.0/24,
            203.0.113.0/24,
            224.0.0.0/3
        }
    }

    chain input {
        type filter hook input priority filter; policy drop;

        iif lo accept comment "loopback"

        iif != lo ip  daddr 127.0.0.0/8 drop comment "spoof loopback v4"
        iif != lo ip6 daddr ::1/128     drop comment "spoof loopback v6"

        ct state invalid drop comment "invalid conntrack"

        ct state { established, related } accept comment "established/related"

        ip saddr @bogon_ipv4 iif != lo drop comment "bogon source drop"

        tcp flags & (fin|syn|rst|ack) != syn ct state new drop comment "invalid tcp new"

        tcp flags syn ct state new limit rate over 25/second burst 50 packets drop comment "syn flood"

        ip  protocol icmp icmp type { echo-request, echo-reply, destination-unreachable, time-exceeded, parameter-problem } limit rate 10/second burst 20 packets accept comment "icmpv4"
        ip6 nexthdr icmpv6 icmpv6 type { echo-request, echo-reply, nd-neighbor-solicit, nd-neighbor-advert, nd-router-advert, nd-router-solicit, mld-listener-query, destination-unreachable, packet-too-big, time-exceeded, parameter-problem } limit rate 10/second burst 20 packets accept comment "icmpv6"

        ip  protocol icmp   drop comment "icmp overlimit"
        ip6 nexthdr icmpv6  drop comment "icmpv6 overlimit"

        # Tor relay/bridge, I2P, OpenVPN, WireGuard inbound
        tcp dport { 9001, 9030, 9050, 9150, 7656, 7657, 7658, 4444, 4447, 1194 } ct state new accept comment "tor-i2p-vpn tcp"
        udp dport { 51820, 1194 } accept comment "wireguard-openvpn udp"

        udp dport 5353 ip  daddr 224.0.0.251 accept comment "mDNS v4"
        udp dport 5353 ip6 daddr ff02::fb    accept comment "mDNS v6"

        udp sport 67 udp dport 68   accept comment "DHCP v4"
        udp sport 547 udp dport 546 accept comment "DHCP v6"

        drop
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }
}

table ip raw_filter {
    chain prerouting {
        type filter hook prerouting priority raw; policy accept;

        tcp flags & (fin|syn) == (fin|syn)         drop comment "fin+syn"
        tcp flags & (syn|rst) == (syn|rst)         drop comment "syn+rst"
        tcp flags & (fin|syn|rst|psh|ack|urg) == 0 drop comment "null scan"
        tcp flags & (fin|psh|urg) == (fin|psh|urg) drop comment "xmas scan"

        ip protocol icmp ip frag-off & 0x1fff != 0 drop comment "frag icmp"
    }
}'

