#!/usr/bin/env bash

# ==============================================================================
# Overkill Linux Edition Installer, Tuner & System Setup Utility
# ==============================================================================

export RED='\033[0;31m'
export GREEN='\033[0;32m'
export YELLOW='\033[1;33m'
export BLUE='\033[0;34m'
export PURPLE='\033[0;35m'
export CYAN='\033[0;36m'
export GOLD='\033[38;5;220m'
export DARK_BLUE='\033[38;5;18m'
export BOLD='\033[1m'
export NC='\033[0m' # No Color

pause_prompt() {
    if [ "$NONINTERACTIVE" = "1" ]; then
        return
    fi
    read -p "Press ENTER to continue..."
}

# Draw Banner
show_banner() {
    clear
    echo -e "${GOLD}============================================================================${NC}"
    echo -e "${GOLD}${BOLD}          ██████╗ ██╗   ██╗███████╗██████╗ ██╗  ██╗██╗██╗     ██╗     ${NC}"
    echo -e "${GOLD}${BOLD}         ██╔═══██╗██║   ██║██╔════╝██╔══██╗██║ ██╔╝██║██║     ██║     ${NC}"
    echo -e "${GOLD}${BOLD}         ██║   ██║██║   ██║█████╗  ██████╔╝█████╔╝ ██║██║     ██║     ${NC}"
    echo -e "${GOLD}${BOLD}         ██║   ██║╚██╗ ██╔╝██╔══╝  ██╔══██╗██╔═██╗ ██║██║     ██║     ${NC}"
    echo -e "${GOLD}${BOLD}         ╚██████╔╝ ╚████╔╝ ███████╗██║  ██║██║  ██╗██║███████╗███████╗${NC}"
    echo -e "${GOLD}${BOLD}          ╚═════╝   ╚═══╝  ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═╝╚══════╝╚══════╝${NC}"
    echo -e "${CYAN}${BOLD}                              O V E R K I L L   L I N U X              ${NC}"
    echo -e "${GOLD}============================================================================${NC}"
    echo -e "${CYAN}System Setup, Optimization, Package Management ${NC}"
    echo -e "${GOLD}============================================================================${NC}"
}

# Root Privilege Check
check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}${BOLD}[ERROR] This script makes system-wide modifications. Please run as root!${NC}"
        echo -e "${YELLOW}Usage: sudo overkill-setup${NC}"
        exit 1
    fi
}

# Edition Information Path
CONF_DIR="/usr/share/edition"
CONF_FILE="$CONF_DIR/edition.conf"

# Read currently installed edition
get_installed_edition() {
    if [ -f "$CONF_FILE" ]; then
        # Sourcing config safely
        CURRENT_EDITION=$(grep -Po '(?<=^EDITION=")[^"]*' "$CONF_FILE")
        CURRENT_DATE=$(grep -Po '(?<=^DATE=")[^"]*' "$CONF_FILE")
        CURRENT_TUNING=$(grep -Po '(?<=^TUNING=")[^"]*' "$CONF_FILE")
    else
        CURRENT_EDITION=""
        CURRENT_DATE=""
        CURRENT_TUNING=""
    fi
}

# Show Status
show_status() {
    get_installed_edition
    if [ -n "$CURRENT_EDITION" ]; then
        echo -e "${GREEN}${BOLD}CURRENT STATUS: Installed Edition: ${GOLD}${CURRENT_EDITION}${NC}"
        echo -e "${GREEN}INSTALL DATE: ${CURRENT_DATE}${NC}"
        if [ "$CURRENT_TUNING" != "none" ] && [ -n "$CURRENT_TUNING" ]; then
            echo -e "${GREEN}APPLIED TUNING: ${YELLOW}${CURRENT_TUNING^^}${NC}"
        else
            echo -e "${GREEN}APPLIED TUNING: ${RED}None / Inactive${NC}"
        fi
    else
        echo -e "${RED}${BOLD}CURRENT STATUS: No installed edition detected!${NC}"
    fi
    echo -e "${GOLD}----------------------------------------------------------------------------${NC}"
}

# Flatpak Setup
prepare_flatpak() {
    if ! command -v flatpak &> /dev/null; then
        echo -e "${CYAN}[INFO] Flatpak is not installed. Installing...${NC}"
        apt-get update && apt-get install -y flatpak
    fi
    # Add flathub remote
    flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
}

# Apply GRUB Tuning
apply_grub_tuning() {
    local cmdline_default_append="$1"
    local cmdline_append="$2"
    local disable_recovery="$3"

    echo -e "${CYAN}[GRUB] Optimizing GRUB configuration...${NC}"
    
    # Back up GRUB file
    if [ ! -f "/etc/default/grub.bak" ]; then
        cp /etc/default/grub /etc/default/grub.bak
        echo -e "${GREEN}[GRUB] /etc/default/grub backed up to /etc/default/grub.bak.${NC}"
    fi

    # GRUB_CMDLINE_LINUX_DEFAULT
    if [ -n "$cmdline_default_append" ]; then
        sed -i -E 's/^(GRUB_CMDLINE_LINUX_DEFAULT=")([^"]*)(")/\1\2 '"$cmdline_default_append"'\3/' /etc/default/grub
        sed -i 's/  */ /g' /etc/default/grub
    fi

    # GRUB_CMDLINE_LINUX
    if [ -n "$cmdline_append" ]; then
        sed -i -E 's/^(GRUB_CMDLINE_LINUX=")([^"]*)(")/\1\2 '"$cmdline_append"'\3/' /etc/default/grub
        sed -i 's/  */ /g' /etc/default/grub
    fi

    # GRUB_DISABLE_RECOVERY
    if [ "$disable_recovery" = "true" ]; then
        if grep -q "^GRUB_DISABLE_RECOVERY=" /etc/default/grub; then
            sed -i 's/^GRUB_DISABLE_RECOVERY=.*/GRUB_DISABLE_RECOVERY="true"/' /etc/default/grub
        else
            echo 'GRUB_DISABLE_RECOVERY="true"' >> /etc/default/grub
        fi
    fi

    # Update GRUB
    if command -v update-grub &> /dev/null; then
        update-grub
    elif command -v grub-mkconfig &> /dev/null; then
        grub-mkconfig -o /boot/grub/grub.cfg
    else
        echo -e "${YELLOW}[WARNING] update-grub or grub-mkconfig command not found. Please update GRUB manually.${NC}"
    fi
}

# Revert GRUB Tuning
revert_grub_tuning() {
    if [ -f "/etc/default/grub.bak" ]; then
        echo -e "${CYAN}[GRUB] Restoring original GRUB configuration...${NC}"
        mv /etc/default/grub.bak /etc/default/grub
        if command -v update-grub &> /dev/null; then
            update-grub
        elif command -v grub-mkconfig &> /dev/null; then
            grub-mkconfig -o /boot/grub/grub.cfg
        fi
        echo -e "${GREEN}[GRUB] Configuration restored successfully.${NC}"
    fi
}

# Apply Sysctl Tuning
apply_sysctl_tuning() {
    local tuning_content="$1"
    echo -e "${CYAN}[SYSCTL] Applying kernel sysctl parameters...${NC}"
    echo "$tuning_content" > /etc/sysctl.d/99-edition-tuning.conf
    sysctl --system
    echo -e "${GREEN}[SYSCTL] Settings successfully written and reloaded.${NC}"
}

# Revert Sysctl Tuning
revert_sysctl_tuning() {
    if [ -f "/etc/sysctl.d/99-edition-tuning.conf" ]; then
        echo -e "${CYAN}[SYSCTL] Removing sysctl parameters...${NC}"
        rm -f /etc/sysctl.d/99-edition-tuning.conf
        sysctl --system
        echo -e "${GREEN}[SYSCTL] Default kernel parameters loaded.${NC}"
    fi
}

# Apply Modprobe Blacklist
apply_modprobe_blacklist() {
    local blacklist_content="$1"
    echo -e "${CYAN}[MODPROBE] Writing modprobe blacklist configuration...${NC}"
    echo "$blacklist_content" > /etc/modprobe.d/99-hardened-blacklists.conf
    echo -e "${GREEN}[MODPROBE] Blacklists saved to /etc/modprobe.d/99-hardened-blacklists.conf.${NC}"
}

# Revert Modprobe Blacklist
revert_modprobe_blacklist() {
    if [ -f "/etc/modprobe.d/99-hardened-blacklists.conf" ]; then
        echo -e "${CYAN}[MODPROBE] Removing modprobe blacklist configurations...${NC}"
        rm -f /etc/modprobe.d/99-hardened-blacklists.conf
        echo -e "${GREEN}[MODPROBE] Modprobe configurations reverted successfully.${NC}"
    fi
}

# Apply nftables Firewall
apply_nftables() {
    local nft_content="$1"
    echo -e "${CYAN}[FIREWALL] Configuring hardened nftables firewall...${NC}"
    
    # Back up existing nftables config
    if [ -f "/etc/nftables.conf" ] && [ ! -f "/etc/nftables.conf.bak" ]; then
        cp /etc/nftables.conf /etc/nftables.conf.bak
        echo -e "${GREEN}[FIREWALL] Original /etc/nftables.conf backed up.${NC}"
    fi

    # Package installation check
    if ! command -v nft &> /dev/null; then
        echo -e "${CYAN}[FIREWALL] Installing nftables package...${NC}"
        apt-get update && apt-get install -y nftables
    fi

    # Write nft rules
    echo "$nft_content" > /etc/nftables.conf
    
    # Start and enable service
    systemctl stop iptables &> /dev/null || true # Avoid conflicts with iptables
    systemctl disable iptables &> /dev/null || true
    systemctl enable nftables
    systemctl restart nftables

    echo -e "${GREEN}[FIREWALL] nftables configured, loaded, and activated successfully.${NC}"
}

# Revert nftables Firewall
revert_nftables() {
    echo -e "${CYAN}[FIREWALL] Disabling nftables firewall...${NC}"
    systemctl stop nftables &> /dev/null || true
    systemctl disable nftables &> /dev/null || true
    
    if [ -f "/etc/nftables.conf.bak" ]; then
        mv /etc/nftables.conf.bak /etc/nftables.conf
        echo -e "${GREEN}[FIREWALL] Original nftables configuration restored.${NC}"
    else
        rm -f /etc/nftables.conf
    fi
}

# Save Edition Info
save_edition_info() {
    local edition_name="$1"
    local tuning_type="$2"
    mkdir -p "$CONF_DIR"
    cat <<EOF > "$CONF_FILE"
EDITION="$edition_name"
DATE="$(date '+%Y-%m-%d %H:%M:%S')"
TUNING="$tuning_type"
EOF
    echo -e "${GREEN}${BOLD}[INFO] Edition details saved to $CONF_FILE.${NC}"
}

# Uninstall Edition
uninstall_edition() {
    get_installed_edition
    if [ -z "$CURRENT_EDITION" ]; then
        echo -e "${RED}${BOLD}[WARNING] No installed edition found in the system! Reversion aborted.${NC}"
        pause_prompt
        return
    fi

    echo -e "${YELLOW}${BOLD}WARNING: You are about to uninstall '${CURRENT_EDITION}'!${NC}"
    echo -e "${YELLOW}This will completely remove all APT packages and Flatpaks associated with this edition.${NC}"
    if [ "$NONINTERACTIVE" = "1" ]; then
        confirm="y"
    else
        read -p "Are you sure you want to proceed? (y/N): " confirm
    fi
    if [[ ! "$confirm" =~ ^[yY]$ ]]; then
        echo -e "${CYAN}Uninstall process cancelled by user.${NC}"
        pause_prompt
        return
    fi

    echo -e "${CYAN}[UNINSTALL] Reverting changes... Please wait.${NC}"

    local apt_pkgs=""
    local flat_pkgs=""
    local is_hardened=false
    local is_hardened_nofw=false
    local is_gaming=false
    local is_multimedia=false
    local is_ai=false

    case "$CURRENT_EDITION" in
        "Development Edition")
            apt_pkgs="docker.io docker-compose docker-buildx cargo rustc golang-go python3-full python3-pip nodejs npm arduino build-essential cmake git gh php ruby"
            flat_pkgs="com.jetbrains.IntelliJ-IDEA-Community dev.zed.Zed io.gdevelop.ide com.google.AndroidStudio com.visualstudio.code org.kde.kommit com.vscodium.codium org.godotengine.Godot io.github.shiftey.Desktop dev.skynomads.Seabird com.jetbrains.RustRover com.jetbrains.Rider com.jetbrains.PhpStorm com.jetbrains.PyCharm-Professional com.jetbrains.GoLand"
            ;;
        "AI Edition")
            apt_pkgs="kde-plasma-desktop kde-standard sddm plasma-nm plasma-discover xdg-desktop-portal-kde fonts-noto-color-emoji firefox-esr network-manager vim nano curl wget git lsof net-tools ca-certificates apt-transport-https smartmontools lsb-release lshw unzip ark kate vlc dbus-x11 fonts-noto-cjk python3-torch python3-torchvision python3-torchaudio python3-xgboost python3-sklearn python3-pandas python3-numpy"
            flat_pkgs="ai.lmstudio.lm-studio com.jeffser.Alpaca ai.jan.Jan com.cherry_ai.CherryStudio io.github.qwersyk.Newelle io.github.Bavarder.Bavarder io.github.koromelodev.mindmate com.iche2.gai page.codeberg.Imaginer.Imaginer br.com.wiselabs.simplexity"
            is_ai=true
            ;;
        "Education Edition")
            apt_pkgs="fonts-noto-color-emoji fonts-noto-cjk libreoffice libreoffice-gtk3 geogebra kalgebra kmplot stellarium marble cantor python3-full python3-pip idle geany tuxtype tuxmath ktouch kwordquiz klettres kanagram kturtle parley goldendict kgeography tuxpaint kolourpaint evince eog gnome-calculator gnome-system-monitor gnome-disk-utility file-roller baobab gnome-clocks"
            ;;
        "Engineer Edition")
            apt_pkgs="freecad blender librecad openscad kicad fritzing octave scilab geogebra evince eog gnome-calculator gnome-system-monitor gnome-disk-utility file-roller baobab gnome-clocks simple-scan pdfarranger"
            ;;
        "Gaming Edition")
            apt_pkgs="wine wine64 wine32:i386 winetricks gamemode libgamemode0 libgamemodeauto0 lutris mangohud retroarch mesa-vulkan-drivers vulkan-tools libvulkan1 libvulkan1:i386 mesa-utils htop iotop lm-sensors psensor pciutils usbutils dmidecode inxi pipewire pipewire-pulse wireplumber joystick jstest-gtk xboxdrv"
            flat_pkgs="com.discordapp.Discord org.vinegarhq.Sober com.valvesoftware.Steam com.heroicgameslauncher.hgl com.usebottles.bottles com.vysp3r.ProtonPlus org.vinegarhq.Vinegar net.windower.Lumoria xyz.hyperplay.HyperPlay com.valvesoftware.SteamLink"
            is_gaming=true
            ;;
        "Hardened Edition")
            apt_pkgs="nftables keepassxc kleopatra"
            flat_pkgs="org.cryptomator.Cryptomator app.drey.Warp"
            is_hardened=true
            ;;
        "Cryptocurrency Edition")
            flat_pkgs="com.ownrwallet.wallet org.electrum.electrum io.exodus.Exodus io.greenfire.Greenery net.peercoin.peercoin-qt org.getmonero.Monero org.firo.firo-qt io.trezor.suite so.onekey.Wallet io.frama.tractor.carburetor org.bitcoincore.bitcoin-qt com.blockstream.Green org.cryptomator.Cryptomator io.github.picocrypt_ng.Picocrypt-NG"
            ;;
        "Cryptocurrency Edition Hardened")
            flat_pkgs="com.ownrwallet.wallet org.electrum.electrum io.exodus.Exodus io.greenfire.Greenery net.peercoin.peercoin-qt org.getmonero.Monero org.firo.firo-qt io.trezor.suite so.onekey.Wallet io.frama.tractor.carburetor org.bitcoincore.bitcoin-qt com.blockstream.Green org.cryptomator.Cryptomator io.github.picocrypt_ng.Picocrypt-NG"
            is_hardened_nofw=true
            ;;
        "Scientific Edition")
            apt_pkgs="libreoffice libreoffice-gtk3 texlive-base texlive-latex-extra texlive-science texlive-fonts-recommended pandoc octave octave-signal octave-image octave-statistics gnuplot gnuplot-qt maxima wxmaxima geogebra kalgebra kmplot cantor scilab step avogadro units kalzium gperiodic stellarium marble ugene clustalw emboss r-base r-base-dev python3-full python3-pip python3-numpy python3-scipy python3-matplotlib python3-pandas python3-sympy python3-sklearn jupyter-notebook geany build-essential cmake gfortran paraview gnome-calculator evince eog gnome-system-monitor gnome-disk-utility file-roller baobab gnome-clocks"
            ;;
        "Office Edition")
            apt_pkgs="libreoffice libreoffice-gtk3 thunderbird evolution planner gnucash homebank evince eog gnome-calculator gnome-system-monitor gnome-disk-utility file-roller baobab gnome-clocks simple-scan pdfarranger"
            ;;
        "Multimedia Edition")
            apt_pkgs="kdenlive obs-studio shotcut pitivi handbrake ffmpeg audacity ardour lmms hydrogen qjackctl calf-plugins gimp inkscape krita darktable rawtherapee scribus mypaint vlc mpv gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly evince eog file-roller baobab"
            is_multimedia=true
            ;;
        "Development Gaming Mix Edition")
            apt_pkgs="docker.io docker-compose docker-buildx cargo rustc golang-go python3-full python3-pip nodejs npm arduino build-essential cmake git gh php ruby wine wine64  winetricks gamemode libgamemode0 libgamemodeauto0 lutris mangohud retroarch mesa-vulkan-drivers vulkan-tools libvulkan1 mesa-utils htop iotop lm-sensors psensor pciutils usbutils dmidecode inxi pipewire pipewire-pulse wireplumber joystick jstest-gtk xboxdrv"
            flat_pkgs="com.jetbrains.IntelliJ-IDEA-Community dev.zed.Zed io.gdevelop.ide com.google.AndroidStudio com.visualstudio.code org.kde.kommit com.vscodium.codium org.godotengine.Godot io.github.shiftey.Desktop dev.skynomads.Seabird com.jetbrains.RustRover com.jetbrains.Rider com.jetbrains.PhpStorm com.jetbrains.PyCharm-Professional com.jetbrains.GoLand com.discordapp.Discord org.vinegarhq.Sober com.valvesoftware.Steam com.heroicgameslauncher.hgl com.usebottles.bottles com.vysp3r.ProtonPlus org.vinegarhq.Vinegar net.windower.Lumoria xyz.hyperplay.HyperPlay com.valvesoftware.SteamLink"
            is_gaming=true
            ;;
        "Development Gaming Multimedia Mix Edition")
            apt_pkgs="docker.io docker-compose docker-buildx cargo rustc golang-go python3-full python3-pip nodejs npm arduino build-essential cmake git gh php ruby wine wine64 winetricks gamemode libgamemode0 libgamemodeauto0 lutris mangohud retroarch mesa-vulkan-drivers vulkan-tools libvulkan1 mesa-utils htop iotop lm-sensors psensor pciutils usbutils dmidecode inxi pipewire pipewire-pulse wireplumber joystick jstest-gtk xboxdrv kdenlive obs-studio shotcut pitivi handbrake ffmpeg audacity ardour lmms hydrogen qjackctl calf-plugins gimp inkscape krita darktable rawtherapee scribus mypaint vlc mpv gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly evince eog file-roller baobab"
            flat_pkgs="com.jetbrains.IntelliJ-IDEA-Community dev.zed.Zed io.gdevelop.ide com.google.AndroidStudio com.visualstudio.code org.kde.kommit com.vscodium.codium org.godotengine.Godot io.github.shiftey.Desktop dev.skynomads.Seabird com.jetbrains.RustRover com.jetbrains.Rider com.jetbrains.PhpStorm com.jetbrains.PyCharm-Professional com.jetbrains.GoLand com.discordapp.Discord org.vinegarhq.Sober com.valvesoftware.Steam com.heroicgameslauncher.hgl com.usebottles.bottles com.vysp3r.ProtonPlus org.vinegarhq.Vinegar net.windower.Lumoria xyz.hyperplay.HyperPlay com.valvesoftware.SteamLink"
            is_gaming=true
            ;;
        "Development AI Mix Edition")
            apt_pkgs="docker.io docker-compose docker-buildx cargo rustc golang-go python3-full python3-pip nodejs npm arduino build-essential cmake git gh php ruby python3-torch python3-torchvision python3-torchaudio python3-xgboost python3-sklearn python3-pandas python3-numpy"
            flat_pkgs="com.jetbrains.IntelliJ-IDEA-Community dev.zed.Zed io.gdevelop.ide com.google.AndroidStudio com.visualstudio.code org.kde.kommit com.vscodium.codium org.godotengine.Godot io.github.shiftey.Desktop dev.skynomads.Seabird com.jetbrains.RustRover com.jetbrains.Rider com.jetbrains.PhpStorm com.jetbrains.PyCharm-Professional com.jetbrains.GoLand ai.lmstudio.lm-studio com.jeffser.Alpaca ai.jan.Jan com.cherry_ai.CherryStudio io.github.qwersyk.Newelle io.github.Bavarder.Bavarder io.github.koromelodev.mindmate com.iche2.gai page.codeberg.Imaginer.Imaginer br.com.wiselabs.simplexity"
            is_ai=true
            ;;
        "Development Cryptocurrency Mix Edition")
            apt_pkgs="docker.io docker-compose docker-buildx cargo rustc golang-go python3-full python3-pip nodejs npm arduino build-essential cmake git gh php ruby"
            flat_pkgs="com.jetbrains.IntelliJ-IDEA-Community dev.zed.Zed io.gdevelop.ide com.google.AndroidStudio com.visualstudio.code org.kde.kommit com.vscodium.codium org.godotengine.Godot io.github.shiftey.Desktop dev.skynomads.Seabird com.jetbrains.RustRover com.jetbrains.Rider com.jetbrains.PhpStorm com.jetbrains.PyCharm-Professional com.jetbrains.GoLand com.ownrwallet.wallet org.electrum.electrum io.exodus.Exodus io.greenfire.Greenery net.peercoin.peercoin-qt org.getmonero.Monero org.firo.firo-qt io.trezor.suite so.onekey.Wallet io.frama.tractor.carburetor org.bitcoincore.bitcoin-qt com.blockstream.Green org.cryptomator.Cryptomator io.github.picocrypt_ng.Picocrypt-NG"
            ;;
        "Development Cryptocurrency Hardened Mix Edition")
            apt_pkgs="docker.io docker-compose docker-buildx cargo rustc golang-go python3-full python3-pip nodejs npm arduino build-essential cmake git gh php ruby"
            flat_pkgs="com.jetbrains.IntelliJ-IDEA-Community dev.zed.Zed io.gdevelop.ide com.google.AndroidStudio com.visualstudio.code org.kde.kommit com.vscodium.codium org.godotengine.Godot io.github.shiftey.Desktop dev.skynomads.Seabird com.jetbrains.RustRover com.jetbrains.Rider com.jetbrains.PhpStorm com.jetbrains.PyCharm-Professional com.jetbrains.GoLand com.ownrwallet.wallet org.electrum.electrum io.exodus.Exodus io.greenfire.Greenery net.peercoin.peercoin-qt org.getmonero.Monero org.firo.firo-qt io.trezor.suite so.onekey.Wallet io.frama.tractor.carburetor org.bitcoincore.bitcoin-qt com.blockstream.Green org.cryptomator.Cryptomator io.github.picocrypt_ng.Picocrypt-NG"
            is_hardened_nofw=true
            ;;
        "Gaming Lite Edition")
            apt_pkgs="lutris"
            flat_pkgs="com.valvesoftware.Steam com.heroicgameslauncher.hgl com.discordapp.Discord"
            is_gaming=true
            ;;
        "Development Lite Edition")
            flat_pkgs="com.visualstudio.code io.github.shiftey.Desktop"
            ;;
        "Development Gaming Lite Mix Edition")
            apt_pkgs="lutris"
            flat_pkgs="com.visualstudio.code io.github.shiftey.Desktop com.valvesoftware.Steam com.heroicgameslauncher.hgl com.discordapp.Discord"
            is_gaming=true
            ;;
        "Gamebox Edition")
            flat_pkgs="com.github.Anuken.Mindustry org.openttd.OpenTTD com.endlessnetwork.aqueducts com.simutrans.Simutrans com.play0ad.zeroad"
            is_gaming=true
            ;;
        *)
            echo -e "${RED}[UNINSTALL] Unrecognized edition. Please inspect configuration files.${NC}"
            ;;
    esac

    # 1. Uninstall APT Packages
    if [ -n "$apt_pkgs" ]; then
        echo -e "${CYAN}[APT] Purging packages: $apt_pkgs${NC}"
        apt-get purge -y $apt_pkgs
        apt-get autoremove -y
        echo -e "${GREEN}[APT] APT packages cleared successfully.${NC}"
    fi

    # 2. Uninstall Flatpaks
    if [ -n "$flat_pkgs" ]; then
        echo -e "${CYAN}[FLATPAK] Removing applications...${NC}"
        flatpak uninstall -y $flat_pkgs
        flatpak uninstall --unused -y
        echo -e "${GREEN}[FLATPAK] Flatpaks cleared successfully.${NC}"
    fi

    # 3. Revert Tuning Configurations
    if [ "$is_hardened" = true ]; then
        revert_sysctl_tuning
        revert_grub_tuning
        revert_modprobe_blacklist
        revert_nftables
    fi

    if [ "$is_hardened_nofw" = true ]; then
        revert_sysctl_tuning
        revert_grub_tuning
        revert_modprobe_blacklist
    fi

    if [ "$is_gaming" = true ]; then
        revert_sysctl_tuning
        revert_grub_tuning
    fi

    if [ "$is_multimedia" = true ]; then
        revert_sysctl_tuning
        revert_grub_tuning
    fi

    if [ "$is_ai" = true ]; then
        revert_sysctl_tuning
        revert_grub_tuning
    fi

    # 4. Clean Configuration File
    rm -f "$CONF_FILE"
    echo -e "${GREEN}${BOLD}Edition removal completed successfully! System cleaned.${NC}"
    pause_prompt
}

# ==============================================================================
# EDITION DEFINITIONS & TUNING CONTENTS
# ==============================================================================

# Gaming sysctl tuning text
GAMING_SYSCTL_TUNING='########################################
# Memory & Swap
